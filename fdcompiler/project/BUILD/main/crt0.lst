00001Fr 4               
00001Fr 4               
00001Fr 4               .macro MetatileReserve name
00001Fr 4               .ident( .sprintf("METATILE_%s", name) ) = METATILES_COUNT
00001Fr 4               METATILES_COUNT .set METATILES_COUNT + 1
00001Fr 4               .endmacro
00001Fr 4               
00001Fr 4               .macro Metatile name, tl, tr, bl, br, at, cl
00001Fr 4               
00001Fr 4               .ident(.sprintf("METATILE_%d_TL", (METATILES_COUNT))) = (<tl)
00001Fr 4               .ident(.sprintf("METATILE_%d_TR", (METATILES_COUNT))) = (<tr)
00001Fr 4               .ident(.sprintf("METATILE_%d_BL", (METATILES_COUNT))) = (<bl)
00001Fr 4               .ident(.sprintf("METATILE_%d_BR", (METATILES_COUNT))) = (<br)
00001Fr 4               .ident(.sprintf("METATILE_%d_AT", (METATILES_COUNT))) = (<at)
00001Fr 4               .ident(.sprintf("METATILE_%d_CL", (METATILES_COUNT))) = (<cl)
00001Fr 4               
00001Fr 4               .if _PRINT_METATILES
00001Fr 4               	.out .sprintf("METATILE_%s = $%02x", name, METATILES_COUNT)
00001Fr 4               .endif
00001Fr 4               MetatileReserve .sprintf("%s", name)
00001Fr 4               
00001Fr 4               .endmacro
00001Fr 4               
00001Fr 4               .endif
