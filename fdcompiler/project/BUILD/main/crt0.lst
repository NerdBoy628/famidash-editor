000000r 2               
000000r 2               ; BUILD FLAGS ================================================
000000r 2               ; Change how the game compiles with this one simple trick!
000000r 2               ; assembly programmers HATE this!
000000r 2               ; ============================================================
000000r 2               
000000r 2               
000000r 2               
000000r 2               ; ADDITIONAL FEATURES ========================================
000000r 2               ; Some extra things
000000r 2               ;
000000r 2               ; Kando's Fun Stuff
000000r 2               ; uncomment to enable kandowontu's added features that aren't
000000r 2               ; in vanilla geometry dash.
000000r 2               _FLAG_KANDO_FUN_STUFF = 1
000000r 2               ; ============================================================
000000r 2               
000000r 2               
000000r 2               
000000r 2               ; DEBUGGING FEATURES =========================================
000000r 2               ; Useful stuff for making a ROM hack or mod.
000000r 2               ;
000000r 2               ; Enable Test Levels
000000r 2               ; uncomment to enable every level id. will break after TEST4.
000000r 2               ; #define FLAG_ENABLE_TEST_LEVELS
000000r 2               ;
000000r 2               ; Print Metatiles When Compiling
000000r 2               ; set to 1 to display metatile data when compiling via the
000000r 2               ; command line.
000000r 2               _PRINT_METATILES = 0
000000r 2               ;
000000r 2               ; Enable Debug Mode
000000r 2               ; Activated by pressing SELECT during gameplay
000000r 2               ; Recommended to be disabled for release builds
000000r 2               _DEBUG_MODE_ENABLED = 1
000000r 2               ;
000000r 2               ; Enable kandokidshackX Variables
000000r 2               ; Activated in convoluted methods
000000r 2               _KANDOKIDSHACKX_ENABLED = 1
000000r 2               ; ============================================================
000000r 2               
000000r 2               
000000r 2               
000000r 2               ; VERSION NUMBER STUFF =======================================
000000r 2               ; These change how the version number is displayed.
000000r 2               ;
000000r 2               ; Enable Version Number
000000r 2               ; uncomment to enable the version number on the credits screen
000000r 2               ; you can ignore everything below this if disabled.
000000r 2               _FLAG_ENABLE_VER_NUM = 1
000000r 2               ;
000000r 2               ; Beta Build
000000r 2               ; uncomment if compiling a demo or beta build.
000000r 2               _FLAG_BETA_BUILD = 1
000000r 2               ;
000000r 2               ; Major Version Number
000000r 2               ; set if releasing a demo/beta.
000000r 2               _FLAG_MAJ_VER = '1'
000000r 2               ;
000000r 2               ; Minor Version Number
000000r 2               ; increment by 1 for officially released patches.
000000r 2               _FLAG_MIN_VER = '2'
000000r 2               ;
000000r 2               ; Patch Version Number
000000r 2               ; increment by 1 for patches
000000r 2               _FLAG_PATCH_VER = '8'
000000r 2               ; ============================================================
000000r 2               
000000r 2               
000000r 2               
000000r 2               ; OPTIMIZATION SETTINGS ======================================
000000r 2               ; Speed up parts of the game with these flag(s).
000000r 2               ;
000000r 2               ; Use Illegal Opcodes
000000r 2               ; set this to 1 to *slightly* speed up some code in nesdash.s.
000000r 2               ; real Famicoms/NESs should have no problems executing code
000000r 2               ; with such opcodes, but clone CPUs in Famiclones such as
000000r 2               ; Dendy as well as some emulators do not execute those
000000r 2               ; reliably, therefore we advise to have it turned off for
000000r 2               ; maximum hardware compatibility.
000000r 2               _USE_ILLEGAL_OPCODES = 0
000000r 2               ; ============================================================
000000r 2               
000000r 2               
000000r 2               
000000r 2               ; ADVANCED SETTINGS ==========================================
000000r 2               ; !! ONLY CHANGE IF YOU KNOW WHAT YOU'RE DOING !!
000000r 2               ;
000000r 2               ; Save File Version
000000r 2               ; increase by 1 if SRAM values are added, changed or deleted.
000000r 2               _FLAG_SAVE_VER = $24
