000100r 2               _famistudio_output_buf:
000100r 2  xx xx xx xx  famistudio_output_buf:     .res 11
000104r 2  xx xx xx xx  
000108r 2  xx xx xx     
00010Br 2  xx           famistudio_sfx_addr_lo:    .res 1
00010Cr 2  xx           famistudio_sfx_addr_hi:    .res 1
00010Dr 2  xx xx xx xx  famistudio_sfx_base_addr:  .res (FAMISTUDIO_CFG_SFX_STREAMS * FAMISTUDIO_SFX_STRUCT_SIZE)
000111r 2  xx xx xx xx  
000115r 2  xx xx xx xx  
00011Cr 2               
00011Cr 2               ; TODO: Refactor SFX memory layout. These uses a AoS approach, not fan.
00011Cr 2               famistudio_sfx_repeat = famistudio_sfx_base_addr + 0
00011Cr 2               famistudio_sfx_ptr_lo = famistudio_sfx_base_addr + 1
00011Cr 2               famistudio_sfx_ptr_hi = famistudio_sfx_base_addr + 2
00011Cr 2               famistudio_sfx_offset = famistudio_sfx_base_addr + 3
00011Cr 2               famistudio_sfx_buffer = famistudio_sfx_base_addr + 4
00011Cr 2               
00011Cr 2               ; .out .sprintf("SIZE OF FAMISTUDIO RAM IS %d", _famistudio_output_buf - _famistudio_state)
00011Cr 2               
00011Cr 2               .endif
00011Cr 2               ;======================================================================================================================
00011Cr 2               ; ZEROPAGE VARIABLES
00011Cr 2               ;
00011Cr 2               ; These are only used as temporary variable during the famistudio_xxx calls.
00011Cr 2               ; Feel free to alias those with other ZP values in your programs to save a few bytes.
00011Cr 2               ;======================================================================================================================
00011Cr 2               
00011Cr 2               .segment .string(FAMISTUDIO_CA65_ZP_SEGMENT) : zeropage
00003Er 2               
00003Er 2  xx           famistudio_r0:   .res 1
00003Fr 2  xx           famistudio_r1:   .res 1
000040r 2  xx           famistudio_r2:   .res 1
000041r 2  xx           famistudio_r3:   .res 1
000042r 2               
000042r 2  xx xx        famistudio_ptr0: .res 2
000044r 2  xx xx        famistudio_ptr1: .res 2
000046r 2               .if FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_S5B
000046r 2               famistudio_ptr2: .res 2
000046r 2               .endif
000046r 2               
000046r 2               famistudio_ptr0_lo = famistudio_ptr0+0
000046r 2               famistudio_ptr0_hi = famistudio_ptr0+1
000046r 2               famistudio_ptr1_lo = famistudio_ptr1+0
000046r 2               famistudio_ptr1_hi = famistudio_ptr1+1
000046r 2               
