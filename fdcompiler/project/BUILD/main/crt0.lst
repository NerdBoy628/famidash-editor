000797r 2               ; char bg_collision_sub();
000797r 2               .segment "CODE_2"
00020Br 2               
00020Br 2               .importzp _temp_x, _temp_y, _temp_room, _collision
00020Br 2               
00020Br 2               .export _bg_collision_sub
00020Br 2               .proc _bg_collision_sub
00020Br 2                   ; Returns collision block indexed by
00020Br 2               	; temp_x for X
00020Br 2               	; temp_room and y for Y
00020Br 2  A5 rr            LDA _temp_y     ;
00020Dr 2  C9 F0            CMP #$F0        ;   if(temp_y >= 0xf0) return 0;
00020Fr 2  B0 22            BCS Return0		;__
000211r 2  29 F0            AND #$F0        ;	temp_y & 0xF0
000213r 2  85 rr            STA tmp1        ;__
000215r 2  A5 rr        	LDA _temp_x		;
000217r 2  4A           	LSR				;
000218r 2  4A           	LSR				;	temp_x >> 4
000219r 2  4A           	LSR				;
00021Ar 2  4A           	LSR				;__
00021Br 2  05 rr        	ORA tmp1		;	coordinates = (temp_x >> 4) + ((temp_y) & 0xf0);
00021Dr 2  A8           	TAY				;__
00021Er 2               
00021Er 2  A5 rr        	LDA _temp_room	;	tmp3 = temp_room&3;
000220r 2  29 03        	AND #$03		;__
000222r 2  09 rr        	ORA #>collMap0
000224r 2  85 rr        	STA ptr1+1
000226r 2  A9 00        	LDA #$00
000228r 2  85 rr        	STA ptr1
00022Ar 2               
00022Ar 2               	.if USE_ILLEGAL_OPCODES
00022Ar 2               		LAX (ptr1),Y
00022Ar 2               	.else
00022Ar 2  B1 rr        		LDA (ptr1),Y
00022Cr 2  AA           		TAX
00022Dr 2               	.endif
00022Dr 2  BD rr rr     	LDA metatiles_coll,X	;	return is_solid[collision];
000230r 2  85 rr        	STA _collision	;
000232r 2  60           	RTS				;__
000233r 2               
000233r 2               	Return0:
000233r 2  A9 00        	LDA #$00
000235r 2  85 rr        	sta _collision
000237r 2  60           	RTS
000238r 2               
000238r 2               .endproc
000238r 2               
000238r 2               .endif
