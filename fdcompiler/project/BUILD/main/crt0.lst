00040Fr 2               
00040Fr 2               .ifndef FAMISTUDIO_CFG_PAL_SUPPORT
00040Fr 2                   FAMISTUDIO_CFG_PAL_SUPPORT = 0
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               .ifndef FAMISTUDIO_CFG_NTSC_SUPPORT
