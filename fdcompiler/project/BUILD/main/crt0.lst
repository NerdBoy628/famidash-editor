000054r 2               ; Standard for function declaration here:
000054r 2               ; C function name
000054r 2               ; .segment declaration
000054r 2               ; [ <empty line>
000054r 2               ; imports ]
000054r 2               ; <empty line>
000054r 2               ; .export declaration
000054r 2               ; the function itself
000054r 2               .if !__THE_ALBUM
000054r 2               ; void __fastcall__ oam_meta_spr_flipped(uint8_t x,uint8_t y,const void *data);
000054r 2               .segment _PLAYER_RENDER_BANK
000000r 2               
000000r 2               .export __oam_meta_spr_flipped
000000r 2               .proc __oam_meta_spr_flipped
000000r 2               	; AX = data
000000r 2               	; sreg[0] = x
000000r 2               	; sreg[1] = y
000000r 2               	; xargs[0] = flip
000000r 2  85 rr        	sta <PTR
000002r 2  86 rr        	stx <PTR+1
000004r 2               
000004r 2  A6 rr        	ldx SPRID
000006r 2  A0 00        	ldy #0
000008r 2               
000008r 2               loop:
000008r 2               
000008r 2  B1 rr        	lda (PTR),y     ;x offset
00000Ar 2  C9 80        	cmp #$80
00000Cr 2  F0 35        	beq end
00000Er 2  C8           	iny
00000Fr 2  18           	clc
000010r 2  24 rr        	BIT xargs+0 ;	Check for bit 6 (HFLIP)
000012r 2  50 05        	BVC :+		;__
000014r 2  49 FF        	EOR #$FF	;	If HLIPd, then two's complement
000016r 2  69 F8        	ADC #($100 - 8)	; Carry is clear
000018r 2  38           	SEC			;__
000019r 2               	:			;
000019r 2  65 rr        	adc sreg+0
00001Br 2  9D rr rr     	sta OAM_BUF+3,x
00001Er 2  B1 rr        	lda (PTR),y     ;y offset
000020r 2  C8           	INY
000021r 2  18           	clc
000022r 2  24 rr        	BIT xargs+0	;	Check for bit 7 (VFLIP)
000024r 2  10 03        	BPL :+		;__
000026r 2  49 FF        	EOR #$FF	;   If VLIPd, then two's complement
000028r 2               	; ADC #($100 - 16)	; Carry is clear, Y is -16'd because of us using 8x16 mode
000028r 2  38           	SEC			;__
000029r 2               	:			;
000029r 2  65 rr        	adc sreg+1
00002Br 2  9D rr rr     	sta OAM_BUF+0,x
00002Er 2  B1 rr        	lda (PTR),y     ;tile
000030r 2  C8           	iny
000031r 2  9D rr rr     	sta OAM_BUF+1,x
000034r 2  B1 rr        	lda (PTR),y     ;attribute
000036r 2  C8           	iny
000037r 2  45 rr        	EOR xargs+0
000039r 2  9D rr rr     	sta OAM_BUF+2,x
00003Cr 2               	.if USE_ILLEGAL_OPCODES
00003Cr 2               		txa			;	aka X += 4
00003Cr 2               		axs #<-4	;__
00003Cr 2               	.else
00003Cr 2  E8           		inx
00003Dr 2  E8           		inx
00003Er 2  E8           		inx
00003Fr 2  E8           		inx
000040r 2               	.endif
000040r 2  4C rr rr     	jmp loop
000043r 2               
000043r 2               end:
000043r 2               
000043r 2  86 rr        	stx SPRID
000045r 2  60           	rts
000046r 2               .endproc
000046r 2               .endif
000046r 2               .segment "RODATA"
000100r 2               
000100r 2               .export _shiftBy4table := shiftBy4table
000100r 2               shiftBy4table:
000100r 2  00 10 20 30  	.byte $00, $10, $20, $30
000104r 2  40 50 60 70  	.byte $40, $50, $60, $70
000108r 2  80 90 A0 B0  	.byte $80, $90, $A0, $B0
00010Cr 2  C0 D0 E0 F0  	.byte $C0, $D0, $E0, $F0
000110r 2               
000110r 2               .segment "CODE"
000000r 2               
000000r 2               .export __one_vram_buffer_repeat
000000r 2               .proc __one_vram_buffer_repeat
000000r 2               	; ax = ppu_address
000000r 2               	; sreg[0] = data
000000r 2               	; sreg[1] = len
000000r 2  A4 rr        	ldy VRAM_INDEX
000002r 2  99 rr rr     	sta VRAM_BUF+1, y
000005r 2  8A           	txa
000006r 2  99 rr rr     	sta VRAM_BUF+0, y
000009r 2               	; ptr1 lo byte is len, hi byte is character to repeat
000009r 2  A5 rr        	lda sreg+1
00000Br 2  09 80        	ora #$80 ; set length + repeat byte
00000Dr 2  99 rr rr     	sta VRAM_BUF+2, y
000010r 2  A5 rr        	lda sreg+0
000012r 2  99 rr rr     	sta VRAM_BUF+3, y
000015r 2  A9 FF        	lda #$ff ;=NT_UPD_EOF
000017r 2  99 rr rr     	sta VRAM_BUF+4, y
00001Ar 2  98           	tya
00001Br 2  18           	clc
00001Cr 2  69 04        	adc #4
00001Er 2  85 rr        	sta VRAM_INDEX
000020r 2  60           	rts
000021r 2               .endproc
000021r 2               
000021r 2               ; void __fastcall__ init_rld(uint8_t level);
000021r 2               .segment "CODE"
000021r 2               
000021r 2               .global _level_list_lo, _level_list_hi, _level_list_bank, _sprite_list_lo, _sprite_list_hi, _sprite_list_bank
000021r 2               .import _current_deco_type, _current_spike_set, _current_block_set, _current_saw_set
000021r 2               .import _song, _speed, _lastgcolortype, _lastbgcolortype, _spawn_y_pos, _spawn_scroll_y_pos, _max_fallspeed
000021r 2               .import _level_data_bank, _sprite_data_bank, _force_platformer
000021r 2               .import _discomode
000021r 2               
000021r 2               .export _init_rld
000021r 2               _init_rld:
000021r 2               	; A - the level ID
000021r 2               
000021r 2               	; Get pointers:
000021r 2  A8           	TAY						;__ Load pointer to tables
000022r 2               
000022r 2  AD rr rr     	LDA	mmc3PRG1Bank		;	Save PRG1 bank
000025r 2  48           	PHA						;__
000026r 2               
000026r 2  B9 rr rr     	LDA _level_list_lo,y	;
000029r 2  85 rr        	STA	ptr1+0				;__	Get low pointer to level data
00002Br 2  B9 rr rr     	LDA _level_list_hi,y	;
00002Er 2  85 rr        	STA	ptr1+1				;__	Get high pointer to level data
000030r 2  B9 rr rr     	LDA _level_list_bank,y	;
000033r 2  8D rr rr     	STA _level_data_bank	;__	Get level data bank
000036r 2               
000036r 2  20 rr rr     	JSR mmc3_set_prg_bank_1
000039r 2               
000039r 2  A0 00        	LDY #$00			;-  For both (zp),y addressing and rld_column
00003Br 2  8C rr rr     	STY	_no_parallax	;__	Reset bit-value variables
00003Er 2  8C rr rr     	STY rld_column		;__ Reset scrolling
000041r 2               
000041r 2               	; Read header
000041r 2               
000041r 2               
000041r 2  B1 rr        	LDA (ptr1),y			;
000043r 2  85 rr        	STA _sprite_data+0		;	Get low pointer to sprite data
000045r 2  C8           	INY						;__
000046r 2  B1 rr        	LDA (ptr1),y			;
000048r 2  85 rr        	STA _sprite_data+1		;	Get high pointer to sprite data
00004Ar 2  C8           	INY						;__
00004Br 2  B1 rr        	LDA (ptr1),y			;
00004Dr 2  8D rr rr     	STA _sprite_data_bank	;	Get sprite data bank
000050r 2  C8           	INY						;__
000051r 2               
000051r 2  B1 rr        	LDA (ptr1),y		;
000053r 2  8D rr rr     	STA _song			;   Song ID
000056r 2  C8           	INY					;__
000057r 2               
000057r 2  B1 rr        	LDA (ptr1),y		;	Starting gamemode and speed
000059r 2  AA           	TAX					;__
00005Ar 2  4A           	LSR					;
00005Br 2  4A           	LSR					;
00005Cr 2  4A           	LSR					;	Get speed
00005Dr 2  4A           	LSR					;
00005Er 2  8D rr rr     	STA	_speed			;__
000061r 2  8A           	TXA					;
000062r 2  29 0F        	AND	#$0F			;
000064r 2  85 rr        	STA	_gamemode		;	Get just the gamemode
000066r 2  C8           	INY					;__
000067r 2               
000067r 2  B1 rr        	LDA (ptr1),y		;spawn y position high byte
000069r 2  8D rr rr     	sta _spawn_y_pos+1
00006Cr 2  C8           	iny
00006Dr 2  B1 rr        	LDA (ptr1),y		;spawn y position low byte
00006Fr 2  8D rr rr     	sta _spawn_y_pos
000072r 2  C8           	iny
000073r 2               
000073r 2  B1 rr        	LDA (ptr1),y		;spawn scroll y position high byte
000075r 2  8D rr rr     	sta _spawn_scroll_y_pos+1
000078r 2  C8           	iny
000079r 2  B1 rr        	LDA (ptr1),y		;spawn scroll y position low byte
00007Br 2  8D rr rr     	sta _spawn_scroll_y_pos
00007Er 2  C8           	iny
00007Fr 2               
00007Fr 2  B1 rr        	LDA (ptr1),y		;max fall speed high byte
000081r 2  8D rr rr     	sta _max_fallspeed
000084r 2  C8           	iny
000085r 2               
000085r 2  B1 rr        	LDA (ptr1),y		;__	Force platformer, Parallax disable
000087r 2  4A           	LSR					;__	Parallax disable in carry
000088r 2  2E rr rr     	ROL _force_platformer	;__	Store where it needs to go
00008Br 2  8D rr rr     	STA _no_parallax	;	The rest is force platformer, store it
00008Er 2  C8           	INY					;__
00008Fr 2               
00008Fr 2  B1 rr        	LDA (ptr1),y			;
000091r 2  8D rr rr     	STA _current_deco_type	;	Deco type
000094r 2  C8           	INY						;__
000095r 2               
000095r 2  B1 rr        	LDA (ptr1),y			;
000097r 2  8D rr rr     	STA _current_spike_set	;	Spike set
00009Ar 2  C8           	INY						;__
00009Br 2               
00009Br 2  B1 rr        	LDA (ptr1),y			;
00009Dr 2  8D rr rr     	STA _current_block_set	;	Block set
0000A0r 2  C8           	INY						;__
0000A1r 2               
0000A1r 2  B1 rr        	LDA (ptr1),y			;
0000A3r 2  8D rr rr     	STA _current_saw_set	;__	Saw set
0000A6r 2               
0000A6r 2  98           	TYA						;
0000A7r 2  38           	SEC						;
0000A8r 2  65 rr        	ADC	ptr1				;
0000AAr 2  85 rr        	STA	ptr1				;	Add Y to the ptr since we're gonna use Y
0000ACr 2  90 02        	BCC	:+					;	SEC for additional increment
0000AEr 2  E6 rr        		INC	ptr1+1			;
0000B0r 2               	:						;__
0000B0r 2  A0 00        	LDY	#$00				;__
0000B2r 2               
0000B2r 2               
0000B2r 2               	;	Deal with the starting BG color
0000B2r 2  B1 rr        	LDA (ptr1),y			;	Starting BG color
0000B4r 2  29 3F        	AND #$3F				;	Store normal color to slot 0
0000B6r 2  8D rr rr     	STA PAL_BUF_RAW+0		;__
0000B9r 2  AE rr rr     	LDX _lastbgcolortype	;
0000BCr 2  E8           	INX						;
0000BDr 2  D0 03        	BNE :+					;	Replace lastbgcolortype if == 0xFF
0000BFr 2  8D rr rr     		STA _lastbgcolortype;
0000C2r 2               	:						;__
0000C2r 2  A8           	TAY						;
0000C3r 2  B1 rr        	LDA (PAL_PTR),y			;	Store it to the buffer
0000C5r 2  8D rr rr     	STA PAL_BUF+0			;__
0000C8r 2               	;	Now fade it
0000C8r 2  B9 rr rr     	LDA palBrightTable3, Y	;
0000CBr 2  8D rr rr     	STA PAL_BUF_RAW+1		;	Store faded color to slots 1 and 9
0000CEr 2  8D rr rr     	STA PAL_BUF_RAW+9		;__
0000D1r 2  8D rr rr     	STA PAL_BUF_RAW+13		;__
0000D4r 2  A8           	TAY						;
0000D5r 2  B1 rr        	LDA (PAL_PTR),y			;	Store it into the buffer
0000D7r 2  8D rr rr     	STA PAL_BUF+1			;
0000DAr 2  8D rr rr     	STA PAL_BUF+9			;__
0000DDr 2  8D rr rr     	STA PAL_BUF+13			;__
0000E0r 2  E6 rr D0 02  	incw ptr1				;	Move on
0000E4r 2  E6 rr        
0000E6r 2  A0 00        	LDY #0					;__
0000E8r 2               
0000E8r 2               	;	Deal with the starting ground color
0000E8r 2  B1 rr        	LDA (ptr1),y			;	Starting ground color
0000EAr 2  29 3F        	AND #$3F				;	Store normal color to slot 6
0000ECr 2  8D rr rr     	STA PAL_BUF_RAW+6		;__
0000EFr 2  AE rr rr     	LDX _lastgcolortype		;
0000F2r 2  E8           	INX						;
0000F3r 2  D0 03        	BNE :+					;	Replace lastgcolortype if == 0xFF
0000F5r 2  8D rr rr     		STA	_lastgcolortype	;
0000F8r 2               	:						;__
0000F8r 2  A8           	TAY						;
0000F9r 2  B1 rr        	LDA (PAL_PTR),y			;	Store it into the buffer
0000FBr 2  8D rr rr     	STA PAL_BUF+6			;__
0000FEr 2               	;	Now fade it
0000FEr 2  B9 rr rr     	LDA palBrightTable3, Y	;	Store faded color to slot 5
000101r 2  8D rr rr     	STA PAL_BUF_RAW+5		;__
000104r 2  A8           	TAY						;
000105r 2  B1 rr        	LDA	(PAL_PTR),y			;	Store it into the buffer
000107r 2  8D rr rr     	STA	PAL_BUF+5			;__
00010Ar 2  E6 rr        	INC <PAL_UPDATE			;__ Yes, we do need to update the palette
00010Cr 2               
00010Cr 2               
00010Cr 2  A0 00        	ldy #0
00010Er 2  E6 rr D0 02  	incw ptr1
000112r 2  E6 rr        
000114r 2               
000114r 2  B1 rr        	LDA	(ptr1),y
000116r 2  AA           	TAX
000117r 2  49 FF        	EOR #$FF			;
000119r 2  18           	CLC					;	Level height
00011Ar 2  69 01        	ADC #$01			;
00011Cr 2  8D rr rr     	STA rld_load_value	;__
00011Fr 2               
00011Fr 2  A9 01        	LDA	#$01			;- (to automatically shift out 1)
000121r 2  E0 1C        	CPX	#27+1			;	Extceil flag
000123r 2  6A           	ROR					;
000124r 2  8D rr rr     	STA	extceil			;__
000127r 2               
000127r 2               	@min_scroll_y_calc:
000127r 2  A9 00        		LDA	#$00			;
000129r 2  8D rr rr     		STA	min_scroll_y+1	;__
00012Cr 2               
00012Cr 2  8A           		TXA						;
00012Dr 2  49 FF        		EOR	#$FF				;	Get 57 - level height
00012Fr 2               		; SEC done by LDA #$01	;	aka the highest row
00012Fr 2  69 39        		ADC #<(1+57-1)			;__
000131r 2  38           		SEC
000132r 2               	@min_scroll_y_loop:
000132r 2  AA           		TAX
000133r 2  E9 0F        		SBC	#15				;__
000135r 2  90 05        		BCC	@min_scroll_y_fin
000137r 2  EE rr rr     		INC	min_scroll_y+1
00013Ar 2  B0 F6        		BCS	@min_scroll_y_loop	; = BRA
00013Cr 2               	@min_scroll_y_fin:
00013Cr 2  BD rr rr     		LDA	shiftBy4table, X
00013Fr 2  09 08        		ORA #$08
000141r 2  8D rr rr     		STA min_scroll_y
000144r 2               
000144r 2  E6 rr D0 02  	incw ptr1
000148r 2  E6 rr        
00014Ar 2               
00014Ar 2               SetupNextRLEByte:
00014Ar 2  A6 rr        	ldx	ptr1+0		;	LZ data ptr
00014Cr 2  A4 rr        	ldy	ptr1+1		;__
00014Er 2               
00014Er 2  20 rr rr     	jsr	LZ_init_decomp
000151r 2               
000151r 2  20 rr rr         jsr	LZ_get_byte		;
000154r 2  C9 00        	cmp	#$00			;
000156r 2  30 0B            bmi single_rle_byte	;	Load rld_run
000158r 2  85 rr            STA rld_run			;__
00015Ar 2               
00015Ar 2  20 rr rr         jsr	LZ_get_byte		;
00015Dr 2  85 rr            STA rld_value		;__	Load rld_value
00015Fr 2               
00015Fr 2  68           	pla						;	Restore PRG1 bank
000160r 2  4C rr rr     	jmp	mmc3_set_prg_bank_1	;__
000163r 2               single_rle_byte:
000163r 2  29 7F        	and #$7f
000165r 2  85 rr        	sta rld_value
000167r 2  A9 00        	lda #0
000169r 2  85 rr        	sta rld_run
00016Br 2               
00016Br 2  68           	pla						;	Restore PRG1 bank
00016Cr 2  4C rr rr     	jmp	mmc3_set_prg_bank_1	;__
00016Fr 2               
00016Fr 2               ; void unrle_next_column();
00016Fr 2               .segment "CODE"
00016Fr 2               
00016Fr 2               .export _unrle_next_column
00016Fr 2               .proc _unrle_next_column
00016Fr 2               
00016Fr 2               	col_idx = tmp1
00016Fr 2               
00016Fr 2               	; Count up to zero to remove a cmp instruction
00016Fr 2  AE rr rr     	ldx rld_load_value
000172r 2  A5 rr        	lda rld_value
000174r 2               
000174r 2               	@FirstLoop:
000174r 2  9D rr rr     		sta columnBuffer - ($100 - (15 + 15 + 15 + 12)), x
000177r 2  C6 rr        		dec rld_run
000179r 2  30 05        		bmi @UpdateValueRun
00017Br 2  E8           		inx
00017Cr 2  30 F6        		bmi @FirstLoop
00017Er 2  10 32        		bpl @End ; Guaranteed jump
000180r 2               
000180r 2               	@UpdateValueRun:
000180r 2  86 rr        		stx	col_idx
000182r 2               
000182r 2               	@ReadNewVal:
000182r 2               		; if bit 7 of the byte is set, then its a run of length 1
000182r 2               		; otherwise this is a length < 127 byte and we need to read another
000182r 2  20 rr rr     		jsr	LZ_get_byte			;
000185r 2  C9 00        		cmp	#$00				;
000187r 2  30 1C        		bmi @SingleByteRun		;	Load rld_run
000189r 2  85 rr        		sta rld_run				;__
00018Br 2               
00018Br 2  20 rr rr     		jsr	LZ_get_byte			;
00018Er 2  C5 rr        		cmp	rld_run				;	Load rld_value
000190r 2  F0 09        		beq	@ParseMetaSeq		;	or meta sequence
000192r 2               	@noMetaSeq:					;
000192r 2  85 rr        		sta rld_value			;__
000194r 2               
000194r 2  A6 rr        		ldx	col_idx
000196r 2  E8           		inx
000197r 2  30 DB        		bmi @FirstLoop
000199r 2  10 17        		bpl @End ; Unconditional
00019Br 2               
00019Br 2               	@ParseMetaSeq:
00019Br 2  C9 7F        		cmp	#$7F			;
00019Dr 2  D0 F3        		bne @noMetaSeq		;	Parse meta sequences
00019Fr 2  20 rr rr     		jsr	loadLevelContinuation
0001A2r 2  4C rr rr     		jmp	@ReadNewVal		;__
0001A5r 2               
0001A5r 2               	@SingleByteRun:
0001A5r 2  29 7F        		and #$7f
0001A7r 2  85 rr        		sta rld_value
0001A9r 2  A0 00        		ldy	#$00
0001ABr 2  84 rr        		sty rld_run
0001ADr 2  A6 rr        		ldx col_idx
0001AFr 2  E8           		inx
0001B0r 2  30 C2        		bmi @FirstLoop
0001B2r 2               		; and then fallthrough to copying to the collision map
0001B2r 2               
0001B2r 2               	@End:
0001B2r 2  AE rr rr     	ldx rld_column
0001B5r 2  E8           	inx
0001B6r 2               	.if USE_ILLEGAL_OPCODES
0001B6r 2               		lda #$0F
0001B6r 2               		sax rld_column
0001B6r 2               	.else
0001B6r 2  8A           		txa
0001B7r 2  29 0F        		and #$0F
0001B9r 2  8D rr rr     		sta rld_column
0001BCr 2               	.endif
0001BCr 2  60           	rts
0001BDr 2               .endproc
0001BDr 2               
0001BDr 2               ; Function not available in C
0001BDr 2               .segment "CODE"
0001BDr 2               
0001BDr 2               .proc loadLevelContinuation
0001BDr 2               	; Meta sequence: load new level chunk
0001BDr 2  20 rr rr     	jsr	LZ_get_byte			;	Get Meta Level ID
0001C0r 2  A8           	tay						;__
0001C1r 2               
0001C1r 2  B9 rr rr     	lda	_level_chunk_list_bank, y	;
0001C4r 2  8D rr rr     	sta	_level_data_bank			;	Get new data bank
0001C7r 2  20 rr rr     	jsr	mmc3_set_prg_bank_1			;__
0001CAr 2               
0001CAr 2  BE rr rr     	ldx	_level_chunk_list_lo, y		;__	Get new data low ptr
0001CDr 2  B9 rr rr     	lda	_level_chunk_list_hi, y		;	Get new data high ptr
0001D0r 2  A8           	tay								;__
0001D1r 2               
0001D1r 2  4C rr rr     	jmp	LZ_init_decomp
0001D4r 2               .endproc
0001D4r 2               
0001D4r 2               ; void __fastcall__ dummy_unrle_columns(uint16_t columns);
0001D4r 2               .segment "CODE"
0001D4r 2               
0001D4r 2               .import umul8x16r24m
0001D4r 2               
0001D4r 2               .export _dummy_unrle_columns
0001D4r 2               .proc _dummy_unrle_columns
0001D4r 2               	lastType = tmp1	; 0 = group of bytes, FF = single byte
0001D4r 2               	mulIn0 = ptr3
0001D4r 2               	mulIn1 = ptr1
0001D4r 2               	mulRes0 = ptr1
0001D4r 2               	mulRes1 = ptr1+1
0001D4r 2               	mulRes2 = sreg
0001D4r 2               	start:
0001D4r 2  85 rr        		sta mulIn0			;
0001D6r 2  86 rr        		stx mulIn0+1		;	Multiply the
0001D8r 2  29 0F        		and #$0F			;	amount of columns
0001DAr 2  8D rr rr     		sta rld_column		;__
0001DDr 2  AD rr rr     		lda rld_load_value	;
0001E0r 2  49 FF        		eor #$FF			;
0001E2r 2  38           		sec					;	by level height
0001E3r 2  69 00        		adc #0				;
0001E5r 2  85 rr        		sta mulIn1			;__
0001E7r 2  20 rr rr     		jsr umul8x16r24m
0001EAr 2               		; result now in ptr1:sreg[0],
0001EAr 2               		; y = 0
0001EAr 2               
0001EAr 2  E6 rr        		inc mulRes1		;	increment for beq ending condition
0001ECr 2  E6 rr        		inc mulRes2		;__
0001EEr 2               
0001EEr 2  A5 rr        		lda mulRes0
0001F0r 2  18           		clc				;	Subtract 1 extra, rld_run after all
0001F1r 2  E5 rr        		sbc rld_run		;__
0001F3r 2  85 rr        		sta mulRes0
0001F5r 2  B0 08        		bcs loop
0001F7r 2               
0001F7r 2  C6 rr        		dec mulRes1
0001F9r 2  D0 04        		bne loop
0001FBr 2               
0001FBr 2  C6 rr        		dec mulRes2
0001FDr 2  F0 24        		beq end_early
0001FFr 2               
0001FFr 2               	loop:
0001FFr 2  20 rr rr     		jsr	LZ_get_byte	; either single-run value or run
000202r 2  C9 00        		cmp	#$00
000204r 2  30 24        		bmi single_byte
000206r 2  85 rr        		sta rld_run
000208r 2               
000208r 2  20 rr rr     		jsr	LZ_get_byte			;
00020Br 2  C5 rr        			cmp	rld_run			;	Load rld_value
00020Dr 2  F0 33        			beq	parseMetaSeq	;	or meta sequence
00020Fr 2               		loop_noMetaSeq:			;
00020Fr 2  AA           			tax					;__
000210r 2               
000210r 2  A5 rr        		lda mulRes0
000212r 2  18           		clc	; subtract 1 extra
000213r 2  E5 rr        		sbc rld_run
000215r 2  85 rr        		sta mulRes0
000217r 2  B0 E6        		bcs loop
000219r 2               
000219r 2  C6 rr        		dec mulRes1
00021Br 2  D0 E2        		bne loop
00021Dr 2               
00021Dr 2  C6 rr        		dec mulRes2
00021Fr 2  D0 DE        		bne loop	; = BRA
000221r 2               
000221r 2               	end_multi:
000221r 2  86 rr        		stx rld_value
000223r 2               		; the remaining rld_run is 2's complement of (mulRes0 - 1)
000223r 2               	end_early:
000223r 2  A5 rr        		lda mulRes0
000225r 2  49 FF        		eor #$FF
000227r 2  85 rr        		sta rld_run
000229r 2  60           		rts
00022Ar 2               
00022Ar 2               
00022Ar 2               	single_byte:
00022Ar 2  C6 rr        		dec mulRes0
00022Cr 2  A6 rr        		ldx mulRes0
00022Er 2  E8           		inx	; less bytes then cpx #$ff
00022Fr 2  D0 CE        		bne loop
000231r 2  C6 rr        		dec mulRes1
000233r 2  D0 CA        		bne loop
000235r 2  C6 rr        		dec mulRes2
000237r 2  D0 C6        		bne loop
000239r 2               
000239r 2               	end_single:
000239r 2  29 7F        		and #$7F
00023Br 2  85 rr        		sta rld_value
00023Dr 2  A9 00        		lda	#$00
00023Fr 2  85 rr        		sta rld_run	; y is still 0
000241r 2  60           		rts
000242r 2               
000242r 2               	parseMetaSeq:
000242r 2  C9 7F        		cmp	#$7F			;
000244r 2  D0 C9        		bne loop_noMetaSeq	;	Parse meta sequences
000246r 2  20 rr rr     		jsr	loadLevelContinuation
000249r 2  4C rr rr     		jmp	loop			;__
00024Cr 2               .endproc
00024Cr 2               
00024Cr 2               
00024Cr 2               
00024Cr 2               .if !__THE_ALBUM
00024Cr 2               .segment _BACKGROUND_RENDER_BANK
000500r 2               
000500r 2               .proc writeToCollisionMap
000500r 2               	; We have 27 writes to make to the collision map, thats 27 * 6 bytes for an unrolled loop.
000500r 2               	; roughly twice the size for much more perf. ill probably make it back to loop
000500r 2  AE rr rr     	ldx rld_column
000503r 2               	.if USE_ILLEGAL_OPCODES
000503r 2               		dex
000503r 2               		lda #$0F
000503r 2               		axs #0
000503r 2               	.else
000503r 2  CA           		dex
000504r 2  8A           		txa
000505r 2  29 0F        		and #$0F
000507r 2  AA           		tax
000508r 2               	.endif
000508r 2  AC rr rr     	ldy rld_load_value
00050Br 2  C0 D6        	cpy #<-(15+15+12)
00050Dr 2  B0 5A        	bcs write_collmap1
00050Fr 2  AD rr rr 9D  		.repeat 15, I
000513r 2  rr rr AD rr  
000517r 2  rr 9D rr rr  
000569r 2               			lda columnBuffer+(15*0) + I
000569r 2               			sta collMap0 + I * 16, x
000569r 2               		.endrepeat
000569r 2               	write_collmap1:
000569r 2  C0 E5        	cpy #<-(15+12)
00056Br 2  B0 5A        	bcs write_collmap2
00056Dr 2  AD rr rr 9D  		.repeat 15, I
000571r 2  rr rr AD rr  
000575r 2  rr 9D rr rr  
0005C7r 2               			lda columnBuffer+(15*1) + I
0005C7r 2               			sta collMap1 + I * 16, x
0005C7r 2               		.endrepeat
0005C7r 2               	write_collmap2:
0005C7r 2  C0 F4        	cpy #<-(12)
0005C9r 2  B0 5A        	bcs write_collmap3
0005CBr 2  AD rr rr 9D  		.repeat 15, I
0005CFr 2  rr rr AD rr  
0005D3r 2  rr 9D rr rr  
000625r 2               			lda columnBuffer+(15*2) + I
000625r 2               			sta collMap2 + I * 16, x
000625r 2               		.endrepeat
000625r 2               	write_collmap3:
000625r 2  AD rr rr 9D  		.repeat 12, I
000629r 2  rr rr AD rr  
00062Dr 2  rr 9D rr rr  
00066Dr 2               			lda columnBuffer+(15*3) + I
00066Dr 2               			sta collMap3 + I * 16, x
00066Dr 2               		.endrepeat
00066Dr 2               	write_ground:
00066Dr 2  BD rr rr 8D  		.repeat 3, I
000671r 2  rr rr BD rr  
000675r 2  rr 8D rr rr  
00067Fr 2               			lda ground + I * 16, x
00067Fr 2               			sta columnBuffer+(15*3)+12+I
00067Fr 2               		.endrepeat
00067Fr 2  60           	rts
000680r 2               .endproc
000680r 2               
000680r 2               
000680r 2               ; [Not used in C]
000680r 2               .segment _BACKGROUND_RENDER_BANK
000680r 2               
000680r 2               .import _scroll_y
000680r 2               
000680r 2               .export get_seam_scroll_y
000680r 2               .proc get_seam_scroll_y
000680r 2               	; No inputs
000680r 2               	; Returns seam_scroll_y in AX
000680r 2               start:
000680r 2  2C rr rr     	BIT	extceil
000683r 2  10 15        	BPL	noSeam
000685r 2               
000685r 2               yesSeam:
000685r 2               	; Seam position:
000685r 2               	; Y ≥	| Y <	| A		| B		|
000685r 2               	; 	0	|  $78	|	0	|	1	|
000685r 2               	;  $78	| $178	|  2/0	|	1	|
000685r 2               	; $178	| $278	|	2	|  3/1	|
000685r 2               	; $278	| $2F0	|	2	|	3	|
000685r 2               
000685r 2               	; Get seam position
000685r 2  AD rr rr     	LDA	_scroll_y
000688r 2  AE rr rr     	LDX	_scroll_y+1
00068Br 2  38           	SEC
00068Cr 2  E9 78        	SBC	#$78	;
00068Er 2  B0 03        	BCS	:+		;	AX = scroll_y - $78
000690r 2  E9 0F        		SBC #$10-1;	(with valid scroll_y coordinates)
000692r 2  CA           		DEX		;__
000693r 2               	:
000693r 2  8D rr rr     	STA	seam_scroll_y
000696r 2  8E rr rr     	STX seam_scroll_y+1
000699r 2               
000699r 2  60           	RTS
00069Ar 2               
00069Ar 2               noSeam:
00069Ar 2               	; The level's ceiling ≤ 27 blocks, no need for a seam
00069Ar 2  A9 78        	LDA	#$78
00069Cr 2  A2 02        	LDX #$02
00069Er 2  8D rr rr     	STA	seam_scroll_y
0006A1r 2  8E rr rr     	STX	seam_scroll_y+1
0006A4r 2  60           	RTS
0006A5r 2               
0006A5r 2               	; Total seam system:
0006A5r 2               	; High byte	| Seam screen	| A		| B		|
0006A5r 2               	;	FF		|	There isn't	|	0	| 	1	|
0006A5r 2               	;	00		|		00		|  2/0	|	1	|
0006A5r 2               	;	01		|		01		|	2	|  3/1	|
0006A5r 2               	;	02		|	There isn't	|	2	|	3	|
0006A5r 2               	;	No seam can be distinguished by high byte >= 02 or bit 1
0006A5r 2               .endproc
0006A5r 2               
0006A5r 2               ; char draw_screen();
0006A5r 2               .segment _BACKGROUND_RENDER_BANK
0006A5r 2               
0006A5r 2               .global dsrt_fr1O : zp
0006A5r 2               
0006A5r 2               .export _draw_screen
0006A5r 2               .proc _draw_screen
0006A5r 2               
0006A5r 2               ; Write architecture:
0006A5r 2               
0006A5r 2               ; Frame 0:
0006A5r 2               ;   Write 0 updates the upper nametable's left tiles
0006A5r 2               ;   Write 1 updates the lower nametable's left tiles
0006A5r 2               ; Frame 1:
0006A5r 2               ;   Write 0 updates the upper nametable's right tiles
0006A5r 2               ;   Write 1 updates the lower nametable's right tiles
0006A5r 2               ; Frame 2:
0006A5r 2               ;   Attributes
0006A5r 2               
0006A5r 2               	frame_free = 0
0006A5r 2               	frame_R_tile_1 = 1
0006A5r 2               	frame_R_attr = 2
0006A5r 2               	frame_UD_tiles_separate_1 = 3
0006A5r 2               	frame_UD_attr_unified = 4
0006A5r 2               	frame_UD_attr_separate = 5
0006A5r 2               
0006A5r 2               start:
0006A5r 2  AE rr rr     	LDX drawing_frame		;	If something is being drawn, continue
0006A8r 2  D0 1D        	BNE switch				;__
0006AAr 2               
0006AAr 2  AD rr rr     	LDA _scroll_x			;
0006ADr 2  4A           	LSR						;
0006AEr 2  4A           	LSR						;	If X == rld column and we are free,
0006AFr 2  4A           	LSR						;	start drawing the right edge
0006B0r 2  4A           	LSR						;
0006B1r 2  CD rr rr     	CMP rld_column			;
0006B4r 2  F0 20        	BEQ draw_screen_R_tiles	;__
0006B6r 2               
0006B6r 2               	;
0006B6r 2               	;	The drawing_frame is 0, but we don't have the right edge to update
0006B6r 2               	;	That means it is time to start updating the vertical scrolling seam
0006B6r 2               	;__
0006B6r 2               
0006B6r 2  AD rr rr     	LDA	extceil						;	If the ceiling is extended
0006B9r 2  49 80        	EOR	#$80						;	and blocks are visible
0006BBr 2  0D rr rr     	ORA	_invisblocks				;	update vertical seam tiles
0006BEr 2  F0 04        	BEQ	jmpto_draw_screen_UD_tiles	;__
0006C0r 2               
0006C0r 2  A9 00        	LDA	#0		;
0006C2r 2  AA           	TAX			;	Otherwise return 0
0006C3r 2  60           	RTS			;__
0006C4r 2               
0006C4r 2               jmpto_draw_screen_UD_tiles:
0006C4r 2  4C rr rr     	JMP draw_screen_UD_tiles_frame0
0006C7r 2               
0006C7r 2               switch:
0006C7r 2  CA           	DEX									;	if drawing_frame == 1, do frame 1
0006C8r 2  F0 rr        	BEQ	draw_screen_R_tiles+dsrt_fr1O	;__	of drawing the right edge (right tile halves)
0006CAr 2  CA           	DEX									;	if drawing_frame == 2, do frame 2
0006CBr 2  D0 03 4C rr  	jeq	draw_screen_R_attributes		;__ of drawing the right edge (attributes)
0006CFr 2  rr           
0006D0r 2  CA           	DEX									;	if drawing_frame == 3, do frame 1
0006D1r 2  D0 03 4C rr  	jeq	draw_screen_UD_tiles_frame1		;__	of drawing the up/down tiles (copy the lower tiles)
0006D5r 2  rr           
0006D6r 2               
0006D6r 2               
0006D6r 2               ; [Subroutine]
0006D6r 2               .global metatiles_top_left, metatiles_top_right, metatiles_bot_left, metatiles_bot_right
0006D6r 2               .import _increase_parallax_scroll_column
0006D6r 2               .import _no_parallax, _invisblocks, _force_platformer
0006D6r 2               
0006D6r 2               .proc draw_screen_R_tiles
0006D6r 2               
0006D6r 2               	TileWriteSize	= (15*2)+2+1
0006D6r 2               
0006D6r 2               	TileOff0		= 0
0006D6r 2               	TileOff1		= 0+TileWriteSize
0006D6r 2               	TileEnd			= 0+TileWriteSize+TileWriteSize
0006D6r 2               
0006D6r 2               	CurrentRow = tmp1
0006D6r 2               	LoopCount = tmp2
0006D6r 2               	SeamValue = ptr3+1
0006D6r 2               
0006D6r 2               
0006D6r 2               
0006D6r 2               frame0:
0006D6r 2  A9 00        	LDA #frame_free
0006D8r 2  8D rr rr     	STA drawing_frame
0006DBr 2               	; Switch banks
0006DBr 2  AC rr rr A9  	crossPRGBankJSR ,_unrle_next_column,_level_data_bank
0006DFr 2  rr A2 rr 20  
0006E3r 2  rr rr        
0006E5r 2  20 rr rr     	JSR writeToCollisionMap
0006E8r 2               frame1:
0006E8r 2               
0006E8r 2               	; thanks ca65, very cool
0006E8r 2               	.if (frame1 - frame0) < 256
0006E8r 2               		.exportzp dsrt_fr1O = <(frame1 - frame0)
0006E8r 2               	.else
0006E8r 2               		.error "too far"
0006E8r 2               	.endif
0006E8r 2               
0006E8r 2               calc_seam_pos:
0006E8r 2               
0006E8r 2  AD rr rr     	LDA seam_scroll_y
0006EBr 2  AE rr rr     	LDX seam_scroll_y+1
0006EEr 2               
0006EEr 2  A0 1E        	LDY	#15+15	;__	Load the starting nametable into Y
0006F0r 2               
0006F0r 2  E0 02        	CPX #$02	;	If there is a seam,
0006F2r 2  B0 0E        	BCS @noseam	;__	calculate its position in metatiles
0006F4r 2               	@yesseam:
0006F4r 2  4A           		LSR					;
0006F5r 2  4A           		LSR					;	Divide by 16, get index
0006F6r 2  4A           		LSR					;	inside screen in metatiles
0006F7r 2  4A           		LSR					;__
0006F8r 2  18           		CLC					;	Add 0 or 15, since scroll_y is nonlinear
0006F9r 2  7D rr rr     		ADC SeamTable, X	;__
0006FCr 2  69 1E        		ADC #30				;__	If the carry was set then something got fucked
0006FEr 2  85 rr        		STA SeamValue
000700r 2  90 08        		BCC @fin	; = BRA, unless the additions got fucked
000702r 2               
000702r 2               	@noseam:		;__	If there is no seam, store an invalid value
000702r 2  86 rr        		STX SeamValue
000704r 2  E0 FF        		CPX	#$FF	;
000706r 2  D0 02        		BNE	@fin	;	If the starting screen is 0, load into Y
000708r 2  A0 00        			LDY #0	;__
00070Ar 2               	@fin:
00070Ar 2  84 rr        		STY	CurrentRow
00070Cr 2               
00070Cr 2               write_start:
00070Cr 2               	; Writing to nesdoug's VRAM buffer starts here
00070Cr 2  A6 rr        	LDX VRAM_INDEX
00070Er 2               
00070Er 2               	; In-house replacement of get_ppu_addr, only counts X
00070Er 2               	; Address is big-endian
00070Er 2  AC rr rr     	LDY rld_column ;   000xxxx0 - the left tiles of the metatiles
000711r 2  88           	DEY
000712r 2  98           	TYA
000713r 2  29 0F        	AND #$0F
000715r 2  0A           	ASL         ;__
000716r 2  AC rr rr     	LDY drawing_frame
000719r 2  F0 02        	BEQ :+
00071Br 2  09 01        		ORA #$01    ;   000xxxx1 - the right tiles of the metatiles
00071Dr 2               	:
00071Dr 2  9D rr rr     	STA VRAM_BUF+TileOff0+1,X
000720r 2  9D rr rr     	STA VRAM_BUF+TileOff1+1,X
000723r 2               
000723r 2               	; Get nametable
000723r 2  AD rr rr     	lda _scroll_x + 1 ; high byte
000726r 2  29 01        	and #%00000001
000728r 2  A8           	tay
000729r 2  B9 rr rr     	lda	ntAddrHiTbl,y
00072Cr 2  9D rr rr     	STA VRAM_BUF+TileOff0,X
00072Fr 2  09 08        	ORA #$08        ; 2nd nametable
000731r 2  9D rr rr     	STA VRAM_BUF+TileOff1,X
000734r 2               
000734r 2               
000734r 2               	; First part of the update: the tiles
000734r 2               	; Amount of data in the sequence - 27*2 tiles (8x8 tiles, left sides of the metatiles)
000734r 2  A9 1E        	LDA #(15*2)
000736r 2  9D rr rr     	STA VRAM_BUF+TileOff0+2,X
000739r 2  9D rr rr     	STA VRAM_BUF+TileOff1+2,X
00073Cr 2               
00073Cr 2               	; The sequence itself:
00073Cr 2               
00073Cr 2               	; Load max value
00073Cr 2  A9 0E        	LDA #15 - 1
00073Er 2  85 rr        	STA LoopCount
000740r 2               	; Check if doing a left or right hand write
000740r 2  AD rr rr     	LDA drawing_frame
000743r 2  29 01        	AND #1
000745r 2  F0 05        	beq @LeftWrite
000747r 2               		; Right side write
000747r 2               		; Call for upper tiles
000747r 2  20 rr rr     		JSR right_tilewriteloop
00074Ar 2  30 03        		BMI @WriteBottomHalf	; The loop keeps looping via a BPL, therefore a BMI = BRA
00074Cr 2               	@LeftWrite:
00074Cr 2  20 rr rr     		JSR left_tilewriteloop
00074Fr 2               @WriteBottomHalf:
00074Fr 2               	; Load new max
00074Fr 2  A9 0E        	LDA #15 - 1
000751r 2  85 rr        	STA LoopCount
000753r 2               	; Add offset to X
000753r 2               	.if USE_ILLEGAL_OPCODES
000753r 2               		TXA
000753r 2               		AXS #<-(TileWriteSize-(15*2))
000753r 2               	.else
000753r 2  8A           		TXA
000754r 2  18           		CLC
000755r 2  69 03        		ADC #(TileWriteSize-(15*2))
000757r 2  AA           		TAX
000758r 2               	.endif
000758r 2               
000758r 2               	; No need to do anything for the screen, as it always increments
000758r 2               
000758r 2  AD rr rr     	LDA drawing_frame
00075Br 2  29 01        	AND #1
00075Dr 2  F0 05        	beq @LeftWrite2
00075Fr 2  20 rr rr     		JSR right_tilewriteloop
000762r 2  30 03        		BMI @RenderParallax	; The loop keeps looping via a BPL, therefore a BMI = BRA
000764r 2               	@LeftWrite2:
000764r 2               		; Call for lower tiles
000764r 2  20 rr rr     		JSR left_tilewriteloop
000767r 2               @RenderParallax:
000767r 2               
000767r 2               	ParallaxBufferStart = tmp1
000767r 2               	ParallaxExtent = tmp3
000767r 2               	; Loop through the vram writes and find any $00 tiles and replace them with parallax
000767r 2               	; Calculate the end of the parallax column offset
000767r 2  AC rr rr     	ldy parallax_scroll_column
00076Ar 2  B9 rr rr     	lda ParallaxBufferOffset, y
00076Dr 2  85 rr        	sta ParallaxBufferStart
00076Fr 2  18           	clc
000770r 2  69 09        	adc #9
000772r 2  85 rr        	sta ParallaxExtent
000774r 2               
000774r 2  A5 rr        	lda ParallaxBufferStart
000776r 2  18           	clc
000777r 2  6D rr rr     	adc parallax_scroll_column_start
00077Ar 2  A8           	tay
00077Br 2               
00077Br 2  A2 1D        	ldx #TileOff0 + TileWriteSize - 1 - (2+1)
00077Dr 2  86 rr        	stx LoopCount
00077Fr 2  A2 00        	ldx #TileOff0
000781r 2  20 rr rr     	jsr RenderParallaxLoop
000784r 2               
000784r 2  A2 1D        	ldx #TileWriteSize - 1 - (2+1)
000786r 2  86 rr        	stx LoopCount
000788r 2  A2 21        	ldx #TileOff1
00078Ar 2  20 rr rr     	jsr RenderParallaxLoop
00078Dr 2               
00078Dr 2               	; move to the next scroll column for next frame
00078Dr 2  20 rr rr     	jsr _increase_parallax_scroll_column
000790r 2               
000790r 2               	; Demarkate end of write
000790r 2  A6 rr        	LDX VRAM_INDEX
000792r 2  A9 FF        	LDA #$FF
000794r 2  9D rr rr     	STA VRAM_BUF+TileEnd,X
000797r 2               
000797r 2               	; Declare this section as taken
000797r 2               	.if USE_ILLEGAL_OPCODES
000797r 2               		; A is already #$FF
000797r 2               		AXS #<-TileEnd
000797r 2               		STX VRAM_INDEX
000797r 2               	.else
000797r 2  8A           		TXA
000798r 2  18           		CLC
000799r 2  69 42        		ADC #TileEnd
00079Br 2  85 rr        		STA	VRAM_INDEX
00079Dr 2               	.endif
00079Dr 2               
00079Dr 2  EE rr rr     	INC drawing_frame
0007A0r 2               
0007A0r 2  A9 01        	LDA #1
0007A2r 2  A2 00        	LDX #0
0007A4r 2  60           	RTS
0007A5r 2               
0007A5r 2               right_tilewriteloop:
0007A5r 2  A4 rr        		ldy CurrentRow
0007A7r 2  AD rr rr     		lda _invisblocks
0007AAr 2  F0 04        		beq @norm
0007ACr 2  A9 00        		lda #0
0007AEr 2  F0 03        		beq @done
0007B0r 2               		@norm:
0007B0r 2  B9 rr rr     		LDA columnBuffer,Y
0007B3r 2               		@done:
0007B3r 2  A8           		tay
0007B4r 2               		; y is the metatile id
0007B4r 2  B9 rr rr     		lda metatiles_top_right, y
0007B7r 2  9D rr rr     		STA VRAM_BUF+TileOff0+3,X
0007BAr 2  B9 rr rr     		lda metatiles_bot_right, y
0007BDr 2  9D rr rr     		STA VRAM_BUF+TileOff0+4,X
0007C0r 2               
0007C0r 2  E8           		INX
0007C1r 2  E8           		INX
0007C2r 2  A5 rr        		LDA CurrentRow
0007C4r 2  C5 rr        		CMP SeamValue
0007C6r 2  38           		SEC		; Does not reset the Zero flag
0007C7r 2  D0 02        		BNE :+	; If the seam doesn't match up, dont subtract
0007C9r 2  E9 1E        			SBC	#30	; Carry still set after this (or invalid otherwise)
0007CBr 2  69 00        		: ADC #0 ; Adds a 1
0007CDr 2  85 rr        		STA CurrentRow
0007CFr 2  C6 rr        		DEC LoopCount
0007D1r 2  10 D2        		BPL right_tilewriteloop
0007D3r 2  60           	rts
0007D4r 2               
0007D4r 2               left_tilewriteloop:
0007D4r 2  A4 rr        		ldy CurrentRow
0007D6r 2  AD rr rr     		lda _invisblocks
0007D9r 2  F0 04        		beq @norm2
0007DBr 2  A9 00        		lda #0
0007DDr 2  F0 03        		beq @done2
0007DFr 2               		@norm2:
0007DFr 2  B9 rr rr     		LDA columnBuffer,Y
0007E2r 2               		@done2:
0007E2r 2  A8           		tay
0007E3r 2               		; y is the metatile id
0007E3r 2  B9 rr rr     		lda metatiles_top_left, y
0007E6r 2  9D rr rr     		STA VRAM_BUF+TileOff0+3,X
0007E9r 2  B9 rr rr     		lda metatiles_bot_left, y
0007ECr 2  9D rr rr     		STA VRAM_BUF+TileOff0+4,X
0007EFr 2               
0007EFr 2  E8           		INX
0007F0r 2  E8           		INX
0007F1r 2  A5 rr        		LDA CurrentRow
0007F3r 2  C5 rr        		CMP SeamValue
0007F5r 2  38           		SEC		; Does not reset the Zero flag
0007F6r 2  D0 02        		BNE :+	; If the seam doesn't match up, dont subtract
0007F8r 2  E9 1E        			SBC	#30	; Carry still set after this (or invalid otherwise)
0007FAr 2  69 00        		: ADC #0 ; Adds a 1
0007FCr 2  85 rr        		STA CurrentRow
0007FEr 2  C6 rr        		DEC LoopCount
000800r 2  10 D2        		BPL left_tilewriteloop
000802r 2  60           	rts
000803r 2               
000803r 2               RenderParallaxLoop:
000803r 2  AD rr rr     	lda _no_parallax
000806r 2  D0 17        	bne @nopar
000808r 2  BD rr rr     		lda VRAM_BUF+TileOff0+3,x
00080Br 2  D0 06        		bne :+
00080Dr 2               			; empty tile, so replace it with the parallax for this
00080Dr 2  B9 rr rr     			lda ParallaxBuffer, y
000810r 2  9D rr rr     			sta VRAM_BUF+TileOff0+3,x
000813r 2               		:
000813r 2  C8           		iny
000814r 2  C4 rr        		cpy ParallaxExtent
000816r 2  D0 02        		bne :+
000818r 2  A4 rr        			ldy ParallaxBufferStart
00081Ar 2               		:
00081Ar 2  E8           		inx
00081Br 2  C6 rr        		dec LoopCount
00081Dr 2  10 E4        		bpl RenderParallaxLoop
00081Fr 2               @nopar:
00081Fr 2  60           		rts
000820r 2               
000820r 2               ; Column striped parallax data definition
000820r 2               ; add to the tile for the next row, up to 6.
000820r 2               ParallaxBuffer:
000820r 2               	ParallaxBufferOffset:
000820r 2  06           		.byte ParallaxBufferCol0 - ParallaxBuffer
000821r 2  0F           		.byte ParallaxBufferCol1 - ParallaxBuffer
000822r 2  18           		.byte ParallaxBufferCol2 - ParallaxBuffer
000823r 2  21           		.byte ParallaxBufferCol3 - ParallaxBuffer
000824r 2  2A           		.byte ParallaxBufferCol4 - ParallaxBuffer
000825r 2  33           		.byte ParallaxBufferCol5 - ParallaxBuffer
000826r 2               	ParallaxBufferCol0:
000826r 2  80 90 A0 B0  		.byte $80, $90, $a0, $b0, $86, $96, $a6, $b6, $8c
00082Ar 2  86 96 A6 B6  
00082Er 2  8C           
00082Fr 2               	ParallaxBufferCol1:
00082Fr 2  81 91 A1 B1  		.byte $81, $91, $a1, $b1, $87, $97, $a7, $b7, $8d
000833r 2  87 97 A7 B7  
000837r 2  8D           
000838r 2               	ParallaxBufferCol2:
000838r 2  82 92 A2 B2  		.byte $82, $92, $a2, $b2, $88, $98, $a8, $b8, $8e
00083Cr 2  88 98 A8 B8  
000840r 2  8E           
000841r 2               	ParallaxBufferCol3:
000841r 2  83 93 A3 B3  		.byte $83, $93, $a3, $b3, $89, $99, $a9, $b9, $9c
000845r 2  89 99 A9 B9  
000849r 2  9C           
00084Ar 2               	ParallaxBufferCol4:
00084Ar 2  84 94 A4 B4  		.byte $84, $94, $a4, $b4, $8a, $9a, $aa, $ba, $9d
00084Er 2  8A 9A AA BA  
000852r 2  9D           
000853r 2               	ParallaxBufferCol5:
000853r 2  85 95 A5 B5  		.byte $85, $95, $a5, $b5, $8b, $9b, $ab, $bb, $9e
000857r 2  8B 9B AB BB  
00085Br 2  9E           
00085Cr 2               
00085Cr 2               SeamTable:
00085Cr 2  00 0F        	.byte 0, 15
00085Er 2               
00085Er 2               ntAddrHiTbl:
00085Er 2  A4 A0        	.byte	$24|$80,	$20|$80
000860r 2               .endproc
000860r 2               
000860r 2               ; [Subroutine]
000860r 2               .global metatiles_attr
000860r 2               .import _no_parallax, _invisblocks, _force_platformer
000860r 2               
000860r 2               .proc draw_screen_R_attributes
000860r 2               	AttrWriteSize	= 3*8
000860r 2               
000860r 2               	AttrOff0		= 0
000860r 2               	AttrOff1		= 0+AttrWriteSize
000860r 2               	AttrEnd			= 0+AttrWriteSize+AttrWriteSize
000860r 2               
000860r 2               	tmp5 = ptr2
000860r 2               	ColumnBufferIdx = ptr2+1
000860r 2               
000860r 2               	NametableAddrHi = tmp1
000860r 2               	LoopCount = tmp2
000860r 2               	SeamValue = ptr3+1
000860r 2               	; Attribute write architecture:
000860r 2               
000860r 2               	; | Ad|dr |dat|
000860r 2               	;   0   1   2
000860r 2               	; Addr = VRAM address
000860r 2               
000860r 2               	; 1 byte can theoretically be saved by using a vertical
000860r 2               	; sequence of 2 bytes, but this comes at a cost of 23
000860r 2               	; cycles per 2 bytes in vblank (80 vs 103), and vlank
000860r 2               	; time is not to be wasted
000860r 2               
000860r 2               	; Decremented rld_column, very useful
000860r 2  AE rr rr     	LDX rld_column
000863r 2  CA           	DEX
000864r 2               	.if USE_ILLEGAL_OPCODES
000864r 2               		LDA #$0F
000864r 2               		SAX ptr3
000864r 2               	.else
000864r 2  8A           		TXA
000865r 2  29 0F        		AND #$0F
000867r 2  85 rr        		STA ptr3
000869r 2               	.endif
000869r 2               
000869r 2               	; Seam pos for attributes:
000869r 2               	; ( <seam_scroll_y & $E0 | >seam_scroll_y & 5) ^ column
000869r 2  AD rr rr     	LDA seam_scroll_y
00086Cr 2  29 E0        	AND #$E0
00086Er 2  85 rr        	STA SeamValue
000870r 2  AD rr rr     	LDA seam_scroll_y+1
000873r 2  29 03        	AND #$03	; add bit 1 to not use if no seam
000875r 2  05 rr        	ORA SeamValue
000877r 2  85 rr        	STA SeamValue
000879r 2               
000879r 2  A0 rr        	LDY	#>collMap2		;__	Get the default value
00087Br 2  29 03        	AND #$03			;	Bits 0 and 1 are directly from >seam_scroll_y
00087Dr 2  C9 03        	CMP	#$03			;	For value $FF start at screen 0, otherwise screen 2
00087Fr 2  D0 02        	BNE	:+				;
000881r 2  A0 rr        		LDY	#>collMap0	;	Get high byte of starting value
000883r 2               	:					;	(the screen)
000883r 2  84 rr        	STY	ptr1+1			;__
000885r 2               
000885r 2  A5 rr        	LDA ptr3			;
000887r 2  29 0E        	AND #$0E			;	Get column (w/o highest bit cuz attributes)
000889r 2               	; ADC #<(collMap0-1) ; the low byte is 0
000889r 2  85 rr        	STA ptr1			;__
00088Br 2  45 rr        	EOR	SeamValue		;	The only overlapping bit is bit 1,
00088Dr 2  85 rr        	STA	SeamValue		;__	if it's invalid the seam won't be drawn
00088Fr 2               
00088Fr 2  A2 00        	LDX #0
000891r 2  86 rr        	STX ColumnBufferIdx
000893r 2  20 rr rr     	JSR attributeCalc
000896r 2               
000896r 2               	; Increment screen (we always increment)
000896r 2  E6 rr        	INC ptr1+1
000898r 2               
000898r 2  C6 rr        	DEC	SeamValue
00089Ar 2               
00089Ar 2  20 rr rr     	JSR attributeCalc
00089Dr 2               
00089Dr 2               	; Get address hi byte (either left or right side)
00089Dr 2  AD rr rr     	lda _scroll_x + 1 	; high byte
0008A0r 2  29 01        	and #%00000001		;
0008A2r 2  A8           	tay					;	5 cycles, 6 bytes
0008A3r 2  B9 rr rr     	lda	ntAddrHiTbl, Y	;__
0008A6r 2  85 rr        	sta NametableAddrHi
0008A8r 2               
0008A8r 2  A5 rr        	LDA ptr3
0008AAr 2  4A           	LSR
0008ABr 2  09 C0        	ORA #$C0
0008ADr 2               
0008ADr 2               	; Store address
0008ADr 2  A6 rr        	LDX VRAM_INDEX
0008AFr 2  18           	CLC
0008B0r 2               	addressLoop:
0008B0r 2               		; Low byte
0008B0r 2  9D rr rr     		STA VRAM_BUF+AttrOff0+1,X
0008B3r 2  9D rr rr     		STA VRAM_BUF+AttrOff1+1,X
0008B6r 2  A8           		TAY
0008B7r 2               		; High byte
0008B7r 2  A5 rr        		lda NametableAddrHi
0008B9r 2  9D rr rr     		STA VRAM_BUF+AttrOff0,X
0008BCr 2  09 08        		ORA #$08
0008BEr 2  9D rr rr     		STA VRAM_BUF+AttrOff1,X
0008C1r 2  98           		TYA
0008C2r 2               
0008C2r 2  E8           		INX
0008C3r 2  E8           		INX
0008C4r 2  E8           		INX
0008C5r 2               
0008C5r 2               		; C is cleared by BCC
0008C5r 2  69 08        		ADC #$08
0008C7r 2  90 E7        		BCC addressLoop
0008C9r 2               
0008C9r 2  A0 10        	LDY #16
0008CBr 2               
0008CBr 2  A5 rr        	LDA VRAM_INDEX
0008CDr 2  69 2F        	ADC #AttrEnd-1  ; Carry is set by the ADC : BCC
0008CFr 2  85 rr        	STA VRAM_INDEX  ; State that the block is now occupied
0008D1r 2  AA           	TAX
0008D2r 2               
0008D2r 2               	dataLoop:
0008D2r 2  B9 rr rr     		LDA columnBuffer-1,Y
0008D5r 2  9D rr rr     		STA VRAM_BUF-3+2,X
0008D8r 2               
0008D8r 2               		.if USE_ILLEGAL_OPCODES
0008D8r 2               			TXA
0008D8r 2               			AXS #3
0008D8r 2               		.else
0008D8r 2  CA           			DEX
0008D9r 2  CA           			DEX
0008DAr 2  CA           			DEX
0008DBr 2               		.endif
0008DBr 2  88           		DEY
0008DCr 2  D0 F4        		BNE dataLoop
0008DEr 2               
0008DEr 2               	; Finish off the routine
0008DEr 2               	; X has the original VRAM_INDEX, mark this block as taken
0008DEr 2  A9 FF        	LDA #$FF
0008E0r 2  9D rr rr     	STA VRAM_BUF+AttrEnd,X
0008E3r 2               	; Reset frame counter
0008E3r 2  A2 00        	LDX #frame_free
0008E5r 2  8E rr rr     	STX drawing_frame
0008E8r 2               
0008E8r 2  A9 01        	LDA #1
0008EAr 2  60           	RTS
0008EBr 2               
0008EBr 2               attributeCalc:
0008EBr 2  A9 07        	LDA #8 - 1
0008EDr 2  85 rr        	STA LoopCount
0008EFr 2               
0008EFr 2               	attributeLoop:
0008EFr 2               		; Read lower right metatile
0008EFr 2  A0 11        		LDY #$11
0008F1r 2               		.if USE_ILLEGAL_OPCODES
0008F1r 2               			lax (ptr1),y
0008F1r 2               		.else
0008F1r 2  B1 rr        			LDA	(ptr1),Y
0008F3r 2  AA           			tax
0008F4r 2               		.endif
0008F4r 2               		; Read lower left metatile
0008F4r 2  88           		dey
0008F5r 2  B1 rr        		LDA (ptr1), Y
0008F7r 2  A8           		tay
0008F8r 2               		; Get their attributes
0008F8r 2  BD rr rr     		lda metatiles_attr,x	; Lower right
0008FBr 2  0A           		ASL
0008FCr 2  0A           		ASL
0008FDr 2  19 rr rr     		ora metatiles_attr,y	; Lower left
000900r 2  85 rr        		STA tmp5
000902r 2               
000902r 2               		; Read upper right metatile
000902r 2  A0 01        		LDY #$01
000904r 2               		.if USE_ILLEGAL_OPCODES
000904r 2               			lax (ptr1),y
000904r 2               		.else
000904r 2  B1 rr        			LDA	(ptr1),Y
000906r 2  AA           			tax
000907r 2               		.endif
000907r 2               		; Read upper left metatile
000907r 2  88           		dey
000908r 2  B1 rr        		LDA (ptr1), Y
00090Ar 2  A8           		tay
00090Br 2               		; Get their attributes
00090Br 2  BD rr rr     		lda metatiles_attr,x	; Upper right
00090Er 2  0A           		ASL
00090Fr 2  0A           		ASL
000910r 2  19 rr rr     		ora metatiles_attr,y	; Upper left
000913r 2               
000913r 2               		; Combine
000913r 2  A4 rr        		LDY tmp5	; Y has the lower metatile attrs, will shift by 4
000915r 2  19 rr rr     		ORA shiftBy4table,Y
000918r 2  A6 rr        		LDX ColumnBufferIdx
00091Ar 2  9D rr rr     		STA columnBuffer,X
00091Dr 2               
00091Dr 2               		; Increment pointer
00091Dr 2  A5 rr        		LDA	ptr1
00091Fr 2  C5 rr        		CMP SeamValue
000921r 2  D0 04        		BNE :+
000923r 2  C6 rr        			DEC ptr1+1
000925r 2  C6 rr        			DEC ptr1+1
000927r 2               		:
000927r 2  18           		CLC
000928r 2  69 20        		ADC #$20
00092Ar 2  85 rr        		STA	ptr1
00092Cr 2               
00092Cr 2  E6 rr        		INC ColumnBufferIdx
00092Er 2  C6 rr        		DEC LoopCount
000930r 2  10 BD        		BPL attributeLoop
000932r 2  60           	RTS
000933r 2               
000933r 2               ntAddrHiTbl:
000933r 2  27 23        	.byte	$27,	$23
000935r 2               .endproc
000935r 2               
000935r 2               
000935r 2               ; [Subroutine]
000935r 2               .global metatiles_top_left, metatiles_top_right, metatiles_bot_left, metatiles_bot_right
000935r 2               .import _no_parallax, _invisblocks, _force_platformer
000935r 2               .import _scroll_y
000935r 2               
000935r 2               .proc draw_screen_UD_tiles_frame0
000935r 2               	scroll_direction = tmp1
000935r 2               	column_idx = tmp2
000935r 2               	loop_count = tmp3
000935r 2               
000935r 2               	new_seam_pos = ptr1
000935r 2               	this_seam_pos = ptr2
000935r 2               	collmap_ptr = ptr3
000935r 2               
000935r 2               	UnifiedTileWriteSize = (16*4)+2+1
000935r 2               	Separate2WritesSize = (16*2)+((2+1)*2)	; Contains 32 tiles in total, in 2 writes
000935r 2               	SepWrABuf = VRAM_BUF+0
000935r 2               	SepWrBBuf = VRAM_BUF+3
000935r 2               	SepWrCBuf = VRAM_BUF+Separate2WritesSize+0
000935r 2               	SepWrDBuf = VRAM_BUF+Separate2WritesSize+3
000935r 2               	SepWriEnd = Separate2WritesSize
000935r 2               
000935r 2               	start:
000935r 2  AD rr rr     		LDA	_scroll_y				;
000938r 2  38           		SEC							;
000939r 2  ED rr rr     		SBC	old_draw_scroll_y		;
00093Cr 2  85 rr        		STA	tmp1					;	XY = scroll_y - old_draw_scroll_y
00093Er 2  AD rr rr     		LDA	_scroll_y+1				;
000941r 2  ED rr rr     		SBC	old_draw_scroll_y+1		;
000944r 2  A8           		TAY							;__
000945r 2               
000945r 2  05 rr        		ORA	tmp1
000947r 2  D0 02        		BNE	calc_new_seam_pos
000949r 2               
000949r 2  AA           		TAX		;	A is 0
00094Ar 2  60           		RTS		;__
00094Br 2               
00094Br 2               	calc_new_seam_pos:
00094Br 2               		@start:
00094Br 2  A9 10        			LDA	#$10
00094Dr 2  85 rr        			STA	sreg+0
00094Fr 2  AD rr rr     			LDA	seam_scroll_y
000952r 2  AE rr rr     			LDX	seam_scroll_y+1
000955r 2  C0 00        			CPY	#$00	;	Puts carry into X
000957r 2  30 28        			BMI	@up		;__
000959r 2               
000959r 2               		@down:
000959r 2  20 rr rr     			JSR	__add_scroll_y		;__	Calculate new seam position
00095Cr 2  85 rr        			STA	this_seam_pos+0		;	Store new seam position
00095Er 2  86 rr        			STX	this_seam_pos+1		;__
000960r 2  20 rr rr     			JSR	@calc_diff			;__	Calculate difference
000963r 2  C9 38        			CMP	#$38				;
000965r 2  8A           			TXA						;	If the difference is less than
000966r 2  A2 02        			LDX	#2					;	($78 - $40), we went too far
000968r 2  E9 00        			SBC	#$00				;	Also load the scrolling direction offset
00096Ar 2  10 28        			BPL	@fin				;__
00096Cr 2               
00096Cr 2               		@ret0:		;
00096Cr 2  A9 00        			LDA	#0	;	Return 0
00096Er 2  AA           			TAX		;	(nothing was done)
00096Fr 2  60           			RTS		;__
000970r 2               
000970r 2               		@calc_diff:	;__	[Subroutine]
000970r 2  85 rr        			STA	new_seam_pos		;	Store new seam position
000972r 2  86 rr        			STX	new_seam_pos+1		;__
000974r 2  85 rr        			STA	sreg+0				;
000976r 2  86 rr        			STX	sreg+1				;	Calculate the difference
000978r 2  AE rr rr     			LDX	_scroll_y			;	between scroll_y and seam position
00097Br 2  AD rr rr     			LDA	_scroll_y+1			;	(doesn't need to be linearized due to its indended range)
00097Er 2  4C rr rr     			JMP	__sub_scroll_y_ext	;__
000981r 2               
000981r 2               		@up:
000981r 2  85 rr        			STA	this_seam_pos+0		;	Store old seam position
000983r 2  86 rr        			STX	this_seam_pos+1		;__
000985r 2  20 rr rr     			JSR	__sub_scroll_y		;__	Calculate new seam position
000988r 2  20 rr rr     			JSR	@calc_diff			;__	Calculate difference
00098Br 2  C9 B8        			CMP	#$B8				;
00098Dr 2  8A           			TXA						;	If the difference is more than
00098Er 2  A2 00        			LDX	#0					;	($78 + $40), we went too far
000990r 2  E9 00        			SBC	#$00				;	Also load scrolling direction offset
000992r 2  10 D8        			BPL	@ret0				;__
000994r 2               
000994r 2               		@fin:
000994r 2  86 rr        			STX	scroll_direction
000996r 2               
000996r 2  AD rr rr     			LDA	_scroll_y
000999r 2  AC rr rr     			LDY	_scroll_y+1
00099Cr 2  8D rr rr     			STA	old_draw_scroll_y
00099Fr 2  8C rr rr     			STY	old_draw_scroll_y+1
0009A2r 2               
0009A2r 2  A5 rr        			LDA	new_seam_pos
0009A4r 2  A4 rr        			LDY	new_seam_pos+1
0009A6r 2  8D rr rr     			STA	seam_scroll_y
0009A9r 2  8C rr rr     			STY	seam_scroll_y+1
0009ACr 2               
0009ACr 2  A4 rr        			LDY	this_seam_pos+1
0009AEr 2  C0 02        			CPY	#$02				;	If no seam, exit early
0009B0r 2  B0 BA        			BCS	@ret0				;__
0009B2r 2               
0009B2r 2               	start_writing:
0009B2r 2               		@get_collmap_ptr:
0009B2r 2               			;	Y contains the >seam_scroll_y, Carry is clear
0009B2r 2  A5 rr        			LDA this_seam_pos	;
0009B4r 2  29 F0        			AND	#$F0			;	Get low byte
0009B6r 2  85 rr        			STA	collmap_ptr		;__	(none of these affect the carry)
0009B8r 2  98           			TYA					;
0009B9r 2  65 rr        			ADC	scroll_direction;
0009BBr 2  09 rr        			ORA	#>collMap0		;	Get high byte
0009BDr 2  85 rr        			STA	collmap_ptr+1	;__
0009BFr 2               
0009BFr 2               		@get_write_type:
0009BFr 2  A6 rr        			LDX	VRAM_INDEX
0009C1r 2               
0009C1r 2               			; 2 scenarios: one write 64 tiles long, or 4 writes, 16-x and x tiles long each (thanks jrowe screen extension)
0009C1r 2  AC rr rr     			LDY	rld_column
0009C4r 2  F0 03 4C rr  			jne write_separate
0009C8r 2  rr           
0009C9r 2               
0009C9r 2               	write_unified:
0009C9r 2               		@shift_addr:
0009C9r 2  A5 rr        			LDA	this_seam_pos	;__	Get bits: hhll uuuu (u will be ignored)
0009CBr 2  0A           			ASL					;	Double 8-bit left shift
0009CCr 2  69 80        			ADC	#$80			;	to shift the mm bits to the high byte
0009CEr 2  2A           			ROL					;__	to get ll00 00hh
0009CFr 2               		@store_low:
0009CFr 2  A8           			TAY					;__	Tmp storage
0009D0r 2  29 C0        			AND	#$C0			;	Store the low byte for X=0
0009D2r 2  9D rr rr     			STA	VRAM_BUF+1,	X	;__
0009D5r 2               		@store_high:
0009D5r 2  AD rr rr     			LDA	_scroll_x+1		;	Thanks jroweboy
0009D8r 2  4A           			LSR					;__
0009D9r 2  98           			TYA					;	These don't affect carry
0009DAr 2  29 03        			AND	#$03			;__
0009DCr 2  B0 02        			BCS	:+				;	Get X of nametable
0009DEr 2  09 04        				ORA	#$04		;__
0009E0r 2  09 60        			:	ORA	#$20|$40	;__	Get valid nametable addr with horizontal seq update
0009E2r 2  A4 rr        			LDY	this_seam_pos+1	;
0009E4r 2  F0 02        			BEQ	:+				;	Get Y of nametable
0009E6r 2  09 08        				ORA	#$08		;__
0009E8r 2  9D rr rr     			:	STA	VRAM_BUF+0,X;__	Store the high byte of nametable addr
0009EBr 2               		@store_length:
0009EBr 2  A9 40        			LDA	#64				;	Store length
0009EDr 2  9D rr rr     			STA	VRAM_BUF+2,	X	;__
0009F0r 2               		@store_finish:
0009F0r 2  A9 FF        			LDA	#$FF
0009F2r 2  9D rr rr     			STA	VRAM_BUF+UnifiedTileWriteSize,	X
0009F5r 2               
0009F5r 2               	write_unified_loop:
0009F5r 2               		@start:
0009F5r 2  A9 00        			LDA	#$00
0009F7r 2  85 rr        			STA	column_idx
0009F9r 2  A9 10        			LDA	#$10
0009FBr 2  85 rr        			STA	loop_count
0009FDr 2               		@loop:
0009FDr 2  A4 rr        			LDY	column_idx			;
0009FFr 2  B1 rr        			LDA	(collmap_ptr),	Y	;	Get metatile
000A01r 2  A8           			TAY						;__
000A02r 2               
000A02r 2  B9 rr rr     			LDA	metatiles_top_left,	Y	;
000A05r 2  9D rr rr     			STA	VRAM_BUF+3+0,	X		;
000A08r 2  B9 rr rr     			LDA	metatiles_top_right,Y	;
000A0Br 2  9D rr rr     			STA	VRAM_BUF+3+1,	X		;	Get and store the tiles
000A0Er 2  B9 rr rr     			LDA	metatiles_bot_left,	Y	;	into the VRAM buffer
000A11r 2  9D rr rr     			STA	VRAM_BUF+3+32,	X		;
000A14r 2  B9 rr rr     			LDA	metatiles_bot_right,Y	;
000A17r 2  9D rr rr     			STA	VRAM_BUF+3+33,	X		;__
000A1Ar 2               
000A1Ar 2  E8           			INX
000A1Br 2  E8           			INX
000A1Cr 2  E6 rr        			INC	column_idx
000A1Er 2  C6 rr        			DEC	loop_count
000A20r 2  D0 DB        			BNE	@loop
000A22r 2               
000A22r 2  A5 rr        		LDA	VRAM_INDEX
000A24r 2  18           		CLC
000A25r 2  69 43        		ADC	#UnifiedTileWriteSize
000A27r 2  85 rr        		STA	VRAM_INDEX
000A29r 2               
000A29r 2               		; TODO eventually: parallax
000A29r 2               
000A29r 2  A9 01        		LDA #1
000A2Br 2  A2 00        		LDX	#0
000A2Dr 2               
000A2Dr 2  60           		RTS
000A2Er 2               
000A2Er 2               	write_separate:
000A2Er 2               		;	Write architecture:
000A2Er 2               		;	Wr:	| Wr. A (32-X)	| Wr. B (X)	| Wr. C (32-X)	| Wr. D (X)	|
000A2Er 2               		;	Loc:|		VRAM buffer			|		Column buffer		|
000A2Er 2               		;	NT:	|	NT. A/C		|	NT. B/D	|	NT. A/C		|	NT. B/D	|
000A2Er 2               		;	Tile|			Upper			|			Lower			|
000A2Er 2               		;	X:	|		X		|	  0		|		X		|	  0		|
000A2Er 2               		;		 \Combined length of 32(+6)/ \Combined length of 32(+6)/
000A2Er 2               
000A2Er 2               		@shift_addr:
000A2Er 2  A5 rr        			LDA	this_seam_pos	;__	Get bits: hhll uuuu (u will be ignored)
000A30r 2  0A           			ASL					;	Double 8-bit left shift
000A31r 2  69 80        			ADC	#$80			;	to shift the mm bits to the high byte
000A33r 2  2A           			ROL					;__	to get ll00 00hh
000A34r 2               		@store_low:
000A34r 2  A8           			TAY					;__	Tmp storage
000A35r 2  29 C0        			AND	#$C0			;	Push the low byte for X=0
000A37r 2  48           			PHA					;__	for writes B&D
000A38r 2  4A           			LSR					;
000A39r 2  0D rr rr     			ORA	rld_column		;	Add the X
000A3Cr 2  0A           			ASL					;__
000A3Dr 2  9D rr rr     			STA	SepWrABuf+1,X	;__	Store write A
000A40r 2  09 20        			ORA	#$20			;	Get and
000A42r 2  9D rr rr     			STA	SepWrCBuf+1,X	;__	store write C
000A45r 2               		@store_high:
000A45r 2  AD rr rr     			LDA	_scroll_x+1		;	Thanks jroweboy
000A48r 2  4A           			LSR					;__
000A49r 2  98           			TYA					;	These don't affect carry
000A4Ar 2  29 03        			AND	#$03			;__
000A4Cr 2  90 02        			BCC	:+				;	Get X of nametable
000A4Er 2  09 04        				ORA	#$04		;__
000A50r 2  09 60        			:	ORA	#$20|$40	;__	Get valid nametable addr with horizontal seq update
000A52r 2  A4 rr        			LDY	this_seam_pos+1	;
000A54r 2  F0 02        			BEQ	:+				;	Get Y of nametable
000A56r 2  09 08        				ORA	#$08		;__
000A58r 2  48           			:	PHA				;__	Push high byte of nametable addr for writes B & D
000A59r 2  9D rr rr     			STA SepWrABuf,	X	;	Store the high byte
000A5Cr 2  9D rr rr     			STA	SepWrCBuf,	X	;__
000A5Fr 2               		@store_length:
000A5Fr 2  A9 10        			LDA	#16				;
000A61r 2  38           			SEC					;
000A62r 2  ED rr rr     			SBC	rld_column		;	Get length for writes A & C
000A65r 2  85 rr        			STA	loop_count		;	Store as a counter to check for writes B & D
000A67r 2  0A           			ASL					;__
000A68r 2  9D rr rr     			STA	SepWrABuf+2,X	;	Store it
000A6Br 2  9D rr rr     			STA	SepWrCBuf+2,X	;__
000A6Er 2               	write_separate_loop:
000A6Er 2               		@setup_first_loop:
000A6Er 2  AD rr rr     			LDA	rld_column
000A71r 2  85 rr        			STA	column_idx
000A73r 2               		@loop_AC:
000A73r 2  A4 rr        			LDY	column_idx			;
000A75r 2  B1 rr        			LDA	(collmap_ptr),	Y	;	Get metatile
000A77r 2  A8           			TAY						;__
000A78r 2               
000A78r 2  B9 rr rr     			LDA	metatiles_top_left,	Y	;
000A7Br 2  9D rr rr     			STA	SepWrABuf+3+0,	X		;
000A7Er 2  B9 rr rr     			LDA	metatiles_top_right,Y	;
000A81r 2  9D rr rr     			STA	SepWrABuf+3+1,	X		;	Get and store the tiles
000A84r 2  B9 rr rr     			LDA	metatiles_bot_left,	Y	;	into the VRAM buffer
000A87r 2  9D rr rr     			STA	SepWrCBuf+3+0,	X		;
000A8Ar 2  B9 rr rr     			LDA	metatiles_bot_right,Y	;
000A8Dr 2  9D rr rr     			STA	SepWrCBuf+3+1,	X		;__
000A90r 2               
000A90r 2  E8           			INX
000A91r 2  E8           			INX
000A92r 2  E6 rr        			INC	column_idx
000A94r 2  C6 rr        			DEC	loop_count
000A96r 2  D0 DB        			BNE	@loop_AC
000A98r 2               		@setup_second_loop:
000A98r 2  A5 rr        			LDA	column_idx
000A9Ar 2  C9 10        			CMP	#$10
000A9Cr 2  D0 27        			BNE @fin
000A9Er 2               
000A9Er 2  A9 00        			LDA	#$00
000AA0r 2  85 rr        			STA	column_idx
000AA2r 2               
000AA2r 2  AD rr rr     			LDA	rld_column		;	Update loop count
000AA5r 2  85 rr        			STA	loop_count		;__
000AA7r 2  0A           			ASL					;
000AA8r 2  9D rr rr     			STA	SepWrBBuf+2,X	;	Store the length
000AABr 2  9D rr rr     			STA	SepWrDBuf+2,X	;__
000AAEr 2               
000AAEr 2  68           			PLA					;	Invert the high byte's
000AAFr 2  49 04        			EOR	#$04			;__	X of the nametable
000AB1r 2  9D rr rr     			STA	SepWrBBuf+0,X	;	Store the high nametable byte
000AB4r 2  9D rr rr     			STA	SepWrDBuf+0,X	;__
000AB7r 2               
000AB7r 2  68           			PLA					;
000AB8r 2  9D rr rr     			STA	SepWrBBuf+1,X	;	Store the low nametable byte
000ABBr 2  09 20        			ORA	#$20			;
000ABDr 2  9D rr rr     			STA	SepWrDBuf+1,X	;__
000AC0r 2               
000AC0r 2  E8           			INX
000AC1r 2  E8           			INX
000AC2r 2  E8           			INX
000AC3r 2               
000AC3r 2  90 AE        			BCC	@loop_AC	;__	Last carry instruction was ASL rld_column, which shifted out a 0
000AC5r 2               
000AC5r 2               		@fin:
000AC5r 2  A9 03        			LDA	#frame_UD_tiles_separate_1
000AC7r 2  8D rr rr     			STA	drawing_frame
000ACAr 2               
000ACAr 2               			; Current X is pointing at the last element - 3
000ACAr 2  E8           			INX
000ACBr 2  E8           			INX
000ACCr 2  E8           			INX
000ACDr 2  86 rr        			STX	VRAM_INDEX
000ACFr 2  A0 26        			LDY	#Separate2WritesSize
000AD1r 2               		@transfer_loop:
000AD1r 2  CA           			DEX
000AD2r 2  BD rr rr     			LDA	SepWrCBuf,	X
000AD5r 2  99 rr rr     			STA	columnBuffer-1,	Y
000AD8r 2  88           			DEY
000AD9r 2  D0 F6        			BNE	@transfer_loop
000ADBr 2               
000ADBr 2  A9 FF        			LDA	#$FF
000ADDr 2  9D rr rr     			STA	VRAM_BUF+Separate2WritesSize,	X
000AE0r 2               
000AE0r 2  A9 01        			LDA	#1
000AE2r 2  A2 00        			LDX	#0
000AE4r 2  60           			RTS
000AE5r 2               
000AE5r 2               
000AE5r 2               .endproc
000AE5r 2               
000AE5r 2               
000AE5r 2               .proc draw_screen_UD_tiles_frame1
000AE5r 2               	Separate2WritesSize = (16*2)+((2+1)*2)	; Contains 32 tiles in total, in 2 writes
000AE5r 2               	@start:
000AE5r 2  A5 rr        		LDA	VRAM_INDEX
000AE7r 2  18           		CLC
000AE8r 2  69 26        		ADC	#Separate2WritesSize
000AEAr 2  85 rr        		STA	VRAM_INDEX
000AECr 2  AA           		TAX
000AEDr 2               
000AEDr 2  A0 26        		LDY	#Separate2WritesSize
000AEFr 2               	@loop:
000AEFr 2  CA           		DEX
000AF0r 2  B9 rr rr     		LDA	columnBuffer-1,	Y
000AF3r 2  9D rr rr     		STA	VRAM_BUF,	X
000AF6r 2  88           		DEY
000AF7r 2  D0 F6        		BNE	@loop
000AF9r 2               	@fin:
000AF9r 2  A9 FF        		LDA	#$FF
000AFBr 2  9D rr rr     		STA	VRAM_BUF+Separate2WritesSize, X
000AFEr 2               
000AFEr 2  A9 01        		LDA	#1
000B00r 2  A2 00        		LDX	#frame_free
000B02r 2  8E rr rr     		STX	drawing_frame
000B05r 2  60           		RTS
000B06r 2               .endproc
000B06r 2               
000B06r 2               .endproc
000B06r 2               
000B06r 2               
000B06r 2               ; void __fastcall__ load_ground(uint8_t id);
000B06r 2               .segment _GROUND_BANK
000000r 2               
000000r 2               .import _ground
000000r 2               
000000r 2               .export _load_ground
000000r 2               .proc _load_ground
000000r 2               	;A = ground num
000000r 2  0A           	ASL						;
000001r 2  AA           	TAX						;
000002r 2  BD rr rr     	LDA _ground, X			;	ptr1 = ground[id]
000005r 2  85 rr        	STA ptr1				;	(we're already within the correct bank)
000007r 2  BD rr rr     	LDA _ground+1, X		;
00000Ar 2  85 rr        	STA ptr1+1				;__
00000Cr 2  A2 D0        	LDX #<-48				;__	X = idx @ collmap data, count up to 0
00000Er 2  A0 00        	LDY	#$00				;__	Y = 0
000010r 2               
000010r 2               	ground_ptr = ground-($100-48)
000010r 2               
000010r 2               	; there's a max of 48 bytes of data to fill,
000010r 2               	; the rle worst case is 96 bytes long,
000010r 2               	; therefore not needing to check for an overflow
000010r 2               
000010r 2               	loop:
000010r 2  B1 rr        		LDA (ptr1),y		;
000012r 2  30 17        		bmi single_rle_byte	;	Run
000014r 2  85 rr        		STA tmp1			;
000016r 2  C8           		iny					;__
000017r 2               
000017r 2  B1 rr        		LDA (ptr1),y		;	Value
000019r 2  C8           		iny					;__
00001Ar 2               
00001Ar 2  84 rr        		STY tmp2
00001Cr 2  A4 rr        		LDY tmp1
00001Er 2               	mult_loop:
00001Er 2  9D rr rr     		STA ground_ptr, X
000021r 2  E8           		INX
000022r 2  F0 10        		BEQ fin
000024r 2  88           		DEY
000025r 2  10 F7        		BPL mult_loop
000027r 2  A4 rr        		LDY tmp2
000029r 2  D0 E5        		BNE loop	; Physically cannot be not 0
00002Br 2               
00002Br 2               	single_rle_byte:
00002Br 2  29 7F        		AND #$7F
00002Dr 2  9D rr rr     		STA ground_ptr, X
000030r 2  C8           		INY
000031r 2  E8           		INX
000032r 2  D0 DC        		BNE loop
000034r 2               
000034r 2               	fin:
000034r 2  60           		RTS
000035r 2               
000035r 2               .endproc
000035r 2               
000035r 2               .endif
000035r 2               
000035r 2               ; void __fastcall__ draw_padded_text(const void * data, uint8_t len, uint8_t total_len, uintptr_t ppu_address)
000035r 2               .segment "CODE"
00024Cr 2               
00024Cr 2               .export __draw_padded_text
00024Cr 2               .proc __draw_padded_text
00024Cr 2               	; AX = ppu_address
00024Cr 2               	; sreg[0] = total_len
00024Cr 2               	; sreg[1] = len
00024Cr 2               	; xargs[0:1] = data
00024Cr 2               
00024Cr 2               	spaceChr = $FE
00024Cr 2               	data = xargs+0
00024Cr 2               	total_len = sreg+0
00024Cr 2               	len = sreg+1
00024Cr 2               
00024Cr 2  A4 rr        	LDY VRAM_INDEX
00024Er 2  99 rr rr     	STA VRAM_BUF+1, Y	;
000251r 2  8A           	TXA					;	vram pointer
000252r 2  99 rr rr     	STA VRAM_BUF+0, Y	;__
000255r 2  A5 rr        	LDA total_len		;	total length
000257r 2  99 rr rr     	STA VRAM_BUF+2, Y	;__
00025Ar 2               
00025Ar 2  38           	SEC					;	Total padding
00025Br 2  E5 rr        	SBC len				;__
00025Dr 2  4A           	LSR					;	Get left offset
00025Er 2  85 rr        	STA tmp1			;__
000260r 2  69 00        	ADC #$00			;	Get right offset
000262r 2  A8           	TAY					;__
000263r 2               
000263r 2  A5 rr        	LDA total_len
000265r 2  65 rr        	ADC	VRAM_INDEX		;	Carry is guaranteed to be clear by LSR : ADC #$00
000267r 2               	; If carry is still set, we have big problems
000267r 2               	; BCS some shit to do
000267r 2  AA           	TAX
000268r 2  69 03        	ADC #$03
00026Ar 2  85 rr        	STA VRAM_INDEX
00026Cr 2               
00026Cr 2  A9 FF        	LDA #$FF			;	Finish off the write
00026Er 2  9D rr rr     	STA VRAM_BUF+3, X	;__
000271r 2               
000271r 2  C0 00        	CPY #$00	; Had to do this, very sorry
000273r 2  F0 09        	BEQ main_data
000275r 2               
000275r 2  A9 FE        	LDA #spaceChr
000277r 2               
000277r 2               	pad_loop_right:
000277r 2  9D rr rr     		STA VRAM_BUF+2, X
00027Ar 2  CA           		DEX
00027Br 2  88           		DEY
00027Cr 2  D0 F9        		BNE pad_loop_right
00027Er 2               
00027Er 2               	main_data:
00027Er 2  A4 rr        		LDY len
000280r 2  88           		DEY
000281r 2               
000281r 2               	main_data_loop:
000281r 2  B1 rr        		LDA (<data), Y
000283r 2  9D rr rr     		STA VRAM_BUF+2, X
000286r 2  CA           		DEX
000287r 2  88           		DEY
000288r 2  10 F7        		BPL main_data_loop
00028Ar 2               
00028Ar 2  A4 rr        	LDY tmp1	;	Pad left amount
00028Cr 2  F0 09        	BEQ fin		;__
00028Er 2               
00028Er 2  A9 FE        	LDA #spaceChr
000290r 2               
000290r 2               	pad_loop_left:
000290r 2  9D rr rr     		STA VRAM_BUF+2, X
000293r 2  CA           		DEX
000294r 2  88           		DEY
000295r 2  D0 F9        		BNE pad_loop_left
000297r 2               
000297r 2               	fin:
000297r 2  60           		RTS
000298r 2               
000298r 2               .endproc
000298r 2               
000298r 2               .if !__THE_ALBUM
000298r 2               ; void movement();
000298r 2               .segment _MOVEMENT_BANK
000000r 2               
000000r 2               .import _cube_movement, _ship_movement, _ball_movement, _ufo_movement, _robot_movement, _spider_movement, _wave_movement
000000r 2               .import _retro_mode
000000r 2               
000000r 2               .export _movement
000000r 2               .proc _movement
000000r 2  A6 rr        	LDX _gamemode
000002r 2  E0 0C        	CPX #<gamemode_count
000004r 2  B0 16        	BCS end
000006r 2  AD rr rr     	lda _retro_mode
000009r 2  F0 09        	beq @no1
00000Br 2  A5 rr        	lda _gamemode
00000Dr 2  C9 01        	cmp #1
00000Fr 2  D0 03        	bne	@no1
000011r 2               		; LDA #<_ufo_movement
000011r 2               		; STA <PTR
000011r 2               		; LDA #>_ufo_movement
000011r 2               		; STA <PTR+1
000011r 2               		; JMP (PTR)
000011r 2  4C rr rr     		JMP _ufo_movement
000014r 2               
000014r 2               	@no1:
000014r 2  BD rr rr     		LDA jump_table_hi, X
000017r 2  48           		PHA
000018r 2  BD rr rr     		LDA jump_table_lo, X
00001Br 2  48           		PHA
00001Cr 2               
00001Cr 2               	end:
00001Cr 2  60           		RTS     ; break or use the RTS trick
00001Dr 2               
00001Dr 2               	jump_table_lo:
00001Dr 2  rr rr rr rr  		.byte <(_cube_movement-1), <(_ship_movement-1), <(_ball_movement-1), <(_ufo_movement-1), <(_cube_movement-1), <(_spider_movement-1), <(_wave_movement-1), <(_ball_movement-1), <(_cube_movement-1), <(_ball_movement-1), <(_wave_movement-1), <(_cube_movement-1)
000021r 2  rr rr rr rr  
000025r 2  rr rr rr rr  
000029r 2               	jump_table_hi:
000029r 2  rr rr rr rr  		.byte >(_cube_movement-1), >(_ship_movement-1), >(_ball_movement-1), >(_ufo_movement-1), >(_cube_movement-1), >(_spider_movement-1), >(_wave_movement-1), >(_ball_movement-1), >(_cube_movement-1), >(_ball_movement-1), >(_wave_movement-1), >(_cube_movement-1)
00002Dr 2  rr rr rr rr  
000031r 2  rr rr rr rr  
000035r 2               
000035r 2               .endproc
000035r 2               .endif
000035r 2               ; void __fastcall__ music_play(uint8_t song);
000035r 2               .segment "CODE"
000298r 2               
000298r 2               .import _options
000298r 2               
000298r 2               .export _music_play
000298r 2               .proc _music_play
000298r 2               
000298r 2               	; CONFIGURATION:
000298r 2               	; If the following value is set and valid, it will be used
000298r 2               	; as the pointer to famistudio_init in all banks. If it
000298r 2               	; isn't, then music_pointers_lo, hi and song count tables
000298r 2               	; are needed for proper operation.
000298r 2               	constInitPtr = $A000
000298r 2               
000298r 2               	.ifndef constInitPtr
000298r 2               		constInitPtr = 0
000298r 2               	.endif
000298r 2               	useConstInitPtr = (constInitPtr >= $6000)
000298r 2               
000298r 2  2C rr rr         bit _options ; sets N flag to bit 7 of _options without affecting A
00029Br 2  10 01            bpl musicon
00029Dr 2  60               rts
00029Er 2               musicon:
00029Er 2  A8           	TAY
00029Fr 2  AD rr rr     	LDA	auto_fs_updates
0002A2r 2  48           	PHA
0002A3r 2  A9 00        	LDA #0
0002A5r 2  8D rr rr     	STA	auto_fs_updates
0002A8r 2  98           	TYA
0002A9r 2               
0002A9r 2  A0 rr            LDY #<FIRST_MUSIC_BANK
0002ABr 2  BA               tsx
0002ACr 2               bank_loop:
0002ACr 2  48               PHA
0002ADr 2  38               SEC
0002AEr 2  F9 rr rr         SBC music_counts-FIRST_MUSIC_BANK, Y
0002B1r 2  90 04            BCC found_bank
0002B3r 2  C8               INY
0002B4r 2  9A               TXS ;Act as if no PHA happened
0002B5r 2  B0 F5            BCS bank_loop  ; BRA
0002B7r 2               found_bank:
0002B7r 2  98               TYA
0002B8r 2  20 rr rr         JSR mmc3_tmp_prg_bank_1
0002BBr 2  CC rr rr         CPY current_song_bank
0002BEr 2  F0 0C            BEQ :+
0002C0r 2                   ;If different bank than before reinitalize FS
0002C0r 2  8C rr rr             STY	current_song_bank
0002C3r 2               		.if useConstInitPtr
0002C3r 2  A2 00        			LDX #<constInitPtr
0002C5r 2  A0 A0        			LDY #>constInitPtr
0002C7r 2               		.else
0002C7r 2               			LDX music_data_locations_lo-FIRST_MUSIC_BANK, Y
0002C7r 2               			LDA	music_data_locations_hi-FIRST_MUSIC_BANK, Y
0002C7r 2               			TAY
0002C7r 2               		.endif
0002C7r 2  A5 rr                LDA cpuRegion
0002C9r 2  20 rr rr             JSR famistudio_init
0002CCr 2               	:
0002CCr 2               
0002CCr 2  68           	PLA
0002CDr 2  20 rr rr     	JSR famistudio_music_play
0002D0r 2               
0002D0r 2  68           	PLA
0002D1r 2  8D rr rr     	STA	auto_fs_updates
0002D4r 2               
0002D4r 2  4C rr rr     	JMP _mmc3_pop_prg_bank_1
0002D7r 2               
0002D7r 2               ; Tables generated by export.py
0002D7r 2               .include "musicPlayRoutines.s"
0002D7r 3               ; Generated by export.py
0002D7r 3               
0002D7r 3               .if .not(useConstInitPtr)
0002D7r 3               music_data_locations_lo:
0002D7r 3               	.byte <music_data_famidash_music0, <music_data_famidash_music1, <music_data_famidash_music2, <music_data_famidash_music3, <music_data_famidash_music4, <music_data_famidash_music5, <music_data_famidash_music6, <music_data_famidash_music7, <music_data_famidash_music8, <music_data_famidash_music9, <music_data_famidash_music10, <music_data_famidash_music11, <music_data_famidash_music12
0002D7r 3               music_data_locations_hi:
0002D7r 3               	.byte >music_data_famidash_music0, >music_data_famidash_music1, >music_data_famidash_music2, >music_data_famidash_music3, >music_data_famidash_music4, >music_data_famidash_music5, >music_data_famidash_music6, >music_data_famidash_music7, >music_data_famidash_music8, >music_data_famidash_music9, >music_data_famidash_music10, >music_data_famidash_music11, >music_data_famidash_music12
0002D7r 3               .endif
0002D7r 3               
0002D7r 3               music_counts:
0002D7r 3  02 02 02 02  	.byte 2, 2, 2, 2, 2, 3, 3, 3, 3, 3, 4, 5, $FF ;last bank is marked with an FF to always stop bank picking
0002DBr 3  02 03 03 03  
0002DFr 3  03 03 04 05  
0002E4r 3               
0002E4r 2               .endproc
0002E4r 2               
0002E4r 2               .segment "CODE"
0002E4r 2               
0002E4r 2               .proc famistudio_dpcm_bank_callback
0002E4r 2  18           	clc
0002E5r 2  69 rr        	adc #<FIRST_DMC_BANK
0002E7r 2  4C rr rr     	jmp mmc3_set_prg_bank_0
0002EAr 2               .endproc
0002EAr 2               
0002EAr 2               
0002EAr 2               ; void __fastcall__ sfx_play(uint8_t sfx_index, uint8_t channel);
0002EAr 2               .segment "CODE"
0002EAr 2               
0002EAr 2               .import _options
0002EAr 2               
0002EAr 2               .export __sfx_play
0002EAr 2               .proc __sfx_play
0002EAr 2                   ; a = sfx
0002EAr 2               	; x = channel
0002EAr 2               
0002EAr 2  2C rr rr         bit _options ; bit 6 is copied to the overflow flag
0002EDr 2  50 01            bvc play
0002EFr 2  60               rts
0002F0r 2               play:
0002F0r 2  A8           	tay
0002F1r 2               
0002F1r 2  AD rr rr     	lda	mmc3PRG1Bank
0002F4r 2  48           	pha
0002F5r 2  A9 rr        	lda #<.bank(sounds)
0002F7r 2  20 rr rr     	jsr mmc3_set_prg_bank_1
0002FAr 2               
0002FAr 2  AD rr rr     	lda	auto_fs_updates
0002FDr 2  48           	pha
0002FEr 2  A9 00        	lda	#0
000300r 2  8D rr rr     	sta	auto_fs_updates
000303r 2               
000303r 2  98           	tya
000304r 2  20 rr rr         jsr famistudio_sfx_play
000307r 2               
000307r 2  68               pla
000308r 2  8D rr rr         sta	auto_fs_updates
00030Br 2               
00030Br 2  68           	pla
00030Cr 2  4C rr rr     	jmp mmc3_set_prg_bank_1
00030Fr 2               .endproc
00030Fr 2               
00030Fr 2               ; void music_update();
00030Fr 2               .segment "CODE"
00030Fr 2               
00030Fr 2               .export _music_update
00030Fr 2               .proc _music_update
00030Fr 2  AD rr rr         LDA current_song_bank
000312r 2  20 rr rr         JSR mmc3_tmp_prg_bank_1
000315r 2  20 rr rr         JSR famistudio_update
000318r 2  4C rr rr         JMP _mmc3_pop_prg_bank_1
00031Br 2               .endproc
00031Br 2               ; Because i JMPed, the routine is over
00031Br 2               
00031Br 2               
00031Br 2               ; void load_next_sprite(uint8_t slot);
00031Br 2               .segment "CODE_2"
00013Ar 2               
00013Ar 2               .import _activesprites_x_lo, _activesprites_x_hi
00013Ar 2               .import _activesprites_y_lo, _activesprites_y_hi
00013Ar 2               .import _activesprites_type, _activesprites_activated, _activesprites_animated
00013Ar 2               .import _activesprites_realx, _activesprites_realy
00013Ar 2               
00013Ar 2               .export _load_next_sprite := load_next_sprite
00013Ar 2               .proc load_next_sprite
00013Ar 2               
00013Ar 2               	; Check that the pointer is valid
00013Ar 2  A4 rr        	ldy _sprite_data+1
00013Cr 2  F0 40        	beq early_exit
00013Er 2               
00013Er 2                   ; Paste current free sprite slot into X
00013Er 2  AA              	tax
00013Fr 2               
00013Fr 2                   ; Now read the data into the sprite
00013Fr 2  A0 00            ldy #0
000141r 2  B1 rr            lda (_sprite_data),y
000143r 2  C9 FF            cmp #$ff
000145r 2  F0 35            beq exit
000147r 2  C8               iny
000148r 2               
000148r 2                   ; X - 2 bytes
000148r 2  9D rr rr         sta _activesprites_x_lo,x
00014Br 2  9D rr rr     	sta _activesprites_realx,x
00014Er 2  B1 rr            lda (_sprite_data),y
000150r 2  C8               iny
000151r 2  9D rr rr         sta _activesprites_x_hi,x
000154r 2               
000154r 2                   ; Y - 2 bytes
000154r 2  B1 rr            lda (_sprite_data),y
000156r 2  C8               iny
000157r 2  9D rr rr         sta _activesprites_y_lo,x
00015Ar 2  9D rr rr     	sta _activesprites_realy,x
00015Dr 2  B1 rr            lda (_sprite_data),y
00015Fr 2  C8               iny
000160r 2  9D rr rr         sta _activesprites_y_hi,x
000163r 2               
000163r 2                   ; id - 1 byte
000163r 2  B1 rr            lda (_sprite_data),y
000165r 2                   ;   no iny, as we ain't using y anymore
000165r 2  9D rr rr         sta _activesprites_type,x
000168r 2               
000168r 2  A9 00            lda #0
00016Ar 2  9D rr rr         sta _activesprites_activated,x
00016Dr 2  9D rr rr     	sta _activesprites_animated,x
000170r 2               
000170r 2                   ; Increment to the next sprite index -
000170r 2                   ; Add the 5 back to the pointer
000170r 2  A9 05            lda	#$05
000172r 2  18               clc
000173r 2  65 rr            adc	_sprite_data
000175r 2  85 rr            sta	_sprite_data
000177r 2  A4 rr        	ldy _sprite_data+1
000179r 2  90 01            bcc	:+
00017Br 2  C8                   iny
00017Cr 2                   :
00017Cr 2               
00017Cr 2               exit:
00017Cr 2               	;	Y is currently 0
00017Cr 2  84 rr        	sty _sprite_data+1	;__	invalidate the sprite pointer
00017Er 2               early_exit:
00017Er 2  60           	rts
00017Fr 2               .endproc
00017Fr 2               
00017Fr 2               ; uint16_t calculate_linear_scroll_y(uint16_t nonlinearScroll);
00017Fr 2               .segment "CODE"
00031Br 2               
00031Br 2               .export _calculate_linear_scroll_y
00031Br 2               .proc _calculate_linear_scroll_y
00031Br 2               	; AX = input, AX = output
00031Br 2               	; clobbers tmp1
00031Br 2  86 rr        	STX tmp1
00031Dr 2  A4 rr        	LDY	tmp1
00031Fr 2  C8           	INY	; for the BEQ ending condition
000320r 2  A2 00        	LDX #0
000322r 2  18           	CLC
000323r 2               	loop:
000323r 2  88           		DEY
000324r 2  F0 08        		BEQ end
000326r 2  69 F0        		ADC #$F0
000328r 2  90 F9        		BCC loop
00032Ar 2  E8           			INX
00032Br 2  18           			CLC
00032Cr 2  90 F5        			BCC loop
00032Er 2               	end:
00032Er 2  60           	RTS
00032Fr 2               .endproc
00032Fr 2               
00032Fr 2               .if !__THE_ALBUM
00032Fr 2               ; void cap_scroll_y_at_top();
00032Fr 2               .segment _SCROLL_BANK
000000r 2               
000000r 2               .importzp _currplayer_y
000000r 2               .import _scroll_y, _player_y, _scroll_y_subpx
000000r 2               
000000r 2               .export _cap_scroll_y_at_top
000000r 2               .proc _cap_scroll_y_at_top
000000r 2               check:
000000r 2  AD rr rr     	lda     _scroll_y		;
000003r 2  CD rr rr     	cmp     _min_scroll_y	;	if (scroll_y < min_scroll_y)
000006r 2  AD rr rr     	lda     _scroll_y+1		;
000009r 2  ED rr rr     	sbc     _min_scroll_y+1	;__
00000Cr 2  90 01        	bcc     doit
00000Er 2  60           	rts
00000Fr 2               
00000Fr 2               doit:
00000Fr 2               	; compensate currplayer_y and player_y
00000Fr 2  AD rr rr     	lda     _scroll_y
000012r 2  AE rr rr     	ldx     _scroll_y+1
000015r 2  85 rr        	sta     sreg
000017r 2  86 rr        	stx     sreg+1
000019r 2  AE rr rr     	ldx     _min_scroll_y	;
00001Cr 2  AD rr rr     	lda     _min_scroll_y+1	;	scroll_y = min_scroll_y
00001Fr 2  8E rr rr     	stx     _scroll_y		;
000022r 2  8D rr rr     	sta     _scroll_y+1		;__
000025r 2  20 rr rr     	jsr     __sub_scroll_y_ext
000028r 2  20 rr rr     	jsr     _calculate_linear_scroll_y
00002Br 2  49 FF        	eor     #$FF			;__	Make the ADCs into SBCs
00002Dr 2  A8           	tay
00002Er 2               
00002Er 2  A5 rr        	lda     _currplayer_y	;
000030r 2  38           	sec						;
000031r 2  ED rr rr     	sbc     _scroll_y_subpx	;
000034r 2  85 rr        	sta     _currplayer_y	;	Compensate currplayer_y
000036r 2  8D rr rr     	sta		_player_y+1		;	(Apparently guaranteed to be 0)
000039r 2  98           	tya						;
00003Ar 2  65 rr        	adc     _currplayer_y+1	;
00003Cr 2  85 rr        	sta     _currplayer_y+1	;
00003Er 2  8D rr rr     	sta     _player_y+1		;__
000041r 2               
000041r 2  AD rr rr     	lda     _player_y+2		;
000044r 2  38           	sec						;
000045r 2  ED rr rr     	sbc     _scroll_y_subpx	;
000048r 2  8D rr rr     	sta     _player_y+2		;	Compensate player_y[1]
00004Br 2  98           	tya						;
00004Cr 2  6D rr rr     	adc     _player_y+2+1	;
00004Fr 2  8D rr rr     	sta     _player_y+2+1	;__
000052r 2               
000052r 2  A9 00        	lda     #0
000054r 2  8D rr rr     	sta     _scroll_y_subpx
000057r 2               
000057r 2               	; we can't do anything with the high byte of the diff anyway
000057r 2               
000057r 2  60           	rts
000058r 2               .endproc
000058r 2               
000058r 2               
000058r 2               ; void cap_scroll_y_at_bottom();
000058r 2               .segment _SCROLL_BANK
000058r 2               
000058r 2               .importzp _currplayer_y
000058r 2               .import _scroll_y, _player_y, _scroll_y_subpx
000058r 2               
000058r 2               .export _cap_scroll_y_at_bottom
000058r 2               .proc _cap_scroll_y_at_bottom
000058r 2               check:
000058r 2  AD rr rr     	lda     _scroll_y_subpx	;
00005Br 2  C9 00        	cmp     #0              ;
00005Dr 2  AD rr rr     	lda     _scroll_y		;
000060r 2  E9 F0        	sbc     #<$02F0			;	if (scroll_y > 0x2EF)
000062r 2  AD rr rr     	lda     _scroll_y+1		;
000065r 2  E9 02        	sbc     #>$02F0			;__
000067r 2  B0 01        	bcs     doit
000069r 2  60           	rts
00006Ar 2               
00006Ar 2               doit:
00006Ar 2               	; compensate currplayer_y
00006Ar 2  AE rr rr     	ldx     _scroll_y
00006Dr 2  AC rr rr     	ldy     _scroll_y+1
000070r 2               
000070r 2  A9 EF        	lda     #<$02EF			;
000072r 2  85 rr        	sta     sreg			;
000074r 2  8D rr rr     	sta     _scroll_y		;	scroll_y = 0x2EF
000077r 2  A9 02        	lda     #>$02EF			;
000079r 2  85 rr        	sta     sreg+1			;
00007Br 2  8D rr rr     	sta     _scroll_y+1		;__
00007Er 2               
00007Er 2  98           	tya									;
00007Fr 2  20 rr rr     	jsr     __sub_scroll_y_ext			;	Get difference
000082r 2  20 rr rr     	jsr     _calculate_linear_scroll_y	;__
000085r 2  A8           	tay
000086r 2               
000086r 2  A5 rr        	lda     _currplayer_y	;
000088r 2  18           	clc						;
000089r 2  6D rr rr     	adc     _scroll_y_subpx	;
00008Cr 2  85 rr        	sta     _currplayer_y	;	Compensate currplayer_y
00008Er 2  8D rr rr     	sta		_player_y+1		;	(Apparently guaranteed to be 0)
000091r 2  98           	tya						;
000092r 2  65 rr        	adc     _currplayer_y+1	;
000094r 2  85 rr        	sta     _currplayer_y+1	;
000096r 2  8D rr rr     	sta     _player_y+1		;__
000099r 2               
000099r 2  AD rr rr     	lda     _player_y+2		;
00009Cr 2  18           	clc						;
00009Dr 2  6D rr rr     	adc     _scroll_y_subpx	;
0000A0r 2  8D rr rr     	sta     _player_y+2		;	Compensate player_y[1]
0000A3r 2  98           	tya						;
0000A4r 2  6D rr rr     	adc     _player_y+2+1	;
0000A7r 2  8D rr rr     	sta     _player_y+2+1	;__
0000AAr 2               
0000AAr 2  A9 00        	lda     #0
0000ACr 2  8D rr rr     	sta     _scroll_y_subpx
0000AFr 2               	; we can't do anything with the high byte of the diff anyway
0000AFr 2               
0000AFr 2  60           	rts
0000B0r 2               .endproc
0000B0r 2               .endif
0000B0r 2               
0000B0r 2               ; void check_spr_objects();
0000B0r 2               .segment "CODE_2"
00017Fr 2               
00017Fr 2               .import _activesprites_active, _scroll_x, _scroll_y, _animating
00017Fr 2               
00017Fr 2               .export _check_spr_objects := check_spr_objects
00017Fr 2               .proc check_spr_objects
00017Fr 2               	realScrollY = ptr1
00017Fr 2               	; save current bank
00017Fr 2  AD rr rr         lda mmc3PRG1Bank
000182r 2  48               pha
000183r 2               
000183r 2               	; load sprite data bank
000183r 2  AD rr rr         lda _sprite_data_bank
000186r 2  20 rr rr         jsr mmc3_set_prg_bank_1
000189r 2               
000189r 2  AD rr rr     	lda	_scroll_y
00018Cr 2  AE rr rr     	ldx	_scroll_y+1
00018Fr 2  20 rr rr     	jsr _calculate_linear_scroll_y
000192r 2  85 rr        	sta realScrollY
000194r 2  86 rr        	stx realScrollY+1
000196r 2               
000196r 2                   ; for each sprite we want to check to see if its active
000196r 2                   ; if it is, update its realx/y position
000196r 2                   ; if its not, attempt to load another sprite
000196r 2  A2 0F            ldx #16 - 1
000198r 2               
000198r 2               check_sprite_loop:
000198r 2                       ; X is the current sprite object
000198r 2  BD rr rr     		lda _activesprites_type, x	;	If the sprite (e.g. color triggers)
00019Br 2  C9 FF        		cmp #$ff					;	has been marked as "complete",
00019Dr 2  F0 23        		beq sprite_dead				;__
00019Fr 2               
00019Fr 2  BD rr rr             lda _activesprites_x_lo, x	;
0001A2r 2  38                   sec							;	Or the sprite has
0001A3r 2  ED rr rr             sbc _scroll_x				;	went offscreen,
0001A6r 2  BD rr rr             lda _activesprites_x_hi, x	;
0001A9r 2  ED rr rr             sbc _scroll_x+1				;__
0001ACr 2  10 1D                bpl sprite_alive
0001AEr 2               
0001AEr 2  BD rr rr     		lda _activesprites_type, x
0001B1r 2  C9 07        		cmp #$07
0001B3r 2  F0 08        		beq coin_dead
0001B5r 2  C9 1A        		cmp #$1A
0001B7r 2  F0 04        		beq coin_dead
0001B9r 2  C9 1B        		cmp #$1B
0001BBr 2  D0 05        		bne sprite_dead
0001BDr 2               	coin_dead:
0001BDr 2  A9 00        		lda #0
0001BFr 2  8D rr rr     		sta _animating
0001C2r 2               	sprite_dead:					;__	Load a new one in its place
0001C2r 2  8A                       txa						;	Takes the "slot" argument in A
0001C3r 2  20 rr rr     			jsr load_next_sprite	;__	But also preserves the X
0001C6r 2  A9 00                    lda #0
0001C8r 2  4C rr rr                 jmp write_active
0001CBr 2                   sprite_alive:
0001CBr 2                       ; Sprite is still alive, so check to see if its on screen
0001CBr 2  D0 32                bne sprite_offscreen2
0001CDr 2                       ; sprite is alive AND onscreen x, so now check the Y position
0001CDr 2  BD rr rr             lda _activesprites_y_lo, x
0001D0r 2  18                   clc ; NOTICE: intentionally subtract 1 extra to position them on the screen better
0001D1r 2  E5 rr                sbc realScrollY
0001D3r 2  9D rr rr             sta _activesprites_realy, x
0001D6r 2  BD rr rr             lda _activesprites_y_hi, x
0001D9r 2  E5 rr                sbc realScrollY+1
0001DBr 2  D0 0E                bne sprite_offscreen
0001DDr 2               	finish:
0001DDr 2                       ; totally onscreen so finish updating its scroll position
0001DDr 2  BD rr rr             lda _activesprites_x_lo, x
0001E0r 2  38                   sec
0001E1r 2  ED rr rr             sbc _scroll_x
0001E4r 2  9D rr rr             sta _activesprites_realx, x
0001E7r 2               
0001E7r 2  A9 01                lda #1
0001E9r 2  D0 16                bne write_active ; unconditional
0001EBr 2               	sprite_offscreen:
0001EBr 2  AD rr rr     		lda _animating
0001EEr 2  F0 0F        		beq sprite_offscreen2
0001F0r 2  BD rr rr     		lda _activesprites_type, x
0001F3r 2  C9 07        		cmp #$07
0001F5r 2  F0 E6        		beq finish
0001F7r 2  C9 1A        		cmp #$1A
0001F9r 2  F0 E2        		beq finish
0001FBr 2  C9 1B        		cmp #$1B
0001FDr 2  F0 DE        		beq finish
0001FFr 2               	sprite_offscreen2:
0001FFr 2  A9 00                lda #0
000201r 2               	write_active:
000201r 2  9D rr rr             sta _activesprites_active, x
000204r 2  CA                   dex
000205r 2  10 91                bpl check_sprite_loop
000207r 2               end:
000207r 2  68           	pla
000208r 2  4C rr rr     	jmp mmc3_set_prg_bank_1
00020Br 2               .endproc
00020Br 2               
00020Br 2               .if !__THE_ALBUM
00020Br 2               
00020Br 2               .segment _PLAYER_RENDER_BANK
000046r 2               
000046r 2               .import _player_x, _player_y, _player_gravity, _player_vel_x, _player_vel_y, _player_mini
000046r 2               .import _ballframe, _robotframe, _robotjumpframe, _spiderframe, _orbed
000046r 2               .import _retro_mode, _icon, _gameState, _titleicon, _skipProcessingCubeRotationLogic
000046r 2               .import _CUBE_GRAVITY_lo, _chargepower
000046r 2               .importzp _cube_rotate, _was_on_slope_counter
000046r 2               .import _CUBE, _SHIP, _BALL, _ROBOT, _ROBOT_ALT, _UFO, _SPIDER, _WAVE, _SWING, _ROBOT_ALT2, _SPIDER_ALT, _SPIDER_ALT2, _POGO, _SNAKE
000046r 2               .import _MINI_CUBE, _MINI_SHIP, _MINI_BALL, _MINI_BALL_ALT, _MINI_ROBOT, _MINI_ROBOT_ALT, _MINI_UFO, _MINI_SPIDER, _MINI_SPIDER_ALT, _MINI_WAVE, _MINI_SWING, _MINI_SWING_ALT, _MINI_POGO, _MINI_SNAKE
000046r 2               .importzp _cube_data, _slope_frames, _slope_type
000046r 2               drawcube_rounding_table:
000046r 2  00 FF FE 03  	.byte 0, <-1, <-2, 3, 2, 1
00004Ar 2  02 01        
00004Cr 2  00 FF FE 03  	.byte 0, <-1, <-2, 3, 2, 1	; doubling it simplifies the routine
000050r 2  02 01        
000052r 2  E8           	.byte <-24
000053r 2               
000053r 2               drawcube_sprite_table:
000053r 2               	; Bits 6-7: FLIP
000053r 2               	; Bits 0-2: actual idx
000053r 2               	.define NOFLIP $00
000053r 2               	.define H_FLIP $40
000053r 2               	.define V_FLIP $80
000053r 2               	.define HVFLIP $C0
000053r 2  00 01 02 03  	.byte NOFLIP|0, NOFLIP|1, NOFLIP|2, NOFLIP|3, NOFLIP|4, NOFLIP|5
000057r 2  04 05        
000059r 2  06 85 84 83  	.byte NOFLIP|6, V_FLIP|5, V_FLIP|4, V_FLIP|3, V_FLIP|2, V_FLIP|1
00005Dr 2  82 81        
00005Fr 2  C0 C1 C2 C3  	.byte HVFLIP|0, HVFLIP|1, HVFLIP|2, HVFLIP|3, HVFLIP|4, HVFLIP|5
000063r 2  C4 C5        
000065r 2  C6 45 44 43  	.byte HVFLIP|6, H_FLIP|5, H_FLIP|4, H_FLIP|3, H_FLIP|2, H_FLIP|1
000069r 2  42 41        
00006Br 2               	.undef NOFLIP
00006Br 2               	.undef H_FLIP
00006Br 2               	.undef V_FLIP
00006Br 2               	.undef HVFLIP
00006Br 2               
00006Br 2               drawcube_sprite_way:
00006Br 2               	; Bits 6-7: FLIP
00006Br 2               	; Bits 0-2: actual idx
00006Br 2               	.define NOFLIP $00
00006Br 2               	.define H_FLIP $40
00006Br 2               	.define V_FLIP $80
00006Br 2               	.define HVFLIP $C0
00006Br 2  00 01 02 03  	.byte NOFLIP|0, NOFLIP|1, NOFLIP|2, NOFLIP|3, NOFLIP|4, NOFLIP|5
00006Fr 2  04 05        
000071r 2  06 45 44 43  	.byte NOFLIP|6, H_FLIP|5, H_FLIP|4, H_FLIP|3, H_FLIP|2, H_FLIP|1
000075r 2  42 41        
000077r 2  40 C1 C2 C3  	.byte H_FLIP|0, HVFLIP|1, HVFLIP|2, HVFLIP|3, HVFLIP|4, HVFLIP|5
00007Br 2  C4 C5        
00007Dr 2  86 85 84 83  	.byte V_FLIP|6, V_FLIP|5, V_FLIP|4, V_FLIP|3, V_FLIP|2, V_FLIP|1
000081r 2  82 81        
000083r 2               	.undef NOFLIP
000083r 2               	.undef H_FLIP
000083r 2               	.undef V_FLIP
000083r 2               	.undef HVFLIP
000083r 2               
000083r 2               drawcube_sprite_none:
000083r 2               	; Bits 6-7: FLIP
000083r 2               	; Bits 0-2: actual idx
000083r 2               	.define NOFLIP $00
000083r 2               	.define H_FLIP $40
000083r 2               	.define V_FLIP $80
000083r 2               	.define HVFLIP $C0
000083r 2  00 01 02 03  	.byte NOFLIP|0, NOFLIP|1, NOFLIP|2, NOFLIP|3, NOFLIP|4, NOFLIP|5
000087r 2  04 05        
000089r 2  06 01 02 03  	.byte NOFLIP|6, NOFLIP|1, NOFLIP|2, NOFLIP|3, NOFLIP|4, NOFLIP|5
00008Dr 2  04 05        
00008Fr 2  06 01 02 03  	.byte NOFLIP|6, NOFLIP|1, NOFLIP|2, NOFLIP|3, NOFLIP|4, NOFLIP|5
000093r 2  04 05        
000095r 2  06 01 02 03  	.byte NOFLIP|6, NOFLIP|1, NOFLIP|2, NOFLIP|3, NOFLIP|4, NOFLIP|5
000099r 2  04 05        
00009Br 2               	.undef NOFLIP
00009Br 2               	.undef H_FLIP
00009Br 2               	.undef V_FLIP
00009Br 2               	.undef HVFLIP
00009Br 2               
00009Br 2               
00009Br 2               drawplayer_center_offsets:
00009Br 2               	;		Cub	Shp Bal	UFO	RBT	SPI	Wav Sng Nja Pgo Snk Ftb
00009Br 2  08 08 08 08  	.byte	8,	8,	8,	8,	4,	4,	8,	8,	8,	8,	8,	8; normal size
00009Fr 2  04 04 08 08  
0000A3r 2  08 08 08 08  
0000A7r 2  04 04 04 04  	.byte	4,	4,	4,	4,	4,	4,	4,	4,	4,	4,	4,	4; mini
0000ABr 2  04 04 04 04  
0000AFr 2  04 04 04 04  
0000B3r 2               
0000B3r 2               ; void drawplayerone();
0000B3r 2               .segment _PLAYER_RENDER_BANK
0000B3r 2               
0000B3r 2               
0000B3r 2               .export _drawplayerone
0000B3r 2               .proc _drawplayerone
0000B3r 2               
0000B3r 2  A6 rr            LDX _cube_data
0000B5r 2  A5 rr            LDA _slope_frames+0
0000B7r 2  05 rr            ORA _slope_type+0
0000B9r 2  F0 05            BEQ :+
0000BBr 2  8A                   TXA
0000BCr 2  09 80                ORA #%10000000
0000BEr 2  D0 03                BNE @skipClearBit
0000C0r 2                   :
0000C0r 2  8A                   TXA
0000C1r 2  29 7F                AND #%01111111
0000C3r 2                   @skipClearBit:
0000C3r 2  85 rr            sta _cube_data
0000C5r 2               
0000C5r 2  AD rr rr     	LDA _player_gravity+0
0000C8r 2  F0 02        	BEQ :+
0000CAr 2  A9 80        		LDA #$80
0000CCr 2  85 rr        	: STA xargs+0
0000CEr 2               
0000CEr 2  AE rr rr     	LDX _player_y+1		;
0000D1r 2  CA           	DEX					;	The Y of oam_meta_spr is high_byte(player_y[0])-1
0000D2r 2  86 rr        	STX sreg+1			;__
0000D4r 2               
0000D4r 2               	; Set up base pointer for jump tables
0000D4r 2  AD rr rr     	LDA _player_mini;
0000D7r 2  F0 02        	BEQ :+          ;   Add 8 if mini mode
0000D9r 2  A9 0C        		LDA #gamemode_count
0000DBr 2               	:               ;__
0000DBr 2  18           	CLC             ;   Actual gamemode itself
0000DCr 2  65 rr        	ADC _gamemode   ;__
0000DEr 2  48           	PHA
0000DFr 2  AE rr rr     	LDX _retro_mode
0000E2r 2  F0 02        	BEQ :+
0000E4r 2  69 18        		ADC #gamemode_count*2	; ain't no way the last one overflowed
0000E6r 2               	:
0000E6r 2  AA           	TAX
0000E7r 2  BD rr rr     	LDA sprite_table_table_lo, X
0000EAr 2  85 rr        	STA ptr1		;__	Get low byte of table ptr
0000ECr 2  BD rr rr     	LDA sprite_table_table_hi, X
0000EFr 2  85 rr        	STA ptr1+1		;__ Get high byte of table ptr
0000F1r 2  68           	PLA				;	Get pure gamemode number
0000F2r 2  AA           	TAX				;__
0000F3r 2               
0000F3r 2  AC rr rr     	LDY _player_x+1     ;__ temp_x = high_byte(player_x[0]);
0000F6r 2               	; The condition if is temp_x == 0 or is > 0xfc,
0000F6r 2               	; this can be expressed as (temp_x - 1) > 0xfb
0000F6r 2  88           	DEY					;
0000F7r 2  C0 FC        	CPY #$FC            ;
0000F9r 2  90 02        	BCC :+              ;	if(temp_x-1 > 0xfb) temp_x = 1;
0000FBr 2  A0 00        		LDY #$00        ;
0000FDr 2               	:                   ;__
0000FDr 2  98           	TYA
0000FEr 2  38           	SEC		; I decremented the Y, this is getting back at it
0000FFr 2  7D rr rr     	ADC drawplayer_center_offsets, X
000102r 2  85 rr        	STA sreg+0			;__ The X of oam_meta_spr is temp_x
000104r 2               
000104r 2               	; The switch
000104r 2  AE rr rr     	LDX _retro_mode
000107r 2  F0 09        	beq @normal
000109r 2  A6 rr        	LDX _gamemode
00010Br 2  E0 08        	cpx #$08
00010Dr 2  D0 03 4C rr  	jeq	robot
000111r 2  rr           
000112r 2               
000112r 2               @normal:
000112r 2  A6 rr        	LDX _gamemode
000114r 2  CA           	DEX			;	case 0x01: ship shit
000115r 2  D0 03 4C rr  	jeq ship	;__
000119r 2  rr           
00011Ar 2  CA           	DEX			;	case 0x02: ball shit
00011Br 2  D0 03 4C rr  	jeq ball	;__
00011Fr 2  rr           
000120r 2  CA           	DEX			;	case 0x03: ufo shit
000121r 2  D0 03 4C rr  	jeq ufo		;__
000125r 2  rr           
000126r 2  CA           	DEX			;	case 0x04: robot shit
000127r 2  D0 03 4C rr  	jeq robot	;__
00012Br 2  rr           
00012Cr 2  CA           	DEX			;	case 0x05: spider shit
00012Dr 2  D0 03 4C rr  	jeq spider	;__
000131r 2  rr           
000132r 2  CA           	dex			;	case 0x06: wave shit
000133r 2  D0 03 4C rr  	jeq	wave	;__
000137r 2  rr           
000138r 2  CA           	dex			;	case 0x07: swing shit
000139r 2  D0 03 4C rr  	jeq	ship	;__
00013Dr 2  rr           
00013Er 2  CA           	dex			;	case 0x08: NINJA
00013Fr 2  D0 03 4C rr  	jeq	cube	;__
000143r 2  rr           
000144r 2  CA           	dex			;	case 0x09: POGO
000145r 2  D0 03 4C rr  	jeq	pogo	;__
000149r 2  rr           
00014Ar 2  CA           	dex			;	case 0x0A: SNAKE
00014Br 2  D0 03 4C rr  	jeq	wave	;__
00014Fr 2  rr           
000150r 2               
000150r 2               	; default: cube
000150r 2                   cube:
000150r 2               		; C code:
000150r 2               			; 		if (player_vel_y[0] == 0) cube_rotate[0] = round to the nearest 90°;
000150r 2               			; 		else cube_rotate[0] += player_gravity[0] ? -CUBE_GRAVITY : CUBE_GRAVITY;
000150r 2               			; 		cap the mf at 0..23
000150r 2               		@rounding_table = drawcube_rounding_table
000150r 2               
000150r 2  24 rr                BIT _cube_data
000152r 2  30 24                BMI @round
000154r 2  AE rr rr     		ldx _skipProcessingCubeRotationLogic			;player trails?
000157r 2  F0 03        		beq @nofin
000159r 2  4C rr rr     		jmp @fin			;if so, get out of here
00015Cr 2               	@nofin:
00015Cr 2               
00015Cr 2  A5 rr        		LDA _gamemode
00015Er 2  C9 0B        		cmp #$0B
000160r 2  D0 0E        		bne @normalagain
000162r 2  AD rr rr     		lda _player_vel_y+1
000165r 2  0D rr rr     		ORA _player_vel_y+0
000168r 2  D0 06        		bne @normalagain
00016Ar 2               
00016Ar 2  A9 00        		lda #0
00016Cr 2  85 rr        		sta _cube_rotate+1
00016Er 2  F0 08        		beq @round
000170r 2               
000170r 2               
000170r 2               		@normalagain:
000170r 2  AD rr rr     		LDA _player_vel_y+1		;	if player_vel_y == 0
000173r 2  0D rr rr     		ORA _player_vel_y+0		;
000176r 2  D0 2A        		BNE @no_round		    ;__
000178r 2                       @round:
000178r 2  85 rr        			STA	_cube_rotate+0	;__ low_byte = 0
00017Ar 2               			.if USE_ILLEGAL_OPCODES
00017Ar 2               				LAX _cube_rotate+1	;	LAX abs is apparently stable
00017Ar 2               			.else
00017Ar 2  A5 rr        				LDA _cube_rotate+1
00017Cr 2  AA           				TAX
00017Dr 2               			.endif
00017Dr 2  38           			SEC					;
00017Er 2  E9 0C        			SBC #12				;
000180r 2  90 02        			BCC :+				;	Limit table idx to 0..12
000182r 2  AA           				TAX				;
000183r 2  18           				CLC				;
000184r 2               			:					;__
000184r 2  A5 rr        			LDA _cube_rotate+1	;	Round the cube rotation
000186r 2  7D rr rr     			ADC @rounding_table, X
000189r 2  85 rr                    STA _cube_rotate+1
00018Br 2  24 rr        			BIT _cube_data
00018Dr 2  10 06                    BPL :+
00018Fr 2  A4 rr                        LDY _slope_type
000191r 2  18                           CLC
000192r 2  79 rr rr                     ADC rounding_slope_table-1, y
000195r 2                           :
000195r 2  AA                       TAX
000196r 2  A5 rr        			lda _gamemode
000198r 2  C9 0B        			cmp #$0B
00019Ar 2  D0 03        			bne @doit
00019Cr 2  4C rr rr     			jmp @no_round
00019Fr 2               			@doit:
00019Fr 2  4C rr rr                 JMP @fin_nold
0001A2r 2               
0001A2r 2               		@no_round:
0001A2r 2  AD rr rr     		LDA	_framerate	;
0001A5r 2  0A           		ASL				;	Physics table index
0001A6r 2  0A           		ASL				;	(just the framerate)
0001A7r 2  A8           		TAY				;__
0001A8r 2               
0001A8r 2               
0001A8r 2  A6 rr        		LDX _gamemode
0001AAr 2  E0 0B        		cpx #$0B
0001ACr 2  D0 58        		bne @normalstuff
0001AEr 2               
0001AEr 2  AD rr rr     		lda _orbed
0001B1r 2  F0 08        		beq @disregard1
0001B3r 2  AD rr rr     		lda _player_vel_y+0
0001B6r 2  0D rr rr     		ora _player_vel_y+1
0001B9r 2  F0 44        		beq @hi
0001BBr 2               
0001BBr 2               
0001BBr 2               
0001BBr 2               	@disregard1:
0001BBr 2  AD rr rr     		lda _player_vel_y+0
0001BEr 2  0D rr rr     		ora _player_vel_y+1
0001C1r 2  D0 43        		bne @normalstuff
0001C3r 2               
0001C3r 2  AD rr rr     		lda _chargepower
0001C6r 2  F0 3E        		beq @normalstuff
0001C8r 2               
0001C8r 2  C9 0A        		cmp #10
0001CAr 2  B0 07        		BCS :+
0001CCr 2  A2 17        		ldx #23
0001CEr 2  86 rr        		stx _cube_rotate+1
0001D0r 2  4C rr rr     		jmp @fin
0001D3r 2               
0001D3r 2  C9 14        	: 	cmp #20
0001D5r 2  B0 07        		BCS :+
0001D7r 2  A2 16        		ldx #22
0001D9r 2  86 rr        		stx _cube_rotate+1
0001DBr 2  4C rr rr     		jmp @fin
0001DEr 2               
0001DEr 2               
0001DEr 2  C9 1E        	: 	cmp #30
0001E0r 2  B0 07        		BCS :+
0001E2r 2  A2 15        		ldx #21
0001E4r 2  86 rr        		stx _cube_rotate+1
0001E6r 2  4C rr rr     		jmp @fin
0001E9r 2               
0001E9r 2               
0001E9r 2  C9 26        	: 	cmp #38
0001EBr 2  B0 07        		BCS :+
0001EDr 2  A2 14        		ldx #20
0001EFr 2  86 rr        		stx _cube_rotate+1
0001F1r 2  4C rr rr     		jmp @fin
0001F4r 2               
0001F4r 2               
0001F4r 2  C9 32        	: 	cmp #50
0001F6r 2  B0 07        		BCS @hi
0001F8r 2  A2 14        		ldx #20
0001FAr 2  86 rr        		stx _cube_rotate+1
0001FCr 2  4C rr rr     		jmp @fin
0001FFr 2               
0001FFr 2               	@hi:
0001FFr 2               
0001FFr 2  A2 06        		ldx #6
000201r 2  86 rr        		stx _cube_rotate+1
000203r 2  4C rr rr     		jmp @fin
000206r 2               
000206r 2               
