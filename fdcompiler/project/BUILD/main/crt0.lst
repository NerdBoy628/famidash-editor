00000Cr 1  xx xx xx xx  RAND_SEED: 			.res 5
000010r 1  xx           
000011r 1  xx xx xx xx  TEMP: 				.res 11
000015r 1  xx xx xx xx  
000019r 1  xx xx xx     
00001Cr 1  xx           SPRID:				.res 1
00001Dr 1               
00001Dr 1               PAD_BUF		=TEMP+1
00001Dr 1               
