00001Er 2               
00001Er 2                   ; Store mirroring value to mmc3 register
00001Er 2                   mmc3_set_prg_bank_0:
00001Er 2                   _mmc3_set_prg_bank_0:
00001Er 2  48                   PHA
00001Fr 2  A9 06                lda #MMC3_REG_SEL_PRG_BANK_0
000021r 2  D0 F1                BNE mmc3_internal_set_bank  ; BRA
000023r 2                   .export _mmc3_set_prg_bank_0
000023r 2               
000023r 2                   mmc3_set_2kb_chr_bank_0:
000023r 2                   _mmc3_set_2kb_chr_bank_0:
000023r 2  48                   PHA
000024r 2  A9 00                lda #MMC3_REG_SEL_2KB_CHR_0
000026r 2  F0 EC                BEQ mmc3_internal_set_bank  ; BRA
000028r 2                   .export _mmc3_set_2kb_chr_bank_0
000028r 2               
000028r 2                   mmc3_set_2kb_chr_bank_1:
000028r 2                   _mmc3_set_2kb_chr_bank_1:
000028r 2  48                   PHA
000029r 2  A9 01                lda #MMC3_REG_SEL_2KB_CHR_1
00002Br 2  D0 E7                BNE mmc3_internal_set_bank  ; BRA
00002Dr 2                   .export _mmc3_set_2kb_chr_bank_1
00002Dr 2               
00002Dr 2                   mmc3_set_1kb_chr_bank_0:
00002Dr 2                   _mmc3_set_1kb_chr_bank_0:
00002Dr 2  48                   PHA
00002Er 2  A9 02                lda #MMC3_REG_SEL_1KB_CHR_0
000030r 2  D0 E2                BNE mmc3_internal_set_bank  ; BRA
000032r 2                   .export _mmc3_set_1kb_chr_bank_0
000032r 2               
