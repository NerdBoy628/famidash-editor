0002CAr 2  A6 rr        	ldx SPRID
0002CCr 2               
0002CCr 2               @loop:
0002CCr 2               
0002CCr 2  B1 rr        	lda (PTR),y		;
0002CEr 2  C9 80        	cmp #$80		;	Load X offset
0002D0r 2  F0 4B        	beq @2			;	Exit if = $80
0002D2r 2  C8           	iny				;__
0002D3r 2               	; The CMP #$80 has practically loaded the last bit
0002D3r 2               	; of the X offset into the carry flag
0002D3r 2  B0 06        	bcs @neg_x_off
0002D5r 2               	@pos_x_off:
0002D5r 2  65 rr        		adc sreg+0		;__	Add it to the metasprite X	(carry already cleared)
0002D7r 2  B0 47        		bcs	@x_overflow	;__	If it had an overflow then don't render the damn sprite
0002D9r 2  90 06        		bcc	@no_x_overflow
0002DBr 2               	@neg_x_off:
0002DBr 2  18           		clc				;	Add it to the metasprite X
0002DCr 2  65 rr        		adc sreg+0		;__
0002DEr 2  90 40        		bcc	@x_overflow	;__	If it had an overflow then don't render the damn sprite
0002E0r 2  18           		clc				;__	We need the clear carry later
0002E1r 2               	@no_x_overflow:
0002E1r 2  9D rr rr     	sta OAM_BUF+3,x	;__	Store the sprite X
0002E4r 2  B1 rr        	lda (PTR),y		;__	Load Y offset
0002E6r 2  30 06        	bmi	@neg_y_off
0002E8r 2               	@pos_y_off:
0002E8r 2  65 rr        		adc sreg+1		;__	Add it to the metasprite Y	(carry already cleared)
0002EAr 2  B0 34        		bcs	@y_overflow	;__	If it had an overflow then don't render the damn sprite
0002ECr 2  90 09        		bcc	@no_y_overflow
0002EEr 2               	@neg_y_off:
0002EEr 2  65 rr        		adc	sreg+1		;__	Add it to the metasprite Y
0002F0r 2  B0 04        		bcs	@neg_no_y_overflow	;__	If it had an overflow then don't render the damn sprite
0002F2r 2  C9 F0        			cmp #$F0		;	Do render the sprite if it ended up
0002F4r 2  90 2A        			bcc	@y_overflow	;__	in the negative space
0002F6r 2               		@neg_no_y_overflow:
0002F6r 2  18           		clc				;__	We need the clear carry later
