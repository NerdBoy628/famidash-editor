000154r 2               ; _buffer_4_mt:
000154r 2               ; 	;a is the index into the data, get 4 metatiles
000154r 2               
000154r 2               ; 	and #$ee ;sanitize, x and y should be even
000154r 2               ; 	tay
000154r 2               ; 	lda (DATA_PTR), y
000154r 2               ; 	sta TEMP+2
000154r 2               ; 	iny
000154r 2               ; 	lda (DATA_PTR), y
000154r 2               ; 	sta TEMP+3
000154r 2               ; 		tya
000154r 2               ; 		clc
000154r 2               ; 		adc #15
000154r 2               ; 			cmp #$f0 ;too far, data set only 240 bytes
000154r 2               ; 			bcs @skip
000154r 2               ; 		tay
000154r 2               ; 	lda (DATA_PTR), y
000154r 2               ; 	sta TEMP+4
000154r 2               ; 	iny
000154r 2               ; 	lda (DATA_PTR), y
000154r 2               ; 	sta TEMP+5
000154r 2               ; @skip:
000154r 2               ; ;metatiles are in TEMP+2 - TEMP+5 now
000154r 2               
000154r 2               ; 	jsr popax ;ppu address
000154r 2               ; 	and #$9c ;sanitize, should be top left
000154r 2               ; 	sta TEMP+7
000154r 2               ; 	stx TEMP+8 ;save for later, ppu_address
000154r 2               
000154r 2               ; 	sta TEMP
000154r 2               ; 	txa
000154r 2               ; 	ora #$40	;NT_UPD_HORZ
000154r 2               ; 	sta TEMP+1
000154r 2               
000154r 2               ; ;buffer the ppu_address
000154r 2               
000154r 2               ; 	lda #0
000154r 2               ; 	sta TEMP+6 ;loop count, index to the metatiles
000154r 2               ; 	ldx VRAM_INDEX
000154r 2               ; @loop:
000154r 2               ; 	lda TEMP ;low byte
000154r 2               ; 	sta VRAM_BUF+1, x
000154r 2               ; 	lda TEMP+1 ;high byte
000154r 2               ; 	sta VRAM_BUF,x
000154r 2               ; 	jsr @sub1 ;adds $20 to the address for next time
000154r 2               
000154r 2               ; 		lda #4 ;tell the system 4 bytes in a row
000154r 2               ; 		sta VRAM_BUF+2,x
000154r 2               ; 		sta VRAM_BUF+9,x ;loops twice, so, it does this twice
000154r 2               
000154r 2               ; 	jsr @sub2 ;set pointer to the metatile and y
000154r 2               
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+3,x ;		buffer the 4 tiles
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+4,x
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+10,x
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+11,x
000154r 2               ; 	jsr @sub4 ;get attrib bits, shift into place
000154r 2               
000154r 2               ; ;same, but for right side
000154r 2               ; 	lda TEMP ;low byte ppu address, again
000154r 2               ; 	sta VRAM_BUF+8,x
000154r 2               ; 	lda TEMP+1 ;high byte
000154r 2               ; 	sta VRAM_BUF+7,x
000154r 2               ; 	jsr @sub1
000154r 2               
000154r 2               ; 	inc TEMP+6 ;count and index
000154r 2               ; 	jsr @sub2 ;set pointer to the metatile and y
000154r 2               
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+5,x ;		buffer the 4 tiles
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+6,x
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+12,x
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y
000154r 2               ; 	sta VRAM_BUF+13,x
000154r 2               ; 	jsr @sub4
000154r 2               
000154r 2               ; 	txa ;adjust the vram index to the next set
000154r 2               ; 	clc
000154r 2               ; 	adc #14
000154r 2               ; 	tax
000154r 2               
000154r 2               ; 	jsr @sub3 ;check if lowest y on screen, skip the la
000154r 2               ; 	bne @loop_done
000154r 2               
000154r 2               ; 	inc TEMP+6
000154r 2               ; 	ldy TEMP+6
000154r 2               ; 	cpy #4
000154r 2               ; 	bcc @loop
000154r 2               
000154r 2               ; @loop_done:
000154r 2               
000154r 2               
000154r 2               
000154r 2               ; ;now push 1 attribute byte to the vram buffer
000154r 2               ; ;first, shift the bits to get an attribute address
000154r 2               ; ;we stored the original at TEMP+7,8, 8 is high byte
000154r 2               ; ;a bunch of bit shifting to get 3 bits from x and 3 y
000154r 2               ; 	lsr TEMP+8 ;high byte
000154r 2               ; 	ror TEMP+7
000154r 2               ; 	lsr TEMP+8
000154r 2               ; 	ror TEMP+7
000154r 2               ; 	lda TEMP+7
000154r 2               ; 	pha ;save
000154r 2               ; 	and #7 ;just the x bits
000154r 2               ; 	sta TEMP
000154r 2               ; 	pla
000154r 2               ; 	lsr a ;just the y bits
000154r 2               ; 	lsr a
000154r 2               ; 	and #$f8
000154r 2               ; 	ora #$c0
000154r 2               ; 	ora TEMP
000154r 2               ; 	sta TEMP ;low byte
000154r 2               ; ;now high byte
000154r 2               ; 	lda TEMP+8
000154r 2               ; 	asl a
000154r 2               ; 	asl a
000154r 2               ; 	ora #$23
000154r 2               ; 	sta TEMP+1 ;high byte, and the low byte is in TEMP
000154r 2               
000154r 2               
000154r 2               ; ;finally, push it all to the vram_buffer as a single byte
000154r 2               ; 	lda TEMP+1 ;high byte
000154r 2               ; 	sta VRAM_BUF,x
000154r 2               ; 	inx
000154r 2               ; 	lda TEMP ;low byte
000154r 2               ; 	sta VRAM_BUF,x
000154r 2               ; 	inx
000154r 2               ; 	lda TEMP+10
000154r 2               ; 	sta VRAM_BUF,x
000154r 2               ; 	inx
000154r 2               ; 	lda #$ff ;=NT_UPD_EOF
000154r 2               ; 	sta VRAM_BUF,x
000154r 2               ; 	stx VRAM_INDEX
000154r 2               ; 	rts
000154r 2               
000154r 2               
000154r 2               ; @sub1:	;add $20 is a 1 down on the screen
000154r 2               ; 	tay ;high byte
000154r 2               ; 	lda TEMP
000154r 2               ; 	clc
000154r 2               ; 	adc #$20
000154r 2               ; 	sta TEMP
000154r 2               ; 	bcc @sub1b
000154r 2               ; 	iny
000154r 2               ; @sub1b:
000154r 2               ; 	sty TEMP+1
000154r 2               ; 	rts
000154r 2               
000154r 2               
000154r 2               ; @sub2:	;get the next metatile offset
000154r 2               ; 	ldy TEMP+6
000154r 2               ; 	lda TEMP+2, y ;metatile temp copied to +2,+3,+5,and +6
000154r 2               ; 	sta META_VAR
000154r 2               ; 	jmp MT_MULT5 ;multiply 5 and set y
000154r 2               ; ;	rts
000154r 2               
000154r 2               
000154r 2               ; @sub3: ;check make sure we're not at the lowest y and overflowing
000154r 2               ; 	ldy #0 ;x is forbidden
000154r 2               ; 	lda TEMP+8 ;high byte
000154r 2               ; 	and #$03
000154r 2               ; 	cmp #$03
000154r 2               ; 	bne @not_overflow
000154r 2               ; 	lda TEMP+7
000154r 2               ; 	cmp #$80 ;last row of mt
000154r 2               ; 	bcc @not_overflow
000154r 2               ; 	iny
000154r 2               ; 	lsr TEMP+10 ;make sure the attrib bits in correct position
000154r 2               ; 	lsr TEMP+10
000154r 2               ; 	lsr TEMP+10
000154r 2               ; 	lsr TEMP+10
000154r 2               ; @not_overflow:
000154r 2               ; 	tya ;set flag
000154r 2               ; 	rts
000154r 2               
000154r 2               
000154r 2               ; @sub4: ;get attrib bits, roll them in place
000154r 2               ; 	iny
000154r 2               ; 	lda (META_PTR2), y ;5th byte = attribute
000154r 2               ; 	and #3 ;just need 2 bits
000154r 2               ; 	ror a ;bit to carry
000154r 2               ; 	ror TEMP+10 ;shift carry in
000154r 2               ; 	ror a ;bit to carry
000154r 2               ; 	ror TEMP+10 ;roll the a.t. bits in the high 2 bits
000154r 2  60           	rts
000155r 2               
000155r 2               
000155r 2               
000155r 2               
000155r 2               ;void __fastcall__ buffer_1_mt(uint16_t ppu_address, uint8_t metatile);
000155r 2               ;__buffer_1_mt:
000155r 2               	;; which metatile, in sreg[0]
000155r 2               	; AX = ppu_address
000155r 2               
000155r 2               ;	ldy sreg+0
000155r 2               	;sty META_VAR
000155r 2               
000155r 2               	; jsr popax ;get ppu address
000155r 2               ;	and #$de ;sanitize, should be even x and y
000155r 2               ;	sta TEMP
000155r 2               ;	txa
000155r 2               ;	ora #$40 ;NT_UPD_HORZ
000155r 2               ;	sta TEMP+1
000155r 2               ;
000155r 2               ;	ldx VRAM_INDEX
000155r 2               ;	lda TEMP				;ppu address
000155r 2               ;	sta VRAM_BUF+1,x
000155r 2               ;		clc
000155r 2               ;		adc #$20 ;shouldn't be rollover
000155r 2               ;	sta VRAM_BUF+6,x
000155r 2               ;
000155r 2               ;	lda TEMP+1
000155r 2               ;	sta VRAM_BUF,x
000155r 2               ;	sta VRAM_BUF+5,x
000155r 2               ;
000155r 2               ;	lda #2 ;tell the system 2 bytes in a row
000155r 2               ;	sta VRAM_BUF+2,x
000155r 2               ;	sta VRAM_BUF+7,x
000155r 2               ;
000155r 2               ;	lda META_VAR ;which metatile
000155r 2               ;	jsr MT_MULT5 ;multiply 5 and set y
000155r 2               ;
000155r 2               ;	lda (META_PTR2), y ;tile
000155r 2               ;	sta VRAM_BUF+3,x
000155r 2               ;	iny
000155r 2               ;	lda (META_PTR2), y ;tile
000155r 2               ;	sta VRAM_BUF+4,x
000155r 2               ;	iny
000155r 2               ;	lda (META_PTR2), y ;tile
000155r 2               ;	sta VRAM_BUF+8,x
000155r 2               ;	iny
000155r 2               ;	lda (META_PTR2), y ;tile
000155r 2               ;	sta VRAM_BUF+9,x
000155r 2               ;
000155r 2               ;	txa
000155r 2               ;	clc
000155r 2               ;	adc #10
000155r 2               ;	sta VRAM_INDEX
000155r 2               ;	tax
000155r 2               ;	lda #$ff ;=NT_UPD_EOF
000155r 2               ;	sta VRAM_BUF,x
000155r 2               ;	rts
000155r 2               ;
000155r 2               ;
000155r 2               
000155r 2               ; MT_MULT5:
000155r 2               ; ;multiply metatile value (8 bit) by 5
000155r 2               ; ;and add to pointer (16 bit)
000155r 2               ; ;mt var should be in META_VAR and in A register
000155r 2               ; ;x is forbidden
000155r 2               
000155r 2               ; 	ldy #0
000155r 2               ; 	sty META_PTR2+1 ;zero the high byte
000155r 2               ; 	asl a ;x2
000155r 2               ; 	rol META_PTR2+1
000155r 2               ; 	asl a ;x4
000155r 2               ; 	rol META_PTR2+1
000155r 2               ; 	clc
000155r 2               ; 	adc META_VAR
000155r 2               ; 	bcc @1
000155r 2               ; 	inc META_PTR2+1
000155r 2               ; @1:
000155r 2               ; 	clc
000155r 2               ; 	adc META_PTR
000155r 2               ; 	bcc @2
000155r 2               ; 	inc META_PTR2+1
000155r 2               ; @2:
000155r 2               ; 	sta META_PTR2 ;set low byte
000155r 2               ; 	lda META_PTR2+1
000155r 2               ; 	clc
000155r 2               ; 	adc META_PTR+1
000155r 2               ; 	sta META_PTR2+1 ;set high byte
000155r 2               ; 	ldy #0
000155r 2               ; 	rts
000155r 2               
000155r 2               
000155r 2               
000155r 2               
000155r 2               ;void __fastcall__ color_emphasis(uint8_t color);
000155r 2               _color_emphasis:
000155r 2               	;a = bits 1110 0000
000155r 2  29 E1        	and #$e1 ;sanitize
000157r 2  85 rr        	sta TEMP
000159r 2  A5 rr        	lda <PPU_MASK_VAR
00015Br 2  29 1E        	and #$1e
00015Dr 2  05 rr        	ora TEMP
00015Fr 2  85 rr        	sta <PPU_MASK_VAR
000161r 2  8D 01 20     	sta PPU_MASK
000164r 2  60           	rts
000165r 2               
000165r 2               
000165r 2               
000165r 2               
000165r 2               ;void __fastcall__ xy_split(uint16_t x, uint16_t y);
000165r 2               __xy_split:
000165r 2               	;Nametable number << 2 (that is: $00, $04, $08, or $0C) to $2006
000165r 2               	;Y to $2005
000165r 2               	;X to $2005
000165r 2               	;Low byte of nametable address to $2006, which is ((Y & $F8) << 2) | (X >> 3)
000165r 2               
000165r 2  85 rr        	sta <TEMP+2 ;y low
000167r 2  86 rr        	stx <TEMP+3
000169r 2               	; jsr popax
000169r 2               	; sta sreg+0 ;x low
000169r 2               	; stx sreg+1
000169r 2               
000169r 2               ;push to stack in reverse order
000169r 2  A5 rr        	lda <TEMP+2 ;low y
00016Br 2  29 F8        	and #$f8
00016Dr 2  0A           	asl a
00016Er 2  0A           	asl a
00016Fr 2  85 rr        	sta <TEMP+4
000171r 2  A5 rr        	lda sreg+0 ;low x
000173r 2  4A           	lsr a
000174r 2  4A           	lsr a
000175r 2  4A           	lsr a
000176r 2  05 rr        	ora <TEMP+4
000178r 2  48           	pha
000179r 2               
000179r 2  A5 rr        	lda sreg+0 ;low x
00017Br 2  48           	pha
00017Cr 2               
00017Cr 2  A5 rr        	lda <TEMP+2 ;low y
00017Er 2  48           	pha
00017Fr 2               
00017Fr 2  A5 rr        	lda <TEMP+3 ;y high
000181r 2  29 01        	and #$01
000183r 2  0A           	asl a
000184r 2  85 rr        	sta <TEMP+4
000186r 2  A5 rr        	lda sreg+1 ;x high
000188r 2  29 01        	and #$01
00018Ar 2  05 rr        	ora <TEMP+4
00018Cr 2  0A           	asl a
00018Dr 2  0A           	asl a
00018Er 2  48           	pha
00018Fr 2               
00018Fr 2               @3:
00018Fr 2               
00018Fr 2  2C 02 20     	bit PPU_STATUS
000192r 2  70 FB        	bvs @3
000194r 2               
000194r 2               @4:
000194r 2               
000194r 2  2C 02 20     	bit PPU_STATUS
000197r 2  50 FB        	bvc @4
000199r 2               .importzp _tmp4
000199r 2  A5 rr        	lda _tmp4
00019Br 2  20 rr rr     	jsr delay_a_27_clocks
00019Er 2               
00019Er 2  68           	pla
00019Fr 2  8D 06 20     	sta $2006
0001A2r 2  68           	pla
0001A3r 2  8D 05 20     	sta $2005
0001A6r 2  68           	pla
0001A7r 2  8D 05 20     	sta $2005
0001AAr 2  68           	pla
0001ABr 2  8D 06 20     	sta $2006
0001AEr 2  60           	rts
0001AFr 2               
0001AFr 2               
0001AFr 2               ;;;;;;;;;;;;;;;;;;;;;;;;
0001AFr 2               ; Delays A clocks + overhead
0001AFr 2               ; Clobbers A. Preserves X,Y.
0001AFr 2               ; Time: A+27 clocks (including JSR)
0001AFr 2               ;;;;;;;;;;;;;;;;;;;;;;;;
0001AFr 2               delay_a_27_clocks:
0001AFr 2  38                   sec
0001B0r 2  E9 05        @L:     sbc #5
0001B2r 2  B0 FC                bcs @L  ;  6 6 6 6 6  FB FC FD FE FF
0001B4r 2  69 03                adc #3  ;  2 2 2 2 2  FE FF 00 01 02
0001B6r 2  90 03                bcc @4  ;  3 3 2 2 2  FE FF 00 01 02
0001B8r 2  4A                   lsr     ;  - - 2 2 2  -- -- 00 00 01
0001B9r 2  F0 01                beq @5  ;  - - 3 3 2  -- -- 00 00 01
0001BBr 2  4A           @4:     lsr     ;  2 2 - - 2  7F 7F -- -- 00
0001BCr 2  B0 00        @5:     bcs @6  ;  2 3 2 3 2  7F 7F 00 00 00
0001BEr 2  60           @6:     rts     ;
0001BFr 2               
0001BFr 2               
0001BFr 2               ;void gray_line();
0001BFr 2               _gray_line:
0001BFr 2  A5 rr        	lda <PPU_MASK_VAR
0001C1r 2  29 1F        	and #$1f ;no color emphasis bits
0001C3r 2  09 01        	ora #1 ;yes gray bit
0001C5r 2  8D 01 20     	sta PPU_MASK
0001C8r 2               
0001C8r 2  A2 14        	ldx #20 ;wait
0001CAr 2               @loop:
0001CAr 2  CA           	dex
0001CBr 2  D0 FD        	bne @loop
0001CDr 2               
0001CDr 2  A5 rr        	lda <PPU_MASK_VAR
0001CFr 2  29 1E        	and #$1e ;no gray bit
0001D1r 2  09 E0        	ora #$e0 ;all color emphasis bits
0001D3r 2  8D 01 20     	sta PPU_MASK
0001D6r 2               
0001D6r 2  A2 14        	ldx #20 ;wait
0001D8r 2               @loop2:
0001D8r 2  CA           	dex
0001D9r 2  D0 FD        	bne @loop2
0001DBr 2               
0001DBr 2  A5 rr        	lda <PPU_MASK_VAR ;normal
0001DDr 2  8D 01 20     	sta PPU_MASK
0001E0r 2  60           	rts
0001E1r 2               
0001E1r 2               
0001E1r 2               
0001E1r 2               
0001E1r 2               ;void seed_rng();
0001E1r 2               _seed_rng:
0001E1r 2  A5 rr        	lda <FRAME_CNT
0001E3r 2  85 rr        	sta <RAND_SEED
0001E5r 2  60           	rts
0001E6r 2               
0001E6r 2               
0001E6r 2               
0001E6r 2               
0001E6r 1               	.include "lz.s"
0001E6r 2               ; THCMod-like LZ decompressor for 6502 by AArt1256
0001E6r 2               ; made and finished in 04/01/2025
0001E6r 2               
0001E6r 2               ; SET THIS TO ANY 256-BYTE ALIGNED RAM ADDRESS!!!!!!!!!!!!
0001E6r 2               LZ_buffer_addr := aart_lz_buffer
0001E6r 2               
0001E6r 2               .segment "ZEROPAGE"
000038r 2  xx xx        LZ_addr: .res 2
00003Ar 2               
00003Ar 2               ; check if the decompression has been finished
00003Ar 2               ; $00 = currently not fully decompressed
00003Ar 2               ; $FF = done/complete!
00003Ar 2  xx           LZ_done: .res 1
00003Br 2               
00003Br 2  xx           LZ_buf_addr: .res 1
00003Cr 2  xx           LZ_copy_left: .res 1
00003Dr 2  xx           LZ_y_temp: .res 1
00003Er 2               
00003Er 2               .segment "BSS"
000054r 2               LZ_buffer := LZ_buffer_addr
000054r 2               LZ_buffer2 := LZ_buffer_addr+256
000054r 2               
000054r 2               .segment "CODE_2"
00039Br 2               
00039Br 2               .export LZ_init_decomp, LZ_get_byte, LZ_done
00039Br 2               
00039Br 2               ; LZ_init_decomp: initialize the LZ decompressor
00039Br 2               ; input:
00039Br 2               ; X = lobyte of compressed data address
00039Br 2               ; Y = hibyte of compressed data address
00039Br 2               ; output: nothing
00039Br 2               ; clobbers: A, X (both are set to 0)
00039Br 2               LZ_init_decomp:
00039Br 2  84 rr          sty LZ_addr+1
00039Dr 2  86 rr          stx LZ_addr
00039Fr 2  A9 00          lda #0
0003A1r 2  85 rr          sta LZ_done
0003A3r 2  85 rr          sta LZ_buf_addr
0003A5r 2  85 rr          sta LZ_copy_left
0003A7r 2               
0003A7r 2  AA             tax
0003A8r 2                 @clear_buf:
0003A8r 2                   ; alexmush note: clearing the first buffer is essential
0003A8r 2  9D rr rr         sta LZ_buffer, x
0003ABr 2  CA               dex
0003ACr 2  D0 FA            bne @clear_buf
0003AEr 2               
0003AEr 2  60             rts
0003AFr 2               
0003AFr 2               
0003AFr 2               ; LZ_get_byte: output the decompressed data one byte at a time
0003AFr 2               ; input: nothing
0003AFr 2               ; output:
0003AFr 2               ; A: the current decompressed byte
0003AFr 2               ; clobbers: A, X, Y
0003AFr 2               LZ_get_byte:
0003AFr 2  A5 rr          lda LZ_done
0003B1r 2  F0 03          beq @is_not_finished
0003B3r 2  A9 00          lda #0
0003B5r 2  60             rts
0003B6r 2               @is_not_finished:
0003B6r 2               
0003B6r 2  A5 rr          lda LZ_copy_left
0003B8r 2  F0 0B          beq @no_continue_copy
0003BAr 2               @continue_copy:
0003BAr 2  A8             tay
0003BBr 2  88             dey
0003BCr 2  B9 rr rr       lda LZ_buffer2, y
0003BFr 2  20 rr rr       jsr @write_byte
0003C2r 2  84 rr          sty LZ_copy_left
0003C4r 2  60             rts
0003C5r 2               
0003C5r 2               @no_continue_copy:
0003C5r 2               
0003C5r 2  20 rr rr       jsr @get_compressed_byte
0003C8r 2  C9 FF          cmp #$ff
0003CAr 2  D0 05          bne @skip_end
0003CCr 2  85 rr          sta LZ_done
0003CEr 2  A9 00          lda #0
0003D0r 2  60             rts
0003D1r 2               
0003D1r 2               @skip_end:
0003D1r 2  C9 80          cmp #$80
0003D3r 2  F0 1F          beq @is_imm ; bcs in OG src, works either way
0003D5r 2  AA             tax
0003D6r 2  E8             inx
0003D7r 2  86 rr          stx LZ_copy_left
0003D9r 2  CA             dex
0003DAr 2  CA             dex
0003DBr 2  20 rr rr       jsr @get_compressed_byte
0003DEr 2  A8             tay
0003DFr 2               @pre_copy_loop:
0003DFr 2  B9 rr rr       lda LZ_buffer, y
0003E2r 2  C8             iny
0003E3r 2  9D rr rr       sta LZ_buffer2+1, x
0003E6r 2  CA             dex
0003E7r 2  10 F6          bpl @pre_copy_loop
0003E9r 2  20 rr rr       jsr @get_compressed_byte
0003ECr 2  8D rr rr       sta LZ_buffer2
0003EFr 2               
0003EFr 2  A5 rr          lda LZ_copy_left
0003F1r 2  4C rr rr       jmp @continue_copy
0003F4r 2               
0003F4r 2               @is_imm:
0003F4r 2  20 rr rr       jsr @get_compressed_byte
0003F7r 2                 ; drops down to @write_byte anyway...
0003F7r 2               
0003F7r 2               @write_byte:
0003F7r 2  A6 rr          ldx LZ_buf_addr
0003F9r 2  9D rr rr       sta LZ_buffer, x
0003FCr 2  E8             inx
0003FDr 2  86 rr          stx LZ_buf_addr
0003FFr 2  60             rts
000400r 2               
000400r 2               @get_compressed_byte:
000400r 2  84 rr          sty LZ_y_temp
000402r 2  A0 00          ldy #0
000404r 2  B1 rr          lda (LZ_addr), y
000406r 2  A4 rr          ldy LZ_y_temp
000408r 2               
000408r 2  E6 rr          inc LZ_addr
00040Ar 2  D0 02          bne :+
00040Cr 2  E6 rr          inc LZ_addr+1
00040Er 2               :
00040Er 2  60             rts
00040Fr 2               
00040Fr 2               
00040Fr 1               
00040Fr 1               CURSED_MUSIC_ENABLE = 1
00040Fr 1               .include "famistudio_ca65.s"
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; THIS VERSION OF THE FAMISTUDIO DRIVER HAS BEEN MODIFIED TO INCLUDE SFX BANKSWITCHING AND ALTERED PAL SUPPORT.
00040Fr 2               ;
00040Fr 2               ; that is all, have a nice day
00040Fr 2               ; - usersniper, alexmush, studsX
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               
00040Fr 2               
00040Fr 2               
00040Fr 2               
00040Fr 2               
00040Fr 2               
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; FAMISTUDIO SOUND ENGINE (4.4.1)
00040Fr 2               ; Copyright (c) 2019-2025 Mathieu Gauthier
00040Fr 2               ;
00040Fr 2               ; Copying and distribution of this file, with or without
00040Fr 2               ; modification, are permitted in any medium without royalty provided
00040Fr 2               ; the copyright notice and this notice are preserved in all source
00040Fr 2               ; code copies. This file is offered as-is, without any warranty.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; This is the FamiStudio sound engine. It is used by the NSF and ROM exporter of FamiStudio and can be used to make
00040Fr 2               ; games. It supports every feature from FamiStudio, some of them are toggeable to save CPU/memory.
00040Fr 2               ;
00040Fr 2               ; This is essentially a heavily modified version of FamiTone2 by Shiru. A lot of his code and comments are still
00040Fr 2               ; present here, so massive thanks to him!! I am not trying to steal his work or anything, i renamed a lot of functions
00040Fr 2               ; and variables because at some point it was becoming a mess of coding standards and getting hard to maintain.
00040Fr 2               ;
00040Fr 2               ; Moderately advanced users can probably figure out how to use the sound engine simply by reading these comments.
00040Fr 2               ; For more in-depth documentation, please go to:
00040Fr 2               ;
00040Fr 2               ;    https://famistudio.org/doc/soundengine/
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; INTERFACE
00040Fr 2               ;
00040Fr 2               ; The interface is pretty much the same as FamiTone2, with a slightly different naming convention. The subroutines you
00040Fr 2               ; can call from your game are:
00040Fr 2               ;
00040Fr 2               ;   - famistudio_init            : Initialize the engine with some music data.
00040Fr 2               ;   - famistudio_music_play      : Start music playback with a specific song.
00040Fr 2               ;   - famistudio_music_pause     : Pause/unpause music playback.
00040Fr 2               ;   - famistudio_music_stop      : Stops music playback.
00040Fr 2               ;   - famistudio_sfx_init        : Initialize SFX engine with SFX data.
00040Fr 2               ;   - famistudio_sfx_play        : Play a SFX.
00040Fr 2               ;   - famistudio_sfx_sample_play : Play a DPCM SFX.
00040Fr 2               ;   - famistudio_update          : Updates the music/SFX engine, call once per frame, ideally from NMI.
00040Fr 2               ;
00040Fr 2               ; You can check the demo ROM to see how they are used or check out the online documentation for more info.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; CONFIGURATION
00040Fr 2               ;
00040Fr 2               ; There are 2 main ways of configuring the engine.
00040Fr 2               ;
00040Fr 2               ;   1) The simplest way is right here, in the section below. Simply comment/uncomment these defines, and move on
00040Fr 2               ;      with your life.
00040Fr 2               ;
00040Fr 2               ;   2) The second way is "externally", using definitions coming from elsewhere in your app or the command line. If you
00040Fr 2               ;      wish do so, simply define FAMISTUDIO_CFG_EXTERNAL=1 and this whole section will be ignored. You are then
00040Fr 2               ;      responsible for providing all configuration. This is useful if you have multiple projects that needs
00040Fr 2               ;      different configurations, while pointing to the same code file. This is how the provided demos and FamiStudio
00040Fr 2               ;      uses it.
00040Fr 2               ;
00040Fr 2               ; Note that unless specified, the engine uses "if" and not "ifdef" for all boolean values so you need to define these
00040Fr 2               ; to non-zero values. Undefined values will be assumed to be zero.
00040Fr 2               ;
00040Fr 2               ; There are 4 main things to configure, each of them will be detailed below.
00040Fr 2               ;
00040Fr 2               ;   1) Segments (ZP/RAM/PRG)
00040Fr 2               ;   2) Audio expansion
00040Fr 2               ;   3) Global engine parameters
00040Fr 2               ;   4) Supported features
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               .ifndef FAMISTUDIO_CFG_EXTERNAL
00040Fr 2                   FAMISTUDIO_CFG_EXTERNAL = 0
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               ; Set this to configure the sound engine from outside (in your app, or from the command line)
00040Fr 2               .if !FAMISTUDIO_CFG_EXTERNAL
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; 1) SEGMENT CONFIGURATION
00040Fr 2               ;
00040Fr 2               ; You need to tell where you want to allocate the zeropage, RAM and code. This section will be slightly different for
00040Fr 2               ; each assembler.
00040Fr 2               ;
00040Fr 2               ; For CA65, you need to specify the name of your ZEROPAGE, RAM/BSS and CODE/PRG segments as c-style macros (.define)
00040Fr 2               ; like the example below.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               .define FAMISTUDIO_CA65_ZP_SEGMENT   ZEROPAGE
00040Fr 2               .define FAMISTUDIO_CA65_RAM_SEGMENT  BSS
00040Fr 2               .define FAMISTUDIO_CA65_CODE_SEGMENT SND_DRV
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; 2) AUDIO EXPANSION CONFIGURATION
00040Fr 2               ;
00040Fr 2               ; You can enable up to one audio expansion (FAMISTUDIO_EXP_XXX). Enabling more than one expansion will lead to
00040Fr 2               ; undefined behavior. Memory usage goes up as more complex expansions are used. The audio expansion you choose
00040Fr 2               ; **MUST MATCH** with the data you will load in the engine. Loading a FDS song while enabling VRC6 will lead to
00040Fr 2               ; undefined behavior.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               ; Konami VRC6 (2 extra square + saw)
00040Fr 2               ; FAMISTUDIO_EXP_VRC6          = 1
00040Fr 2               
00040Fr 2               ; Rainbow-Net (homebrew clone of VRC6)
00040Fr 2               ; FAMISTUDIO_EXP_RAINBOW       = 1
00040Fr 2               
00040Fr 2               ; Konami VRC7 (6 FM channels)
00040Fr 2               ; FAMISTUDIO_EXP_VRC7          = 1
00040Fr 2               
00040Fr 2               ; Nintendo MMC5 (2 extra squares, extra DPCM not supported)
00040Fr 2               ; FAMISTUDIO_EXP_MMC5          = 1
00040Fr 2               
00040Fr 2               ; Sunsoft S5B (3 extra squares, advanced features not supported.)
00040Fr 2               ; FAMISTUDIO_EXP_S5B           = 1
00040Fr 2               
00040Fr 2               ; Famicom Disk System (extra wavetable channel)
00040Fr 2               ; FAMISTUDIO_EXP_FDS           = 1
00040Fr 2               
00040Fr 2               ; Namco 163 (between 1 and 8 extra wavetable channels) + number of channels.
00040Fr 2               ; FAMISTUDIO_EXP_N163          = 1
00040Fr 2               ; FAMISTUDIO_EXP_N163_CHN_CNT  = 4
00040Fr 2               
00040Fr 2               ; EPSM (Expansion Port Sound Module)
00040Fr 2               ; FAMISTUDIO_EXP_EPSM          = 1
00040Fr 2               ; Fine-tune control for enabling specific channels
00040Fr 2               ; Default values for the channels are to enable all channels.
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT     = 3
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_FM_CHN_CNT      = 6
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_RHYTHM_CHN1_ENABLE = 1
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_RHYTHM_CHN2_ENABLE = 1
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_RHYTHM_CHN3_ENABLE = 1
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_RHYTHM_CHN4_ENABLE = 1
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_RHYTHM_CHN5_ENABLE = 1
00040Fr 2               ; FAMISTUDIO_EXP_EPSM_RHYTHM_CHN6_ENABLE = 1
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; 3) GLOBAL ENGINE CONFIGURATION
00040Fr 2               ;
00040Fr 2               ; These are parameters that configures the engine, but are independent of the data you will be importing, such as
00040Fr 2               ; which platform (PAL/NTSC) you want to support playback for, whether SFX are enabled or not, etc. They all have the
00040Fr 2               ; form FAMISTUDIO_CFG_XXX.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               ; One of these MUST be defined (PAL or NTSC playback). Note that only NTSC support is supported when using any of the audio expansions.
00040Fr 2               FAMISTUDIO_CFG_PAL_SUPPORT   = 1
00040Fr 2               FAMISTUDIO_CFG_NTSC_SUPPORT  = 1
00040Fr 2               
00040Fr 2               ; Support for sound effects playback + number of SFX that can play at once.
00040Fr 2               FAMISTUDIO_CFG_SFX_SUPPORT   = 1
00040Fr 2               FAMISTUDIO_CFG_SFX_STREAMS   = 1
00040Fr 2               
00040Fr 2               ; Blaarg's smooth vibrato technique. Eliminates phase resets ("pops") on square channels.
00040Fr 2               FAMISTUDIO_CFG_SMOOTH_VIBRATO = 1
00040Fr 2               
00040Fr 2               ; Enables DPCM playback support.
00040Fr 2               FAMISTUDIO_CFG_DPCM_SUPPORT   = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if you are calling sound effects from a different thread than the sound engine update.
00040Fr 2               FAMISTUDIO_CFG_THREAD         = 1
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; 4) SUPPORTED FEATURES CONFIGURATION
00040Fr 2               ;
00040Fr 2               ; Every feature supported in FamiStudio is supported by this sound engine. If you know for sure that you are not using
00040Fr 2               ; specific features in your music, you can disable them to save memory/processing time. Using a feature in your song
00040Fr 2               ; and failing to enable it will likely lead to crashes (BRK), or undefined behavior. They all have the form
00040Fr 2               ; FAMISTUDIO_USE_XXX.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
00040Fr 2               ; Must be enabled if the songs you will be importing have been created using FamiTracker tempo mode. If you are using
00040Fr 2               ; FamiStudio tempo mode, this must be undefined. You cannot mix and match tempo modes, the engine can only run in one
00040Fr 2               ; mode or the other.
00040Fr 2               ; More information at: https://famistudio.org/doc/song/#tempo-modes
00040Fr 2               FAMISTUDIO_USE_FAMITRACKER_TEMPO = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if the songs uses delayed notes or delayed cuts. This is obviously only available when using
00040Fr 2               ; FamiTracker tempo mode as FamiStudio tempo mode does not need this.
00040Fr 2               FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if the songs uses release notes.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#release-point
00040Fr 2               FAMISTUDIO_USE_RELEASE_NOTES = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses the volume track. The volume track allows manipulating the volume at the track level
00040Fr 2               ; independently from instruments.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#editing-volume-tracks-effects
00040Fr 2               FAMISTUDIO_USE_VOLUME_TRACK      = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses slides on the volume track. Volume track must be enabled too.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#editing-volume-tracks-effects
00040Fr 2               FAMISTUDIO_USE_VOLUME_SLIDES     = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses the pitch track. The pitch track allows manipulating the pitch at the track level
00040Fr 2               ; independently from instruments.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#pitch
00040Fr 2               FAMISTUDIO_USE_PITCH_TRACK       = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses slide notes. Slide notes allows portamento and slide effects.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#slide-notes
00040Fr 2               FAMISTUDIO_USE_SLIDE_NOTES       = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses slide notes on the noise channel too.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#slide-notes
00040Fr 2               FAMISTUDIO_USE_NOISE_SLIDE_NOTES = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses the vibrato speed/depth effect track.
00040Fr 2               ; More information at: https://famistudio.org/doc/pianoroll/#vibrato-depth-speed
00040Fr 2               FAMISTUDIO_USE_VIBRATO           = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses arpeggios (not to be confused with instrument arpeggio envelopes, those are always
00040Fr 2               ; supported).
00040Fr 2               ; More information at: (TODO)
00040Fr 2               FAMISTUDIO_USE_ARPEGGIO          = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses the "Duty Cycle" effect (equivalent of FamiTracker Vxx, also called "Timbre").
00040Fr 2               FAMISTUDIO_USE_DUTYCYCLE_EFFECT  = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if any song uses the DPCM delta counter. Only makes sense if DPCM samples
00040Fr 2               ; are enabled (FAMISTUDIO_CFG_DPCM_SUPPORT).
00040Fr 2               ; More information at: (TODO)
00040Fr 2               FAMISTUDIO_USE_DELTA_COUNTER     = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if your project uses more than 1 bank of DPCM samples.
00040Fr 2               ; When using this, you must implement the "famistudio_dpcm_bank_callback" callback
00040Fr 2               ; and switch to the correct bank every time a sample is played.
00040Fr 2               FAMISTUDIO_USE_DPCM_BANKSWITCHING = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if your project uses more than 63 unique DPCM mappings (a mapping is DPCM sample
00040Fr 2               ; assigned to a note, with a specific pitch/loop, etc.). Implied when using FAMISTUDIO_USE_DPCM_BANKSWITCHING.
00040Fr 2               ; FAMISTUDIO_USE_DPCM_EXTENDED_RANGE = 1
00040Fr 2               
00040Fr 2               ; Allows having up to 256 instrument at the cost of slightly higher CPU usage when switching instrument.
00040Fr 2               ; When this is off, the limit is 64 for regular instruments and 32 for expansion instrumnets.
00040Fr 2               ; FAMISTUDIO_USE_INSTRUMENT_EXTENDED_RANGE = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if your project uses the "Phase Reset" effect.
00040Fr 2               FAMISTUDIO_USE_PHASE_RESET = 1
00040Fr 2               
00040Fr 2               ; Must be enabled if your project uses the FDS expansion and at least one instrument with FDS Auto-Mod enabled.
00040Fr 2               ; FAMISTUDIO_USE_FDS_AUTOMOD  = 1
00040Fr 2               
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               ; Memory location of the DPCM samples. Must be between $c000 and $ffc0, and a multiple of 64.
00040Fr 2               .ifndef FAMISTUDIO_DPCM_OFF
00040Fr 2                   FAMISTUDIO_DPCM_OFF = $c000
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               ;======================================================================================================================
00040Fr 2               ; END OF CONFIGURATION
00040Fr 2               ;
00040Fr 2               ; Ideally, you should not have to change anything below this line.
00040Fr 2               ;======================================================================================================================
00040Fr 2               
