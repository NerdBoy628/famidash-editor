0000DCr 2  xx xx xx xx  famistudio_chn_env_override:      .res FAMISTUDIO_NUM_CHANNELS ; bit 7 = pitch, bit 0 = arpeggio.
0000E0r 2  xx           
0000E1r 2               .endif
0000E1r 2               .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
0000E1r 2  xx xx xx xx  famistudio_chn_note_delay:        .res FAMISTUDIO_NUM_CHANNELS
0000E5r 2  xx           
0000E6r 2  xx xx xx xx  famistudio_chn_cut_delay:         .res FAMISTUDIO_NUM_CHANNELS
0000EAr 2  xx           
0000EBr 2               .endif
0000EBr 2               .if FAMISTUDIO_CFG_EQUALIZER
0000EBr 2               famistudio_chn_note_counter:      .res FAMISTUDIO_NUM_CHANNELS
0000EBr 2               .endif
0000EBr 2               .if FAMISTUDIO_USE_PHASE_RESET
0000EBr 2  xx           famistudio_phase_reset:           .res 1 ; bit 0/1 = 2a03, bit 2/3/4 = vrc6, 5/6 = mmc5, bit 7 = fds
0000ECr 2               .if FAMISTUDIO_EXP_N163
0000ECr 2               famistudio_phase_reset_n163:      .res 1 ; bit 0...7 = n163
0000ECr 2               .endif
0000ECr 2               .endif
