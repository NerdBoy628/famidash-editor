000100r 2               ; FDS, N163 and VRC7 have very different instrument layout and are 16-bytes, so we keep them seperate.
000100r 2               .if FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_S5B
