00001Fr 4               COL_SLOPE_LU66_BOT = $1e
00001Fr 4               COL_SLOPE_RU66_BOT = $1d
00001Fr 4               COL_SLOPE_LU66_TOP = $1c
00001Fr 4               COL_SLOPE_RU66_TOP = $1b
00001Fr 4               COL_SLOPE_LU22_RIGHT = $1a
00001Fr 4               COL_SLOPE_LU22_LEFT = $19
00001Fr 4               COL_SLOPE_RU22_RIGHT = $18
00001Fr 4               COL_SLOPE_RU22_LEFT = $17
00001Fr 4               COL_SLOPE_LU45 = $16
00001Fr 4               COL_SLOPE_RU45 = $15
00001Fr 4               COL_SLOPE_LD66_BOT = $14
00001Fr 4               COL_SLOPE_RD66_BOT = $13
00001Fr 4               COL_SLOPE_LD66_TOP = $12
