00005Br 2               ;uint8_t __fastcall__ check_collision(void * object1, void * object2);
00005Br 2               ; __check_collision:
00005Br 2               _check_collision:
00005Br 2               	; sprite object collision code
00005Br 2               	; this would work with any size struct, as long as the first 4 bytes are...
00005Br 2               	; x, y, width, height
00005Br 2               	; note PTR is the same as TEMP and TEMP+1
00005Br 2               
00005Br 2               	; sta PTR
00005Br 2               	; stx PTR+1 ;set up a pointer to the first object
00005Br 2               	; jsr popax
00005Br 2               	; sta sreg
00005Br 2               	; stx sreg+1 ;set up a pointer to the second object
00005Br 2               
00005Br 2               
00005Br 2               	; ldy #0
00005Br 2               	; lda (PTR),y
00005Br 2               	; sta TEMP+4  	;X 1
00005Br 2               	; lda (sreg), y
00005Br 2               	; sta TEMP+6		;X 2
00005Br 2               	; iny
00005Br 2               	; iny
00005Br 2               	; lda (PTR),y
00005Br 2               	; sta TEMP+5 		;width1
00005Br 2               	; lda (sreg), y
00005Br 2               	; sta TEMP+7		;width2
00005Br 2               
00005Br 2               
00005Br 2               ;see if they are colliding x
00005Br 2               
00005Br 2               ;first check if obj1 R (obj1 x + width) < obj2 L
00005Br 2               
00005Br 2  AD rr rr     	lda _Generic+0	; X 1
00005Er 2  18           	clc
00005Fr 2  6D rr rr     	adc _Generic+2 ;width 1
000062r 2  B0 05        	bcs :+
000064r 2  CD rr rr     		cmp _Generic2+0 ;X 2
000067r 2  90 2F        		bcc @no
000069r 2                	:
000069r 2               
000069r 2               ;now check if obj1 L > obj2 R (obj2 x + width)
000069r 2               
000069r 2  AD rr rr     	lda _Generic2+0 ;X 2
00006Cr 2  18           	clc
00006Dr 2  6D rr rr     	adc _Generic2+2 ;width 2
000070r 2  B0 05        	bcs :+
000072r 2  CD rr rr     		cmp _Generic+0 ;X 1
000075r 2  90 21        		bcc @no
000077r 2               	:
000077r 2               
000077r 2               
000077r 2               ;repeat process with y
000077r 2               	; ldy #1
000077r 2               	; lda (PTR),y
000077r 2               	; sta TEMP+4  		;Y 1
000077r 2               	; lda (sreg), y
000077r 2               	; sta TEMP+6		;Y 2
000077r 2               	; iny
000077r 2               	; iny
000077r 2               	; lda (PTR),y
000077r 2               	; sta TEMP+5 		;height1
000077r 2               	; lda (sreg), y
000077r 2               	; sta TEMP+7		;height2
000077r 2               
000077r 2               ;see if they are colliding y
000077r 2               
000077r 2               ;first check if obj1 Bottom (obj1 y + height) < obj2 Top
000077r 2               
000077r 2  AD rr rr     	lda _Generic+1 ;Y 1
00007Ar 2  18           	clc
00007Br 2  6D rr rr     	adc _Generic+3 ;height 1
00007Er 2  B0 05        	bcs :+
000080r 2  CD rr rr     		cmp _Generic2+1 ;Y 2
000083r 2  90 13        		bcc @no
000085r 2               	:
000085r 2               
000085r 2               ;now check if obj1 Top > obj2 Bottom (obj2 y + height)
000085r 2               
000085r 2  AD rr rr     	lda _Generic2+1 ;Y 2
000088r 2  18           	clc
000089r 2  6D rr rr     	adc _Generic2+3 ;height 2
00008Cr 2  B0 05        	bcs @yes
00008Er 2  CD rr rr     		cmp _Generic+1 ;Y 1
000091r 2  90 05        		bcc @no
000093r 2               
000093r 2               
000093r 2               @yes:
000093r 2  A9 01        	lda #1
000095r 2  A2 00        	ldx #0
000097r 2  60           	rts
000098r 2               
000098r 2               @no:
000098r 2  A9 00        	lda #0
