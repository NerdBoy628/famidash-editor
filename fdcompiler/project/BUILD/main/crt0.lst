00040Fr 2               .endif
00040Fr 2               
00040Fr 2               .ifndef FAMISTUDIO_EXP_FDS
00040Fr 2                   FAMISTUDIO_EXP_FDS = 0
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               .ifndef FAMISTUDIO_EXP_N163
00040Fr 2                   FAMISTUDIO_EXP_N163 = 0
