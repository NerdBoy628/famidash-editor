0006BDr 2               .segment "OAMALIGN"
000000r 2               
000000r 2               MOUSE_PORT = CTRL_PORT2
000000r 2               CONTROLLER_PORT = CTRL_PORT1
000000r 2               
000000r 2               .if !VS_SYSTEM ; not used for the VS System version of the game fsr
000000r 2               
000000r 2               .proc oam_and_readjoypad
000000r 2               	; save the previous controller state for calcuating the previous results
000000r 2  A5 rr        	lda joypad1
000002r 2  85 rr        	sta TEMP + 4
000004r 2               
000004r 2               	; and do the same for the controller 2
000004r 2  A5 rr        	lda joypad2
000006r 2  85 rr        	sta TEMP + 5
000008r 2               
000008r 2               	; Save the previous mouse state so we can calculate the next frames press/release
000008r 2  A5 rr        	lda mouse + kMouseY
00000Ar 2  85 rr        	sta TEMP + 0
00000Cr 2  A5 rr        	lda mouse + kMouseX
00000Er 2  85 rr        	sta TEMP + 1
000010r 2  A5 rr        	lda mouse + kMouseButtons
000012r 2  85 rr        	sta TEMP + 2
000014r 2               
000014r 2               	; Strobe the joypads.
000014r 2  A2 00        	LDX #$00
000016r 2  A0 01        	LDY #$01
000018r 2  84 rr        	STY mouse
00001Ar 2  8C 16 40     	STY CTRL_PORT1
00001Dr 2               
00001Dr 2                .if 0
00001Dr 2               	; Clock official mouse sensitivity. NOTE: This can be removed if not needed.
00001Dr 2               	LDA advance_sensitivity
00001Dr 2               	BEQ :+
00001Dr 2               	LDA MOUSE_PORT
00001Dr 2               	STX advance_sensitivity
00001Dr 2                :
00001Dr 2                .endif
00001Dr 2               
00001Dr 2  8E 16 40     	STX CTRL_PORT1
000020r 2               
000020r 2  A9 rr        	LDA #>OAM_BUF
000022r 2  8D 14 40     	STA PPU_OAM_DMA
000025r 2               
000025r 2               	; Desync cycles: 432, 576, 672, 848, 432*2-4 (860)
000025r 2               
000025r 2               	; DMC DMA:         ; PUT GET PUT GET        ; Starts: 0
000025r 2               
000025r 2                :
000025r 2  A5 rr        	LDA mouse_mask     ; get put get*     *576  ; Starts: 4, 158, 312, 466, [620]
000027r 2  2D 17 40     	AND MOUSE_PORT   ; put get put GET
00002Ar 2  C9 01        	CMP #$01           ; put get
00002Cr 2  36 rr        	ROL mouse,X        ; put get put get* PUT GET  *432
00002Er 2  90 F5        	BCC :-             ; put get (put)
000030r 2               
000030r 2  E8           	INX                ; put get
000031r 2  E0 04        	CPX #$04           ; put get
000033r 2  94 rr        	STY mouse,X        ; put get put GET
000035r 2  D0 EE        	BNE :-             ; put get (put)
000037r 2               
000037r 2                :
000037r 2  AD 16 40     	LDA CONTROLLER_PORT ; put get put GET        ; Starts: 619
00003Ar 2  29 03        	AND #$03           ; put get*         *672
00003Cr 2  C9 01        	CMP #$01           ; put get
00003Er 2  26 rr        	ROL joypad1 ; put get put get put    ; This can desync, but we finish before it matters.
000040r 2  90 F5        	BCC :-             ; get put (get)
000042r 2               
000042r 2                .if 0 ; TODO support SNES extra buttons
000042r 2               	STY joypad1+1 ; get put get
000042r 2               	NOP                ; put get
000042r 2                :
000042r 2               	LDA CONTROLLER_PORT ; put get* put GET *848  ; Starts: 751, [879]
000042r 2               	AND #$03           ; put get
000042r 2               	CMP #$01           ; put get
000042r 2               	ROL joypad1+1 ; put get put get put    ; This can desync, but we finish before it matters.
000042r 2               	BCC :-             ; get* put (get)   *860
000042r 2               
000042r 2               	; NEXT: 878
000042r 2                .endif ; CONTROLLER_SIZE = 2
000042r 2               
000042r 2  60           	rts
000043r 2               .endproc
000043r 2               
000043r 2               .endif
000043r 2               
000043r 2               .segment "STARTUP"
00014Dr 2               
00014Dr 2               .proc calculate_extra_fields
00014Dr 2               	; calculate the press/release state for the controller buttons
00014Dr 2               
00014Dr 2               	; Pressed
00014Dr 2  A5 rr        	lda TEMP+4
00014Fr 2  49 FF        	eor #%11111111
000151r 2  25 rr        	and joypad1
000153r 2  85 rr        	sta joypad1 + 1
000155r 2               
000155r 2               	; Released
000155r 2  A5 rr        	lda joypad1
000157r 2  49 FF        	eor #%11111111
000159r 2  25 rr        	and TEMP+4
00015Br 2  85 rr        	sta joypad1 + 2
00015Dr 2               
00015Dr 2               	; Check the report to see if we have a snes mouse plugged in
00015Dr 2  A5 rr        	lda mouse + kMouseButtons
00015Fr 2  29 0F        	and #$0f
000161r 2  C9 01        	cmp #$01
000163r 2  F0 1D        	beq snes_mouse_detected
000165r 2               		; treat this as a standard NES controller instead and
000165r 2               		; calculate the press/release for it
000165r 2  A5 rr        		lda mouse + kMouseZero
000167r 2  85 rr        		sta joypad2
000169r 2               		; Pressed
000169r 2  A5 rr        		lda TEMP+5
00016Br 2  49 FF        		eor #%11111111
00016Dr 2  25 rr        		and joypad2
00016Fr 2  85 rr        		sta joypad2 + 1
000171r 2               
000171r 2               		; Released
000171r 2  A5 rr        		lda joypad2
000173r 2  49 FF        		eor #%11111111
000175r 2  25 rr        		and TEMP+5
000177r 2  85 rr        		sta joypad2 + 2
000179r 2               
000179r 2               		; no snes mouse, so leave the first field empty
000179r 2  A9 00        		lda #0
00017Br 2  85 rr        		sta mouse + kMouseZero
00017Dr 2  A9 01        	lda #1
00017Fr 2  85 rr        	sta noMouse
000181r 2  60           		rts
000182r 2               snes_mouse_detected:
000182r 2               .if !VS_SYSTEM
000182r 2               	; convert the X/Y displacement into X/Y positions on the screen
000182r 2  A2 01        	ldx #1
000184r 2               loop:
000184r 2  B5 rr        		lda mouse + kMouseY,x
000186r 2  10 16        		bpl :+
000188r 2               			; subtract the negative number instead
000188r 2  29 7F        			and #$7f
00018Ar 2  85 rr        			sta mouse + kMouseZero ; reuse this value as a temp value
00018Cr 2  B5 rr        			lda TEMP,x
00018Er 2  38           			sec
00018Fr 2  E5 rr        			sbc mouse + kMouseZero
000191r 2               			; check if we underflowed
000191r 2  90 05        			bcc wrappednegative
000193r 2               			; check the lower bounds
000193r 2  DD rr rr     			cmp MouseBoundsMin,x
000196r 2  B0 13        			bcs setvalue ; didn't wrap so set the value now
000198r 2               		wrappednegative:
000198r 2  BD rr rr     			lda MouseBoundsMin,x
00019Br 2  4C rr rr     			jmp setvalue
00019Er 2               		:
00019Er 2               		; add the positive number
00019Er 2  18           		clc
00019Fr 2  75 rr        		adc TEMP,x
0001A1r 2               		; check if we wrapped, set to the max bounds if we did
0001A1r 2  B0 05        		bcs wrapped
0001A3r 2               		; check the upper bounds
0001A3r 2  DD rr rr     		cmp MouseBoundsMax,x
0001A6r 2  90 03        		bcc setvalue ; didn't wrap so set the value
0001A8r 2               wrapped:
0001A8r 2  BD rr rr     		lda MouseBoundsMax,x
0001ABr 2               setvalue:
0001ABr 2  95 rr        		sta mouse + kMouseY,x
0001ADr 2  CA           		dex
0001AEr 2  10 D4        		bpl loop
0001B0r 2               	; calculate newly pressed buttons and shift it into byte zero
0001B0r 2  A5 rr        	lda TEMP+2
0001B2r 2  49 C0        	eor #%11000000
0001B4r 2  25 rr        	and mouse + kMouseButtons
0001B6r 2  2A           	rol
0001B7r 2  66 rr        	ror mouse + kMouseZero
0001B9r 2  2A           	rol
0001BAr 2  66 rr        	ror mouse + kMouseZero
0001BCr 2               
0001BCr 2               	; calculate newly released buttons
0001BCr 2  A5 rr        	lda mouse + kMouseButtons
0001BEr 2  49 C0        	eor #%11000000
0001C0r 2  25 rr        	and TEMP+2
0001C2r 2  2A           	rol
0001C3r 2  66 rr        	ror mouse + kMouseZero
0001C5r 2  2A           	rol
0001C6r 2  66 rr        	ror mouse + kMouseZero
0001C8r 2               
0001C8r 2               	; Set the connected bit
0001C8r 2  38           	sec
0001C9r 2  66 rr        	ror mouse + kMouseZero
0001CBr 2               .endif
0001CBr 2  60           	rts
0001CCr 2               
0001CCr 2               MOUSE_Y_MINIMUM = 1
0001CCr 2               MOUSE_X_MINIMUM = 1
0001CCr 2               MOUSE_Y_MAXIMUM = 239
0001CCr 2               MOUSE_X_MAXIMUM = 255
0001CCr 2               
0001CCr 2               MouseBoundsMin:
0001CCr 2  01 01        	.byte MOUSE_Y_MINIMUM, MOUSE_X_MINIMUM
0001CEr 2               MouseBoundsMax:
0001CEr 2  EF FF        	.byte MOUSE_Y_MAXIMUM, MOUSE_X_MAXIMUM
0001D0r 2               .endproc
0001D0r 2               
0001D0r 2               .popseg
0006BDr 2               
0006BDr 2               .import _current_spike_set, _current_block_set, _current_saw_set
0006BDr 2               .import _no_parallax, _parallax_scroll_x, _level
0006BDr 2               .export _set_tile_banks
0006BDr 2               .proc _set_tile_banks
0006BDr 2               	; inlined into ASM so we can call it from NMI
0006BDr 2               
0006BDr 2               	; if no parallax is 1, then it will maybe add an offset to the chr
0006BDr 2               	; other wise it will add 0 (effectively disabling it without branching)
0006BDr 2               
0006BDr 2  A9 01        	lda #1
0006BFr 2  2D rr rr     	and _parallax_scroll_x
0006C2r 2  85 rr        	sta CHRBANK_TEMP
0006C4r 2  18           	clc
0006C5r 2  AD rr rr     	lda _current_spike_set
0006C8r 2  65 rr        	adc CHRBANK_TEMP
0006CAr 2  20 rr rr     	jsr _mmc3_set_1kb_chr_bank_0
0006CDr 2  AD rr rr     	lda _current_block_set
0006D0r 2  65 rr        	adc CHRBANK_TEMP
0006D2r 2  20 rr rr     	jsr _mmc3_set_1kb_chr_bank_1
0006D5r 2  AD rr rr     	lda _current_saw_set
0006D8r 2  C9 6F        	cmp #111
0006DAr 2  F0 02        	beq :+
0006DCr 2  65 rr        		adc CHRBANK_TEMP
0006DEr 2               	:
0006DEr 2  20 rr rr     	jsr _mmc3_set_1kb_chr_bank_3
0006E1r 2               
0006E1r 2               	; and then decide on the last bank
0006E1r 2  AD rr rr     	lda _no_parallax
0006E4r 2  F0 11        	beq @asdf
0006E6r 2               
0006E6r 2               	.ifdef _level_luckydraw
0006E6r 2               		lda _level
0006E6r 2               		cmp #::_level_luckydraw
0006E6r 2               		beq @slop
0006E6r 2               	.endif
0006E6r 2               
0006E6r 2  A9 10        	lda #::_SLOPESA
0006E8r 2  18           	clc
0006E9r 2  65 rr        	adc CHRBANK_TEMP
0006EBr 2  4C rr rr     	jmp _mmc3_set_1kb_chr_bank_2
0006EEr 2  A9 01        	lda #1
0006F0r 2  F0 05        	beq @asdf
0006F2r 2               @slop:
0006F2r 2  A9 10        	lda #::_SLOPESA
0006F4r 2  4C rr rr     	jmp _mmc3_set_1kb_chr_bank_2
0006F7r 2               @asdf:
0006F7r 2  AD rr rr     	lda _parallax_scroll_x
0006FAr 2  69 rr        	adc #<.bank(_PARALLAX_CHR)
0006FCr 2  4C rr rr     	jmp _mmc3_set_1kb_chr_bank_2
0006FFr 2               .endproc
0006FFr 2               
0006FFr 1               	.include "nesdash.s"
0006FFr 2               ; Custom routines implemented specifically for famidash (some are totally not stolen from famitower)
0006FFr 2               .importzp _gamemode
0006FFr 2               .importzp _tmp1, _tmp2, _tmp3, _tmp4, _tmp5, _tmp6, _tmp7, _tmp8, _tmp9  ; C-safe temp storage
0006FFr 2               .import pusha, pushax, callptr4
0006FFr 2               .import _scroll_x, _cursedmusic
0006FFr 2               
0006FFr 2               .if VS_SYSTEM
0006FFr 2               	.import _draw_arrow
0006FFr 2               .endif
0006FFr 2               
0006FFr 2               .macpack longbranch
0006FFr 3               .macro  jeq     Target
0006FFr 3                       .if     .match(Target, 0)
0006FFr 3                       bne     *+5
0006FFr 3                       jmp     Target
0006FFr 3                       .elseif .def(Target) .and .const((*-2)-(Target)) .and ((*+2)-(Target) <= 127)
0006FFr 3                               beq     Target
