000003r 1               ;
000003r 1               ; NES 2.0 header
000003r 1               ;
000003r 1               .segment "HEADER"
000000r 1               
000000r 1                   NES2_0_IDENTIFIER = %00001000
000000r 1               
000000r 1  4E 45 53 1A      .byte 'N', 'E', 'S', $1A ; ID
000004r 1  rr               .byte <PRG_BANK_COUNT
000005r 1  rr               .byte <CHR_BANK_COUNT
000006r 1  rr               .byte <(MIRRORING | (SRAM << 1) | (TRAINER << 2) | ((MAPPER & $00F) << 4))
000007r 1  rr               .byte <((MAPPER & $0F0) | CONSOLE_TYPE | NES2_0_IDENTIFIER)
000008r 1  rr               .byte <(((MAPPER & $F00) >> 8) | SUBMAPPER << 4)
000009r 1  rr               .byte <(((PRG_BANK_COUNT & $F00) >> 8) | ((CHR_BANK_COUNT & $F00) >> 4))
00000Ar 1  rr               .byte <(PRG_RAM_COUNT | (PRG_NVRAM_COUNT << 4))
00000Br 1  rr               .byte <(CHR_RAM_COUNT | (CHR_NVRAM_COUNT << 4))
00000Cr 1  rr rr rr rr      .byte <CPU_PPU_TIMING, <HARDWARE_TYPE, <MISC_ROMS, <DEF_EXP_DEVICE
000010r 1               
000010r 1               .segment "STARTUP"
000000r 1               
000000r 1               start:
000000r 1               _exit:
000000r 1  A9 80        	lda #%10000000					;	Stolen from initialize_mapper
000002r 1  8D 01 A0     	sta MMC3_REG_PRG_RAM_PROTECT	;__
000005r 1  A5 00            lda $00
000007r 1  8D FE 7F         sta $7FFE
00000Ar 1  A5 01            lda $01
00000Cr 1  8D FF 7F         sta $7FFF
00000Fr 1               
00000Fr 1               
00000Fr 1  78               sei
000010r 1  D8           	cld
000011r 1  A2 40        	ldx #$40
000013r 1  8E 17 40     	stx CTRL_PORT2
000016r 1  A2 FF            ldx #$ff
000018r 1  9A               txs
000019r 1  E8               inx
00001Ar 1  8E 01 20         stx PPU_MASK
00001Dr 1  8E 10 40         stx DMC_FREQ
000020r 1  8E 00 20         stx PPU_CTRL		;no NMI
000023r 1               
000023r 1               initPPU_first:		;
000023r 1  2C 02 20         bit PPU_STATUS	;
000026r 1               @1:					;	Wait out the first frame
000026r 1  2C 02 20         bit PPU_STATUS	;
000029r 1  10 FB            bpl @1			;__
00002Br 1               
00002Br 1               ; We now have about 30,000 cycles to burn before the PPU stabilizes.
00002Br 1               ; One thing we can do with this time is put RAM in a known state.
00002Br 1               ; Here we fill it with $00, which matches what (say) a C compiler
00002Br 1               ; expects for BSS.  Conveniently, X is still 0.
00002Br 1               
00002Br 1               initRNG:
00002Br 1  AD rr rr     	lda _donotresetrng
00002Er 1  C9 01        	cmp #1
000030r 1  D0 1C        	bne @setseed
000032r 1  A5 rr        	lda RAND_SEED
000034r 1  8D rr rr     	sta aart_lz_buffer
000037r 1  A5 rr        	lda RAND_SEED+1
000039r 1  8D rr rr     	sta aart_lz_buffer+1
00003Cr 1  A5 rr        	lda RAND_SEED+2
00003Er 1  8D rr rr     	sta aart_lz_buffer+2
000041r 1  A5 rr        	lda RAND_SEED+3
000043r 1  8D rr rr     	sta aart_lz_buffer+3
000046r 1  A5 rr        	lda RAND_SEED+4
000048r 1  8D rr rr     	sta aart_lz_buffer+4
00004Br 1  4C rr rr     	jmp clearRAM
00004Er 1               
00004Er 1               @setseed:
00004Er 1  A5 FC        	lda $FC
000050r 1  D0 02        	bne @cont1
000052r 1               @fallback1:
000052r 1  A9 FD        	lda #$FD
000054r 1               @cont1:
000054r 1  8D rr rr     	sta aart_lz_buffer
000057r 1  A5 FD        	lda $FD
000059r 1  D0 02        	bne @cont2
00005Br 1               @fallback2:
00005Br 1  A9 FD        	lda #$FD
00005Dr 1               @cont2:
00005Dr 1  8D rr rr     	sta aart_lz_buffer+1
000060r 1  A5 FE        	lda $FE
000062r 1  D0 02        	bne @cont3
000064r 1               @fallback3:
000064r 1  A9 FD        	lda #$FD
000066r 1               @cont3:
000066r 1  8D rr rr     	sta aart_lz_buffer+2
000069r 1  A5 FF        	lda $FF
00006Br 1  D0 02            bne @cont4
00006Dr 1               @fallback4:
00006Dr 1  A9 FD        	lda #$FD
00006Fr 1               @cont4:
00006Fr 1  8D rr rr     	sta aart_lz_buffer+3
000072r 1  A5 FB        	lda $FB
000074r 1  D0 02            bne @cont5
000076r 1               @fallback5:
000076r 1  A9 FD        	lda #$FD
000078r 1               @cont5:
000078r 1  8D rr rr     	sta aart_lz_buffer+4
00007Br 1               
00007Br 1               clearRAM:
00007Br 1  8A               txa
00007Cr 1               @1:
00007Cr 1  95 00            sta $00,x   ;
00007Er 1  9D 00 01         sta $0100,x ;
000081r 1  9D 00 02         sta $0200,x ;
000084r 1  9D 00 03         sta $0300,x ;   Clear regular NES RAM
000087r 1  9D 00 04         sta $0400,x ;
00008Ar 1  9D 00 05         sta $0500,x ;
00008Dr 1  9D 00 06         sta $0600,x ;
000090r 1  9D 00 07         sta $0700,x ;__
000093r 1  9D 00 60     	sta $6000,x ;
000096r 1  9D 00 61     	sta $6100,x ;   Clear the collision map space
000099r 1  9D 00 62         sta $6200,x ;
00009Cr 1  9D 00 63     	sta $6300,x ;__
00009Fr 1  E8               inx
0000A0r 1  D0 DA            bne @1
0000A2r 1               
0000A2r 1  85 rr            sta	framerate
0000A4r 1  85 rr            sta	cpuRegion
0000A6r 1               
0000A6r 1  AD rr rr     	lda aart_lz_buffer
0000A9r 1  85 rr        	sta RAND_SEED
0000ABr 1  AD rr rr     	lda aart_lz_buffer+1
0000AEr 1  85 rr        	sta RAND_SEED+1
0000B0r 1  AD rr rr     	lda aart_lz_buffer+2
0000B3r 1  85 rr        	sta RAND_SEED+2
0000B5r 1  AD rr rr     	lda aart_lz_buffer+3
0000B8r 1  85 rr        	sta RAND_SEED+3
0000BAr 1  AD rr rr     	lda aart_lz_buffer+4
0000BDr 1  85 rr        	sta RAND_SEED+4
0000BFr 1               
0000BFr 1  A9 01        	lda #1
0000C1r 1  8D rr rr     	sta _donotresetrng
0000C4r 1               
0000C4r 1  20 rr rr     	jsr initialize_mapper
0000C7r 1               
0000C7r 1               	; jsr	zerobss	; Unnecessary, we already zeroed out the entire memory
0000C7r 1               	; jsr	copydata	; Sets all the initial values of variables
0000C7r 1               
0000C7r 1  A9 rr            lda #<(__C_STACK_START__+__C_STACK_SIZE__) ;changed
0000C9r 1  85 rr            sta	sp
0000CBr 1  A9 rr            lda	#>(__C_STACK_START__+__C_STACK_SIZE__)
0000CDr 1  85 rr            sta	sp+1            ; Set argument stack ptr
0000CFr 1               
0000CFr 1               	; jsr	initlib	; removed. this called the CONDES function
0000CFr 1               
0000CFr 1               
0000CFr 1               initPPU_second:
0000CFr 1               @1:
0000CFr 1  2C 02 20         bit PPU_STATUS
0000D2r 1  10 FB            bpl @1
0000D4r 1               
0000D4r 1               clearPalette:
0000D4r 1  A9 3F        	lda #$3f
0000D6r 1  8D 06 20     	sta PPU_ADDR
0000D9r 1  8E 06 20     	stx PPU_ADDR
0000DCr 1  A9 0F        	lda #$0f
0000DEr 1  A2 20        	ldx #$20
0000E0r 1               @1:
0000E0r 1  8D 07 20     	sta PPU_DATA
0000E3r 1  CA           	dex
0000E4r 1  D0 FA        	bne @1
0000E6r 1               
0000E6r 1               clearVRAM:
0000E6r 1  8A           	txa
0000E7r 1  A0 20        	ldy #$20
0000E9r 1  8C 06 20     	sty PPU_ADDR
0000ECr 1  8D 06 20     	sta PPU_ADDR
0000EFr 1  A0 10        	ldy #$10
0000F1r 1               @1:
0000F1r 1  8D 07 20     	sta PPU_DATA
0000F4r 1  E8           	inx
0000F5r 1  D0 FA        	bne @1
0000F7r 1  88           	dey
0000F8r 1  D0 F7        	bne @1
0000FAr 1               
0000FAr 1  A9 04        	lda #4
0000FCr 1  20 rr rr     	jsr _pal_bright
0000FFr 1  20 rr rr     	jsr _pal_clear
000102r 1  20 rr rr     	jsr _oam_clear
000105r 1               
000105r 1  A9 A0        	lda #%10100000
000107r 1  85 rr        	sta <PPU_CTRL_VAR
000109r 1  8D 00 20     	sta PPU_CTRL		;enable NMI
00010Cr 1  A9 06        	lda #%00000110
00010Er 1  85 rr        	sta <PPU_MASK_VAR
000110r 1               
000110r 1  20 rr rr     	jsr	getTVSystem		;	0 = NTSC, 1 = PAL, 2 = Dendy, 3 = unknown
000113r 1  85 rr        	sta	fullRegion		;
000115r 1  8D rr rr     	sta	trueFullRegion	;__
000118r 1  49 03        	eor	#3				;__ 0 = unknown, 1 = Dendy, 2 = PAL, 3 = NTSC
00011Ar 1  C9 03        	cmp	#3				;
00011Cr 1  2E rr rr     	rol	trueFramerate	;	Set framerate to 1 if value <= NTSC
00011Fr 1  C9 03        	cmp	#3				;	(so 50Hz systems - PAL, Dendy and unknown get 0)
000121r 1  26 rr        	rol	framerate		;__
000123r 1  29 01        	and	#1				;	Set framerate to the last bit of the value
000125r 1  85 rr        	sta	cpuRegion		;	(so 1 = NTSC / Dendy, 0 = PAL / unknown)
000127r 1  8D rr rr     	sta	trueCpuRegion	;__
00012Ar 1               	;__	As a result of the code above, an unknown region will behave like PAL
00012Ar 1               
00012Ar 1  20 rr rr     	jsr _ppu_off
00012Dr 1               
00012Dr 1               init_famistudio:
00012Dr 1  A9 FF        	LDA #<-1			;   Do famistudio_init
00012Fr 1  20 rr rr         JSR _music_play		;__
000132r 1  20 rr rr         JSR	famistudio_music_stop
000135r 1               
000135r 1  A9 rr            LDA #<.bank(sounds)
000137r 1  20 rr rr         JSR mmc3_tmp_prg_bank_1
00013Ar 1               
00013Ar 1  A2 rr        	ldx #<sounds
00013Cr 1  A0 rr        	ldy #>sounds
00013Er 1  20 rr rr     	jsr famistudio_sfx_init
000141r 1               
000141r 1               finish:
000141r 1  A9 00        	lda #0
000143r 1  8D 05 20     	sta PPU_SCROLL
000146r 1  8D 05 20     	sta PPU_SCROLL
000149r 1               
000149r 1  58               cli
00014Ar 1               
00014Ar 1  4C rr rr     	jmp _main			;no parameters
00014Dr 1               
00014Dr 1               	.include "get_tv_system.s"
00014Dr 2               ;
00014Dr 2               ; NES TV system detection code
00014Dr 2               ; Copyright 2011 Damian Yerrick
00014Dr 2               ;
00014Dr 2               ; Copying and distribution of this file, with or without
00014Dr 2               ; modification, are permitted in any medium without royalty provided
00014Dr 2               ; the copyright notice and this notice are preserved in all source
00014Dr 2               ; code copies.  This file is offered as-is, without any warranty.
00014Dr 2               ;
00014Dr 2               .export getTVSystem
00014Dr 2               nmis := FRAME_CNT
00014Dr 2               
00014Dr 2               .segment "TVDETECT"
000000r 2               
000000r 2               .align 32  ; ensure that branches do not cross a page boundary
000000r 2               
000000r 2               ;;
000000r 2               ; Detects which of NTSC, PAL, or Dendy is in use by counting cycles
000000r 2               ; between NMIs.
000000r 2               ;
000000r 2               ; NTSC NES produces 262 scanlines, with 341/3 CPU cycles per line.
000000r 2               ; PAL NES produces 312 scanlines, with 341/3.2 CPU cycles per line.
000000r 2               ; Its vblank is longer than NTSC, and its CPU is slower.
000000r 2               ; Dendy is a Russian famiclone distributed by Steepler that uses the
000000r 2               ; PAL signal with a CPU as fast as the NTSC CPU.  Its vblank is as
000000r 2               ; long as PAL's, but its NMI occurs toward the end of vblank (line
000000r 2               ; 291 instead of 241) so that cycle offsets from NMI remain the same
000000r 2               ; as NTSC, keeping Balloon Fight and any game using a CPU cycle-
000000r 2               ; counting mapper (e.g. FDS, Konami VRC) working.
000000r 2               ;
000000r 2               ; nmis is a variable that the NMI handler modifies every frame.
000000r 2               ; Make sure your NMI handler finishes within 1500 or so cycles (not
000000r 2               ; taking the whole NMI or waiting for sprite 0) while calling this,
000000r 2               ; or the result in A will be wrong.
000000r 2               ;
000000r 2               ; @return A: TV system (0: NTSC, 1: PAL, 2: Dendy; 3: unknown
000000r 2               ;         Y: high byte of iterations used (1 iteration = 11 cycles)
000000r 2               ;         X: low byte of iterations used
000000r 2               .proc getTVSystem
000000r 2  A2 00            ldx #0
000002r 2  A0 00            ldy #0
000004r 2  A5 rr            lda nmis
000006r 2               nmiwait1:
000006r 2  C5 rr            cmp nmis
000008r 2  F0 FC            beq nmiwait1
00000Ar 2  A5 rr            lda nmis
00000Cr 2               
00000Cr 2               nmiwait2:
00000Cr 2                   ; Each iteration takes 11 cycles.
00000Cr 2                   ; NTSC NES: 29780 cycles or 2707 = $A93 iterations
00000Cr 2                   ; PAL NES:  33247 cycles or 3022 = $BCE iterations
00000Cr 2                   ; Dendy:    35464 cycles or 3224 = $C98 iterations
00000Cr 2                   ; so we can divide by $100 (rounding down), subtract ten,
00000Cr 2                   ; and end up with 0=ntsc, 1=pal, 2=dendy, 3=unknown
00000Cr 2  E8               inx
00000Dr 2  D0 01            bne :+
00000Fr 2  C8               iny
000010r 2               :
000010r 2  C5 rr            cmp nmis
000012r 2  F0 F8            beq nmiwait2
000014r 2  98               tya
000015r 2  38               sec
000016r 2  E9 0A            sbc #10
000018r 2  C9 03            cmp #3
00001Ar 2  90 02            bcc notAbove3
00001Cr 2  A9 03            lda #3
00001Er 2               notAbove3:
00001Er 2  60               rts
00001Fr 2               .endproc
00001Fr 2               
00001Fr 1               .if !__THE_ALBUM
00001Fr 1               	.include "METATILES/metatiles.s"
00001Fr 2               
00001Fr 2               .include "metatiles.inc"
00001Fr 3               .include "metatiles_macro.inc"
00001Fr 4               
