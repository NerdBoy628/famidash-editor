00040Fr 2               .endif
00040Fr 2               
00040Fr 2               .if FAMISTUDIO_USE_DPCM_BANKSWITCHING && (FAMISTUDIO_CFG_DPCM_SUPPORT = 0)
00040Fr 2                   .error "DPCM bankswitching only makes sense if DPCM samples are enabled."
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               ; This is the best way i found to test if a C-style macro is defined or not...
00040Fr 2               .if .xmatch(.string(FAMISTUDIO_CA65_ZP_SEGMENT), "FAMISTUDIO_CA65_ZP_SEGMENT")
00040Fr 2                   .error "You must .define FAMISTUDIO_CA65_ZP_SEGMENT with the name of your zeropage segment."
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               .if .xmatch(.string(FAMISTUDIO_CA65_RAM_SEGMENT), "FAMISTUDIO_CA65_RAM_SEGMENT")
00040Fr 2                   .error "You must .define FAMISTUDIO_CA65_RAM_SEGMENT with the name of your RAM/BSS segment."
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               .if .xmatch(.string(FAMISTUDIO_CA65_CODE_SEGMENT), "FAMISTUDIO_CA65_CODE_SEGMENT")
00040Fr 2                   .error "You must .define FAMISTUDIO_CA65_CODE_SEGMENT with the name of your CODE/PRG segment."
00040Fr 2               .endif
00040Fr 2               
00040Fr 2               FAMISTUDIO_DPCM_PTR = (FAMISTUDIO_DPCM_OFF & $3fff) >> 6
00040Fr 2               
00040Fr 2               .if FAMISTUDIO_EXP_NONE
00040Fr 2                   FAMISTUDIO_NUM_ENVELOPES        = 3+3+2+3
00040Fr 2                   FAMISTUDIO_NUM_PITCH_ENVELOPES  = 3
00040Fr 2                   FAMISTUDIO_NUM_CHANNELS         = 5
00040Fr 2                   FAMISTUDIO_NUM_DUTY_CYCLES      = 3
00040Fr 2               .endif
00040Fr 2               .if FAMISTUDIO_EXP_VRC6
00040Fr 2                   FAMISTUDIO_NUM_ENVELOPES        = 3+3+2+3+3+3+3
00040Fr 2                   FAMISTUDIO_NUM_PITCH_ENVELOPES  = 6
00040Fr 2                   FAMISTUDIO_NUM_CHANNELS         = 8
00040Fr 2                   FAMISTUDIO_NUM_DUTY_CYCLES      = 6
00040Fr 2               .endif
00040Fr 2               .if FAMISTUDIO_EXP_VRC7
00040Fr 2                   FAMISTUDIO_NUM_ENVELOPES        = 3+3+2+3+2+2+2+2+2+2
00040Fr 2                   FAMISTUDIO_NUM_PITCH_ENVELOPES  = 9
00040Fr 2                   FAMISTUDIO_NUM_CHANNELS         = 11
00040Fr 2                   FAMISTUDIO_NUM_DUTY_CYCLES      = 3
00040Fr 2               .endif
