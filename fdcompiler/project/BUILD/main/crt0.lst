000793r 2                   sta famistudio_chn_vrc7_trigger-FAMISTUDIO_VRC7_CH0_IDX,x ; Set release flag for VRC7
000793r 2               .endif
000793r 2               
000793r 2               .if FAMISTUDIO_EXP_FDS
000793r 2               @opcode_fds_release_note:
