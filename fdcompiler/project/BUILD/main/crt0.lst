0005C6r 2               	; sreg = len
0005C6r 2               	; xargs[0:1] = dst
0005C6r 2               
0005C6r 2  A2 00        	ldx #0
0005C8r 2               
0005C8r 2               @hi_loop:
0005C8r 2               
0005C8r 2  E4 rr        	cpx sreg+1	; x is always 0 at this point
0005CAr 2  F0 0A        	beq @lo_start
0005CCr 2  20 rr rr     	jsr @fill_start
0005CFr 2  C6 rr        	dec sreg+1
0005D1r 2  E6 rr        	inc xargs+1
0005D3r 2  4C rr rr     	jmp @hi_loop
0005D6r 2               
0005D6r 2               @lo_start:
0005D6r 2               
0005D6r 2  A6 rr        	ldx sreg
0005D8r 2  F0 08        	beq @end
0005DAr 2               
0005DAr 2               @fill_start:
0005DAr 2               
0005DAr 2  A0 00        	ldy #0
0005DCr 2               
0005DCr 2               @fill_loop:
0005DCr 2               
0005DCr 2  91 rr        	sta (xargs),y
0005DEr 2  C8           	iny
0005DFr 2  CA           	dex
0005E0r 2  D0 FA        	bne @fill_loop
0005E2r 2               
0005E2r 2               @end:
0005E2r 2               
0005E2r 2  60           	rts
