0000EDr 2               famistudio_s5b_env_period_hi:     .res 1
0000EDr 2               famistudio_s5b_env_override:      .res 1 ; if non zero, it means we had an env period effect this frame.
0000EDr 2               famistudio_s5b_chn_env_shape:     .res 3 ; bit 7 = note attack
0000EDr 2               famistudio_s5b_chn_env_octave:    .res 3
0000EDr 2               .endif
0000EDr 2               .if FAMISTUDIO_USE_DUTYCYCLE_EFFECT
