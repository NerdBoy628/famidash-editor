000038r 2  A9 04                lda #MMC3_REG_SEL_1KB_CHR_2
00003Ar 2  D0 D8                BNE mmc3_internal_set_bank  ; BRA
00003Cr 2                   .export _mmc3_set_1kb_chr_bank_2
00003Cr 2               
