0000EDr 2               .endif
0000EDr 2               .if FAMISTUDIO_EXP_VRC6
0000EDr 2               famistudio_vrc6_saw_volume:       .res 1 ; -1 = 1/4, 0 = 1/2, 1 = Full
0000EDr 2               .if FAMISTUDIO_USE_PHASE_RESET
0000EDr 2               famistudio_vrc6_pulse1_prev_hi:   .res 1
0000EDr 2               famistudio_vrc6_pulse2_prev_hi:   .res 1
0000EDr 2               famistudio_vrc6_saw_prev_hi:      .res 1
0000EDr 2               .else
0000EDr 2               famistudio_vrc6_pulse1_prev_hi = famistudio_vrc6_saw_volume
0000EDr 2               famistudio_vrc6_pulse2_prev_hi = famistudio_vrc6_saw_volume
0000EDr 2               famistudio_vrc6_saw_prev_hi    = famistudio_vrc6_saw_volume
