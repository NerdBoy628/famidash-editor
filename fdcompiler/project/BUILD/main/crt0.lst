0006FFr 2               ; You get your arguments back in ptr3
0006FFr 2               .macro crossPRGBankJSR inArgCount, routine, bank
0006FFr 2               	.ifblank routine
0006FFr 2               		.error "Have to supply routine and argument count for crossPRGBankJSR"
0006FFr 2               	.endif
0006FFr 2               
0006FFr 2               	.ifnblank bank
0006FFr 2               		LDY bank
0006FFr 2               	.else
0006FFr 2               		LDY #.bank(routine)
0006FFr 2               	.endif
0006FFr 2               
0006FFr 2               	.ifnblank inArgCount
0006FFr 2               		.if inArgCount >= 2
0006FFr 2               			STX ptr3+1
0006FFr 2               		.endif
0006FFr 2               		.if inArgCount >= 1
0006FFr 2               			STA ptr3
0006FFr 2               		.endif
0006FFr 2               	.endif
0006FFr 2               
0006FFr 2               	LDA #<routine
0006FFr 2               	LDX #>routine
0006FFr 2               	jsr crossPRGBankJump
0006FFr 2               .endmacro
