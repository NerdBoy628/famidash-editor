000D8Er 2               .endif
000D8Er 2               .if FAMISTUDIO_EXP_EPSM_RHYTHM_CHN2_ENABLE
000D8Er 2                   .byte .lobyte(EPSM_CHANNEL2_RHYTHM_OFFSET)
