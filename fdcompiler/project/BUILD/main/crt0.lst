000041r 2                   .macro mmc3_set_mirroring
000041r 2                       sta MMC3_REG_MIRRORING
000041r 2                   .endmacro
000041r 2               
000041r 2                   initialize_mapper:
000041r 2                       ; lda #(MMC3_REG_SEL_CHR_MODE_A | MMC3_REG_SEL_PRG2_8000)
000041r 2  A9 C0                lda #(MMC3_REG_SEL_CHR_MODE_B | MMC3_REG_SEL_PRG2_8000)
000043r 2  85 rr                sta mmc3ChrInversionSetting
000045r 2               
000045r 2               		; lda #%10000000
000045r 2               		; sta MMC3_REG_PRG_RAM_PROTECT
000045r 2               
000045r 2  A9 01                lda #1
000047r 2  8D 00 A0             sta MMC3_REG_MIRRORING  ; Set mirroring to horizontal
00004Ar 2  4C rr rr             jmp mmc3_set_prg_bank_1
00004Dr 2               
00004Dr 2               
00004Dr 2               
00004Dr 2                   mmc3_disable_irq:
00004Dr 2                   _mmc3_disable_irq:
00004Dr 2  8D 00 E0             sta $e000 ;any value
000050r 2  A0 00                ldy #0
000052r 2  8C rr rr             sty _irqTableIdx
000055r 2  A9 FF                lda #$ff
000057r 2  8D rr rr             sta _irqTable
00005Ar 2  A9 rr                lda #<_irqTable
00005Cr 2  A2 rr                ldx #>_irqTable
00005Er 2                       ; fall through to setting the pointer
00005Er 2                   .export _mmc3_disable_irq
00005Er 2                   set_irq_ptr:
00005Er 2                   _set_irq_ptr:
00005Er 2                       ;ax = pointer
00005Er 2  85 rr                sta mmc3IRQTablePtr
000060r 2  86 rr                stx mmc3IRQTablePtr+1
000062r 2                       ;lda #$ff    ; set the first byte of the irq table to $ff
000062r 2                       ;sta _irqTable; just to be on the safe side
000062r 2  60                   rts
000063r 2                   .export _set_irq_ptr
000063r 2               
000063r 2                   is_irq_done:
000063r 2                   _is_irq_done:
000063r 2  A5 rr                lda mmc3IRQJoever
000065r 2  A2 00                ldx #0
000067r 2  60                   rts
000068r 2                   .export _is_irq_done
000068r 2               
000068r 2               
000068r 2                   irq:
000068r 2  48                   pha
000069r 2  8A                   txa
00006Ar 2  48                   pha
00006Br 2  98                   tya
00006Cr 2  48                   pha
00006Dr 2               
00006Dr 2  8D 00 E0             sta $e000    ; disable mmc3 irq
000070r 2                                   ; any value will do
000070r 2               
000070r 2  20 rr rr             jsr irq_parser
000073r 2               
000073r 2  68                   pla
000074r 2  A8                   tay
000075r 2  68                   pla
000076r 2  AA                   tax
000077r 2  68                   pla
000078r 2               
000078r 2  40                   rti
000079r 2               
000079r 2               
000079r 2                   ;format
000079r 2                   ;value < 0xf0, it's a scanline count
000079r 2                   ;zero is valid, it triggers an IRQ at the end of the current line
000079r 2               
000079r 2                   ;if >= 0xf0...
000079r 2                   ;f0 = 2000 write, next byte is write value
000079r 2                   ;f1 = 2001 write, next byte is write value
000079r 2                   ;f2-f4 unused - future TODO ?
000079r 2                   ;f5 = 2005 write, next byte is H Scroll value
000079r 2                   ;f6 = 2006 write, next 2 bytes are write values
000079r 2               
000079r 2               
000079r 2                   ;f7 = change CHR mode 0, next byte is write value
000079r 2                   ;f8 = change CHR mode 1, next byte is write value
000079r 2                   ;f9 = change CHR mode 2, next byte is write value
000079r 2                   ;fa = change CHR mode 3, next byte is write value
000079r 2                   ;fb = change CHR mode 4, next byte is write value
000079r 2                   ;fc = change CHR mode 5, next byte is write value
000079r 2               
000079r 2                   ;fd = very short wait, no following byte
000079r 2                   ;fe = short wait, next byte is quick loop value
000079r 2                   ;(for fine tuning timing of things)
000079r 2               
000079r 2                   ;ff = end of data set
000079r 2               
000079r 2               
000079r 2                   irq_parser:
000079r 2  A4 rr                ldy mmc3IRQTableIndex
00007Br 2                   ;    ldx #0
00007Br 2                   @loop:
00007Br 2  B1 rr                lda (mmc3IRQTablePtr), y ; get value from array
00007Dr 2  C8                   iny
00007Er 2  C9 FD                cmp #$fd ;very short wait
000080r 2  F0 F9                beq @loop
000082r 2               
000082r 2  C9 FE                cmp #$fe ;fe-ff wait or exit
000084r 2  B0 41                bcs @wait
000086r 2               
000086r 2  C9 F0                cmp #$f0
000088r 2  B0 03                bcs @1
00008Ar 2  4C rr rr             jmp @scanline ;below f0
00008Dr 2                   @1:
00008Dr 2               
00008Dr 2  C9 F7                cmp #$f7
00008Fr 2  B0 46                bcs @chr_change
000091r 2                   ;f0-f6
000091r 2  AA                   tax
000092r 2  B1 rr                lda (mmc3IRQTablePtr), y ; get value from array
000094r 2  C8                   iny
000095r 2  E0 F0                cpx #$f0
000097r 2  D0 06                bne @2
000099r 2  8D 00 20             sta $2000 ; f0
00009Cr 2  4C rr rr             jmp @loop
00009Fr 2                   @2:
00009Fr 2  E0 F1                cpx #$f1
0000A1r 2  D0 06                bne @3
0000A3r 2  8D 01 20             sta $2001 ; f1
0000A6r 2  4C rr rr             jmp @loop
0000A9r 2                   @3:
0000A9r 2  E0 F5                cpx #$f5
0000ABr 2  D0 0E                bne @4
0000ADr 2  A2 04                ldx #4
0000AFr 2                   @better_timing: ; don't change till near the end of the line
0000AFr 2  CA                   dex
0000B0r 2  D0 FD                bne @better_timing
0000B2r 2               
0000B2r 2  8D 05 20             sta $2005 ; f5
0000B5r 2  8D 05 20             sta $2005 ; second value doesn't matter
0000B8r 2  4C rr rr             jmp @loop
0000BBr 2                   @4:
0000BBr 2  8D 06 20             sta $2006 ; f6
0000BEr 2  B1 rr                lda (mmc3IRQTablePtr), y ; get 2nd value from array
0000C0r 2  C8                   iny
0000C1r 2  8D 06 20             sta $2006
0000C4r 2  4C rr rr             jmp @loop
0000C7r 2               
0000C7r 2                   @wait: ; fe-ff wait or exit
0000C7r 2  C9 FF                cmp #$ff
0000C9r 2  F0 2C                beq @exit
0000CBr 2  B1 rr                lda (mmc3IRQTablePtr), y ; get value from array
0000CDr 2  C8                   iny
0000CEr 2  AA                   tax
0000CFr 2  F0 AA                beq @loop ; if zero, just exit
0000D1r 2                   @wait_loop: ; the timing of this wait could change if this crosses a page boundary
0000D1r 2  CA                   dex
0000D2r 2  D0 FD                bne @wait_loop
0000D4r 2  4C rr rr             jmp @loop
0000D7r 2               
0000D7r 2                   @chr_change:
0000D7r 2                   ;f7-fc change a CHR set
0000D7r 2  38                   sec
0000D8r 2  E9 F7                sbc #$f7 ;should result in 0-5
0000DAr 2  09 80                ora #$80 ;A12_INVERT
0000DCr 2  8D 00 80             sta $8000
0000DFr 2  B1 rr                lda (mmc3IRQTablePtr), y ; get next value
0000E1r 2  C8                   iny
0000E2r 2  8D 01 80             sta $8001
0000E5r 2               
0000E5r 2  A5 rr                lda mmc3_8000 ;restore the MMC3 bank select register
0000E7r 2  8D 00 80             sta $8000     ;in case we interrupted something
0000EAr 2  4C rr rr             jmp @loop
0000EDr 2               
0000EDr 2                   @scanline:
0000EDr 2  EA                   nop ;trying to improve stability
0000EEr 2  EA                   nop
0000EFr 2  EA                   nop
0000F0r 2  EA                   nop
0000F1r 2  20 rr rr             jsr set_scanline_count ;this terminates the set
0000F4r 2  84 rr                sty mmc3IRQTableIndex
0000F6r 2  60                   rts
0000F7r 2               
0000F7r 2                   @exit:
0000F7r 2  85 rr                sta mmc3IRQJoever ;value 0xff
0000F9r 2  88                   dey ; undo the previous iny, keep it pointed to ff
0000FAr 2  84 rr                sty mmc3IRQTableIndex
0000FCr 2  60                   rts
0000FDr 2               
0000FDr 2               
0000FDr 2                   set_scanline_count:
0000FDr 2                       ; any value will do for most of these registers
0000FDr 2  8D 00 E0             sta $e000 ; disable mmc3 irq
000100r 2  8D 00 C0             sta $c000 ; set the irq counter reload value
000103r 2  8D 01 C0             sta $c001 ; reload the reload value
000106r 2  8D 01 E0             sta $e001 ; enable the mmc3 irq
000109r 2  58                   cli ;make sure irqs are enabled
00010Ar 2  60                   rts
00010Br 2               
00010Br 2               
00010Br 2               
00010Br 2                   write_irq_table:    ; FIRST ASM ROUTINE BY USERSNIPER
00010Br 2                   _write_irq_table:   ; how did i do
00010Br 2                       ;ax = pointer
00010Br 2               
00010Br 2                       ; replace mmc3IRQTablePtr temporarily
00010Br 2  85 rr                sta mmc3IRQTablePtr
00010Dr 2  86 rr                stx mmc3IRQTablePtr+1
00010Fr 2               
00010Fr 2                       ; write two bytes ahead in SRAM (unused space)
00010Fr 2                       ; as a failsafe in the event that the table is
00010Fr 2                       ; not fully written to or read from
00010Fr 2  A9 FF                lda #$ff
000111r 2  8D rr rr             sta _irqTable+$20
000114r 2  8D rr rr             sta _irqTable+$21
000117r 2               
000117r 2  A0 00                ldy #0
000119r 2                   @loop:
000119r 2  B1 rr                lda (mmc3IRQTablePtr), y
00011Br 2  99 rr rr             sta _irqTable, y
00011Er 2  C8                   iny
00011Fr 2               
00011Fr 2  C0 20                cpy #$20
000121r 2  F0 04                beq @done
000123r 2               
000123r 2  C9 FF                cmp #$ff
000125r 2  D0 F2                bne @loop
000127r 2               
000127r 2                   @done:
000127r 2                       ; set mmc3IRQTablePtr back to what it was
000127r 2  A9 rr                lda #<_irqTable
000129r 2  A2 rr                ldx #>_irqTable
00012Br 2  20 rr rr             jsr set_irq_ptr
00012Er 2               
00012Er 2  60                   rts
00012Fr 2                   .export _write_irq_table
00012Fr 2               
00012Fr 2               
00012Fr 2               .segment "CODE_2"
00012Fr 2                   edit_irq_table:
00012Fr 2                   __edit_irq_table:
00012Fr 2                      ; a = byte
00012Fr 2                      ; x = offset
00012Fr 2               
00012Fr 2                      ; increment the counter
00012Fr 2  AC rr rr            ldy _irqTableIdx
000132r 2  C0 20               cpy #$20
000134r 2  B0 03               bcs @joever ; is the counter >=$20?
000136r 2               
000136r 2  9D rr rr            sta _irqTable, x ; if not, add the byte
000139r 2                   @joever:
000139r 2  60                  rts
00013Ar 2                   .export __edit_irq_table
00013Ar 2               
00013Ar 2               
00013Ar 1               	.include "neslib.s"
00013Ar 2               ;NES hardware-dependent functions by Shiru (shiru@mail.ru)
00013Ar 2               ;with improvements by VEG
00013Ar 2               ;Feel free to do anything you want with this code, consider it Public Domain
00013Ar 2               
00013Ar 2               ;for nesdoug version 1.2, 1/1/2022
00013Ar 2               ;changed nmi to prevent possible incomplete sprite
00013Ar 2               ;added a little bit at the end of _flush_vram_update
00013Ar 2               ;changed the name of flush_vram_update_nmi to flush_vram_update2
00013Ar 2               
00013Ar 2               ;minor change %%, added ldx #0 to functions returning char
00013Ar 2               ;removed sprid from c functions to speed them up
00013Ar 2               
00013Ar 2               	.import _use_auto_chrswitch
00013Ar 2               
00013Ar 2               	.export _pal_all,_pal_bg,_pal_spr,_pal_clear
00013Ar 2               	.export _pal_bright
00013Ar 2               	.export _ppu_off,_ppu_on_all,_ppu_on_bg,_ppu_on_spr,_ppu_mask,_ppu_system
00013Ar 2               	.export _oam_clear,_oam_clear_player,__oam_spr,__oam_meta_spr,__oam_meta_spr_disco, _oam_clear_two_players
00013Ar 2               	;.export _oam_hide_rest,_oam_size,_bank_bg,_rand8
00013Ar 2               	.export _ppu_wait_nmi
00013Ar 2               	.export __scroll,_split,_newrand
00013Ar 2               	.export _bank_spr
00013Ar 2               	.export __vram_read,__vram_write
00013Ar 2               	.export _set_rand
00013Ar 2               	.export __vram_fill,_vram_inc,_vram_unrle
00013Ar 2               	.export __memcpy,__memfill,_delay
00013Ar 2               
00013Ar 2               	.export _flush_vram_update2, _oam_set, _oam_get
00013Ar 2               	.import _disco_sprites, _slowmode, _kandoframecnt, _kandokidshack4, _pauseStatus
00013Ar 2               
00013Ar 2               	.if VS_SYSTEM
00013Ar 2               		.import _coins_inserted, _CREDITS1_PREV, _CREDITS2_PREV, _showarrownow
00013Ar 2               	.endif
00013Ar 2               
00013Ar 2               	.segment "NESLIB"
000000r 2               
000000r 2               ;NMI handler
000000r 2               
000000r 2               nmi:
000000r 2  48           	pha
000001r 2  8A           	txa
000002r 2  48           	pha
000003r 2  98           	tya
000004r 2  48           	pha
000005r 2               
000005r 2  A5 rr        	lda <PPU_MASK_VAR	;if rendering is disabled, do not access the VRAM at all
000007r 2  8D 01 20     	sta PPU_MASK
00000Ar 2  29 18        	and #%00011000
00000Cr 2  D0 03        	bne @renderingOn
00000Er 2  4C rr rr     	jmp	@skipAll
000011r 2               
000011r 2               @renderingOn:
000011r 2  A5 rr        	lda <VRAM_UPDATE ;is the frame complete?
000013r 2  D0 03        	bne @doUpdate
000015r 2  4C rr rr     	jmp @skipAll ;skipUpd
000018r 2               
000018r 2               @doUpdate:
000018r 2  A9 00        	lda #0
00001Ar 2  85 rr        	sta <VRAM_UPDATE
00001Cr 2               
00001Cr 2               	; lda <PPU_MASK_VAR
00001Cr 2               	; and #%11100111		;	Disable BG and sprites
00001Cr 2               	; ora #%11100000		;	Enable dark emphasis
00001Cr 2               	; sta PPU_MASK
00001Cr 2               
00001Cr 2               	; If nametables are updating, don't do the palette update this frame
00001Cr 2  A5 rr        	lda <NAME_UPD_ENABLE
00001Er 2  F0 0D        	beq @checkPal
000020r 2               	; don't run palette switches on the same frame that we flush vram to save time
000020r 2  AD rr rr     	lda VRAM_BUF
000023r 2  C9 FF        	cmp #$ff
000025r 2  F0 06        	beq @checkPal
000027r 2  20 rr rr     		jsr _flush_vram_update2
00002Ar 2  4C rr rr     		jmp @skipUpd
00002Dr 2               @checkPal:
00002Dr 2  A5 rr        	lda <PAL_UPDATE		;update palette if needed
00002Fr 2  D0 03        	bne @updPal
000031r 2  4C rr rr     	jmp @skipUpd
000034r 2               
000034r 2               @updPal:
000034r 2               
000034r 2  A2 00        	ldx #0
000036r 2  86 rr        	stx <PAL_UPDATE
000038r 2               
000038r 2  A9 3F        	lda #$3f
00003Ar 2  8D 06 20     	sta PPU_ADDR
00003Dr 2  8E 06 20     	stx PPU_ADDR
000040r 2               
000040r 2  A9 rr        	lda #<PAL_BUF-1
000042r 2  20 rr rr     	jsr palette_popslide_buffer
000045r 2               
000045r 2               @skipUpd:
000045r 2               
000045r 2  A9 00        	lda #0
000047r 2  8D 06 20     	sta PPU_ADDR
00004Ar 2  8D 06 20     	sta PPU_ADDR
00004Dr 2               
00004Dr 2  A5 rr        	lda <SCROLL_X
00004Fr 2  8D 05 20     	sta PPU_SCROLL
000052r 2  A5 rr        	lda <SCROLL_Y
000054r 2  8D 05 20     	sta PPU_SCROLL
000057r 2               
000057r 2  A5 rr        	lda <PPU_CTRL_VAR
000059r 2  8D 00 20     	sta PPU_CTRL
00005Cr 2               
00005Cr 2  AD rr rr     	lda _use_auto_chrswitch
00005Fr 2  F0 03        	beq :+
000061r 2  20 rr rr     		jsr _set_tile_banks
000064r 2               	:
000064r 2               
000064r 2  A9 00        	lda #0
000066r 2  85 rr        	sta mmc3IRQTableIndex
000068r 2  85 rr        	sta mmc3IRQJoever
00006Ar 2               
00006Ar 2  20 rr rr     	jsr irq_parser ; needs to happen inside v-blank...
00006Dr 2               									 ; so goes before the music
00006Dr 2               						; but, if screen is off this should be skipped
00006Dr 2               
00006Dr 2               
00006Dr 2  AD rr rr     	lda _pauseStatus
000070r 2  D0 13        	bne @readJoypadCycleAligned
000072r 2  AD rr rr     	lda _kandokidshack4
000075r 2  C9 0F        	cmp #$0f
000077r 2  F0 05        	beq @calc2
000079r 2  AD rr rr     	lda _slowmode
00007Cr 2  F0 07        	beq @readJoypadCycleAligned
00007Er 2               @calc2:
00007Er 2  AD rr rr     	lda _kandoframecnt
000081r 2  29 01        	and #$01
000083r 2  D0 33        	bne @skipAll
000085r 2               
000085r 2               @readJoypadCycleAligned:
000085r 2               	.if !VS_SYSTEM
000085r 2               		; The only reason we need legacy joypad reading is Nestopia
000085r 2               		; Nestopia doesn't support the SNES Mouse
000085r 2               		; Therefore this is the only 100% accurate way to determine
000085r 2               		; if we are on Nestopia
000085r 2  A5 rr        		lda noMouse
000087r 2  D0 0F        		bne @readJoypadLegacy
000089r 2               		; Read the raw controller data synced with OAM DMA to prevent
000089r 2               		; DMC DMA bugs
000089r 2  20 rr rr     		jsr oam_and_readjoypad
00008Cr 2               
00008Cr 2               		; Since we have to have a mouse in port 2 to get here,
00008Cr 2               		; Check if the signature is correct
00008Cr 2  A5 rr        		lda <(mouse + kMouseButtons)
00008Er 2  29 0F        		and #$0f
000090r 2  C9 01        		cmp #$01
000092r 2  F0 21        		beq @readJoypadFinish
000094r 2               
000094r 2               		; If it isn't, say that we don't have a mouse anymore
000094r 2  E6 rr        		inc noMouse
000096r 2  D0 1D        		bne @readJoypadFinish	; = BRA
000098r 2               	.endif
000098r 2               @readJoypadLegacy:
000098r 2  A9 rr        	LDA #>OAM_BUF
00009Ar 2  8D 14 40     	STA PPU_OAM_DMA
00009Dr 2               
00009Dr 2               	; save the previous controller state for calcuating the previous results
00009Dr 2  A5 rr        	lda <joypad1
00009Fr 2  85 rr        	sta TEMP + 4
0000A1r 2  A5 rr        	lda <joypad2
0000A3r 2  85 rr        	sta TEMP + 5
0000A5r 2               
0000A5r 2  A9 00        	lda #$0
0000A7r 2  85 rr        	sta <(mouse + kMouseButtons)
0000A9r 2               
0000A9r 2               	; Poll controller port 1
0000A9r 2  A8           	tay
0000AAr 2  20 rr rr     	jsr pad_poll
0000ADr 2  85 rr        	sta <joypad1
0000AFr 2               
0000AFr 2               	; Poll controller port 2
0000AFr 2  C8           	iny
0000B0r 2  20 rr rr     	jsr pad_poll
0000B3r 2  85 rr        	sta <(mouse + kMouseZero)	; where calculate_extra_fields expects it to be
0000B5r 2               
0000B5r 2               @readJoypadFinish:
0000B5r 2               	; Calculate the press/release for the controllers
0000B5r 2               	; and also update mouse X/Y coords after the timing sensitive parts
0000B5r 2               	; of NMI are complete
0000B5r 2               
0000B5r 2  20 rr rr     	jsr calculate_extra_fields
0000B8r 2               
0000B8r 2               @skipAll:
0000B8r 2               
0000B8r 2               
0000B8r 2               	.if __VS_SYSTEM
0000B8r 2               		ldx #0
0000B8r 2               		lda _CREDITS1_PREV
0000B8r 2               		and #%00100000
0000B8r 2               		beq @check_slot_2_creds
0000B8r 2               		lda $4016
0000B8r 2               		and #%00100000
0000B8r 2               		bne @check_slot_2_creds
0000B8r 2               		lda	_coins_inserted
0000B8r 2               		cmp	#$FF
0000B8r 2               		beq	@skip1
0000B8r 2               		cmp #0
0000B8r 2               		bne @justinc
0000B8r 2               		lda #1
