000328r 2               
000328r 2               ; void increment_attempt_count();
000328r 2               .if !__THE_ALBUM
000328r 2               .segment "XCD_BANK_00"
0006C7r 2               
0006C7r 2               .import _attemptCounter
0006C7r 2               
0006C7r 2               .export _increment_attempt_count
0006C7r 2               .proc _increment_attempt_count
0006C7r 2               	; This can be totally made into a generic routine, just ping @alexmush (but itll be less optimized)
0006C7r 2  A0 0A        	ldy #10	; the number limit
0006C9r 2  A9 00        	lda #0	; store if overflows
0006CBr 2               
0006CBr 2  EE rr rr     	inc _attemptCounter+0	;	attemptCounter[0]++;
0006CEr 2  CC rr rr     	cpy _attemptCounter+0	;	if (10 == attemptCounter[0]) {
0006D1r 2  D0 3D        	bne finish				;		(Note the Yoda notation, sorta reflects the cpy)
0006D3r 2  8D rr rr     	sta _attemptCounter+0	;__		attemptCounter[0] = 0;
0006D6r 2               
0006D6r 2  EE rr rr     	inc _attemptCounter+1	;		attemptCounter[1]++;
0006D9r 2  CC rr rr     	cpy _attemptCounter+1	;		if (10 == attemptCounter[1]) {
0006DCr 2  D0 32        	bne finish				;			attemptCounter[2] = 0;
0006DEr 2  8D rr rr     	sta _attemptCounter+1	;__	and so on until digit 7
0006E1r 2               
0006E1r 2  EE rr rr     	inc _attemptCounter+2
0006E4r 2  CC rr rr     	cpy _attemptCounter+2
0006E7r 2  D0 27        	bne finish
0006E9r 2  8D rr rr     	sta _attemptCounter+2
0006ECr 2               
0006ECr 2  EE rr rr     	inc _attemptCounter+3
0006EFr 2  CC rr rr     	cpy _attemptCounter+3
0006F2r 2  D0 1C        	bne finish
0006F4r 2  8D rr rr     	sta _attemptCounter+3
0006F7r 2               
0006F7r 2  EE rr rr     	inc _attemptCounter+4
0006FAr 2  CC rr rr     	cpy _attemptCounter+4
0006FDr 2  D0 11        	bne finish
0006FFr 2  8D rr rr     	sta _attemptCounter+4
000702r 2               
000702r 2  EE rr rr     	inc _attemptCounter+5
000705r 2  CC rr rr     	cpy _attemptCounter+5
000708r 2  D0 06        	bne finish
00070Ar 2  8D rr rr     	sta _attemptCounter+5
00070Dr 2               
00070Dr 2  EE rr rr     	inc _attemptCounter+6	; No checks here lmao (can be added tho)
000710r 2               
000710r 2               	finish:
000710r 2  60           	rts
000711r 2               .endproc
000711r 2               
000711r 2               ; void display_attempt_counter (uint8_t zeroChr, uintptr_t ppu_address);
000711r 2               .segment _LVLDONE_BANK
000035r 2               
000035r 2               .import _attemptCounter
000035r 2               
000035r 2               .export __display_attempt_counter
000035r 2               .proc __display_attempt_counter
000035r 2               	; AX = ppu_address
000035r 2               	; sreg[0] = zeroChr
000035r 2               	zeroChr = sreg
000035r 2               
000035r 2               	start:
000035r 2  48           		pha		; temp storage
000036r 2  A0 07        		ldy #7	; size of _attemptCounter
000038r 2               
000038r 2               	numsize_loop:
000038r 2  88           		dey
000039r 2  F0 34        		beq	use_one_vram_buffer	; If Y decrements to 0, we are just printing the last digit
00003Br 2  B9 rr rr     		lda	_attemptCounter, y
00003Er 2  F0 F8        		beq	numsize_loop
000040r 2               
000040r 2               		; now we have the (amount of digits to print - 1) in Y
000040r 2               	vram_write_header:
000040r 2  84 rr        		sty	tmp1
000042r 2               
000042r 2  8A           		txa					;
000043r 2  09 40        		ora	#$40			;	NT_UPD_HORZ
000045r 2  A6 rr        		ldx	VRAM_INDEX		;
000047r 2  9D rr rr     		sta	VRAM_BUF+0,	x	;	Calculate the vram address of the leftmost digit
00004Ar 2  68           		pla					;	and store in the buffer
00004Br 2  38           		sec					;
00004Cr 2  E5 rr        		sbc	tmp1			;
00004Er 2  9D rr rr     		sta	VRAM_BUF+1,	x	;__
000051r 2  C8           		iny					;
000052r 2  98           		tya					;	The amount of bytes needs to be incremented
000053r 2  9D rr rr     		sta	VRAM_BUF+2,	x	;__
000056r 2               
000056r 2  18           		clc
000057r 2               	vram_write_main:
000057r 2  B9 rr rr     		lda	_attemptCounter-1, y
00005Ar 2               		; clc should not be needed as the writes SHOULD NOT overflow
00005Ar 2  65 rr        		adc	zeroChr
00005Cr 2  9D rr rr     		sta	VRAM_BUF+3,	x
00005Fr 2  E8           		inx
000060r 2  88           		dey
000061r 2  D0 F4        		bne vram_write_main
000063r 2               
000063r 2               	vram_write_finish:
000063r 2  A9 FF        		lda	#$FF
000065r 2  9D rr rr     		sta	VRAM_BUF+3,	x
000068r 2  8A           		txa
000069r 2  18           		clc
00006Ar 2  69 03        		adc	#3
00006Cr 2  85 rr        		sta	VRAM_INDEX
00006Er 2  60           		rts
00006Fr 2               
00006Fr 2               	use_one_vram_buffer:
00006Fr 2  AD rr rr     		lda	_attemptCounter+0
000072r 2               
000072r 2  18           		clc
000073r 2  65 rr        		adc	zeroChr
000075r 2  85 rr        		sta	sreg	; doesn't matter, it's not used anymore anyway
000077r 2               
000077r 2               		; X has remained the same high byte of PPU address
000077r 2               		; A has to be recovered rq
000077r 2  68           		pla
000078r 2               
000078r 2  4C rr rr     		jmp	__one_vram_buffer
00007Br 2               .endproc
00007Br 2               .endif
00007Br 2               
00007Br 2               
00007Br 2               .if !__THE_ALBUM
00007Br 2               
00007Br 2               ; void draw_dialog_box(const char * data);
00007Br 2               .segment _DIALOG_BOX_BANK
000B06r 2               
000B06r 2               .import popax	; Unfortunately
000B06r 2               .import _paletteSettings
000B06r 2               .import _DialogBox
000B06r 2               
000B06r 2               .export _draw_dialog_box
000B06r 2               .proc _draw_dialog_box
000B06r 2               	dataPtr = ptr1
000B06r 2               	vramPtr = ptr2
000B06r 2               
000B06r 2               start:
000B06r 2  85 rr        	sta	dataPtr			;	Store the data pointer
000B08r 2  86 rr        	stx	dataPtr+1		;__
000B0Ar 2               
000B0Ar 2  A0 20        	ldy	#$20						;
000B0Cr 2  8C 06 20     	sty	PPU_ADDR					;
000B0Fr 2  A0 00        	ldy	#$00						;
000B11r 2  8C 06 20     	sty	PPU_ADDR					;	Unrle the base dialog box to nametable A
000B14r 2  A9 rr        	lda	#<_DialogBox				;
000B16r 2  A2 rr        	ldx	#>_DialogBox				;
000B18r 2  20 rr rr     	jsr	_vram_unrle					;__
000B1Br 2               
000B1Br 2  A9 rr        	lda	#<_paletteSettings	;
000B1Dr 2  A2 rr        	ldx	#>_paletteSettings	;	Load the correct palette
000B1Fr 2  20 rr rr     	jsr	_pal_bg				;__
000B22r 2               
000B22r 2  A9 20        	lda	#$20			;
000B24r 2  85 rr        	sta	vramPtr+1		;
000B26r 2  8D 06 20     	sta	PPU_ADDR		;	Store the upper left corner
000B29r 2  A9 C5        	lda	#$C5			;	as the VRAM address
000B2Br 2  85 rr        	sta	vramPtr			;
000B2Dr 2  8D 06 20     	sta	PPU_ADDR		;__
000B30r 2               
000B30r 2  A4 rr        	ldy	dataPtr			;
000B32r 2  A9 00        	lda	#$00			;	Index with Y
000B34r 2  85 rr        	sta	dataPtr			;__
000B36r 2               
000B36r 2               get_symbol:
000B36r 2  B1 rr        	lda	(dataPtr),	y	;__	Load symbol
000B38r 2  C8           	iny					;
000B39r 2  D0 02        	bne :+				;	Increment data pointer
000B3Br 2  E6 rr        		inc	dataPtr+1	;
000B3Dr 2               	:					;__
000B3Dr 2  C9 10        	cmp	#$10			;	If the symbol < $10,
000B3Fr 2  90 0B        	bcc	control_code	;__	it's a control code
000B41r 2               regular_symbol:			;	If it is not, store
000B41r 2  8D 07 20     	sta	PPU_DATA		;__	the symbol to the PPU
000B44r 2  E6 rr        	inc	vramPtr			;
000B46r 2  D0 EE        	bne	get_symbol		;	Increment the VRAM ptr
000B48r 2  E6 rr        	inc	vramPtr+1		;
000B4Ar 2  D0 EA        	bne	get_symbol		;__ = BRA
000B4Cr 2               
000B4Cr 2               control_code:
000B4Cr 2  E9 0A        	sbc	#$0B-1		;__	Subtract maximum real control code, carry is clear
000B4Er 2  D0 03 4C rr  	jeq	vert_skip	;__	\v - skip some lines down
000B52r 2  rr           
000B53r 2  AA           	tax				;
000B54r 2  E8           	inx				;	\n - newline
000B55r 2  F0 0A        	beq	newline		;__
000B57r 2  E8           	inx				;	\t - skip some chars forward
000B58r 2  F0 20        	beq	space		;__
000B5Ar 2  E8           	inx				;	\b - fill line with black space
000B5Br 2  F0 39        	beq	black_line	;__
000B5Dr 2  E8           	inx				;	\a - include a substring
000B5Er 2  F0 5D        	beq	recurse		;__
000B60r 2  60           	rts				;__	Any other control code terminates the routine
000B61r 2               
000B61r 2               newline:
000B61r 2  A5 rr        	lda	vramPtr
000B63r 2  A6 rr        	ldx	vramPtr+1
000B65r 2  69 1F        	adc	#$20-1		;__	Carry is set
000B67r 2  29 E0        	and	#$E0
000B69r 2  09 05        	ora	#$05
000B6Br 2  85 rr        	sta	vramPtr
000B6Dr 2  90 03        	bcc	:+
000B6Fr 2  E8           		inx
000B70r 2  86 rr        		stx	vramPtr+1
000B72r 2               	:
000B72r 2  8E 06 20     	stx	PPU_ADDR
000B75r 2  8D 06 20     	sta	PPU_ADDR
000B78r 2  D0 BC        	bne	get_symbol
000B7Ar 2               
000B7Ar 2               space:
000B7Ar 2  B1 rr        	lda	(dataPtr), y	;
000B7Cr 2  C8           	iny
000B7Dr 2  D0 02        	bne	:+
000B7Fr 2  E6 rr        		inc	dataPtr+1
000B81r 2               	:
000B81r 2               
000B81r 2  A6 rr        	ldx	vramPtr+1
000B83r 2               
000B83r 2  18           	clc
000B84r 2  65 rr        	adc	vramPtr
000B86r 2  90 03        	bcc	:+
000B88r 2  E8           		inx
000B89r 2  86 rr        		stx	vramPtr+1
000B8Br 2               	:
000B8Br 2  8E 06 20     	stx	PPU_ADDR
000B8Er 2  85 rr        	sta	vramPtr
000B90r 2  8D 06 20     	sta	PPU_ADDR
000B93r 2  4C rr rr     	jmp	get_symbol
000B96r 2               
000B96r 2               black_line:
000B96r 2  A6 rr        	ldx	vramPtr+1
000B98r 2  A5 rr        	lda	vramPtr
000B9Ar 2  29 E0        	and	#$E0
000B9Cr 2  09 05        	ora	#$05
000B9Er 2  85 rr        	sta	vramPtr
000BA0r 2               
000BA0r 2  8E 06 20     	stx	PPU_ADDR
000BA3r 2  8D 06 20     	sta	PPU_ADDR
000BA6r 2               
000BA6r 2  A2 16        	ldx	#22
000BA8r 2  A9 FE        	lda	#$FE
000BAAr 2               
000BAAr 2               	@loop:
000BAAr 2  8D 07 20     		sta	PPU_DATA
000BADr 2  CA           		dex
000BAEr 2  D0 FA        		bne	@loop
000BB0r 2               
000BB0r 2  A6 rr        	ldx	vramPtr+1
000BB2r 2  A5 rr        	lda	vramPtr
000BB4r 2  8E 06 20     	stx	PPU_ADDR
000BB7r 2  8D 06 20     	sta	PPU_ADDR
000BBAr 2  4C rr rr     	jmp	get_symbol
000BBDr 2               
000BBDr 2               recurse:
000BBDr 2  A5 rr        	lda	dataPtr+1	;
000BBFr 2  48           	pha				;	Push the old data
000BC0r 2  98           	tya				;	to hardware stack
000BC1r 2  48           	pha				;__
000BC2r 2               
000BC2r 2  20 rr rr     	jsr	popax		;	Pop the new
000BC5r 2  A8           	tay				;	data from
000BC6r 2  86 rr        	stx	dataPtr+1	;__	software stack
000BC8r 2               
000BC8r 2  20 rr rr     	jsr	get_symbol
000BCBr 2               
000BCBr 2  68           	pla				;
000BCCr 2  A8           	tay				;	Pop the old data
000BCDr 2  68           	pla				;	from hardware stack
000BCEr 2  85 rr        	sta	dataPtr+1	;__
000BD0r 2               
000BD0r 2  4C rr rr     	jmp	get_symbol
000BD3r 2               
000BD3r 2               vert_skip:
000BD3r 2  B1 rr        	lda	(dataPtr), y	;
000BD5r 2  C8           	iny					;
000BD6r 2  D0 02        	bne	:+				;	Load amount of lines to skip
000BD8r 2  E6 rr        		inc	dataPtr+1	;
000BDAr 2               	:					;__
000BDAr 2               
000BDAr 2  29 1F        	and	#$1F			;
000BDCr 2  C9 10        	cmp	#$10			;	Put bit 4 into tmp memory
000BDEr 2  26 rr        	rol	dataPtr			;__
000BE0r 2  29 0F        	and	#$0F			;
000BE2r 2  C9 08        	cmp	#$08			;	Put bit 3 into tmp memory
000BE4r 2  26 rr        	rol	dataPtr			;__
000BE6r 2  0A           	asl					;
000BE7r 2  AA           	tax					;	A <<= 5
000BE8r 2  BD rr rr     	lda	shiftBy4table,x	;__
000BEBr 2               
000BEBr 2  65 rr        	adc	vramPtr			;__	Carry is clear by the ASL
000BEDr 2  29 E0        	and	#$E0			;	Rewind to beginning of line
000BEFr 2  09 05        	ora	#$05			;__	(does not affect carry)
000BF1r 2  AA           	tax					;__	Temp mem
000BF2r 2  A5 rr        	lda	dataPtr			;	Add high byte
000BF4r 2  65 rr        	adc	vramPtr+1		;__
000BF6r 2  8D 06 20     	sta	PPU_ADDR		;	Store high byte
000BF9r 2  85 rr        	sta	vramPtr+1		;__
000BFBr 2  8E 06 20     	stx	PPU_ADDR		;	Store low byte
000BFEr 2  86 rr        	stx	vramPtr			;__
000C00r 2               
000C00r 2  A2 00        	ldx	#$00			;	Reset temp mem back to 0
000C02r 2  86 rr        	stx	dataPtr			;__
000C04r 2               
000C04r 2  4C rr rr     	jmp	get_symbol
000C07r 2               
000C07r 2               .endproc
000C07r 2               
000C07r 2               .endif
000C07r 2               
000C07r 2               
000C07r 2               
000C07r 2               ; void init_sprites();
000C07r 2               .segment "CODE_2"
000328r 2               
000328r 2               .importzp _sprite_data
000328r 2               .import _sprite_data_bank
000328r 2               .import _activesprites_type, _activesprites_x_hi, _activesprites_x_lo, _activesprites_active
000328r 2               
000328r 2               .export _init_sprites
000328r 2               .proc _init_sprites
000328r 2               	; No arguments, at all
000328r 2               
000328r 2               	x_counter = tmp1
000328r 2               
000328r 2               	; Pointers are already set up by init_rld (at X=0)
000328r 2               
000328r 2  AD rr rr     	LDA	mmc3PRG1Bank			;
00032Br 2  48           	PHA							;
00032Cr 2  AD rr rr     	LDA	_sprite_data_bank		;	Switch to the correct bank
00032Fr 2  20 rr rr     	JSR	mmc3_set_prg_bank_1		;__
000332r 2               
000332r 2  A2 10        	LDX	#::_max_loaded_sprites
000334r 2  A9 FF        	LDA	#$FF		;
000336r 2               	clear_spritetype_loop:				;
000336r 2  9D rr rr     		STA	_activesprites_type-1,	X	;	Clear sprites to load them
000339r 2  CA           		DEX								;
00033Ar 2  D0 FA        		BNE	clear_spritetype_loop		;__
00033Cr 2               
00033Cr 2               	; Everything is init'd at X=0, so skip some sprite data if X != 0
00033Cr 2               
00033Cr 2               
00033Cr 2  A0 01        	LDY	#1					;__	Offset of high X byte, move inside block if opened
00033Er 2               	.if 0	; Feature is currently disabled due to no levels exceeding 4096 blocks (256*256px)
00033Er 2               	; First loop, for non-zero 3/4 bytes of scroll_x
00033Er 2               	; Flies thru sprite data till they overflow enough
00033Er 2               	; Note: may skip shit if there's too little sprites
00033Er 2               	; AND MAY NOT ACTUALLY WORK PROPERLY
00033Er 2               	old_hi_byte = tmp2
00033Er 2               
00033Er 2               	highest_bytes_setup:
00033Er 2               		LDA	_scroll_x+2			;
00033Er 2               		ORA	_scroll_x+3			;	Skip this altogether if the scroll_x isn't ass big
00033Er 2               		BEQ	high_byte_setup		;__
00033Er 2               
00033Er 2               		LDX	_scroll_x+3			;
00033Er 2               		INX						;	Store highest byte, inc for BEQ ending condition
00033Er 2               		STX	x_counter			;__
00033Er 2               
00033Er 2               		LDX	_scroll_x+2			;
00033Er 2               		INX						;__
00033Er 2               
00033Er 2               		JMP	highest_bytes_loop_entrypoint
00033Er 2               
00033Er 2               	highest_bytes_loop:
00033Er 2               		LDA	#5-1				;
00033Er 2               		ADC	sprite_data			;	Relies on set carry
00033Er 2               		STA	sprite_data			;__
00033Er 2               		BCC	:+					;
00033Er 2               			INC	sprite_data+1	;	Overflow
00033Er 2               		:						;__
00033Er 2               
00033Er 2               		@entrypoint:
00033Er 2               
00033Er 2               		LDA	(sprite_data),y		;
00033Er 2               		CMP	old_hi_byte			;	If no overflow just
00033Er 2               		STA	old_hi_byte			;	increment the pointer
00033Er 2               		BCS	highest_bytes_loop	;__
00033Er 2               
00033Er 2               		; An overflow of x_hi happened, decrement the counters
00033Er 2               
00033Er 2               		SEC						;__	Set for the addition at the beginning
00033Er 2               		DEX						;	Decrement the 3rd byte counter
00033Er 2               		BNE	highest_bytes_loop	;__
00033Er 2               		DEC	x_counter			;	Decrement the 4th byte counter
00033Er 2               		BNE	highest_bytes_loop	;__
00033Er 2               
00033Er 2               		highest_bytes_loop_entrypoint := @entrypoint
00033Er 2               
00033Er 2               	.endif
00033Er 2               
00033Er 2               	high_byte_setup:
00033Er 2  AE rr rr     		LDX	_scroll_x+1
000341r 2  F0 13        		BEQ	low_byte_setup
000343r 2  D0 0A        		BNE @entrypoint	; BRA
000345r 2               			@data_comparison_loop:
000345r 2  A9 04        				LDA	#5-1				;
000347r 2  65 rr        				ADC	sprite_data			;	Relies on set carry
000349r 2  85 rr        				STA	sprite_data			;__
00034Br 2  90 02        				BCC	@entrypoint			;	Overflow
00034Dr 2  E6 rr        					INC	sprite_data+1	;__
00034Fr 2               
00034Fr 2               			@entrypoint:
00034Fr 2  8A           				TXA						;
000350r 2  D1 rr        				CMP	(sprite_data),	y	;	return if scroll_x <= sprite x
000352r 2  F0 02        				BEQ	@return				;
000354r 2  B0 EF        				BCS	@data_comparison_loop;__
000356r 2               
000356r 2               			@return:
000356r 2               	low_byte_setup:
000356r 2  86 rr        		STX	x_counter
000358r 2  AE rr rr     		LDX	_scroll_x
00035Br 2  F0 19        		BEQ @skip
00035Dr 2  D0 0A        		BNE @entrypoint
00035Fr 2               			@data_comparison_loop:
00035Fr 2  A9 04        				LDA	#5-1				;
000361r 2  65 rr        				ADC	sprite_data			;	Relies on set carry
000363r 2  85 rr        				STA	sprite_data			;__
000365r 2  90 02        				BCC	@entrypoint			;	Overflow
000367r 2  E6 rr        					INC	sprite_data+1	;__
000369r 2               
000369r 2               			@entrypoint:
000369r 2  88           				DEY
00036Ar 2  8A           				TXA						;
00036Br 2  D1 rr        				CMP	(sprite_data),	y	;	return if scroll_x <= sprite x
00036Dr 2  C8           				INY						;
00036Er 2  A5 rr        				LDA	x_counter			;
000370r 2  F1 rr        				SBC	(sprite_data),	y	;
000372r 2  F0 02        				BEQ	@return				;
000374r 2  B0 E9        				BCS	@data_comparison_loop;__
000376r 2               
000376r 2               			@return:
000376r 2               		@skip:
000376r 2               
000376r 2               
000376r 2               	; BAM, the pointer is adjusted
000376r 2               	; Load the sprites now
000376r 2               
000376r 2  88           	DEY	; Y is 1
000377r 2               
000377r 2  A2 10        	LDX	#::_max_loaded_sprites
000379r 2               	loading_loop:
000379r 2               		;__	Y is 0
000379r 2  B1 rr        		LDA	(sprite_data),	y	;
00037Br 2  C9 FF        		CMP	#$FF				;	If sprite data ended, stfu
00037Dr 2  F0 0B        		BEQ	return				;__
00037Fr 2               
00037Fr 2  CA           		DEX						;
000380r 2  8A           		TXA						;	Load next sprite
000381r 2  20 rr rr     		JSR	_load_next_sprite	;
000384r 2  A0 00        		LDY	#0					;__ Reset Y
000386r 2               
000386r 2               		; Part where it was writing to activesprites_active
000386r 2               		; is ommited as it is done in load_next_sprite
000386r 2               
000386r 2  E0 00        		CPX	#0					;	Repeat for all sprite slots
000388r 2  D0 EF        		BNE	loading_loop		;__
00038Ar 2               
00038Ar 2               	return:
00038Ar 2               
00038Ar 2  68           	PLA
00038Br 2  4C rr rr     	JMP mmc3_set_prg_bank_1
00038Er 2               
00038Er 2               .endproc
00038Er 2               
00038Er 2               
00038Er 2               ; void update_currplayer_table_idx();
00038Er 2               .segment "CODE_2"
00038Er 2               
00038Er 2               .importzp _currplayer_mini, _currplayer_gravity, _currplayer_table_idx
00038Er 2               
00038Er 2               .export _update_currplayer_table_idx
00038Er 2               .proc _update_currplayer_table_idx
00038Er 2  A5 rr        	LDA	_currplayer_gravity		;__	A = gggggggg;	C = ?
000390r 2  29 80        	AND	#$80					;__	A = g-------;	C = ?
000392r 2  05 rr        	ORA	framerate				;__	A = g------f;	C = ?
000394r 2  0A           	ASL							;__	A = ------f-;	C = g
000395r 2  05 rr        	ORA	_currplayer_mini		;__	A = ------fm;	C = g
000397r 2  2A           	ROL							;__	A = -----fmg;	C = 0
000398r 2  85 rr        	STA	_currplayer_table_idx	;__	Store the result
00039Ar 2  60           	RTS
00039Br 2               .endproc
00039Br 2               
00039Br 2               ; void set_tile_banks();
00039Br 2               ;
00039Br 2               ;	if (!no_parallax) {
00039Br 2               ;		mmc3_set_1kb_chr_bank_0(current_spike_set + (parallax_scroll_x & 1));
00039Br 2               ;		mmc3_set_1kb_chr_bank_1(current_block_set + (parallax_scroll_x & 1));	//tile graphics
00039Br 2               ;		mmc3_set_1kb_chr_bank_2(parallax_scroll_x + GET_BANK(PARALLAX_CHR));
00039Br 2               ;		mmc3_set_1kb_chr_bank_3(current_saw_set + (parallax_scroll_x & 1));
00039Br 2               ;	}
00039Br 2               ;	else {
00039Br 2               ;		mmc3_set_1kb_chr_bank_0(current_spike_set);
00039Br 2               ;		mmc3_set_1kb_chr_bank_1(current_block_set);	//tile graphics
00039Br 2               ;		mmc3_set_1kb_chr_bank_2(SLOPESA);
00039Br 2               ;		mmc3_set_1kb_chr_bank_3(current_saw_set);
00039Br 2               ;	}
00039Br 2               
00039Br 1               	.include "nesdoug.s"
00039Br 2               ;written by Doug Fraker
00039Br 2               ;version 1.3, 10/31/2022
00039Br 2               
00039Br 2               .export _set_vram_buffer, __multi_vram_buffer, __one_vram_buffer
00039Br 2               .export _get_frame_count ;_get_pad_new
00039Br 2               .export _check_collision, __pal_fade_to, _set_scroll_x, _set_scroll_y, __add_scroll_y, __sub_scroll_y, __sub_scroll_y_ext
00039Br 2               .export  __get_ppu_addr, _get_at_addr
00039Br 2               ; .export _set_data_pointer, _set_mt_pointer, _buffer_1_mt, _buffer_4_mt
00039Br 2               .export _color_emphasis, __xy_split, _gray_line, _seed_rng
00039Br 2               .export _clear_vram_buffer
00039Br 2               
00039Br 2               .segment "NESDOUG"
000000r 2               
000000r 2               
000000r 2               
000000r 2               
000000r 2               ;void set_vram_buffer()
000000r 2               _set_vram_buffer:
000000r 2  A2 FF        	ldx #$ff
000002r 2  8E rr rr     	stx VRAM_BUF
000005r 2  86 rr        	stx <NAME_UPD_ENABLE
000007r 2  E8           	inx ;x=0
