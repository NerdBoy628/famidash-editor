000000r 2               FAMISTUDIO_EPSM_REG_VOL_C  = $0a
000000r 2               FAMISTUDIO_EPSM_REG_ENV_LO = $0b
000000r 2               FAMISTUDIO_EPSM_REG_ENV_HI = $0c
000000r 2               FAMISTUDIO_EPSM_REG_SHAPE  = $0d
000000r 2               FAMISTUDIO_EPSM_REG_IO_A   = $0e
000000r 2               FAMISTUDIO_EPSM_REG_IO_B   = $0f
000000r 2               
000000r 2               FAMISTUDIO_MMC5_PL1_VOL    = $5000
000000r 2               FAMISTUDIO_MMC5_PL1_SWEEP  = $5001
000000r 2               FAMISTUDIO_MMC5_PL1_LO     = $5002
000000r 2               FAMISTUDIO_MMC5_PL1_HI     = $5003
000000r 2               FAMISTUDIO_MMC5_PL2_VOL    = $5004
000000r 2               FAMISTUDIO_MMC5_PL2_SWEEP  = $5005
000000r 2               FAMISTUDIO_MMC5_PL2_LO     = $5006
000000r 2               FAMISTUDIO_MMC5_PL2_HI     = $5007
000000r 2               FAMISTUDIO_MMC5_PCM_MODE   = $5010
000000r 2               FAMISTUDIO_MMC5_SND_CHN    = $5015
000000r 2               FAMISTUDIO_MMC5_EXRAM_MODE = $5104
000000r 2               
000000r 2               FAMISTUDIO_N163_SILENCE       = $e000
000000r 2               FAMISTUDIO_N163_ADDR          = $f800
000000r 2               FAMISTUDIO_N163_DATA          = $4800
000000r 2               FAMISTUDIO_N163_REG_FREQ_LO   = $78
000000r 2               FAMISTUDIO_N163_REG_PHASE_LO  = $79
000000r 2               FAMISTUDIO_N163_REG_FREQ_MID  = $7a
000000r 2               FAMISTUDIO_N163_REG_PHASE_MID = $7b
000000r 2               FAMISTUDIO_N163_REG_FREQ_HI   = $7c
000000r 2               FAMISTUDIO_N163_REG_PHASE_HI  = $7d
000000r 2               FAMISTUDIO_N163_REG_WAVE      = $7e
000000r 2               FAMISTUDIO_N163_REG_VOLUME    = $7f
000000r 2               
000000r 2               FAMISTUDIO_S5B_ADDR       = $c000
000000r 2               FAMISTUDIO_S5B_DATA       = $e000
000000r 2               FAMISTUDIO_S5B_REG_LO_A   = $00
000000r 2               FAMISTUDIO_S5B_REG_HI_A   = $01
000000r 2               FAMISTUDIO_S5B_REG_LO_B   = $02
000000r 2               FAMISTUDIO_S5B_REG_HI_B   = $03
000000r 2               FAMISTUDIO_S5B_REG_LO_C   = $04
000000r 2               FAMISTUDIO_S5B_REG_HI_C   = $05
000000r 2               FAMISTUDIO_S5B_REG_NOISE  = $06
000000r 2               FAMISTUDIO_S5B_REG_TONE   = $07
000000r 2               FAMISTUDIO_S5B_REG_VOL_A  = $08
000000r 2               FAMISTUDIO_S5B_REG_VOL_B  = $09
000000r 2               FAMISTUDIO_S5B_REG_VOL_C  = $0a
000000r 2               FAMISTUDIO_S5B_REG_ENV_LO = $0b
000000r 2               FAMISTUDIO_S5B_REG_ENV_HI = $0c
000000r 2               FAMISTUDIO_S5B_REG_SHAPE  = $0d
000000r 2               FAMISTUDIO_S5B_REG_IO_A   = $0e
000000r 2               FAMISTUDIO_S5B_REG_IO_B   = $0f
000000r 2               
000000r 2               FAMISTUDIO_FDS_WAV_START  = $4040
000000r 2               FAMISTUDIO_FDS_VOL_ENV    = $4080
000000r 2               FAMISTUDIO_FDS_FREQ_LO    = $4082
000000r 2               FAMISTUDIO_FDS_FREQ_HI    = $4083
000000r 2               FAMISTUDIO_FDS_SWEEP_ENV  = $4084
000000r 2               FAMISTUDIO_FDS_SWEEP_BIAS = $4085
000000r 2               FAMISTUDIO_FDS_MOD_LO     = $4086
000000r 2               FAMISTUDIO_FDS_MOD_HI     = $4087
000000r 2               FAMISTUDIO_FDS_MOD_TABLE  = $4088
000000r 2               FAMISTUDIO_FDS_VOL        = $4089
000000r 2               FAMISTUDIO_FDS_ENV_SPEED  = $408A
000000r 2               
000000r 2               .if !FAMISTUDIO_CFG_SFX_SUPPORT
000000r 2                   ; Output directly to APU
000000r 2                   FAMISTUDIO_ALIAS_PL1_VOL    = FAMISTUDIO_APU_PL1_VOL
000000r 2                   FAMISTUDIO_ALIAS_PL1_LO     = FAMISTUDIO_APU_PL1_LO
000000r 2                   FAMISTUDIO_ALIAS_PL1_HI     = FAMISTUDIO_APU_PL1_HI
000000r 2                   FAMISTUDIO_ALIAS_PL2_VOL    = FAMISTUDIO_APU_PL2_VOL
000000r 2                   FAMISTUDIO_ALIAS_PL2_LO     = FAMISTUDIO_APU_PL2_LO
000000r 2                   FAMISTUDIO_ALIAS_PL2_HI     = FAMISTUDIO_APU_PL2_HI
000000r 2                   FAMISTUDIO_ALIAS_TRI_LINEAR = FAMISTUDIO_APU_TRI_LINEAR
000000r 2                   FAMISTUDIO_ALIAS_TRI_LO     = FAMISTUDIO_APU_TRI_LO
000000r 2                   FAMISTUDIO_ALIAS_TRI_HI     = FAMISTUDIO_APU_TRI_HI
000000r 2                   FAMISTUDIO_ALIAS_NOISE_VOL  = FAMISTUDIO_APU_NOISE_VOL
000000r 2                   FAMISTUDIO_ALIAS_NOISE_LO   = FAMISTUDIO_APU_NOISE_LO
000000r 2               .else
000000r 2                   ; Otherwise write to the output buffer
000000r 2                   FAMISTUDIO_ALIAS_PL1_VOL    = famistudio_output_buf + 0
000000r 2                   FAMISTUDIO_ALIAS_PL1_LO     = famistudio_output_buf + 1
000000r 2                   FAMISTUDIO_ALIAS_PL1_HI     = famistudio_output_buf + 2
000000r 2                   FAMISTUDIO_ALIAS_PL2_VOL    = famistudio_output_buf + 3
000000r 2                   FAMISTUDIO_ALIAS_PL2_LO     = famistudio_output_buf + 4
000000r 2                   FAMISTUDIO_ALIAS_PL2_HI     = famistudio_output_buf + 5
000000r 2                   FAMISTUDIO_ALIAS_TRI_LINEAR = famistudio_output_buf + 6
000000r 2                   FAMISTUDIO_ALIAS_TRI_LO     = famistudio_output_buf + 7
000000r 2                   FAMISTUDIO_ALIAS_TRI_HI     = famistudio_output_buf + 8
000000r 2                   FAMISTUDIO_ALIAS_NOISE_VOL  = famistudio_output_buf + 9
000000r 2                   FAMISTUDIO_ALIAS_NOISE_LO   = famistudio_output_buf + 10
000000r 2               .endif
000000r 2               
000000r 2               ;======================================================================================================================
000000r 2               ; FAMISTUDIO_INIT (public)
000000r 2               ;
000000r 2               ; Reset APU, initialize the sound engine with some music data.
000000r 2               ;
000000r 2               ; [in] a : Playback platform, zero for PAL, non-zero for NTSC.
000000r 2               ; [in] x : Pointer to music data (lo)
000000r 2               ; [in] y : Pointer to music data (hi)
000000r 2               ;======================================================================================================================
000000r 2               
000000r 2               famistudio_init:
000000r 2               
000000r 2                   @music_data_ptr = famistudio_ptr0
000000r 2               
000000r 2  8E rr rr         stx famistudio_song_list_lo
000003r 2  8C rr rr         sty famistudio_song_list_hi
000006r 2  86 rr            stx @music_data_ptr+0
000008r 2  84 rr            sty @music_data_ptr+1
00000Ar 2               
00000Ar 2               .if FAMISTUDIO_DUAL_SUPPORT
00000Ar 2  AA               tax
00000Br 2  F0 02            beq @pal
00000Dr 2  A9 61            lda #97
00000Fr 2               @pal:
00000Fr 2               .else
00000Fr 2                   .if FAMISTUDIO_CFG_PAL_SUPPORT
00000Fr 2                       lda #0
00000Fr 2                   .endif
00000Fr 2                   .if FAMISTUDIO_CFG_NTSC_SUPPORT
00000Fr 2                       lda #97
00000Fr 2                   .endif
00000Fr 2               .endif
00000Fr 2  8D rr rr         sta famistudio_pal_adjust
000012r 2               
000012r 2  20 rr rr         jsr famistudio_music_stop
000015r 2               
000015r 2                   ; Instrument address
000015r 2  A0 01            ldy #1
000017r 2  B1 rr            lda (@music_data_ptr),y
000019r 2  8D rr rr         sta famistudio_instrument_lo
00001Cr 2  C8               iny
00001Dr 2  B1 rr            lda (@music_data_ptr),y
00001Fr 2  8D rr rr         sta famistudio_instrument_hi
000022r 2  C8               iny
000023r 2               
000023r 2                   ; Expansions instrument address
000023r 2                   .if FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_S5B
000023r 2                       lda (@music_data_ptr),y
000023r 2                       sta famistudio_exp_instrument_lo
000023r 2                       iny
000023r 2                       lda (@music_data_ptr),y
000023r 2                       sta famistudio_exp_instrument_hi
000023r 2                       iny
000023r 2                   .endif
000023r 2               
000023r 2                   ; Sample list address
000023r 2  B1 rr            lda (@music_data_ptr),y
000025r 2  8D rr rr         sta famistudio_dpcm_list_lo
000028r 2  C8               iny
000029r 2  B1 rr            lda (@music_data_ptr),y
00002Br 2  8D rr rr         sta famistudio_dpcm_list_hi
00002Er 2               
00002Er 2  A9 80            lda #$80 ; Previous pulse period MSB, to not write it when not changed
000030r 2  8D rr rr         sta famistudio_pulse1_prev
000033r 2  8D rr rr         sta famistudio_pulse2_prev
000036r 2               
000036r 2  A9 0F            lda #$0f ; Enable channels, stop DMC
000038r 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
00003Br 2  A9 80            lda #$80 ; Disable triangle length counter
00003Dr 2  8D 08 40         sta FAMISTUDIO_APU_TRI_LINEAR
000040r 2  A9 00            lda #$00 ; Load noise length
000042r 2  8D 0F 40         sta FAMISTUDIO_APU_NOISE_HI
000045r 2               
000045r 2  A9 30            lda #$30 ; Volumes to 0
000047r 2  8D 00 40         sta FAMISTUDIO_APU_PL1_VOL
00004Ar 2  8D 04 40         sta FAMISTUDIO_APU_PL2_VOL
00004Dr 2  8D 0C 40         sta FAMISTUDIO_APU_NOISE_VOL
000050r 2  A9 08            lda #$08 ; No sweep
000052r 2  8D 01 40         sta FAMISTUDIO_APU_PL1_SWEEP
000055r 2  8D 05 40         sta FAMISTUDIO_APU_PL2_SWEEP
000058r 2               
000058r 2               .if FAMISTUDIO_EXP_VRC6
000058r 2               @init_vrc6:
000058r 2                   lda #0
000058r 2                   sta FAMISTUDIO_VRC6_FREQ_CTRL ; NESDEV wiki says to write zero at startup.
000058r 2               .endif
000058r 2               
000058r 2               .if FAMISTUDIO_EXP_VRC7
000058r 2               @init_vrc7:
000058r 2                   lda #0
000058r 2                   sta FAMISTUDIO_VRC7_SILENCE ; Enable VRC7 audio.
000058r 2               .endif
000058r 2               
000058r 2               @init_epsm:
000058r 2               .if FAMISTUDIO_EXP_EPSM
000058r 2                   lda #FAMISTUDIO_EPSM_REG_TONE
000058r 2                   sta FAMISTUDIO_EPSM_ADDR
000058r 2                   lda #$38 ; No noise, just 3 tones for now.
000058r 2                   sta FAMISTUDIO_EPSM_DATA
000058r 2                   lda #$29
000058r 2                   sta FAMISTUDIO_EPSM_ADDR
000058r 2                   lda #$80
000058r 2                   sta FAMISTUDIO_EPSM_DATA
000058r 2                   lda #$27
000058r 2                   sta FAMISTUDIO_EPSM_ADDR
000058r 2                   lda #$00
000058r 2                   sta FAMISTUDIO_EPSM_DATA
000058r 2                   lda #$11
000058r 2                   sta FAMISTUDIO_EPSM_ADDR
000058r 2                   lda #$37
000058r 2                   sta FAMISTUDIO_EPSM_DATA
000058r 2               .endif
000058r 2               
000058r 2               .if FAMISTUDIO_EXP_MMC5
000058r 2               @init_mmc5:
000058r 2                   lda #$00
000058r 2                   sta FAMISTUDIO_MMC5_PCM_MODE
000058r 2                   lda #$03
000058r 2                   sta FAMISTUDIO_MMC5_SND_CHN
000058r 2                   lda #$80 ; Previous pulse period MSB, to not write it when not changed
000058r 2                   sta famistudio_mmc5_pulse1_prev
000058r 2                   sta famistudio_mmc5_pulse2_prev
000058r 2               .endif
000058r 2               
000058r 2               .if FAMISTUDIO_EXP_S5B
000058r 2               @init_s5b:
000058r 2                   lda #FAMISTUDIO_S5B_REG_TONE
000058r 2                   sta FAMISTUDIO_S5B_ADDR
000058r 2                   lda #$38 ; No noise, just 3 tones for now.
000058r 2                   sta FAMISTUDIO_S5B_DATA
000058r 2               .endif
000058r 2               
000058r 2  4C rr rr         jmp famistudio_music_stop
00005Br 2               
00005Br 2               ;======================================================================================================================
00005Br 2               ; FAMISTUDIO_MUSIC_STOP (public)
00005Br 2               ;
00005Br 2               ; Stops any music currently playing, if any. Note that this will not update the APU, so sound might linger. Calling
00005Br 2               ; famistudio_update after this will update the APU.
00005Br 2               ;
00005Br 2               ; [in] no input params.
00005Br 2               ;======================================================================================================================
00005Br 2               
00005Br 2               famistudio_music_stop:
00005Br 2               
00005Br 2  A9 00            lda #0
00005Dr 2  8D rr rr         sta famistudio_song_speed
000060r 2  8D rr rr         sta famistudio_dpcm_effect
000063r 2               
000063r 2  A2 00            ldx #0
000065r 2               
000065r 2               @set_channels:
000065r 2               
000065r 2  9D rr rr         sta famistudio_chn_repeat,x
000068r 2  9D rr rr         sta famistudio_chn_note,x
00006Br 2  9D rr rr         sta famistudio_chn_ref_len,x
00006Er 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
00006Er 2  9D rr rr             sta famistudio_chn_volume_track,x
000071r 2                   .endif
000071r 2                   .if FAMISTUDIO_USE_VIBRATO || FAMISTUDIO_USE_ARPEGGIO
000071r 2  9D rr rr             sta famistudio_chn_env_override,x
000074r 2                   .endif
000074r 2                   .if FAMISTUDIO_CFG_EQUALIZER
000074r 2                       sta famistudio_chn_note_counter,x
000074r 2                   .endif
000074r 2                   .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
000074r 2  A9 FF                lda #$ff
000076r 2  9D rr rr             sta famistudio_chn_note_delay,x
000079r 2  9D rr rr             sta famistudio_chn_cut_delay,x
00007Cr 2  A9 00                lda #0
00007Er 2                   .endif
00007Er 2  E8               inx
00007Fr 2  E0 05            cpx #FAMISTUDIO_NUM_CHANNELS
000081r 2  D0 E2            bne @set_channels
000083r 2               
000083r 2               .if FAMISTUDIO_USE_DUTYCYCLE_EFFECT
000083r 2  A2 00        ldx #0
000085r 2               @set_duty_cycles:
000085r 2  9D rr rr         sta famistudio_duty_cycle,x
000088r 2  E8               inx
000089r 2  E0 03            cpx #FAMISTUDIO_NUM_DUTY_CYCLES
00008Br 2  D0 F8            bne @set_duty_cycles
00008Dr 2               .endif
00008Dr 2               
00008Dr 2               .if FAMISTUDIO_USE_SLIDE_NOTES
00008Dr 2  A2 00            ldx #0
00008Fr 2               @set_slides:
00008Fr 2  9D rr rr         sta famistudio_slide_step, x
000092r 2  E8               inx
000093r 2  E0 04            cpx #FAMISTUDIO_NUM_SLIDES
000095r 2  D0 F8            bne @set_slides
000097r 2               .endif
000097r 2               
000097r 2               .if FAMISTUDIO_USE_VOLUME_SLIDES
000097r 2  A2 00            ldx #0
000099r 2               @set_volume_slides:
000099r 2  9D rr rr         sta famistudio_chn_volume_slide_step, x
00009Cr 2  9D rr rr         sta famistudio_chn_volume_slide_target, x
00009Fr 2  E8               inx
0000A0r 2  E0 04            cpx #FAMISTUDIO_NUM_VOLUME_SLIDES
0000A2r 2  D0 F5            bne @set_volume_slides
0000A4r 2               .endif
0000A4r 2               
0000A4r 2  A2 00            ldx #0
0000A6r 2               
0000A6r 2               @set_envelopes:
0000A6r 2               
0000A6r 2  A9 rr            lda #<famistudio_dummy_envelope
0000A8r 2  9D rr rr         sta famistudio_env_addr_lo,x
0000ABr 2  A9 rr            lda #>famistudio_dummy_envelope
0000ADr 2  9D rr rr         sta famistudio_env_addr_hi,x
0000B0r 2  A9 00            lda #0
0000B2r 2  9D rr rr         sta famistudio_env_repeat,x
0000B5r 2  9D rr rr         sta famistudio_env_value,x
0000B8r 2  9D rr rr         sta famistudio_env_ptr,x
0000BBr 2  E8               inx
0000BCr 2  E0 0B            cpx #FAMISTUDIO_NUM_ENVELOPES
0000BEr 2  D0 E6            bne @set_envelopes
0000C0r 2               
0000C0r 2  A2 00            ldx #0
0000C2r 2               @set_pitch_envelopes:
0000C2r 2               
0000C2r 2  A9 rr            lda #<famistudio_dummy_pitch_envelope
0000C4r 2  9D rr rr         sta famistudio_pitch_env_addr_lo,x
0000C7r 2  A9 rr            lda #>famistudio_dummy_pitch_envelope
0000C9r 2  9D rr rr         sta famistudio_pitch_env_addr_hi,x
0000CCr 2  A9 00            lda #0
0000CEr 2  9D rr rr         sta famistudio_pitch_env_repeat,x
0000D1r 2  9D rr rr         sta famistudio_pitch_env_value_lo,x
0000D4r 2  9D rr rr         sta famistudio_pitch_env_value_hi,x
0000D7r 2                   .if FAMISTUDIO_USE_PITCH_TRACK
0000D7r 2  9D rr rr             sta famistudio_pitch_env_fine_value,x
0000DAr 2                   .endif
0000DAr 2  A9 01            lda #1
0000DCr 2  9D rr rr         sta famistudio_pitch_env_ptr,x
0000DFr 2  E8               inx
0000E0r 2  E0 03            cpx #FAMISTUDIO_NUM_PITCH_ENVELOPES
0000E2r 2  D0 DE            bne @set_pitch_envelopes
0000E4r 2               
0000E4r 2  4C rr rr         jmp famistudio_sample_stop
0000E7r 2               
0000E7r 2               ;======================================================================================================================
0000E7r 2               ; FAMISTUDIO_MUSIC_PLAY (public)
0000E7r 2               ;
0000E7r 2               ; Plays a song from the loaded music data (from a previous call to famistudio_init).
0000E7r 2               ;
0000E7r 2               ; [in] a : Song index.
0000E7r 2               ;======================================================================================================================
0000E7r 2               
0000E7r 2               famistudio_music_play:
0000E7r 2                   @tmp = famistudio_r0
0000E7r 2                   @song_list_ptr = famistudio_ptr0
0000E7r 2                   @temp_env_ptr  = famistudio_ptr1
0000E7r 2               
0000E7r 2  AE rr rr         ldx famistudio_song_list_lo
0000EAr 2  86 rr            stx @song_list_ptr+0
0000ECr 2  AE rr rr         ldx famistudio_song_list_hi
0000EFr 2  86 rr            stx @song_list_ptr+1
0000F1r 2               
0000F1r 2  A0 00            ldy #0
0000F3r 2  D1 rr            cmp (@song_list_ptr),y
0000F5r 2  90 01            bcc @valid_song
0000F7r 2  60               rts ; Invalid song index.
0000F8r 2               
0000F8r 2               @valid_song:
0000F8r 2               .if FAMISTUDIO_NUM_CHANNELS = 5
0000F8r 2                   ; Here we basically assume we have 17 songs or less (17 songs * 14 bytes per song + 5 bytes header < 256).
0000F8r 2  0A               asl
0000F9r 2  85 rr            sta @tmp
0000FBr 2  0A               asl
0000FCr 2  AA               tax
0000FDr 2  0A               asl
0000FEr 2  65 rr            adc @tmp
000100r 2  86 rr            stx @tmp
000102r 2  65 rr            adc @tmp
000104r 2  69 05            adc #5 ; Song count + instrument ptr + sample ptr
000106r 2  A8               tay
000107r 2               .else
000107r 2                   ; This supports a larger number of songs as it increments the pointer itself, not Y.
000107r 2                   ; As the number of channel becomes huge, this become necessary to support a decent
000107r 2                   ; number of songs.
000107r 2                   tax
000107r 2                   lda @song_list_ptr+0
000107r 2                   @song_mult_loop:
000107r 2                       dex
000107r 2                       bmi @song_mult_loop_done
000107r 2                       adc #(FAMISTUDIO_NUM_CHANNELS * 2 + 4)
000107r 2                       bcc @song_mult_loop
000107r 2                       inc @song_list_ptr+1
000107r 2                       clc
000107r 2                       bcc @song_mult_loop
000107r 2               
000107r 2                   @song_mult_loop_done:
000107r 2                       sta @song_list_ptr+0
000107r 2               
000107r 2               .if FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_S5B
000107r 2                   ldy #7 ; Song count + instrument ptr + exp instrument ptr + sample ptr
000107r 2               .else
000107r 2                   ldy #5 ; Song count + instrument ptr + sample ptr
000107r 2               .endif
000107r 2               .endif
000107r 2               
000107r 2  20 rr rr         jsr famistudio_music_stop
00010Ar 2               
00010Ar 2  A2 00            ldx #0
00010Cr 2               
00010Cr 2               @set_channels:
00010Cr 2               
00010Cr 2                   ; Channel data address
00010Cr 2  B1 rr            lda (@song_list_ptr),y
00010Er 2  9D rr rr         sta famistudio_chn_ptr_lo,x
000111r 2  C8               iny
000112r 2  B1 rr            lda (@song_list_ptr),y
000114r 2  9D rr rr         sta famistudio_chn_ptr_hi,x
000117r 2  C8               iny
000118r 2               
000118r 2  A9 00            lda #0
00011Ar 2  9D rr rr         sta famistudio_chn_repeat,x
00011Dr 2  9D rr rr         sta famistudio_chn_note,x
000120r 2  9D rr rr         sta famistudio_chn_ref_len,x
000123r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
000123r 2  A9 F0                lda #$f0
000125r 2  9D rr rr             sta famistudio_chn_volume_track,x
000128r 2                   .endif
000128r 2                   .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
000128r 2  A9 FF                lda #$ff
00012Ar 2  9D rr rr             sta famistudio_chn_note_delay,x
00012Dr 2  9D rr rr             sta famistudio_chn_cut_delay,x
000130r 2                   .endif
000130r 2               
000130r 2               @nextchannel:
000130r 2  E8               inx
000131r 2  E0 05            cpx #FAMISTUDIO_NUM_CHANNELS
000133r 2  D0 D7            bne @set_channels
000135r 2               
000135r 2               .if FAMISTUDIO_USE_FAMITRACKER_TEMPO
000135r 2               ;!!! FAMISTUDIO DRIVER MODIFICATION BEGIN
000135r 2               .if 0   ;*  ORIGINAL BEGIN
000135r 2                   lda famistudio_pal_adjust
000135r 2               .endif  ;*  ORIGINAL END
000135r 2               ;*  MODIFIED
000135r 2  A5 rr            lda framerate
000137r 2               ;!!! FAMISTUDIO DRIVER MODIFICATION END
000137r 2  F0 02            beq @pal
000139r 2  C8               iny
00013Ar 2  C8               iny
00013Br 2               @pal:
00013Br 2               
00013Br 2                   ; Tempo increment.
00013Br 2  B1 rr            lda (@song_list_ptr),y
00013Dr 2  8D rr rr         sta famistudio_tempo_step_lo
000140r 2  C8               iny
000141r 2  B1 rr            lda (@song_list_ptr),y
000143r 2  8D rr rr         sta famistudio_tempo_step_hi
000146r 2               
000146r 2  A9 00            lda #0 ; Reset tempo accumulator
000148r 2  8D rr rr         sta famistudio_tempo_acc_lo
00014Br 2  A9 06            lda #6 ; Default speed
00014Dr 2  8D rr rr         sta famistudio_tempo_acc_hi
000150r 2  8D rr rr         sta famistudio_song_speed ; Apply default speed, this also enables music
000153r 2               .else
000153r 2                   lda (@song_list_ptr),y
000153r 2                   sta famistudio_tempo_env_ptr_lo
000153r 2                   sta @temp_env_ptr+0
000153r 2                   iny
000153r 2                   lda (@song_list_ptr),y
000153r 2                   sta famistudio_tempo_env_ptr_hi
000153r 2                   sta @temp_env_ptr+1
000153r 2                   iny
000153r 2                   lda (@song_list_ptr),y
000153r 2               .if FAMISTUDIO_DUAL_SUPPORT ; Dual mode
000153r 2               ;!!! FAMISTUDIO DRIVER MODIFICATION BEGIN
000153r 2               .if 0   ;*  ORIGINAL BEGIN
000153r 2                   ldx famistudio_pal_adjust
000153r 2               .endif  ;*  ORIGINAL END
000153r 2               ;*  MODIFIED
000153r 2                   ldx framerate
000153r 2               ;!!! FAMISTUDIO DRIVER MODIFICATION END
000153r 2                   bne @ntsc_target
000153r 2                   ora #1
000153r 2                   @ntsc_target:
000153r 2               .elseif FAMISTUDIO_CFG_PAL_SUPPORT ; PAL only
000153r 2                   ora #1
000153r 2               .endif
000153r 2                   tax
000153r 2                   lda famistudio_tempo_frame_lookup, x ; Lookup contains the number of frames to run (0,1,2) to maintain tempo
000153r 2                   sta famistudio_tempo_frame_num
000153r 2                   ldy #0
000153r 2                   sty famistudio_tempo_env_idx
000153r 2                   lda (@temp_env_ptr),y
000153r 2                   clc
000153r 2                   adc #1
000153r 2                   sta famistudio_tempo_env_counter
000153r 2                   lda #6
000153r 2                   sta famistudio_song_speed ; Non-zero simply so the song isnt considered paused.
000153r 2               .endif
000153r 2               
000153r 2               .if FAMISTUDIO_EXP_VRC7
000153r 2                   lda #0
000153r 2                   ldx #5
000153r 2                   @clear_vrc7_loop:
000153r 2                       sta famistudio_chn_vrc7_prev_hi, x
000153r 2                       sta famistudio_chn_vrc7_patch, x
000153r 2                       sta famistudio_chn_vrc7_trigger,x
000153r 2                       dex
000153r 2                       bpl @clear_vrc7_loop
000153r 2               .endif
000153r 2               
000153r 2               .if FAMISTUDIO_EXP_EPSM
000153r 2               .if FAMISTUDIO_EXP_EPSM_TRIG_CHN > 0
000153r 2                   lda #0
000153r 2                   ldx #FAMISTUDIO_EXP_EPSM_FM_CHN_CNT + FAMISTUDIO_EXP_EPSM_RHYTHM_CNT - 1
000153r 2                   @clear_epsm_loop:
000153r 2                       sta famistudio_chn_epsm_trigger,x
000153r 2                       dex
000153r 2                       bpl @clear_epsm_loop
000153r 2               .endif
000153r 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT > 0
000153r 2                   lda #0
000153r 2                   sta famistudio_epsm_env_period_lo
000153r 2                   sta famistudio_epsm_env_period_hi
000153r 2                   sta famistudio_epsm_env_override
000153r 2                   ldx #(FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT - 1)
000153r 2                   @clear_epsm_sq_loop:
000153r 2                       sta famistudio_epsm_chn_env_shape, x
000153r 2                       sta famistudio_epsm_chn_env_octave, x
000153r 2                       dex
000153r 2                       bpl @clear_epsm_sq_loop
000153r 2               .endif
000153r 2               .endif
000153r 2               
000153r 2               .if FAMISTUDIO_EXP_VRC6
000153r 2                   lda #0
000153r 2                   sta famistudio_vrc6_saw_volume
000153r 2                   .if FAMISTUDIO_USE_PHASE_RESET
000153r 2                       sta famistudio_vrc6_pulse1_prev_hi
000153r 2                       sta famistudio_vrc6_pulse2_prev_hi
000153r 2                       sta famistudio_vrc6_saw_prev_hi
000153r 2                   .endif
000153r 2               .endif
000153r 2               
000153r 2               .if FAMISTUDIO_USE_PHASE_RESET
000153r 2  A9 00            lda #0
000155r 2  8D rr rr         sta famistudio_phase_reset
000158r 2                   .if FAMISTUDIO_EXP_N163
000158r 2                       sta famistudio_phase_reset_n163
000158r 2                   .endif
000158r 2               .endif
000158r 2               
000158r 2               .if FAMISTUDIO_USE_DELTA_COUNTER
000158r 2  A9 FF            lda #$ff
00015Ar 2  8D rr rr         sta famistudio_dmc_delta_counter
00015Dr 2               .endif
00015Dr 2               
00015Dr 2               .if FAMISTUDIO_EXP_FDS
00015Dr 2                   lda #0
00015Dr 2                   sta famistudio_fds_mod_envelope+0
00015Dr 2                   sta famistudio_fds_mod_envelope+1
00015Dr 2                   sta famistudio_fds_mod_speed+0
00015Dr 2                   sta famistudio_fds_mod_speed+1
00015Dr 2                   sta famistudio_fds_mod_depth
00015Dr 2                   sta famistudio_fds_mod_delay
00015Dr 2                   sta famistudio_fds_mod_delay_counter
00015Dr 2                   sta famistudio_fds_override_flags
00015Dr 2                   sta famistudio_fds_wave_index
00015Dr 2                   .if FAMISTUDIO_USE_FDS_AUTOMOD
00015Dr 2                       sta famistudio_fds_automod_numer
00015Dr 2                       sta famistudio_fds_automod_denom
00015Dr 2                   .endif
00015Dr 2                   .if FAMISTUDIO_USE_PHASE_RESET
00015Dr 2                       sta famistudio_fds_prev_hi
00015Dr 2                   .endif
00015Dr 2               .endif
00015Dr 2               
00015Dr 2               .if FAMISTUDIO_EXP_N163
00015Dr 2                   lda #0
00015Dr 2                   ldx #(FAMISTUDIO_EXP_N163_CHN_CNT - 1)
00015Dr 2                   @clear_n163_loop:
00015Dr 2                       sta famistudio_chn_n163_wave_index, x
00015Dr 2                       sta famistudio_chn_n163_wave_len, x
00015Dr 2                       dex
00015Dr 2                       bpl @clear_n163_loop
00015Dr 2               .endif
00015Dr 2               
00015Dr 2               .if FAMISTUDIO_EXP_S5B
00015Dr 2                   lda #0
00015Dr 2                   sta famistudio_s5b_env_period_lo
00015Dr 2                   sta famistudio_s5b_env_period_hi
00015Dr 2                   sta famistudio_s5b_env_override
00015Dr 2                   sta famistudio_s5b_chn_env_shape+0
00015Dr 2                   sta famistudio_s5b_chn_env_shape+1
00015Dr 2                   sta famistudio_s5b_chn_env_shape+2
00015Dr 2                   sta famistudio_s5b_chn_env_octave+0
00015Dr 2                   sta famistudio_s5b_chn_env_octave+1
00015Dr 2                   sta famistudio_s5b_chn_env_octave+2
00015Dr 2               .endif
00015Dr 2               
00015Dr 2               @skip:
00015Dr 2  60               rts
00015Er 2               
00015Er 2               ;======================================================================================================================
00015Er 2               ; FAMISTUDIO_MUSIC_PAUSE (public)
00015Er 2               ;
00015Er 2               ; Pause/unpause the currently playing song. Note that this will not update the APU, so sound might linger. Calling
00015Er 2               ; famistudio_update after this will update the APU.
00015Er 2               ;
00015Er 2               ; [in] a : zero to play, non-zero to pause.
00015Er 2               ;======================================================================================================================
00015Er 2               
00015Er 2               famistudio_music_pause:
00015Er 2               
00015Er 2  AA               tax
00015Fr 2  F0 18            beq @unpause
000161r 2               
000161r 2               @pause:
000161r 2               
000161r 2  20 rr rr         jsr famistudio_sample_stop
000164r 2               
000164r 2  A9 00            lda #0
000166r 2  8D rr rr         sta famistudio_env_value+FAMISTUDIO_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000169r 2  8D rr rr         sta famistudio_env_value+FAMISTUDIO_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
00016Cr 2  8D rr rr         sta famistudio_env_value+FAMISTUDIO_CH2_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
00016Fr 2  8D rr rr         sta famistudio_env_value+FAMISTUDIO_CH3_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .if FAMISTUDIO_EXP_VRC6
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC6_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC6_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC6_CH2_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_VRC7
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC7_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC7_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC7_CH2_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC7_CH3_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC7_CH4_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_VRC7_CH5_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_FDS
000172r 2                   sta famistudio_env_value+FAMISTUDIO_FDS_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_MMC5
000172r 2                   sta famistudio_env_value+FAMISTUDIO_MMC5_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_MMC5_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_N163
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH2_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH3_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH4_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH5_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH6_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_N163_CH7_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_S5B
000172r 2                   sta famistudio_env_value+FAMISTUDIO_S5B_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_S5B_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2                   sta famistudio_env_value+FAMISTUDIO_S5B_CH2_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 0
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 1
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH1_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 2
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH2_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 3
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH3_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 4
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH4_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 5
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH5_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 6
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH6_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 7
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH7_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .if FAMISTUDIO_EXP_EPSM_ENV_CNT > 8
000172r 2                   sta famistudio_env_value+FAMISTUDIO_EPSM_CH8_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
000172r 2               .endif
000172r 2               .endif
000172r 2  AD rr rr         lda famistudio_song_speed ; <= 0 pauses the music
000175r 2  09 80            ora #$80
000177r 2  D0 05            bne @done
000179r 2               @unpause:
000179r 2  AD rr rr         lda famistudio_song_speed ; > 0 unpause music
00017Cr 2  29 7F            and #$7f
00017Er 2               @done:
00017Er 2  8D rr rr         sta famistudio_song_speed
000181r 2               
000181r 2  60               rts
000182r 2               
000182r 2               ;======================================================================================================================
000182r 2               ; FAMISTUDIO_GET_NOTE_PITCH_MACRO (internal)
000182r 2               ;
000182r 2               ; Uber-macro used to compute the final pitch of a note, taking into account the current note, arpeggios, instrument
000182r 2               ; pitch envelopes, slide notes and fine pitch tracks.
000182r 2               ;
000182r 2               ; [in] x : note index.
000182r 2               ; [in] y : slide/pitch envelope index.
000182r 2               ; [out] famistudio_ptr1 : Final note pitch.
000182r 2               ;======================================================================================================================
000182r 2               
000182r 2               .macro famistudio_get_note_pitch_macro pitch_env_offset, pitch_shift, note_table_lsb, note_table_msb
000182r 2               
000182r 2                   .local @pitch
000182r 2                   .local @tmp_ror
000182r 2                   .local @pos
000182r 2                   .local @no_slide
000182r 2                   .local @no_adjust
000182r 2               
000182r 2                   @pitch   = famistudio_ptr1
000182r 2                   @tmp_ror = famistudio_r0
000182r 2               
000182r 2               .if FAMISTUDIO_USE_PITCH_TRACK
000182r 2               
000182r 2                   ; Pitch envelope + fine pitch (sign extended)
000182r 2                   clc
000182r 2                   lda famistudio_pitch_env_fine_value+pitch_env_offset, y
000182r 2                   adc famistudio_pitch_env_value_lo+pitch_env_offset, y
000182r 2                   sta @pitch+0
000182r 2                   lda famistudio_pitch_env_fine_value+pitch_env_offset, y
000182r 2                   and #$80
000182r 2                   beq @pos
000182r 2                   lda #$ff
000182r 2               @pos:
000182r 2                   adc famistudio_pitch_env_value_hi+pitch_env_offset, y
000182r 2                   sta @pitch+1
000182r 2               
000182r 2               .else
000182r 2               
000182r 2                   ; Pitch envelope only
000182r 2                   lda famistudio_pitch_env_value_lo+pitch_env_offset, y
000182r 2                   sta @pitch+0
000182r 2                   lda famistudio_pitch_env_value_hi+pitch_env_offset, y
000182r 2                   sta @pitch+1
000182r 2               
000182r 2               .endif
000182r 2               
000182r 2               .if FAMISTUDIO_USE_SLIDE_NOTES
000182r 2               
000182r 2                   ; Check if there is an active slide.
000182r 2                   lda famistudio_slide_step+pitch_env_offset, y
000182r 2                   beq @no_slide
000182r 2               
000182r 2                   ; Add slide
000182r 2               .if pitch_shift >= 1
000182r 2                   ; These channels dont have fractional part for slides and have the same shift for slides + pitch.
000182r 2                   clc
000182r 2                   lda famistudio_slide_pitch_lo+pitch_env_offset, y
000182r 2                   adc @pitch+0
000182r 2                   sta @pitch+0
000182r 2                   lda famistudio_slide_pitch_hi+pitch_env_offset, y
000182r 2                   adc @pitch+1
000182r 2                   sta @pitch+1
000182r 2                .else
000182r 2                   ; Most channels have 1 bit of fraction for slides.
000182r 2                   lda famistudio_slide_pitch_hi+pitch_env_offset, y
000182r 2                   cmp #$80 ; Sign extend upcoming right shift.
000182r 2                   ror ; We have 1 bit of fraction for slides, shift right hi byte.
000182r 2                   sta @tmp_ror
000182r 2                   lda famistudio_slide_pitch_lo+pitch_env_offset, y
000182r 2                   ror ; Shift right low byte.
000182r 2                   clc
000182r 2                   adc @pitch+0
000182r 2                   sta @pitch+0
000182r 2                   lda @tmp_ror
000182r 2                   adc @pitch+1
000182r 2                   sta @pitch+1
000182r 2               .endif
000182r 2               .endif
000182r 2               
000182r 2               @no_slide:
000182r 2               
000182r 2                   .if pitch_shift >= 1
000182r 2                       asl @pitch+0
000182r 2                       rol @pitch+1
000182r 2                   .if pitch_shift >= 2
000182r 2                       asl @pitch+0
000182r 2                       rol @pitch+1
000182r 2                   .if pitch_shift >= 3
000182r 2                       asl @pitch+0
000182r 2                       rol @pitch+1
000182r 2                   .if pitch_shift >= 4
000182r 2                       asl @pitch+0
000182r 2                       rol @pitch+1
000182r 2                   .if pitch_shift >= 5
000182r 2                       asl @pitch+0
000182r 2                       rol @pitch+1
000182r 2                   .endif
000182r 2                   .endif
000182r 2                   .endif
000182r 2                   .endif
000182r 2                   .endif
000182r 2               
000182r 2                   ; Finally, add note pitch.
000182r 2                   clc
000182r 2                   lda note_table_lsb,x
000182r 2                   adc @pitch+0
000182r 2                   sta @pitch+0
000182r 2                   lda note_table_msb,x
000182r 2                   adc @pitch+1
000182r 2                   sta @pitch+1
000182r 2               
000182r 2               .endmacro
000182r 2               
000182r 2               famistudio_get_note_pitch:
000182r 2  18 B9 rr rr      famistudio_get_note_pitch_macro 0, 0, famistudio_note_table_lsb, famistudio_note_table_msb
000186r 2  79 rr rr 85  
00018Ar 2  rr B9 rr rr  
0001C4r 2  60               rts
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_VRC6
0001C5r 2               famistudio_get_note_pitch_vrc6_saw:
0001C5r 2                   famistudio_get_note_pitch_macro 0, 0, famistudio_saw_note_table_lsb, famistudio_saw_note_table_msb
0001C5r 2                   rts
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_SMOOTH_VIBRATO (internal)
0001C5r 2               ;
0001C5r 2               ; Implementation of Blaarg's smooth vibrato to eliminate pops on square channels. Called either from regular channel
0001C5r 2               ; updates or from SFX code.
0001C5r 2               ;
0001C5r 2               ; [in] a : new hi period.
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               .macro famistudio_smooth_vibrato pulse_lo, pulse_prev, reg_hi, reg_lo, reg_sweep
0001C5r 2               
0001C5r 2                   .local @hi_delta_too_big
0001C5r 2                   .local @done
0001C5r 2               
0001C5r 2                   ; Blaarg's smooth vibrato technique, only used if high period delta is 1 or -1.
0001C5r 2                   and #7 ; Clamp hi-period to sane range, breaks smooth vibrato otherwise.
0001C5r 2                   tax ; X = new hi-period
0001C5r 2                   sec
0001C5r 2                   sbc pulse_prev ; A = signed hi-period delta.
0001C5r 2                   beq @done
0001C5r 2                   stx pulse_prev
0001C5r 2                   tay
0001C5r 2                   iny ; We only care about -1 ($ff) and 1. Adding one means we only check of 0 or 2, we already checked for zero (so < 3).
0001C5r 2                   cpy #$03
0001C5r 2                   bcs @hi_delta_too_big
0001C5r 2                   ldx #$40
0001C5r 2                   stx FAMISTUDIO_APU_FRAME_CNT ; Reset frame counter in case it was about to clock
0001C5r 2                   lda famistudio_smooth_vibrato_period_lo_lookup, y ; Be sure low 8 bits of timer period are $ff (for positive delta), or $00 (for negative delta)
0001C5r 2                   sta reg_lo
0001C5r 2                   lda famistudio_smooth_vibrato_sweep_lookup, y ; Sweep enabled, shift = 7, set negative flag or delta is negative..
0001C5r 2                   sta reg_sweep
0001C5r 2                   lda #$c0
0001C5r 2                   sta FAMISTUDIO_APU_FRAME_CNT ; Clock sweep immediately
0001C5r 2                   lda #$08
0001C5r 2                   sta reg_sweep ; Disable sweep
0001C5r 2                   lda pulse_lo
0001C5r 2                   sta reg_lo ; Restore lo-period.
0001C5r 2                   jmp @done
0001C5r 2               @hi_delta_too_big:
0001C5r 2                   stx reg_hi
0001C5r 2               @done:
0001C5r 2               .endmacro
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Uber-macro used to update the APU registers for a given 2A03/VRC6/MMC5 channel. This macro is an absolute mess, but
0001C5r 2               ; it is still more maintainable than having many different functions.
0001C5r 2               ;
0001C5r 2               ; [in] no input params.
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               .macro famistudio_update_channel_sound idx, env_offset, pulse_prev, reg_hi, reg_lo, reg_vol, reg_sweep
0001C5r 2               
0001C5r 2                   .local @pitch
0001C5r 2                   .local @tmp
0001C5r 2                   .local @nocut
0001C5r 2                   .local @set_volume
0001C5r 2                   .local @compute_volume
0001C5r 2                   .local @hi_delta_too_big
0001C5r 2                   .local @noise_slide_shift_loop
0001C5r 2                   .local @no_noise_slide
0001C5r 2               
0001C5r 2                   @tmp   = famistudio_r0
0001C5r 2                   @pitch = famistudio_ptr1
0001C5r 2               
0001C5r 2                   lda famistudio_chn_note+idx
0001C5r 2                   bne @nocut
0001C5r 2                   jmp @set_volume
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2                   clc
0001C5r 2                   adc famistudio_env_value+env_offset+FAMISTUDIO_ENV_NOTE_OFF
0001C5r 2               
0001C5r 2               .if idx = 3 ; Noise channel is a bit special
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_USE_NOISE_SLIDE_NOTES
0001C5r 2               
0001C5r 2                   ; Check if there is an active slide on the noise channel.
0001C5r 2                   ldy famistudio_slide_step+FAMISTUDIO_NOISE_SLIDE_INDEX
0001C5r 2                   beq @no_noise_slide
0001C5r 2               
0001C5r 2                       ; We have 4 bits of fraction for noise slides.
0001C5r 2                       sta @tmp
0001C5r 2               
0001C5r 2                       lda famistudio_slide_pitch_lo+FAMISTUDIO_NOISE_SLIDE_INDEX
0001C5r 2                       sta @pitch+0
0001C5r 2                       lda famistudio_slide_pitch_hi+FAMISTUDIO_NOISE_SLIDE_INDEX
0001C5r 2                       cmp #$80
0001C5r 2                       ror
0001C5r 2                       ror @pitch+0
0001C5r 2                       cmp #$80
0001C5r 2                       ror
0001C5r 2                       ror @pitch+0
0001C5r 2                       cmp #$80
0001C5r 2                       ror
0001C5r 2                       ror @pitch+0
0001C5r 2                       cmp #$80
0001C5r 2                       ror
0001C5r 2                       lda @pitch+0
0001C5r 2                       ror
0001C5r 2               
0001C5r 2                       clc
0001C5r 2                       adc @tmp
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               @no_noise_slide:
0001C5r 2                   and #$0f
0001C5r 2                   eor #$0f
0001C5r 2                   sta @tmp
0001C5r 2               
0001C5r 2                   ldx famistudio_env_value+env_offset+FAMISTUDIO_ENV_DUTY_OFF
0001C5r 2                   lda famistudio_duty_lookup, x
0001C5r 2                   asl a
0001C5r 2                   and #$80
0001C5r 2                   ora @tmp
0001C5r 2               
0001C5r 2               .else
0001C5r 2               
0001C5r 2                   .if FAMISTUDIO_DUAL_SUPPORT
0001C5r 2                       clc
0001C5r 2                       adc famistudio_pal_adjust
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; This basically does same as "famistudio_channel_to_pitch_env"
0001C5r 2                   .if idx < 3
0001C5r 2                       ldy #idx
0001C5r 2                   .else
0001C5r 2                       ldy #(idx - 2)
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2                   .if FAMISTUDIO_EXP_VRC6 && idx = FAMISTUDIO_VRC6_CH2_IDX
0001C5r 2                       jsr famistudio_get_note_pitch_vrc6_saw
0001C5r 2                   .else
0001C5r 2                       jsr famistudio_get_note_pitch
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2                   lda @pitch+0
0001C5r 2                   sta reg_lo
0001C5r 2                   lda @pitch+1
0001C5r 2               
0001C5r 2                   ; HACK : VRC6 only. We are out of macro param for NESASM. TODO : Is that still true?
0001C5r 2                   .if idx >= FAMISTUDIO_VRC6_CH0_IDX && idx <= FAMISTUDIO_VRC6_CH2_IDX
0001C5r 2                       .if FAMISTUDIO_USE_PHASE_RESET
0001C5r 2                           sta pulse_prev
0001C5r 2                       .endif
0001C5r 2                       ora #$80
0001C5r 2                   .else
0001C5r 2                       .if (!.blank(pulse_prev)) && ((!FAMISTUDIO_CFG_SFX_SUPPORT) || (.blank(reg_sweep)))
0001C5r 2                           .if (!.blank(reg_sweep)) && FAMISTUDIO_CFG_SMOOTH_VIBRATO
0001C5r 2                               famistudio_smooth_vibrato @pitch, pulse_prev, reg_hi, reg_lo, reg_sweep
0001C5r 2                           .else
0001C5r 2                               cmp pulse_prev
0001C5r 2                               beq @compute_volume
0001C5r 2                               sta pulse_prev
0001C5r 2                           .endif
0001C5r 2                       .endif
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2               .endif ; idx = 3
0001C5r 2               
0001C5r 2               .if .blank(pulse_prev) || .blank(reg_sweep) || FAMISTUDIO_CFG_SFX_SUPPORT || (!FAMISTUDIO_CFG_SMOOTH_VIBRATO)
0001C5r 2                   sta reg_hi
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               @compute_volume:
0001C5r 2               
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+idx
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+env_offset+FAMISTUDIO_ENV_VOLUME_OFF
0001C5r 2                       tax
0001C5r 2                       lda famistudio_volume_table, x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+env_offset+FAMISTUDIO_ENV_VOLUME_OFF
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_VRC6 && (idx = FAMISTUDIO_VRC6_CH2_IDX)
0001C5r 2                   ; VRC6 saw has 6-bits
0001C5r 2                   ldx famistudio_vrc6_saw_volume
0001C5r 2                   bmi @set_volume
0001C5r 2                   asl
0001C5r 2                   ldx famistudio_vrc6_saw_volume
0001C5r 2                   beq @set_volume
0001C5r 2                   asl
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               @set_volume:
0001C5r 2               
0001C5r 2               .if idx = 0 || idx = 1 || idx = 3 || (FAMISTUDIO_EXP_MMC5 && (idx = FAMISTUDIO_MMC5_CH0_IDX || idx = FAMISTUDIO_MMC5_CH1_IDX))
0001C5r 2                   ldx famistudio_env_value+env_offset+FAMISTUDIO_ENV_DUTY_OFF
0001C5r 2                   ora famistudio_duty_lookup, x
0001C5r 2               .elseif FAMISTUDIO_EXP_VRC6 && (idx = FAMISTUDIO_VRC6_CH0_IDX || idx = FAMISTUDIO_VRC6_CH1_IDX)
0001C5r 2                   ldx famistudio_env_value+env_offset+FAMISTUDIO_ENV_DUTY_OFF
0001C5r 2                   ora famistudio_vrc6_duty_lookup, x
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               ; HACK : We are out of macro param for NESASM.
0001C5r 2               .if idx = 2
0001C5r 2                   ora #$80
0001C5r 2               .elseif idx = 3
0001C5r 2                   ora #$f0
0001C5r 2               .endif
0001C5r 2               
0001C5r 2                   sta reg_vol
0001C5r 2               
0001C5r 2               .endmacro
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_FDS
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_USE_FDS_AUTOMOD
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_MUL (internal)
0001C5r 2               ;
0001C5r 2               ; From : https://codebase64.org/doku.php?id=base:8bit_multiplication_16bit_product
0001C5r 2               ; Using the 16x8 version. May overflow if using too large numbers.
0001C5r 2               ;
0001C5r 2               ; [in]  ptr0 : 16-bit number
0001C5r 2               ; [in]  r1   : 8-bit number
0001C5r 2               ; [out] x+a  : Result lo-byte
0001C5r 2               ; [out] y    : Result hi-byte
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               famistudio_mul:
0001C5r 2               
0001C5r 2                   @num1 = famistudio_ptr1
0001C5r 2                   @num2 = famistudio_r1
0001C5r 2               
0001C5r 2                   lda #$00
0001C5r 2                   tay
0001C5r 2                   beq @enter_loop
0001C5r 2               @do_add:
0001C5r 2                   clc
0001C5r 2                   adc @num1+0
0001C5r 2                   tax
0001C5r 2                   tya
0001C5r 2                   adc @num1+1
0001C5r 2                   tay
0001C5r 2                   txa
0001C5r 2               @loop:
0001C5r 2                   asl @num1+0
0001C5r 2                   rol @num1+1
0001C5r 2               @enter_loop:
0001C5r 2                   lsr @num2
0001C5r 2                   bcs @do_add
0001C5r 2                   bne @loop
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_DIV (internal)
0001C5r 2               ;
0001C5r 2               ; From : https://forums.nesdev.org/viewtopic.php?p=895&sid=5c263dea8d9e3cf15cd1093856f211a9#p895 (tepples)
0001C5r 2               ;
0001C5r 2               ; [in]  ptr0 : 16-bit number
0001C5r 2               ; [in]  r1   : 8-bit divisor
0001C5r 2               ; [out] ptr0 : Result
0001C5r 2               ; [out] a    : Remainder
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               famistudio_div:
0001C5r 2               
0001C5r 2                   @dividend = famistudio_ptr1
0001C5r 2                   @divisor  = famistudio_r1
0001C5r 2               
0001C5r 2                   ldx #16
0001C5r 2                   lda #0
0001C5r 2               @divloop:
0001C5r 2                   asl @dividend
0001C5r 2                   rol @dividend+1
0001C5r 2                   rol a
0001C5r 2                   cmp @divisor
0001C5r 2                   bcc @no_sub
0001C5r 2                   sbc @divisor
0001C5r 2                   inc @dividend
0001C5r 2               @no_sub:
0001C5r 2                   dex
0001C5r 2                   bne @divloop
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_FDS_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the FDS audio registers.
0001C5r 2               ;
0001C5r 2               ; [in] no input params.
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               famistudio_update_fds_channel_sound:
0001C5r 2               
0001C5r 2                   @pitch = famistudio_ptr1
0001C5r 2                   @mul   = famistudio_r1
0001C5r 2                   @div   = famistudio_r1
0001C5r 2               
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_FDS_CH0_IDX
0001C5r 2                   bne @nocut
0001C5r 2                   lda #0
0001C5r 2                   sta FAMISTUDIO_FDS_MOD_LO
0001C5r 2                   sta FAMISTUDIO_FDS_SWEEP_BIAS
0001C5r 2                   lda #$80
0001C5r 2                   sta FAMISTUDIO_FDS_MOD_HI
0001C5r 2                   sta FAMISTUDIO_FDS_SWEEP_ENV
0001C5r 2                   jmp @set_volume
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2               
0001C5r 2                   jsr famistudio_update_fds_wave
0001C5r 2               
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_FDS_CH0_IDX
0001C5r 2                   clc
0001C5r 2                   adc famistudio_env_value+FAMISTUDIO_FDS_CH0_ENVS+FAMISTUDIO_ENV_NOTE_OFF
0001C5r 2                   .if FAMISTUDIO_DUAL_SUPPORT
0001C5r 2                       clc
0001C5r 2                       adc famistudio_pal_adjust
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ldy #0
0001C5r 2                   famistudio_get_note_pitch_macro FAMISTUDIO_FDS_CH0_PITCH_ENV_IDX, 0, famistudio_fds_note_table_lsb, famistudio_fds_note_table_msb
0001C5r 2               
0001C5r 2                   lda @pitch+0
0001C5r 2                   sta FAMISTUDIO_FDS_FREQ_LO
0001C5r 2                   lda @pitch+1
0001C5r 2                   sta FAMISTUDIO_FDS_FREQ_HI
0001C5r 2                   .if FAMISTUDIO_USE_PHASE_RESET
0001C5r 2                       sta famistudio_fds_prev_hi
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2               @check_mod_delay:
0001C5r 2                   lda famistudio_fds_mod_delay_counter
0001C5r 2                   beq @zero_delay
0001C5r 2                   lda #0
0001C5r 2                   sta FAMISTUDIO_FDS_MOD_LO
0001C5r 2                   sta FAMISTUDIO_FDS_SWEEP_BIAS
0001C5r 2                   lda #$80
0001C5r 2                   sta FAMISTUDIO_FDS_MOD_HI
0001C5r 2                   sta FAMISTUDIO_FDS_SWEEP_ENV
0001C5r 2                   dec famistudio_fds_mod_delay_counter
0001C5r 2                   bne @compute_volume
0001C5r 2               
0001C5r 2               @zero_delay:
0001C5r 2               
0001C5r 2                   lda famistudio_fds_mod_depth
0001C5r 2                   beq @mod_depth
0001C5r 2               
0001C5r 2                   .if FAMISTUDIO_USE_FDS_AUTOMOD
0001C5r 2                       lda famistudio_fds_automod_numer
0001C5r 2                       beq @manual_mod
0001C5r 2               
0001C5r 2                       @auto_mod_mul_div:
0001C5r 2                           sta @mul
0001C5r 2                           jsr famistudio_mul
0001C5r 2                           stx @pitch+0
0001C5r 2                           sty @pitch+1
0001C5r 2                           lda famistudio_fds_automod_denom
0001C5r 2                           sta @div
0001C5r 2                           jsr famistudio_div
0001C5r 2                           lda @pitch+1
0001C5r 2                           cmp #$10
0001C5r 2                           bcc @write_auto_mod
0001C5r 2                           @write_max:
0001C5r 2                               lda #$0f
0001C5r 2                               sta FAMISTUDIO_FDS_MOD_HI
0001C5r 2                               lda #$ff
0001C5r 2                               sta FAMISTUDIO_FDS_MOD_LO
0001C5r 2                               jmp @mod_depth
0001C5r 2               
0001C5r 2                           @write_auto_mod:
0001C5r 2                               sta FAMISTUDIO_FDS_MOD_HI
0001C5r 2                               lda @pitch+0
0001C5r 2                               sta FAMISTUDIO_FDS_MOD_LO
0001C5r 2                               jmp @mod_depth
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2                   @manual_mod:
0001C5r 2                       lda famistudio_fds_mod_speed+1
0001C5r 2                       sta FAMISTUDIO_FDS_MOD_HI
0001C5r 2                       lda famistudio_fds_mod_speed+0
0001C5r 2                       sta FAMISTUDIO_FDS_MOD_LO
0001C5r 2               
0001C5r 2                   @mod_depth:
0001C5r 2                       lda famistudio_fds_mod_depth
0001C5r 2                       ora #$80
0001C5r 2                       sta FAMISTUDIO_FDS_SWEEP_ENV
0001C5r 2               
0001C5r 2               @compute_volume:
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_FDS_CH0_IDX
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+FAMISTUDIO_FDS_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
0001C5r 2                       tax
0001C5r 2                       lda famistudio_volume_table, x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+FAMISTUDIO_FDS_CH0_ENVS+FAMISTUDIO_ENV_VOLUME_OFF
0001C5r 2                   .endif
0001C5r 2                   asl ; FDS volume is 6-bits, but clamped to 32. Just double it.
0001C5r 2               
0001C5r 2               @set_volume:
0001C5r 2                   ora #$80
0001C5r 2                   sta FAMISTUDIO_FDS_VOL_ENV
0001C5r 2                   lda #0
0001C5r 2                   sta famistudio_fds_override_flags
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_VRC7
0001C5r 2               
0001C5r 2               famistudio_vrc7_reg_table_lo:
0001C5r 2                   .byte FAMISTUDIO_VRC7_REG_LO_1, FAMISTUDIO_VRC7_REG_LO_2, FAMISTUDIO_VRC7_REG_LO_3, FAMISTUDIO_VRC7_REG_LO_4, FAMISTUDIO_VRC7_REG_LO_5, FAMISTUDIO_VRC7_REG_LO_6
0001C5r 2               famistudio_vrc7_reg_table_hi:
0001C5r 2                   .byte FAMISTUDIO_VRC7_REG_HI_1, FAMISTUDIO_VRC7_REG_HI_2, FAMISTUDIO_VRC7_REG_HI_3, FAMISTUDIO_VRC7_REG_HI_4, FAMISTUDIO_VRC7_REG_HI_5, FAMISTUDIO_VRC7_REG_HI_6
0001C5r 2               famistudio_vrc7_vol_table:
0001C5r 2                   .byte FAMISTUDIO_VRC7_REG_VOL_1, FAMISTUDIO_VRC7_REG_VOL_2, FAMISTUDIO_VRC7_REG_VOL_3, FAMISTUDIO_VRC7_REG_VOL_4, FAMISTUDIO_VRC7_REG_VOL_5, FAMISTUDIO_VRC7_REG_VOL_6
0001C5r 2               famistudio_vrc7_env_table:
0001C5r 2                   .byte FAMISTUDIO_VRC7_CH0_ENVS, FAMISTUDIO_VRC7_CH1_ENVS, FAMISTUDIO_VRC7_CH2_ENVS, FAMISTUDIO_VRC7_CH3_ENVS, FAMISTUDIO_VRC7_CH4_ENVS, FAMISTUDIO_VRC7_CH5_ENVS
0001C5r 2               famistudio_vrc7_invert_vol_table:
0001C5r 2                   .byte $0f, $0e, $0d, $0c, $0b, $0a, $09, $08, $07, $06, $05, $04, $03, $02, $01, $00
0001C5r 2               
0001C5r 2               ; From nesdev wiki.
0001C5r 2               famistudio_vrc7_wait_reg_write:
0001C5r 2                   stx famistudio_vrc7_dummy
0001C5r 2                   ldx #$08
0001C5r 2                   @wait_loop:
0001C5r 2                       dex
0001C5r 2                       bne @wait_loop
0001C5r 2                       ldx famistudio_vrc7_dummy
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               ; From nesdev wiki.
0001C5r 2               famistudio_vrc7_wait_reg_select:
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_VRC7_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the VRC7 audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: VRC7 channel idx (0,1,2,3,4,5)
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               famistudio_update_vrc7_channel_sound:
0001C5r 2               
0001C5r 2                   @tmp   = famistudio_r0
0001C5r 2                   @pitch = famistudio_ptr1
0001C5r 2               
0001C5r 2               @check_cut:
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_VRC7_CH0_IDX,y
0001C5r 2                   bne @check_release
0001C5r 2               
0001C5r 2               @cut:
0001C5r 2                   ; Untrigger note.
0001C5r 2                   lda famistudio_vrc7_reg_table_hi,y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_SEL
0001C5r 2                   jsr famistudio_vrc7_wait_reg_select
0001C5r 2               
0001C5r 2                   lda famistudio_chn_vrc7_prev_hi, y
0001C5r 2                   and #$cf ; Remove trigger + sustain
0001C5r 2                   sta famistudio_chn_vrc7_prev_hi, y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_WRITE
0001C5r 2                   jsr famistudio_vrc7_wait_reg_write
0001C5r 2               
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               @check_release:
0001C5r 2               
0001C5r 2                   lda famistudio_chn_vrc7_trigger,y
0001C5r 2                   bpl @check_attack
0001C5r 2               
0001C5r 2                   @release:
0001C5r 2               
0001C5r 2                       lda famistudio_chn_vrc7_prev_hi, y
0001C5r 2                       and #$ef ; remove trigger
0001C5r 2                       sta famistudio_chn_vrc7_prev_hi, y
0001C5r 2                       jmp @musical_note
0001C5r 2               
0001C5r 2               @check_attack:
0001C5r 2               
0001C5r 2                   lda famistudio_chn_vrc7_trigger,y
0001C5r 2                   and #1
0001C5r 2                   beq @musical_note
0001C5r 2               
0001C5r 2                   @attack:
0001C5r 2               
0001C5r 2                       lda famistudio_chn_vrc7_prev_hi, y
0001C5r 2                       and #$10
0001C5r 2                       beq @prev_note_had_release
0001C5r 2               
0001C5r 2                       ; Two attacks in a row, need to insert a dummy release.
0001C5r 2                       @prev_note_had_attack:
0001C5r 2               
0001C5r 2                           lda famistudio_vrc7_reg_table_hi,y
0001C5r 2                           sta FAMISTUDIO_VRC7_REG_SEL
0001C5r 2                           jsr famistudio_vrc7_wait_reg_select
0001C5r 2                           lda #0
0001C5r 2                           sta FAMISTUDIO_VRC7_REG_WRITE
0001C5r 2                           jsr famistudio_vrc7_wait_reg_write
0001C5r 2                           jmp @musical_note
0001C5r 2               
0001C5r 2                       @prev_note_had_release:
0001C5r 2                           lda famistudio_chn_vrc7_prev_hi, y
0001C5r 2                           ora #$10
0001C5r 2                           sta famistudio_chn_vrc7_prev_hi, y
0001C5r 2               
0001C5r 2               @musical_note:
0001C5r 2               
0001C5r 2                   ; Read/multiply volume
0001C5r 2                   ldx famistudio_vrc7_env_table,y
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_VRC7_CH0_IDX, y
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; Write volume
0001C5r 2                   lda famistudio_vrc7_vol_table,y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_SEL
0001C5r 2                   jsr famistudio_vrc7_wait_reg_select
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_volume_table,x
0001C5r 2                       tax
0001C5r 2                   .endif
0001C5r 2                   lda famistudio_vrc7_invert_vol_table,x
0001C5r 2                   ora famistudio_chn_vrc7_patch,y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_WRITE
0001C5r 2                   jsr famistudio_vrc7_wait_reg_write
0001C5r 2               
0001C5r 2                   ; Read note, apply arpeggio
0001C5r 2                   ldx famistudio_vrc7_env_table,y
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_VRC7_CH0_IDX,y
0001C5r 2                   clc
0001C5r 2                   adc famistudio_env_value+FAMISTUDIO_ENV_NOTE_OFF,x
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; Apply pitch envelope, fine pitch & slides
0001C5r 2                   famistudio_get_note_pitch_macro FAMISTUDIO_VRC7_CH0_PITCH_ENV_IDX, FAMISTUDIO_VRC7_PITCH_SHIFT, famistudio_vrc7_note_table_lsb, famistudio_vrc7_note_table_msb
0001C5r 2               
0001C5r 2                   ; Compute octave by dividing by 2 until we are <= 512 (0x100).
0001C5r 2                   ldx #0
0001C5r 2                   @compute_octave_loop:
0001C5r 2                       lda @pitch+1
0001C5r 2                       cmp #2
0001C5r 2                       bcc @octave_done
0001C5r 2                       lsr
0001C5r 2                       sta @pitch+1
0001C5r 2                       ror @pitch+0
0001C5r 2                       inx
0001C5r 2                       jmp @compute_octave_loop
0001C5r 2               
0001C5r 2                   @octave_done:
0001C5r 2               
0001C5r 2                   ; Write pitch (lo)
0001C5r 2                   lda famistudio_vrc7_reg_table_lo,y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_SEL
0001C5r 2                   jsr famistudio_vrc7_wait_reg_select
0001C5r 2               
0001C5r 2                   lda @pitch+0
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_WRITE
0001C5r 2                   jsr famistudio_vrc7_wait_reg_write
0001C5r 2               
0001C5r 2                   ; Write pitch (hi)
0001C5r 2                   lda famistudio_chn_vrc7_prev_hi, y
0001C5r 2                   and #$10
0001C5r 2                   sta @tmp
0001C5r 2               
0001C5r 2                   lda famistudio_vrc7_reg_table_hi,y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_SEL
0001C5r 2                   jsr famistudio_vrc7_wait_reg_select
0001C5r 2               
0001C5r 2                   txa
0001C5r 2                   asl
0001C5r 2                   ora #$20
0001C5r 2                   ora @pitch+1
0001C5r 2                   ora @tmp
0001C5r 2                   sta famistudio_chn_vrc7_prev_hi, y
0001C5r 2                   sta FAMISTUDIO_VRC7_REG_WRITE
0001C5r 2                   jsr famistudio_vrc7_wait_reg_write
0001C5r 2               
0001C5r 2                   lda #0
0001C5r 2                   sta famistudio_chn_vrc7_trigger,y
0001C5r 2               
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_EPSM
0001C5r 2               FM_ENV_OFFSET = FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT*4
0001C5r 2               RHY_ENV_OFFSET = FM_ENV_OFFSET + FAMISTUDIO_EXP_EPSM_FM_CHN_CNT*2
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
0001C5r 2               famistudio_epsm_vol_table_op1:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_TL, FAMISTUDIO_EPSM_REG_TL+1, FAMISTUDIO_EPSM_REG_TL+2,FAMISTUDIO_EPSM_REG_TL, FAMISTUDIO_EPSM_REG_TL+1, FAMISTUDIO_EPSM_REG_TL+2
0001C5r 2               famistudio_epsm_vol_table_op2:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_TL+8, FAMISTUDIO_EPSM_REG_TL+1+8, FAMISTUDIO_EPSM_REG_TL+2+8,FAMISTUDIO_EPSM_REG_TL+8, FAMISTUDIO_EPSM_REG_TL+1+8, FAMISTUDIO_EPSM_REG_TL+2+8
0001C5r 2               famistudio_epsm_vol_table_op3:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_TL+4, FAMISTUDIO_EPSM_REG_TL+1+4, FAMISTUDIO_EPSM_REG_TL+2+4,FAMISTUDIO_EPSM_REG_TL+4, FAMISTUDIO_EPSM_REG_TL+1+4, FAMISTUDIO_EPSM_REG_TL+2+4
0001C5r 2               famistudio_epsm_vol_table_op4:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_TL+12, FAMISTUDIO_EPSM_REG_TL+1+12, FAMISTUDIO_EPSM_REG_TL+2+12,FAMISTUDIO_EPSM_REG_TL+12, FAMISTUDIO_EPSM_REG_TL+1+12, FAMISTUDIO_EPSM_REG_TL+2+12
0001C5r 2               famistudio_epsm_fm_vol_table:
0001C5r 2                   .byte $7e, $65, $50, $3f, $32, $27, $1e, $17, $12, $0d, $09, $06, $04, $02, $01, $00
0001C5r 2               famistudio_epsm_fm_stereo_reg_table:
0001C5r 2                   .byte $b4,$b5,$b6
0001C5r 2                   .byte $b4,$b5,$b6
0001C5r 2               famistudio_channel_epsm_chan_table:
0001C5r 2                   .byte $00, $01, $02
0001C5r 2                   .byte $00, $01, $02
0001C5r 2               .endif
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
0001C5r 2               famistudio_epsm_rhythm_key_table:
0001C5r 2                   .byte $01,$02,$04,$08,$10,$20
0001C5r 2               famistudio_epsm_rhythm_reg_table:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_RHY_BD, FAMISTUDIO_EPSM_REG_RHY_SD, FAMISTUDIO_EPSM_REG_RHY_TC, FAMISTUDIO_EPSM_REG_RHY_HH, FAMISTUDIO_EPSM_REG_RHY_TOM, FAMISTUDIO_EPSM_REG_RHY_RIM
0001C5r 2               .endif
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
0001C5r 2               famistudio_epsm_reg_table_lo:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_FN_LO, FAMISTUDIO_EPSM_REG_FN_LO2, FAMISTUDIO_EPSM_REG_FN_LO3, FAMISTUDIO_EPSM_REG_FN_LO, FAMISTUDIO_EPSM_REG_FN_LO2, FAMISTUDIO_EPSM_REG_FN_LO3
0001C5r 2               famistudio_epsm_reg_table_hi:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_FN_HI, FAMISTUDIO_EPSM_REG_FN_HI2, FAMISTUDIO_EPSM_REG_FN_HI3, FAMISTUDIO_EPSM_REG_FN_HI, FAMISTUDIO_EPSM_REG_FN_HI2, FAMISTUDIO_EPSM_REG_FN_HI3
0001C5r 2               famistudio_epsm_vol_table:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_VOL_1, FAMISTUDIO_EPSM_REG_VOL_2, FAMISTUDIO_EPSM_REG_VOL_3, FAMISTUDIO_EPSM_REG_VOL_4, FAMISTUDIO_EPSM_REG_VOL_5, FAMISTUDIO_EPSM_REG_VOL_6
0001C5r 2               famistudio_epsm_fm_env_table:
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS + FM_ENV_OFFSET
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS + FM_ENV_OFFSET + 2
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS + FM_ENV_OFFSET + 4
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS + FM_ENV_OFFSET + 6
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS + FM_ENV_OFFSET + 8
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS + FM_ENV_OFFSET + 10
0001C5r 2               famistudio_epsm_register_order:
0001C5r 2                   .byte $B0, $B4, $30, $50, $60, $70, $80, $90, $38, $58, $68, $78, $88, $98, $34, $54, $64, $74, $84, $94, $3c, $5c, $6c, $7c, $8c, $9c, $40, $48, $44, $4c, $22 ;40,48,44,4c replaced for not sending data there during instrument updates,
0001C5r 2               famistudio_epsm_channel_key_table:
0001C5r 2                   .byte $f0, $f1, $f2, $f4, $f5, $f6
0001C5r 2               .endif
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT > 0
0001C5r 2               famistudio_epsm_sqr_reg_table_lo:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_LO_A, FAMISTUDIO_EPSM_REG_LO_B, FAMISTUDIO_EPSM_REG_LO_C
0001C5r 2               famistudio_epsm_sqr_reg_table_hi:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_HI_A, FAMISTUDIO_EPSM_REG_HI_B, FAMISTUDIO_EPSM_REG_HI_C
0001C5r 2               famistudio_epsm_square_vol_table:
0001C5r 2                   .byte FAMISTUDIO_EPSM_REG_VOL_A, FAMISTUDIO_EPSM_REG_VOL_B, FAMISTUDIO_EPSM_REG_VOL_C
0001C5r 2               famistudio_epsm_square_env_table:
0001C5r 2                   .byte FAMISTUDIO_EPSM_CH0_ENVS, FAMISTUDIO_EPSM_CH1_ENVS, FAMISTUDIO_EPSM_CH2_ENVS
0001C5r 2               famistudio_epsm_square_noise_mask:
0001C5r 2                   .byte $08, $10, $20
0001C5r 2               .endif
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_EPSM_SQUARE_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the EPSM audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: EPSM channel idx (0,1,2)
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT > 0
0001C5r 2               famistudio_update_epsm_square_channel_sound:
0001C5r 2               
0001C5r 2                   @pitch   = famistudio_ptr1
0001C5r 2                   @env_bit = famistudio_ptr1_lo
0001C5r 2               
0001C5r 2                   ; These are shared by all 3 channels.
0001C5r 2                   @env_period = famistudio_ptr0
0001C5r 2                   @attack     = famistudio_ptr2
0001C5r 2                   @env_shape  = famistudio_r1
0001C5r 2                   @env_octave = famistudio_r2
0001C5r 2                   @noise_freq = famistudio_r3
0001C5r 2               
0001C5r 2                   ; First channel will clear these, last channel will write the registers.
0001C5r 2                   cpy #0
0001C5r 2                   bne @not_first_channel
0001C5r 2                   sty @env_shape
0001C5r 2                   sty @noise_freq
0001C5r 2                   sty @attack
0001C5r 2                   lda #$80 ; This mean 'manual pitch'
0001C5r 2                   sty @env_octave
0001C5r 2               
0001C5r 2               @not_first_channel:
0001C5r 2                   ldx #0 ; This will fetch volume 0.
0001C5r 2                   stx @env_bit
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_EPSM_CH0_IDX,y
0001C5r 2                   bne @nocut
0001C5r 2                   jmp @update_volume
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2                   ; Store noise if mixer has it enabled
0001C5r 2                   ldx famistudio_epsm_square_env_table,y
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
0001C5r 2                   and famistudio_epsm_square_noise_mask,y
0001C5r 2                   bne @nonoise
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
0001C5r 2                   sta @noise_freq
0001C5r 2               
0001C5r 2               @nonoise:
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_EPSM_CH0_IDX,y
0001C5r 2                   ; Read note, apply arpeggio
0001C5r 2                   clc
0001C5r 2                   ldx famistudio_epsm_square_env_table,y
0001C5r 2                   adc famistudio_env_value+FAMISTUDIO_ENV_NOTE_OFF,x
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; Apply pitch envelope, fine pitch & slides
0001C5r 2                   famistudio_get_note_pitch_macro FAMISTUDIO_EPSM_CH0_PITCH_ENV_IDX, 0, famistudio_epsm_s_note_table_lsb, famistudio_epsm_s_note_table_msb
0001C5r 2               
0001C5r 2                   ; Write pitch
0001C5r 2                   lda famistudio_epsm_sqr_reg_table_lo,y
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   lda @pitch+0
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2                   lda famistudio_epsm_sqr_reg_table_hi,y
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   lda @pitch+1
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2                   ; Store env shape + period if active.
0001C5r 2                   lda famistudio_epsm_chn_env_shape,y
0001C5r 2                   and #$0f
0001C5r 2                   beq @noenv
0001C5r 2                   sta @env_shape
0001C5r 2               
0001C5r 2                   ; If bit 7 of any channel is on, well reset the envelope.
0001C5r 2                   lda famistudio_epsm_chn_env_shape,y
0001C5r 2                   ora @attack
0001C5r 2                   sta @attack
0001C5r 2                   lda famistudio_epsm_chn_env_shape,y
0001C5r 2                   and #$0f
0001C5r 2                   sta famistudio_epsm_chn_env_shape,y
0001C5r 2               
0001C5r 2                   ; Store auto-period settings
0001C5r 2                   lda famistudio_epsm_chn_env_octave,y
0001C5r 2                   sta @env_octave
0001C5r 2                   cmp #$80 ; This mean 'manual pitch'
0001C5r 2                   beq @manual_period
0001C5r 2               
0001C5r 2                   @auto_period:
0001C5r 2                       lda @pitch+0
0001C5r 2                       sta @env_period+0
0001C5r 2                       lda @pitch+1
0001C5r 2                       sta @env_period+1
0001C5r 2                       jmp @set_envelope_volume_flag
0001C5r 2               
0001C5r 2                   @manual_period:
0001C5r 2                       lda famistudio_epsm_env_period_lo
0001C5r 2                       sta @env_period+0
0001C5r 2                       lda famistudio_epsm_env_period_hi
0001C5r 2                       sta @env_period+1
0001C5r 2               
0001C5r 2               @set_envelope_volume_flag:
0001C5r 2                   lda #$10
0001C5r 2               
0001C5r 2               @noenv:
0001C5r 2                   sta @env_bit
0001C5r 2               
0001C5r 2                   ; Read/multiply volume
0001C5r 2                   ldx famistudio_epsm_square_env_table,y
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_EPSM_CH0_IDX, y
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2               @update_volume:
0001C5r 2                   ; Write volume
0001C5r 2                   lda famistudio_epsm_square_vol_table,y
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_volume_table,x
0001C5r 2                       ora @env_bit
0001C5r 2                   .else
0001C5r 2                       txa
0001C5r 2                       ora @env_bit
0001C5r 2                   .endif
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2               @write_shared_registers:
0001C5r 2                   ; Channel 2 writes all 5 shared registers.
0001C5r 2                   cpy #(FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT - 1)
0001C5r 2                   bne @done
0001C5r 2                   lda @env_shape
0001C5r 2                   beq @write_shared_noise
0001C5r 2                   ldx @env_octave
0001C5r 2                   cpx #$80
0001C5r 2                   beq @write_shared_env_register
0001C5r 2               
0001C5r 2               @compute_auto_period:
0001C5r 2                   cpx #0
0001C5r 2                   beq @write_shared_env_register
0001C5r 2                   bpl @positive_octave_loop
0001C5r 2               
0001C5r 2                   @negative_octave_loop:
0001C5r 2                           asl @env_period+0
0001C5r 2                           rol @env_period+1
0001C5r 2                           inx
0001C5r 2                           bne @negative_octave_loop
0001C5r 2                       beq @write_shared_env_register
0001C5r 2               
0001C5r 2                   @positive_octave_loop:
0001C5r 2                       cpx #1
0001C5r 2                       bne @do_shift
0001C5r 2                       @rounding:
0001C5r 2                           lda @env_period+0
0001C5r 2                           and #1
0001C5r 2                           beq @do_shift
0001C5r 2                           lda @env_period+0
0001C5r 2                           clc
0001C5r 2                           adc #1
0001C5r 2                           sta @env_period+0
0001C5r 2                           bcc @do_shift
0001C5r 2                           inc @env_period+1
0001C5r 2                       @do_shift:
0001C5r 2                           lsr @env_period+1
0001C5r 2                           ror @env_period+0
0001C5r 2                           dex
0001C5r 2                           bne @positive_octave_loop
0001C5r 2               
0001C5r 2               @write_shared_env_register:
0001C5r 2               
0001C5r 2                   ; Envelope period.
0001C5r 2                   lda #FAMISTUDIO_EPSM_REG_ENV_LO
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   lda @env_period+0
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2                   lda #FAMISTUDIO_EPSM_REG_ENV_HI
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   lda @env_period+1
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2                   ; Reset envelope if there was an attack.
0001C5r 2                   lda @attack
0001C5r 2                   bpl @write_shared_noise
0001C5r 2                       lda #FAMISTUDIO_EPSM_REG_SHAPE
0001C5r 2                       sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                       lda @env_shape
0001C5r 2                       sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2               @write_shared_noise:
0001C5r 2               
0001C5r 2                   ; Tone/noise enabled.
0001C5r 2                   lda #FAMISTUDIO_EPSM_REG_TONE
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT = 3
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_EPSM_CH2_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2                   asl
0001C5r 2                   ora famistudio_env_value+FAMISTUDIO_EPSM_CH1_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2                   asl
0001C5r 2                   ora famistudio_env_value+FAMISTUDIO_EPSM_CH0_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2               .elseif FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT = 2
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_EPSM_CH1_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2                   asl
0001C5r 2                   ora famistudio_env_value+FAMISTUDIO_EPSM_CH0_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2               .else
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_EPSM_CH0_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2               .endif
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2                   ; Noise freq
0001C5r 2                   lda #FAMISTUDIO_EPSM_REG_NOISE
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   lda @noise_freq
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2                   lda #0
0001C5r 2                   sta famistudio_epsm_env_override
0001C5r 2               
0001C5r 2               @done:
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_EPSM_FM_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the EPSM audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: EPSM channel idx (0,1,2,3,4,5)
0001C5r 2               ;======================================================================================================================
0001C5r 2               famistudio_update_epsm_fm_channel_sound:
0001C5r 2               
0001C5r 2                   @pitch      = famistudio_ptr1
0001C5r 2                   @reg_offset = famistudio_r1
0001C5r 2                   @vol_offset = famistudio_r0
0001C5r 2                   @chan_idx   = famistudio_r2
0001C5r 2               
0001C5r 2                   sty @chan_idx
0001C5r 2                   ; If the writes are done to channels 0-2, use FAMISTUDIO_EPSM_REG_SEL0 if 3-5 use FAMISTUDIO_EPSM_REG_SEL1
0001C5r 2                   ; This reg_offset stores the difference so we can later load it into x and do sta FAMISTUDIO_EPSM_REG_SEL0, x
0001C5r 2                   ; to account for the difference
0001C5r 2                   lda #0
0001C5r 2                   cpy #3
0001C5r 2                   bcc @fm_0_2
0001C5r 2                       lda #2
0001C5r 2                   @fm_0_2:
0001C5r 2                   sta @reg_offset
0001C5r 2               
0001C5r 2               @check_cut:
0001C5r 2               
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_EPSM_CHAN_FM_START,y
0001C5r 2                   bne @nocut
0001C5r 2               
0001C5r 2               @cut:
0001C5r 2                   ; Untrigger note.
0001C5r 2                   lda #FAMISTUDIO_EPSM_REG_KEY
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_SEL0
0001C5r 2               
0001C5r 2                   lda famistudio_epsm_channel_key_table, y
0001C5r 2                   and #$0f ; remove trigger
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_WRITE0
0001C5r 2               
0001C5r 2                   ;Mute channel
0001C5r 2                   ldx @reg_offset
0001C5r 2                   lda famistudio_epsm_fm_stereo_reg_table,y
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                   lda #$00
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2               
0001C5r 2                   ; Check if the channel needs to stop the note
0001C5r 2               
0001C5r 2                   ; Un-trigger previous note if needed.
0001C5r 2                   lda famistudio_chn_epsm_trigger,y
0001C5r 2                   beq @update_instrument_check
0001C5r 2                   @untrigger_prev_note:
0001C5r 2                       ; Untrigger note.
0001C5r 2                       lda #FAMISTUDIO_EPSM_REG_KEY
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0
0001C5r 2               
0001C5r 2                       lda famistudio_epsm_channel_key_table, y
0001C5r 2                       and #$0f ; remove trigger
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0
0001C5r 2               ;        nop
0001C5r 2               ;        nop
0001C5r 2               ;        nop
0001C5r 2                       nop
0001C5r 2                       nop
0001C5r 2                       nop
0001C5r 2               ;        rts
0001C5r 2                   @update_instrument_check:
0001C5r 2                   lda famistudio_chn_epsm_fm_instrument,y
0001C5r 2                   cmp #$ff
0001C5r 2                   beq @no_instrument_update
0001C5r 2                   jsr update_fm_instrument
0001C5r 2                   ldy @chan_idx
0001C5r 2                   lda #$ff
0001C5r 2                   sta famistudio_chn_epsm_fm_instrument,y
0001C5r 2                   @no_instrument_update:
0001C5r 2               
0001C5r 2                   ldx @reg_offset
0001C5r 2                   lda famistudio_epsm_fm_stereo_reg_table,y
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                   lda famistudio_chn_epsm_fm_stereo,y
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_EPSM_CHAN_FM_START,y
0001C5r 2                   ; Read note, apply arpeggio
0001C5r 2                   clc
0001C5r 2                   ldx famistudio_epsm_fm_env_table,y
0001C5r 2                   adc famistudio_env_value+FAMISTUDIO_ENV_NOTE_OFF,x
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; Apply pitch envelope, fine pitch & slides
0001C5r 2                   famistudio_get_note_pitch_macro (FAMISTUDIO_EPSM_CH0_PITCH_ENV_IDX + FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT), FAMISTUDIO_EPSM_PITCH_SHIFT, famistudio_epsm_note_table_lsb, famistudio_epsm_note_table_msb
0001C5r 2               
0001C5r 2                   ; Compute octave by dividing by 2 until we are <= 512 (0x100).
0001C5r 2                   ldx #0
0001C5r 2               
0001C5r 2                   lda @pitch+1
0001C5r 2                   cmp #$02 ; check if shifted the pitch to a 9 bit number yet.
0001C5r 2                   bcc @octave_done
0001C5r 2                   @compute_octave_loop:
0001C5r 2                       inx
0001C5r 2                       lsr
0001C5r 2                       ror @pitch+0
0001C5r 2                       cmp #$02
0001C5r 2                       bcc @octave_done
0001C5r 2                       bcs @compute_octave_loop ;unconditional
0001C5r 2                   @octave_done:
0001C5r 2                   sta @pitch+1
0001C5r 2               
0001C5r 2                   ; 9 bit pitch * 4 to get the pitch back to an 11 bit number
0001C5r 2                   ; the final 16 bit pitch will look like 00ooohhh llllllll where o = octave, h = pitch bits 8-11, l = pitch bits 0-8
0001C5r 2                   asl @pitch+0
0001C5r 2                   rol @pitch+1
0001C5r 2                   asl @pitch+0
0001C5r 2                   rol @pitch+1
0001C5r 2               
0001C5r 2                   txa ; x holds the 3 bit octave information. octave = log2(pitch_hi)
0001C5r 2                   asl
0001C5r 2                   asl
0001C5r 2                   asl
0001C5r 2                   ora @pitch+1
0001C5r 2                   sta @pitch+1
0001C5r 2               
0001C5r 2                   @write_hi_period:
0001C5r 2               
0001C5r 2                   ; Write pitch (hi)
0001C5r 2                   ldx @reg_offset
0001C5r 2                   lda famistudio_epsm_reg_table_hi,y
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                   lda @pitch+1
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2               
0001C5r 2                   ; Write pitch (lo)
0001C5r 2                   lda famistudio_epsm_reg_table_lo,y
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                   lda @pitch+0
0001C5r 2                   sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2               
0001C5r 2                   ; Read/multiply volume
0001C5r 2                   ldx famistudio_epsm_fm_env_table,y
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_EPSM_CHAN_FM_START, y
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .endif
0001C5r 2               
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       tax
0001C5r 2                       lda famistudio_volume_table,x
0001C5r 2                   .endif
0001C5r 2                       sta @vol_offset
0001C5r 2               
0001C5r 2                   @update_volume:
0001C5r 2                   ldx @vol_offset
0001C5r 2                   lda famistudio_epsm_fm_vol_table,x
0001C5r 2                   sta @vol_offset ; store volume level here
0001C5r 2               
0001C5r 2                   ldx @reg_offset
0001C5r 2                   lda famistudio_chn_epsm_alg,y
0001C5r 2                   cmp #4
0001C5r 2                   bcc @op_4 ; 0-1-2-3
0001C5r 2                   beq @op_2_4 ; 4
0001C5r 2                   cmp #7 ; 5
0001C5r 2                   bcc @op_2_3_4 ; 6
0001C5r 2                              ; 7
0001C5r 2                   @op_1_2_3_4:
0001C5r 2                       lda famistudio_epsm_vol_table_op1,y
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                       lda famistudio_chn_epsm_vol_op1,y
0001C5r 2                       clc
0001C5r 2                       adc @vol_offset
0001C5r 2                       bpl @save_op1
0001C5r 2                       lda #127
0001C5r 2                   @save_op1:
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2                   @op_2_3_4:
0001C5r 2                       lda famistudio_epsm_vol_table_op3,y
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                       lda famistudio_chn_epsm_vol_op3,y
0001C5r 2                       clc
0001C5r 2                       adc @vol_offset
0001C5r 2                       bpl @save_op3
0001C5r 2                       lda #127
0001C5r 2                   @save_op3:
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2                   @op_2_4:
0001C5r 2                       lda famistudio_epsm_vol_table_op2,y
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0,x
0001C5r 2                       lda famistudio_chn_epsm_vol_op2,y
0001C5r 2                       clc
0001C5r 2                       adc @vol_offset
0001C5r 2                       bpl @save_op2
0001C5r 2                       lda #127
0001C5r 2                   @save_op2:
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0,x
0001C5r 2                   @op_4:
0001C5r 2                       ; Write volume
0001C5r 2                       lda famistudio_epsm_vol_table_op4,y ; 4
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0,x ; 5
0001C5r 2                       lda famistudio_chn_epsm_vol_op4,y ; 4
0001C5r 2                   clc ; 2
0001C5r 2                       adc @vol_offset ; 3
0001C5r 2                       bpl @save_op4 ; 2/3
0001C5r 2                       lda #127 ; 2
0001C5r 2                   @save_op4:
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0,x ; 5  = 26/27
0001C5r 2               
0001C5r 2                       nop
0001C5r 2                       clc
0001C5r 2                       lda famistudio_chn_epsm_trigger,y
0001C5r 2                       bpl @no_release
0001C5r 2               
0001C5r 2               @release:
0001C5r 2                       ; Untrigger note.
0001C5r 2                       lda #FAMISTUDIO_EPSM_REG_KEY
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0
0001C5r 2               
0001C5r 2                       lda famistudio_epsm_channel_key_table, y
0001C5r 2                       and #$0f ; remove trigger
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0
0001C5r 2               
0001C5r 2                       rts
0001C5r 2               @no_release:
0001C5r 2                       lda #0
0001C5r 2                       sta famistudio_chn_epsm_trigger,y
0001C5r 2                       lda #FAMISTUDIO_EPSM_REG_KEY
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0
0001C5r 2                       lda famistudio_epsm_channel_key_table, y
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0
0001C5r 2               
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_EPSM_WRITE_PATCH_REGISTER (internal)
0001C5r 2               ;
0001C5r 2               ; Internal function to set a EPSM instrument for a given channel
0001C5r 2               ;
0001C5r 2               ; [in] y/r0: channel index
0001C5r 2               ; [in] x:    index of first envelope of instrument
0001C5r 2               ; [in] a:    instrument index.
0001C5r 2               ;======================================================================================================================
0001C5r 2               .macro famistudio_epsm_write_patch_registers select, write
0001C5r 2               
0001C5r 2                   .local @loop_main_patch
0001C5r 2                   .local @loop_extra_patch
0001C5r 2                   .local @alg_4
0001C5r 2                   .local @alg_5_6
0001C5r 2                   .local @alg_0_1_2_3
0001C5r 2               
0001C5r 2                   ldy #30-5 ; we skip updating the 4 operators
0001C5r 2                   ldx @reg_offset
0001C5r 2                   @loop_extra_patch:
0001C5r 2                       txa    ; 2
0001C5r 2                       ora famistudio_epsm_register_order,y ; 4
0001C5r 2                       sta select ; 4
0001C5r 2                       lda (@ex_patch),y ; 5
0001C5r 2                       sta write ; 4
0001C5r 2                       dey    ; 2
0001C5r 2                       nop    ; 2 DELAY FOR MESEN-X
0001C5r 2                       bpl @loop_extra_patch ; 3  ; =26
0001C5r 2               
0001C5r 2                   ldx @chan_idx2
0001C5r 2                   lda famistudio_chn_epsm_alg,x
0001C5r 2                   cmp #4
0001C5r 2                   bcc @alg_0_1_2_3 ; 0-1-2-3
0001C5r 2                   beq @alg_4 ; 4
0001C5r 2                   jmp @alg_5_6 ; 5
0001C5r 2                   @alg_0_1_2_3:
0001C5r 2                   ;3+2+1
0001C5r 2                   ldy #27
0001C5r 2                   ldx @reg_offset
0001C5r 2                   txa    ; 2
0001C5r 2                   ora famistudio_epsm_register_order,y ; 4
0001C5r 2                   sta select ; 4
0001C5r 2                   lda (@ex_patch),y ; 5
0001C5r 2                   sta write ; 4
0001C5r 2                   nop    ; 2 DELAY FOR MESEN-X
0001C5r 2                   @alg_4:
0001C5r 2                   ;3+1
0001C5r 2                   ldy #28
0001C5r 2                   ldx @reg_offset
0001C5r 2                   txa    ; 2
0001C5r 2                   ora famistudio_epsm_register_order,y ; 4
0001C5r 2                   sta select ; 4
0001C5r 2                   lda (@ex_patch),y ; 5
0001C5r 2                   sta write ; 4
0001C5r 2                   nop    ; 2 DELAY FOR MESEN-X
0001C5r 2                   @alg_5_6:
0001C5r 2                   ;1
0001C5r 2                   ldy #26
0001C5r 2                   ldx @reg_offset
0001C5r 2                   txa    ; 2
0001C5r 2                   ora famistudio_epsm_register_order,y ; 4
0001C5r 2                   sta select ; 4
0001C5r 2                   lda (@ex_patch),y ; 5
0001C5r 2                   sta write ; 4
0001C5r 2                   nop    ; 2 DELAY FOR MESEN-X
0001C5r 2               .endmacro
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_EPSM_FM_INSTRUMENT (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the EPSM audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: EPSM channel idx (0,1,2,3,4,5)
0001C5r 2               ;======================================================================================================================
0001C5r 2                   ; Now we are dealing with either a FM or Rhythm instrument. a = channel index
0001C5r 2                   ; if we are an FM instrument then there is a offset we need to apply to the register select
0001C5r 2               
0001C5r 2                   ; Skip over the two SSG specific envelopes by jumping up 4 bytes
0001C5r 2               update_fm_instrument:
0001C5r 2                   @ptr          = famistudio_ptr1
0001C5r 2                   @env_ptr      = famistudio_ptr2
0001C5r 2                   @ex_patch     = famistudio_ptr2
0001C5r 2                   @chan_idx     = famistudio_r0
0001C5r 2                   @chan_idx2    = famistudio_r2
0001C5r 2                   @update_flags = famistudio_r1 ; bit 7 = no attack, bit 6 = has set delayed cut
0001C5r 2                   @reg_offset   = famistudio_r3
0001C5r 2                   jsr famistudio_get_exp_inst_ptr
0001C5r 2                   clc
0001C5r 2                   tya
0001C5r 2                   adc #14 ; skip over envelopes + square stuff.
0001C5r 2                   tay
0001C5r 2                   ; And then read the pointer to the extended instrument patch data
0001C5r 2                   lda (@ptr),y
0001C5r 2                   sta @ex_patch
0001C5r 2                   iny
0001C5r 2                   lda (@ptr),y
0001C5r 2                   sta @ex_patch+1
0001C5r 2               
0001C5r 2               @fm_channel:
0001C5r 2                   ldx @chan_idx2
0001C5r 2                   ; FM channel 1-6, we need to look up the register select offset from the table
0001C5r 2                   lda famistudio_channel_epsm_chan_table,x
0001C5r 2                   sta @reg_offset
0001C5r 2                   ldy #0
0001C5r 2                   ; Now we need to store the algorithm and stereo for later use
0001C5r 2                   lda (@ex_patch),y
0001C5r 2                   and #$07
0001C5r 2                   sta famistudio_chn_epsm_alg,x ;store algorithm
0001C5r 2                   iny
0001C5r 2                   lda (@ex_patch),y
0001C5r 2                   sta famistudio_chn_epsm_fm_stereo ,x
0001C5r 2                   dey
0001C5r 2               
0001C5r 2                   ; Now if we are channels 1-3 then we use @reg_set_0, otherwise for 4-6 its reg set 1
0001C5r 2                   lda @chan_idx2
0001C5r 2                   cmp #3
0001C5r 2                   bpl @reg_set_1
0001C5r 2               
0001C5r 2                   @reg_set_0:
0001C5r 2                       famistudio_epsm_write_patch_registers FAMISTUDIO_EPSM_REG_SEL0, FAMISTUDIO_EPSM_REG_WRITE0
0001C5r 2                       jmp @last_reg
0001C5r 2               
0001C5r 2                   @reg_set_1:
0001C5r 2                       famistudio_epsm_write_patch_registers FAMISTUDIO_EPSM_REG_SEL1, FAMISTUDIO_EPSM_REG_WRITE1
0001C5r 2                       nop
0001C5r 2               
0001C5r 2                   @last_reg:
0001C5r 2                       ldy #30 ; last reg patch ptr
0001C5r 2                       lda #$22 ; famistudio_epsm_register_order,x
0001C5r 2                       clc
0001C5r 2                       adc @reg_offset
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_SEL0
0001C5r 2                       lda (@ex_patch),y
0001C5r 2                       sta FAMISTUDIO_EPSM_REG_WRITE0
0001C5r 2                       lda @chan_idx2
0001C5r 2                       tax
0001C5r 2                       ldy #26
0001C5r 2                       lda (@ex_patch),y
0001C5r 2                       sta famistudio_chn_epsm_vol_op1,x
0001C5r 2                       iny
0001C5r 2                       lda (@ex_patch),y
0001C5r 2                       sta famistudio_chn_epsm_vol_op2,x
0001C5r 2                       iny
0001C5r 2                       lda (@ex_patch),y
0001C5r 2                       sta famistudio_chn_epsm_vol_op3,x
0001C5r 2                       iny
0001C5r 2                       lda (@ex_patch),y
0001C5r 2                       sta famistudio_chn_epsm_vol_op4,x
0001C5r 2                   @done:
0001C5r 2               rts
0001C5r 2               .endif
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_EPSM_RHYTHM_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the EPSM audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: EPSM channel idx (0,1,2,3,4,5)
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
0001C5r 2               famistudio_update_epsm_rhythm_channel_sound:
0001C5r 2               
0001C5r 2                   @pitch = famistudio_ptr1
0001C5r 2               
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_EPSM_CHAN_RHYTHM_START,y
0001C5r 2                   bne @nocut
0001C5r 2                   sta famistudio_chn_epsm_trigger+FAMISTUDIO_EXP_EPSM_FM_CHN_CNT,y
0001C5r 2                   ldx #0 ; This will fetch volume 0.
0001C5r 2                   beq @noupdate
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2               
0001C5r 2                   lda famistudio_chn_epsm_trigger+FAMISTUDIO_EXP_EPSM_FM_CHN_CNT,y
0001C5r 2                   cmp #$10
0001C5r 2                   beq @noupdate
0001C5r 2               
0001C5r 2                   ; Read/multiply volume
0001C5r 2                   ldx famistudio_chn_epsm_rhythm_volume,y
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_EPSM_CHAN_RHYTHM_START, y
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_chn_epsm_rhythm_volume,y
0001C5r 2                   .else
0001C5r 2                       lda famistudio_chn_epsm_rhythm_volume,y
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2               @update_volume:
0001C5r 2                   ; Write volume
0001C5r 2                   lda famistudio_epsm_rhythm_reg_table,y
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_volume_table,x
0001C5r 2                   .else
0001C5r 2                       txa
0001C5r 2                   .endif
0001C5r 2                       rol
0001C5r 2                       adc famistudio_chn_epsm_rhythm_stereo,y
0001C5r 2                       sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2                   lda #$10 ;FAMISTUDIO_EPSM_REG_RHY_KY
0001C5r 2                   sta famistudio_chn_epsm_trigger+FAMISTUDIO_EXP_EPSM_FM_CHN_CNT,y
0001C5r 2                   sta FAMISTUDIO_EPSM_ADDR
0001C5r 2                   nop ;Some delay needed before writing the rhythm key
0001C5r 2                   nop
0001C5r 2                   lda famistudio_epsm_rhythm_key_table,y
0001C5r 2                   sta FAMISTUDIO_EPSM_DATA
0001C5r 2               
0001C5r 2               @noupdate:
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_N163
0001C5r 2               
0001C5r 2               ; This is getting out of hand. Maybe we should compute those on the fly.
0001C5r 2               famistudio_n163_freq_table_lo:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_LO - $38
0001C5r 2               famistudio_n163_freq_table_mid:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_MID - $38
0001C5r 2               famistudio_n163_freq_table_hi:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_FREQ_HI - $38
0001C5r 2               famistudio_n163_vol_table:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_VOLUME - $38
0001C5r 2               famistudio_n163_env_table:
0001C5r 2                   .byte FAMISTUDIO_N163_CH0_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH1_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH2_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH3_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH4_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH5_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH6_ENVS
0001C5r 2                   .byte FAMISTUDIO_N163_CH7_ENVS
0001C5r 2               .if FAMISTUDIO_USE_PHASE_RESET
0001C5r 2               famistudio_n163_phase_table_lo:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_LO - $38
0001C5r 2               famistudio_n163_phase_table_mid:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_MID - $38
0001C5r 2               famistudio_n163_phase_table_hi:
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $00
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $08
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $10
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $18
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $20
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $28
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $30
0001C5r 2                   .byte FAMISTUDIO_N163_REG_PHASE_HI - $38
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_N163_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the N163 audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: N163 channel idx (0,1,2,3,4,5,6,7)
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               famistudio_update_n163_channel_sound:
0001C5r 2               
0001C5r 2                   @pitch    = famistudio_ptr1
0001C5r 2                   @pitch_hi = famistudio_r2
0001C5r 2               
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_N163_CH0_IDX,y
0001C5r 2                   bne @nocut
0001C5r 2                   ldx #0 ; This will fetch volume 0.
0001C5r 2                   jmp @update_volume
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2               
0001C5r 2                   jsr famistudio_update_n163_wave
0001C5r 2               
0001C5r 2                   ; Read note, apply arpeggio
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_N163_CH0_IDX,y
0001C5r 2                   clc
0001C5r 2                   ldx famistudio_n163_env_table,y
0001C5r 2                   adc famistudio_env_value+FAMISTUDIO_ENV_NOTE_OFF,x
0001C5r 2                   .if FAMISTUDIO_DUAL_SUPPORT
0001C5r 2                       clc
0001C5r 2                       adc famistudio_pal_adjust
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; Apply pitch envelope, fine pitch & slides
0001C5r 2                   famistudio_get_note_pitch_macro FAMISTUDIO_N163_CH0_PITCH_ENV_IDX, FAMISTUDIO_N163_PITCH_SHIFT, famistudio_n163_note_table_lsb, famistudio_n163_note_table_msb
0001C5r 2               
0001C5r 2                   ; Convert 16-bit -> 18-bit.
0001C5r 2                   asl @pitch+0
0001C5r 2                   rol @pitch+1
0001C5r 2                   lda #0
0001C5r 2                   adc #0
0001C5r 2                   sta @pitch_hi
0001C5r 2                   asl @pitch+0
0001C5r 2                   rol @pitch+1
0001C5r 2                   rol @pitch_hi
0001C5r 2               
0001C5r 2                   ; Write pitch
0001C5r 2                   lda famistudio_n163_freq_table_lo,y
0001C5r 2                   sta FAMISTUDIO_N163_ADDR
0001C5r 2                   lda @pitch+0
0001C5r 2                   sta FAMISTUDIO_N163_DATA
0001C5r 2                   lda famistudio_n163_freq_table_mid,y
0001C5r 2                   sta FAMISTUDIO_N163_ADDR
0001C5r 2                   lda @pitch+1
0001C5r 2                   sta FAMISTUDIO_N163_DATA
0001C5r 2                   lda famistudio_n163_freq_table_hi,y
0001C5r 2                   sta FAMISTUDIO_N163_ADDR
0001C5r 2                   lda famistudio_chn_n163_wave_len,y
0001C5r 2                   ora @pitch_hi
0001C5r 2                   sta FAMISTUDIO_N163_DATA
0001C5r 2               
0001C5r 2                   ; Read/multiply volume
0001C5r 2                   ldx famistudio_n163_env_table,y
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_N163_CH0_IDX, y
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2               @update_volume:
0001C5r 2                   ; Write volume
0001C5r 2                   lda famistudio_n163_vol_table,y
0001C5r 2                   sta FAMISTUDIO_N163_ADDR
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_volume_table,x
0001C5r 2                   .else
0001C5r 2                       txa
0001C5r 2                   .endif
0001C5r 2                   ora #FAMISTUDIO_N163_CHN_MASK
0001C5r 2                   sta FAMISTUDIO_N163_DATA
0001C5r 2               
0001C5r 2               @done:
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_EXP_S5B
0001C5r 2               
0001C5r 2               famistudio_s5b_reg_table_lo:
0001C5r 2                   .byte FAMISTUDIO_S5B_REG_LO_A, FAMISTUDIO_S5B_REG_LO_B, FAMISTUDIO_S5B_REG_LO_C
0001C5r 2               famistudio_s5b_reg_table_hi:
0001C5r 2                   .byte FAMISTUDIO_S5B_REG_HI_A, FAMISTUDIO_S5B_REG_HI_B, FAMISTUDIO_S5B_REG_HI_C
0001C5r 2               famistudio_s5b_vol_table:
0001C5r 2                   .byte FAMISTUDIO_S5B_REG_VOL_A, FAMISTUDIO_S5B_REG_VOL_B, FAMISTUDIO_S5B_REG_VOL_C
0001C5r 2               famistudio_s5b_env_table:
0001C5r 2                   .byte FAMISTUDIO_S5B_CH0_ENVS, FAMISTUDIO_S5B_CH1_ENVS, FAMISTUDIO_S5B_CH2_ENVS
0001C5r 2               famistudio_s5b_noise_mask:
0001C5r 2                   .byte $08, $10, $20
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_UPDATE_S5B_CHANNEL_SOUND (internal)
0001C5r 2               ;
0001C5r 2               ; Updates the S5B audio registers for a given channel.
0001C5r 2               ;
0001C5r 2               ; [in] y: S5B channel idx (0,1,2)
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               famistudio_update_s5b_channel_sound:
0001C5r 2               
0001C5r 2                   @pitch   = famistudio_ptr1
0001C5r 2                   @env_bit = famistudio_ptr1_lo
0001C5r 2               
0001C5r 2                   ; These are shared by all 3 channels.
0001C5r 2                   @env_period = famistudio_ptr0
0001C5r 2                   @attack     = famistudio_ptr2
0001C5r 2                   @env_shape  = famistudio_r1
0001C5r 2                   @env_octave = famistudio_r2
0001C5r 2                   @noise_freq = famistudio_r3
0001C5r 2               
0001C5r 2                   ; First channel will clear these, last channel will write the registers.
0001C5r 2                   cpy #0
0001C5r 2                   bne @not_first_channel
0001C5r 2                   sty @env_shape
0001C5r 2                   sty @noise_freq
0001C5r 2                   sty @attack
0001C5r 2                   lda #$80 ; This mean 'manual pitch'
0001C5r 2                   sty @env_octave
0001C5r 2               
0001C5r 2               @not_first_channel:
0001C5r 2                   ldx #0 ; This will fetch volume 0.
0001C5r 2                   stx @env_bit
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_S5B_CH0_IDX,y
0001C5r 2                   bne @nocut
0001C5r 2                   jmp @update_volume
0001C5r 2               
0001C5r 2               @nocut:
0001C5r 2                   ; Store noise if mixer has it enabled
0001C5r 2                   ldx famistudio_s5b_env_table,y
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
0001C5r 2                   and famistudio_s5b_noise_mask,y
0001C5r 2                   bne @nonoise
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
0001C5r 2                   sta @noise_freq
0001C5r 2               
0001C5r 2               @nonoise:
0001C5r 2                   lda famistudio_chn_note+FAMISTUDIO_S5B_CH0_IDX,y
0001C5r 2                   ; Read note, apply arpeggio
0001C5r 2                   clc
0001C5r 2                   ldx famistudio_s5b_env_table,y
0001C5r 2                   adc famistudio_env_value+FAMISTUDIO_ENV_NOTE_OFF,x
0001C5r 2                   .if FAMISTUDIO_DUAL_SUPPORT
0001C5r 2                       clc
0001C5r 2                       adc famistudio_pal_adjust
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2                   ; Apply pitch envelope, fine pitch & slides
0001C5r 2                   famistudio_get_note_pitch_macro FAMISTUDIO_S5B_CH0_PITCH_ENV_IDX, 0, famistudio_note_table_lsb, famistudio_note_table_msb
0001C5r 2               
0001C5r 2                   ; Write pitch + 1 (pitches on S5B are off by one compared to regular note table)
0001C5r 2                   lda famistudio_s5b_reg_table_lo,y
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   lda @pitch+0
0001C5r 2                   clc
0001C5r 2                   adc #1
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2                   sta @pitch+0
0001C5r 2                   lda famistudio_s5b_reg_table_hi,y
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   lda @pitch+1
0001C5r 2                   adc #0
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2                   sta @pitch+1
0001C5r 2               
0001C5r 2                   ; Store env shape + period if active.
0001C5r 2                   lda famistudio_s5b_chn_env_shape,y
0001C5r 2                   and #$0f
0001C5r 2                   beq @noenv
0001C5r 2                   sta @env_shape
0001C5r 2               
0001C5r 2                   ; If bit 7 of any channel is on, well reset the envelope.
0001C5r 2                   lda famistudio_s5b_chn_env_shape,y
0001C5r 2                   ora @attack
0001C5r 2                   sta @attack
0001C5r 2                   lda famistudio_s5b_chn_env_shape,y
0001C5r 2                   and #$0f
0001C5r 2                   sta famistudio_s5b_chn_env_shape,y
0001C5r 2               
0001C5r 2                   ; Store auto-period settings
0001C5r 2                   lda famistudio_s5b_chn_env_octave,y
0001C5r 2                   sta @env_octave
0001C5r 2                   cmp #$80 ; This mean 'manual pitch'
0001C5r 2                   beq @manual_period
0001C5r 2               
0001C5r 2                   @auto_period:
0001C5r 2                       lda @pitch+0
0001C5r 2                       sta @env_period+0
0001C5r 2                       lda @pitch+1
0001C5r 2                       sta @env_period+1
0001C5r 2                       jmp @set_envelope_volume_flag
0001C5r 2               
0001C5r 2                   @manual_period:
0001C5r 2                       lda famistudio_s5b_env_period_lo
0001C5r 2                       sta @env_period+0
0001C5r 2                       lda famistudio_s5b_env_period_hi
0001C5r 2                       sta @env_period+1
0001C5r 2               
0001C5r 2               @set_envelope_volume_flag:
0001C5r 2                   lda #$10
0001C5r 2               
0001C5r 2               @noenv:
0001C5r 2                   sta @env_bit
0001C5r 2               
0001C5r 2                   ; Read/multiply volume
0001C5r 2                   ldx famistudio_s5b_env_table,y
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_chn_volume_track+FAMISTUDIO_S5B_CH0_IDX, y
0001C5r 2                       .if FAMISTUDIO_USE_VOLUME_SLIDES
0001C5r 2                           ; During a slide, the lower 4 bits are fraction.
0001C5r 2                           and #$f0
0001C5r 2                       .endif
0001C5r 2                       ora famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .else
0001C5r 2                       lda famistudio_env_value+FAMISTUDIO_ENV_VOLUME_OFF,x
0001C5r 2                   .endif
0001C5r 2                   tax
0001C5r 2               
0001C5r 2               @update_volume:
0001C5r 2                   ; Write volume
0001C5r 2                   lda famistudio_s5b_vol_table,y
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   .if FAMISTUDIO_USE_VOLUME_TRACK
0001C5r 2                       lda famistudio_volume_table,x
0001C5r 2                       ora @env_bit
0001C5r 2                   .else
0001C5r 2                       txa
0001C5r 2                       ora @env_bit
0001C5r 2                   .endif
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2               
0001C5r 2               @write_shared_registers:
0001C5r 2                   ; Channel 2 writes all 5 shared registers.
0001C5r 2                   cpy #2
0001C5r 2                   bne @done
0001C5r 2                   lda @env_shape
0001C5r 2                   beq @write_shared_noise
0001C5r 2                   ldx @env_octave
0001C5r 2                   cpx #$80
0001C5r 2                   beq @write_shared_env_register
0001C5r 2               
0001C5r 2               @compute_auto_period:
0001C5r 2                   cpx #0
0001C5r 2                   beq @write_shared_env_register
0001C5r 2                   bpl @positive_octave_loop
0001C5r 2               
0001C5r 2                   @negative_octave_loop:
0001C5r 2                           asl @env_period+0
0001C5r 2                           rol @env_period+1
0001C5r 2                           inx
0001C5r 2                           bne @negative_octave_loop
0001C5r 2                       beq @write_shared_env_register
0001C5r 2               
0001C5r 2                   @positive_octave_loop:
0001C5r 2                       cpx #1
0001C5r 2                       bne @do_shift
0001C5r 2                       @rounding:
0001C5r 2                           lda @env_period+0
0001C5r 2                           and #1
0001C5r 2                           beq @do_shift
0001C5r 2                           lda @env_period+0
0001C5r 2                           clc
0001C5r 2                           adc #1
0001C5r 2                           sta @env_period+0
0001C5r 2                           bcc @do_shift
0001C5r 2                           inc @env_period+1
0001C5r 2                       @do_shift:
0001C5r 2                           lsr @env_period+1
0001C5r 2                           ror @env_period+0
0001C5r 2                           dex
0001C5r 2                           bne @positive_octave_loop
0001C5r 2               
0001C5r 2               @write_shared_env_register:
0001C5r 2               
0001C5r 2                   ; Envelope period.
0001C5r 2                   lda #FAMISTUDIO_S5B_REG_ENV_LO
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   lda @env_period+0
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2                   lda #FAMISTUDIO_S5B_REG_ENV_HI
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   lda @env_period+1
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2               
0001C5r 2                   ; Reset envelope if there was an attack.
0001C5r 2                   lda @attack
0001C5r 2                   bpl @write_shared_noise
0001C5r 2                       lda #FAMISTUDIO_S5B_REG_SHAPE
0001C5r 2                       sta FAMISTUDIO_S5B_ADDR
0001C5r 2                       lda @env_shape
0001C5r 2                       sta FAMISTUDIO_S5B_DATA
0001C5r 2               
0001C5r 2               @write_shared_noise:
0001C5r 2               
0001C5r 2                   ; Tone/noise enabled.
0001C5r 2                   lda #FAMISTUDIO_S5B_REG_TONE
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   lda famistudio_env_value+FAMISTUDIO_S5B_CH2_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2                   asl
0001C5r 2                   ora famistudio_env_value+FAMISTUDIO_S5B_CH1_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2                   asl
0001C5r 2                   ora famistudio_env_value+FAMISTUDIO_S5B_CH0_ENVS+FAMISTUDIO_ENV_MIXER_IDX_OFF
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2               
0001C5r 2                   ; Noise freq
0001C5r 2                   lda #FAMISTUDIO_S5B_REG_NOISE
0001C5r 2                   sta FAMISTUDIO_S5B_ADDR
0001C5r 2                   lda @noise_freq
0001C5r 2                   sta FAMISTUDIO_S5B_DATA
0001C5r 2               
0001C5r 2                   lda #0
0001C5r 2                   sta famistudio_s5b_env_override
0001C5r 2               
0001C5r 2               @done:
0001C5r 2                   rts
0001C5r 2               
0001C5r 2               .endif
0001C5r 2               
0001C5r 2               .if FAMISTUDIO_USE_PHASE_RESET
0001C5r 2               
0001C5r 2               ;======================================================================================================================
0001C5r 2               ; FAMISTUDIO_PROCESS_PHASE_RESETS (internal)
0001C5r 2               ;
0001C5r 2               ; Reset phases for channels that requested it this frame.
0001C5r 2               ;======================================================================================================================
0001C5r 2               
0001C5r 2               .macro conditional_phase_reset_regular prev_hi, reg_hi
0001C5r 2                   .local @done
0001C5r 2                   lsr
0001C5r 2                   bcc @done
0001C5r 2                   ldy prev_hi
0001C5r 2                   sty reg_hi
0001C5r 2                   @done:
0001C5r 2               .endmacro
0001C5r 2               
0001C5r 2               .macro conditional_phase_reset_vrc6 prev_hi, reg_hi
0001C5r 2                   .local @done
0001C5r 2                   lsr
0001C5r 2                   bcc @done
0001C5r 2                   tax
0001C5r 2                   lda prev_hi
0001C5r 2                   sta reg_hi
0001C5r 2                   ora #$80
0001C5r 2                   sta reg_hi
0001C5r 2                   txa
0001C5r 2                   @done:
0001C5r 2               .endmacro
0001C5r 2               
0001C5r 2               .macro conditional_phase_reset_fds prev_hi, reg_hi
0001C5r 2                   .local @done
0001C5r 2                   lsr
0001C5r 2                   bcc @done
0001C5r 2                   lda prev_hi
0001C5r 2                   ora #$80
0001C5r 2                   sta reg_hi
0001C5r 2                   and #$7f
0001C5r 2                   sta reg_hi
0001C5r 2                   @done:
0001C5r 2               .endmacro
0001C5r 2               
0001C5r 2               famistudio_process_phase_resets:
0001C5r 2               
0001C5r 2                   ; We group all the phase resets here at the end of the frame to make it easier to replicate in the main app since
0001C5r 2                   ; this routine will have very predictable # of cycle between channels, and having channels closers mean its easier
0001C5r 2                   ; to sync 2 channels together. The downside is that we need to keep the previous hi-period for VRC6 (3-bytes) and
0001C5r 2                   ; FDS (1-byte).
0001C5r 2               
0001C5r 2  AD rr rr         lda famistudio_phase_reset
0001C8r 2               
0001C8r 2                   ; TODO : What about SFX here? A phase reset here will reset the SFX? Or will it?
0001C8r 2  4A 90 06 AC      conditional_phase_reset_regular famistudio_pulse1_prev, FAMISTUDIO_APU_PL1_HI
0001CCr 2  rr rr 8C 03  
0001D0r 2  40           
0001D1r 2  4A 90 06 AC      conditional_phase_reset_regular famistudio_pulse2_prev, FAMISTUDIO_APU_PL2_HI
0001D5r 2  rr rr 8C 07  
0001D9r 2  40           
0001DAr 2               
0001DAr 2                   .if FAMISTUDIO_EXP_VRC6
0001DAr 2                       conditional_phase_reset_vrc6 famistudio_vrc6_pulse1_prev_hi, FAMISTUDIO_VRC6_PL1_HI
0001DAr 2                       conditional_phase_reset_vrc6 famistudio_vrc6_pulse2_prev_hi, FAMISTUDIO_VRC6_PL2_HI
0001DAr 2                       conditional_phase_reset_vrc6 famistudio_vrc6_saw_prev_hi, FAMISTUDIO_VRC6_SAW_HI
0001DAr 2                   .else
0001DAr 2  4A                   lsr
0001DBr 2  4A                   lsr
0001DCr 2  4A                   lsr
0001DDr 2                   .endif
0001DDr 2               
0001DDr 2                   .if FAMISTUDIO_EXP_MMC5
0001DDr 2                       conditional_phase_reset_regular famistudio_mmc5_pulse1_prev, FAMISTUDIO_MMC5_PL1_HI
0001DDr 2                       conditional_phase_reset_regular famistudio_mmc5_pulse2_prev, FAMISTUDIO_MMC5_PL2_HI
0001DDr 2                   .else
0001DDr 2  4A                   lsr
0001DEr 2  4A                   lsr
0001DFr 2                   .endif
0001DFr 2               
0001DFr 2                   .if FAMISTUDIO_EXP_FDS
0001DFr 2                       conditional_phase_reset_fds famistudio_fds_prev_hi, FAMISTUDIO_FDS_FREQ_HI
0001DFr 2                   .endif
0001DFr 2               
0001DFr 2                   .if FAMISTUDIO_EXP_N163
0001DFr 2                   ldx #0
0001DFr 2                   @n163_phase_reset_loop:
0001DFr 2                       lda famistudio_channel_to_phase_reset_mask+FAMISTUDIO_N163_CH0_IDX, x
0001DFr 2                       and famistudio_phase_reset_n163
0001DFr 2                       beq @next_n163_channel
0001DFr 2                           ldy #0
0001DFr 2                           lda famistudio_n163_phase_table_lo,x
0001DFr 2                           sta FAMISTUDIO_N163_ADDR
0001DFr 2                           sty FAMISTUDIO_N163_DATA
0001DFr 2                           lda famistudio_n163_phase_table_mid,x
0001DFr 2                           sta FAMISTUDIO_N163_ADDR
0001DFr 2                           sty FAMISTUDIO_N163_DATA
0001DFr 2                           lda famistudio_n163_phase_table_hi,x
0001DFr 2                           sta FAMISTUDIO_N163_ADDR
0001DFr 2                           sty FAMISTUDIO_N163_DATA
0001DFr 2                       @next_n163_channel:
0001DFr 2                           inx
0001DFr 2                           cpx #FAMISTUDIO_EXP_N163_CHN_CNT
0001DFr 2                           bne @n163_phase_reset_loop
0001DFr 2                   .endif
0001DFr 2               
0001DFr 2                   @clear_phase_reset_flags:
0001DFr 2  A9 00                lda #0
0001E1r 2  8D rr rr             sta famistudio_phase_reset
0001E4r 2                       .if FAMISTUDIO_EXP_N163
0001E4r 2                           sta famistudio_phase_reset_n163
0001E4r 2                       .endif
0001E4r 2  60                   rts
0001E5r 2               
0001E5r 2               .endif
0001E5r 2               
0001E5r 2               .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
0001E5r 2               
0001E5r 2               ;======================================================================================================================
0001E5r 2               ; FAMISTUDIO_UPDATE_ROW_WITH_DELAYS (internal)
0001E5r 2               ;
0001E5r 2               ; Advance the song for a given channel, but while managing notes/cuts delays.
0001E5r 2               ;
0001E5r 2               ; [in] x: channel index (also true when leaving the function)
0001E5r 2               ;======================================================================================================================
0001E5r 2               
0001E5r 2               famistudio_advance_channel_with_delays:
0001E5r 2               
0001E5r 2                   ; Is the tempo telling us to advance by 1 row?
0001E5r 2  AD rr rr         lda famistudio_tempo_advance_row
0001E8r 2  F0 10            beq @check_delayed_note
0001EAr 2               
0001EAr 2                   ; Tempo says we need to advance, was there a delayed note wairing?
0001EAr 2  BD rr rr         lda famistudio_chn_note_delay,x
0001EDr 2  30 18            bmi @advance
0001EFr 2               
0001EFr 2                   ; Need to clear any pending delayed note before advancing (will be inaudible).
0001EFr 2                   @clear_delayed_note:
0001EFr 2  A9 FF            lda #$ff
0001F1r 2  9D rr rr         sta famistudio_chn_note_delay,x
0001F4r 2  20 rr rr         jsr famistudio_advance_channel ; This is the update for the de delayed note.
0001F7r 2  4C rr rr         jmp @advance
0001FAr 2               
0001FAr 2                   ; Tempo said we didnt need to advance, see if there is delayed note with a counter that reached zero.
0001FAr 2                   @check_delayed_note:
0001FAr 2  BD rr rr         lda famistudio_chn_note_delay,x
0001FDr 2  30 0B            bmi @check_delayed_cut
0001FFr 2  38               sec
000200r 2  E9 01            sbc #1
000202r 2  9D rr rr         sta famistudio_chn_note_delay,x
000205r 2  10 03            bpl @check_delayed_cut ; When wrapping from 0 -> 0xff, we play the note.
000207r 2               
000207r 2                   ; Finally, advance by 1 row.
000207r 2                   @advance:
000207r 2  20 rr rr         jsr famistudio_advance_channel
00020Ar 2               
00020Ar 2                   ; Handle delayed cuts.
00020Ar 2                   @check_delayed_cut:
00020Ar 2  BD rr rr         lda famistudio_chn_cut_delay,x
00020Dr 2  30 14            bmi @done
00020Fr 2  38               sec
000210r 2  E9 01            sbc #1
000212r 2  9D rr rr         sta famistudio_chn_cut_delay,x
000215r 2  10 0C            bpl @done ; When wrapping from 0 -> 0xff, we play the note.
000217r 2               
000217r 2                   ; Write a stop note.
000217r 2  A9 00            lda #0
000219r 2  9D rr rr         sta famistudio_chn_note,x
00021Cr 2               
00021Cr 2                   ; Special case for DPCM, need to stop it manually.
00021Cr 2  E0 04            cpx #4
00021Er 2  D0 03            bne @done
000220r 2  20 rr rr         jsr famistudio_sample_stop
000223r 2               
000223r 2                   @done:
000223r 2  60               rts
000224r 2               
000224r 2               .endif
000224r 2               
000224r 2               ;======================================================================================================================
000224r 2               ; FAMISTUDIO_UPDATE (public)
000224r 2               ;
000224r 2               ; Main update function, should be called once per frame, ideally at the end of NMI. Will update the tempo, advance
000224r 2               ; the song if needed, update instrument and apply any change to the APU registers.
000224r 2               ;
000224r 2               ; [in] no input params.
000224r 2               ;======================================================================================================================
000224r 2               
000224r 2               famistudio_update:
000224r 2               
000224r 2                   @pitch_env_type = famistudio_r0
000224r 2                   @temp_pitch     = famistudio_r1
000224r 2                   @tempo_env_ptr  = famistudio_ptr0
000224r 2                   @env_ptr        = famistudio_ptr0
000224r 2                   @pitch_env_ptr  = famistudio_ptr0
000224r 2               
000224r 2               .if FAMISTUDIO_CFG_THREAD
000224r 2  A5 rr            lda famistudio_ptr0_lo
000226r 2  48               pha
000227r 2  A5 rr            lda famistudio_ptr0_hi
000229r 2  48               pha
00022Ar 2               .endif
00022Ar 2               
00022Ar 2  AD rr rr         lda famistudio_song_speed ; Speed 0 means that no music is playing currently
00022Dr 2  30 02            bmi @pause ; Bit 7 set is the pause flag
00022Fr 2  D0 03            bne @update
000231r 2               @pause:
000231r 2               .if !FAMISTUDIO_USE_FAMITRACKER_TEMPO
000231r 2                   lda #1
000231r 2                   sta famistudio_tempo_frame_cnt
000231r 2               .endif
000231r 2  4C rr rr         jmp @update_sound
000234r 2               
000234r 2               ;----------------------------------------------------------------------------------------------------------------------
000234r 2               @update:
000234r 2               
000234r 2               .if FAMISTUDIO_USE_FAMITRACKER_TEMPO
000234r 2               
000234r 2  AD rr rr         lda famistudio_tempo_acc_hi
000237r 2  CD rr rr         cmp famistudio_song_speed
00023Ar 2                   .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
00023Ar 2  A2 00                ldx #0
00023Cr 2  8E rr rr             stx famistudio_tempo_advance_row
00023Fr 2  90 0B                bcc @advance_song
000241r 2                   .else
000241r 2                       bcc @update_envelopes
000241r 2                   .endif
000241r 2  ED rr rr         sbc famistudio_song_speed ; Carry is set.
000244r 2  8D rr rr         sta famistudio_tempo_acc_hi
000247r 2                   .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
000247r 2  A2 01                ldx #1
000249r 2  8E rr rr             stx famistudio_tempo_advance_row
00024Cr 2                   .endif
00024Cr 2               
00024Cr 2               .else ; FamiStudio tempo
00024Cr 2               
00024Cr 2                   ; Decrement envelope counter, see if we need to advance.
00024Cr 2                   dec famistudio_tempo_env_counter
00024Cr 2                   beq @advance_tempo_envelope
00024Cr 2                   lda #1
00024Cr 2                   jmp @store_frame_count
00024Cr 2               
00024Cr 2               @advance_tempo_envelope:
00024Cr 2                   ; Advance the envelope by one step.
00024Cr 2                   lda famistudio_tempo_env_ptr_lo
00024Cr 2                   sta @tempo_env_ptr+0
00024Cr 2                   lda famistudio_tempo_env_ptr_hi
00024Cr 2                   sta @tempo_env_ptr+1
00024Cr 2               
00024Cr 2                   inc famistudio_tempo_env_idx
00024Cr 2                   ldy famistudio_tempo_env_idx
00024Cr 2                   lda (@tempo_env_ptr),y
00024Cr 2                   bpl @store_counter ; Negative value means we loop back to to index 1.
00024Cr 2               
00024Cr 2               @tempo_envelope_end:
00024Cr 2                   ldy #1
00024Cr 2                   sty famistudio_tempo_env_idx
00024Cr 2                   lda (@tempo_env_ptr),y
00024Cr 2               
00024Cr 2               @store_counter:
00024Cr 2                   ; Reset the counter
00024Cr 2                   sta famistudio_tempo_env_counter
00024Cr 2                   lda famistudio_tempo_frame_num
00024Cr 2                   bne @store_frame_count
00024Cr 2                   jmp @skip_frame
00024Cr 2               
00024Cr 2               @store_frame_count:
00024Cr 2                   sta famistudio_tempo_frame_cnt
00024Cr 2               
00024Cr 2               .endif
00024Cr 2               
00024Cr 2               ;----------------------------------------------------------------------------------------------------------------------
00024Cr 2               @advance_song:
00024Cr 2  A2 00            ldx #0
00024Er 2                   @channel_loop:
00024Er 2                       .if !FAMISTUDIO_CFG_DPCM_SUPPORT
00024Er 2                           cpx #4
00024Er 2                           beq @channel_loop_end
00024Er 2                       .endif
00024Er 2                       .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
00024Er 2  20 rr rr                 jsr famistudio_advance_channel_with_delays
000251r 2                       .else
000251r 2                           jsr famistudio_advance_channel
000251r 2                       .endif
000251r 2                       @channel_loop_end:
000251r 2  E8                   inx
000252r 2  E0 05                cpx #FAMISTUDIO_NUM_CHANNELS
000254r 2  D0 F8                bne @channel_loop
000256r 2               
000256r 2               ;----------------------------------------------------------------------------------------------------------------------
000256r 2               @update_envelopes:
000256r 2  A2 00            ldx #0
000258r 2               
000258r 2               @env_process:
000258r 2  BD rr rr         lda famistudio_env_repeat,x
00025Br 2  F0 05            beq @env_read
00025Dr 2  DE rr rr         dec famistudio_env_repeat,x
000260r 2  D0 2B            bne @env_next
000262r 2               
000262r 2               @env_read:
000262r 2  BD rr rr         lda famistudio_env_addr_lo,x
000265r 2  85 rr            sta @env_ptr+0
000267r 2  BD rr rr         lda famistudio_env_addr_hi,x
00026Ar 2  85 rr            sta @env_ptr+1
00026Cr 2  BC rr rr         ldy famistudio_env_ptr,x
00026Fr 2               
00026Fr 2               @env_read_value:
00026Fr 2  B1 rr            lda (@env_ptr),y
000271r 2  10 09            bpl @env_special ; Values below 128 used as a special code, loop or repeat
000273r 2  18               clc              ; Values above 128 are output value+192 (output values are signed -63..64)
000274r 2  69 40            adc #256-192
000276r 2  9D rr rr         sta famistudio_env_value,x
000279r 2  C8               iny
00027Ar 2  D0 0D            bne @env_next_store_ptr
00027Cr 2               
00027Cr 2               @env_special:
00027Cr 2  D0 07            bne @env_set_repeat  ; Zero is the loop point, non-zero values used for the repeat counter
00027Er 2  C8               iny
00027Fr 2  B1 rr            lda (@env_ptr),y     ; Read loop position
000281r 2  A8               tay
000282r 2  4C rr rr         jmp @env_read_value
000285r 2               
000285r 2               @env_set_repeat:
000285r 2  C8               iny
000286r 2  9D rr rr         sta famistudio_env_repeat,x ; Store the repeat counter value
000289r 2               
000289r 2               @env_next_store_ptr:
000289r 2  98               tya
00028Ar 2  9D rr rr         sta famistudio_env_ptr,x
00028Dr 2               
00028Dr 2               @env_next:
00028Dr 2  E8               inx
00028Er 2               
00028Er 2  E0 0B            cpx #FAMISTUDIO_NUM_ENVELOPES
000290r 2  D0 C6            bne @env_process
000292r 2               
000292r 2               ;----------------------------------------------------------------------------------------------------------------------
000292r 2               @update_pitch_envelopes:
000292r 2  A2 00            ldx #0
000294r 2  4C rr rr         jmp @pitch_env_process
000297r 2               
000297r 2               @pitch_env_process:
000297r 2  BD rr rr         lda famistudio_pitch_env_repeat,x
00029Ar 2  F0 05            beq @pitch_env_read
00029Cr 2  DE rr rr         dec famistudio_pitch_env_repeat,x
00029Fr 2  D0 61            bne @pitch_env_next
0002A1r 2               
0002A1r 2               @pitch_env_read:
0002A1r 2  BD rr rr         lda famistudio_pitch_env_addr_lo,x
0002A4r 2  85 rr            sta @pitch_env_ptr+0
0002A6r 2  BD rr rr         lda famistudio_pitch_env_addr_hi,x
0002A9r 2  85 rr            sta @pitch_env_ptr+1
0002ABr 2  A0 00            ldy #0
0002ADr 2  B1 rr            lda (@pitch_env_ptr),y
0002AFr 2  85 rr            sta @pitch_env_type ; First value is 0 for absolute envelope, 0x80 for relative.
0002B1r 2  BC rr rr         ldy famistudio_pitch_env_ptr,x
0002B4r 2               
0002B4r 2               @pitch_env_read_value:
0002B4r 2  B1 rr            lda (@pitch_env_ptr),y
0002B6r 2  10 37            bpl @pitch_env_special
0002B8r 2  18               clc
0002B9r 2  69 40            adc #256-192
0002BBr 2  24 rr            bit @pitch_env_type
0002BDr 2  30 15            bmi @pitch_relative
0002BFr 2               
0002BFr 2               @pitch_absolute:
0002BFr 2  9D rr rr         sta famistudio_pitch_env_value_lo,x
0002C2r 2  09 00            ora #0
0002C4r 2  30 05            bmi @pitch_absolute_neg
0002C6r 2  A9 00            lda #0
0002C8r 2  4C rr rr         jmp @pitch_absolute_set_value_hi
0002CBr 2               @pitch_absolute_neg:
0002CBr 2  A9 FF            lda #$ff
0002CDr 2               @pitch_absolute_set_value_hi:
0002CDr 2  9D rr rr         sta famistudio_pitch_env_value_hi,x
0002D0r 2  C8               iny
0002D1r 2  4C rr rr         jmp @pitch_env_next_store_ptr
0002D4r 2               
0002D4r 2               @pitch_relative:
0002D4r 2  85 rr            sta @temp_pitch
0002D6r 2  18               clc
0002D7r 2  7D rr rr         adc famistudio_pitch_env_value_lo,x
0002DAr 2  9D rr rr         sta famistudio_pitch_env_value_lo,x
0002DDr 2  A5 rr            lda @temp_pitch
0002DFr 2  29 80            and #$80
0002E1r 2  10 02            bpl @pitch_relative_pos
0002E3r 2  A9 FF            lda #$ff
0002E5r 2               @pitch_relative_pos:
0002E5r 2  7D rr rr         adc famistudio_pitch_env_value_hi,x
0002E8r 2  9D rr rr         sta famistudio_pitch_env_value_hi,x
0002EBr 2  C8               iny
0002ECr 2  4C rr rr         jmp @pitch_env_next_store_ptr
0002EFr 2               
0002EFr 2               @pitch_env_special:
0002EFr 2  D0 07            bne @pitch_env_set_repeat
0002F1r 2  C8               iny
0002F2r 2  B1 rr            lda (@pitch_env_ptr),y
0002F4r 2  A8               tay
0002F5r 2  4C rr rr         jmp @pitch_env_read_value
0002F8r 2               
0002F8r 2               @pitch_env_set_repeat:
0002F8r 2  C8               iny
0002F9r 2  05 rr            ora @pitch_env_type ; This is going to set the relative flag in the hi-bit.
0002FBr 2  9D rr rr         sta famistudio_pitch_env_repeat,x
0002FEr 2               
0002FEr 2               @pitch_env_next_store_ptr:
0002FEr 2  98               tya
0002FFr 2  9D rr rr         sta famistudio_pitch_env_ptr,x
000302r 2               
000302r 2               @pitch_env_next:
000302r 2  E8               inx
000303r 2               
000303r 2  E0 03            cpx #FAMISTUDIO_NUM_PITCH_ENVELOPES
000305r 2  D0 90            bne @pitch_env_process
000307r 2               
000307r 2               .if FAMISTUDIO_USE_SLIDE_NOTES
000307r 2               ;----------------------------------------------------------------------------------------------------------------------
000307r 2               @update_slides:
000307r 2  A2 00            ldx #0
000309r 2               
000309r 2               @slide_process:
000309r 2  BD rr rr         lda famistudio_slide_step,x ; Zero repeat means no active slide.
00030Cr 2  F0 2B            beq @slide_next
00030Er 2  18               clc ; Add step to slide pitch (16bit + 8bit signed).
00030Fr 2  BD rr rr         lda famistudio_slide_step,x
000312r 2  7D rr rr         adc famistudio_slide_pitch_lo,x
000315r 2  9D rr rr         sta famistudio_slide_pitch_lo,x
000318r 2  BD rr rr         lda famistudio_slide_step,x
00031Br 2  29 80            and #$80
00031Dr 2  F0 0D            beq @positive_slide
00031Fr 2               
00031Fr 2               @negative_slide:
00031Fr 2  A9 FF            lda #$ff
000321r 2  7D rr rr         adc famistudio_slide_pitch_hi,x
000324r 2  9D rr rr         sta famistudio_slide_pitch_hi,x
000327r 2  10 10            bpl @slide_next
000329r 2  4C rr rr         jmp @clear_slide
00032Cr 2               
00032Cr 2               @positive_slide:
00032Cr 2  7D rr rr         adc famistudio_slide_pitch_hi,x
00032Fr 2  9D rr rr         sta famistudio_slide_pitch_hi,x
000332r 2  30 05            bmi @slide_next
000334r 2               
000334r 2               @clear_slide:
000334r 2  A9 00            lda #0
000336r 2  9D rr rr         sta famistudio_slide_step,x
000339r 2               
000339r 2               @slide_next:
000339r 2  E8               inx
00033Ar 2  E0 04            cpx #FAMISTUDIO_NUM_SLIDES
00033Cr 2  D0 CB            bne @slide_process
00033Er 2               .endif
00033Er 2               
00033Er 2               .if FAMISTUDIO_USE_VOLUME_SLIDES
00033Er 2               
00033Er 2               ; FIXME : This seem wayyyy more complicated than it should.
00033Er 2               ; - The track volume has 4 bits of fraction : VVVVFFFF
00033Er 2               ; - The slide step is signed : SVVVFFFF
00033Er 2               ; - The slide target (end volume) is simply : VVVV0000
00033Er 2               ;
00033Er 2               ; foreach slides
00033Er 2               ;     if step != 0
00033Er 2               ;         volume += step
00033Er 2               ;         if step > 0 && volume >= target || step < 0 && volume <= target
00033Er 2               ;             volume = target
00033Er 2               ;             step = 0
00033Er 2               
00033Er 2               @update_volume_slides:
00033Er 2  A2 00            ldx #0
000340r 2               
000340r 2               @volume_side_process:
000340r 2  BD rr rr         lda famistudio_chn_volume_slide_step,x
000343r 2  F0 3B            beq @volume_slide_next
000345r 2  18               clc
000346r 2  30 0F            bmi @negative_volume_slide
000348r 2               
000348r 2               @positive_volume_slide:
000348r 2                   ; If the slide goes up, stop if we hit the target or go over it, over 15 (carry will be set)
000348r 2  7D rr rr         adc famistudio_chn_volume_track,x
00034Br 2  B0 28            bcs @clear_volume_slide
00034Dr 2  9D rr rr         sta famistudio_chn_volume_track,x
000350r 2  DD rr rr         cmp famistudio_chn_volume_slide_target,x
000353r 2  90 2B            bcc @volume_slide_next
000355r 2  B0 1E            bcs @clear_volume_slide
000357r 2               
000357r 2               @negative_volume_slide:
000357r 2                   ; If the slide goes do, stop if we hit the target or go below it, or below zero.
000357r 2                   ; This is a bit trickier since we cant rely on the carry or any flag to
000357r 2                   ; tell us if we wrapped around.
000357r 2  7D rr rr         adc famistudio_chn_volume_track,x
00035Ar 2  BC rr rr         ldy famistudio_chn_volume_track,x
00035Dr 2  30 0C            bmi @slide_upper_half
00035Fr 2               
00035Fr 2               @slide_lower_half:
00035Fr 2  9D rr rr         sta famistudio_chn_volume_track,x
000362r 2  DD rr rr         cmp famistudio_chn_volume_slide_target,x
000365r 2  F0 0E            beq @clear_volume_slide
000367r 2  30 0C            bmi @clear_volume_slide
000369r 2  10 15            bpl @volume_slide_next
00036Br 2               
00036Br 2               @slide_upper_half:
00036Br 2  9D rr rr         sta famistudio_chn_volume_track,x
00036Er 2  DD rr rr         cmp famistudio_chn_volume_slide_target,x
000371r 2  F0 02            beq @clear_volume_slide
000373r 2  B0 0B            bcs @volume_slide_next
000375r 2               
000375r 2               @clear_volume_slide:
000375r 2  BD rr rr         lda famistudio_chn_volume_slide_target,x
000378r 2  9D rr rr         sta famistudio_chn_volume_track,x
00037Br 2  A9 00            lda #0
00037Dr 2  9D rr rr         sta famistudio_chn_volume_slide_step,x
000380r 2               
000380r 2               @volume_slide_next:
000380r 2  E8               inx
000381r 2  E0 04            cpx #FAMISTUDIO_NUM_VOLUME_SLIDES
000383r 2  D0 BB            bne @volume_side_process
000385r 2               .endif
000385r 2               
000385r 2               .if FAMISTUDIO_CFG_EQUALIZER
000385r 2               @update_equalizer:
000385r 2                   ldx #0
000385r 2                   @eq_channel_loop:
000385r 2                       lda famistudio_chn_note_counter, x
000385r 2                       beq @no_note
000385r 2                           dec famistudio_chn_note_counter, x
000385r 2                       @no_note:
000385r 2                       inx
000385r 2                       cpx #FAMISTUDIO_NUM_CHANNELS
000385r 2                       bne @eq_channel_loop
000385r 2               .endif
000385r 2               
000385r 2               ;----------------------------------------------------------------------------------------------------------------------
000385r 2               @update_sound:
000385r 2               
000385r 2  AD rr rr D0      famistudio_update_channel_sound 0, FAMISTUDIO_CH0_ENVS, famistudio_pulse1_prev, FAMISTUDIO_ALIAS_PL1_HI, FAMISTUDIO_ALIAS_PL1_LO, FAMISTUDIO_ALIAS_PL1_VOL, FAMISTUDIO_APU_PL1_SWEEP
000389r 2  03 4C rr rr  
00038Dr 2  18 6D rr rr  
0003BAr 2  AD rr rr D0      famistudio_update_channel_sound 1, FAMISTUDIO_CH1_ENVS, famistudio_pulse2_prev, FAMISTUDIO_ALIAS_PL2_HI, FAMISTUDIO_ALIAS_PL2_LO, FAMISTUDIO_ALIAS_PL2_VOL, FAMISTUDIO_APU_PL2_SWEEP
0003BEr 2  03 4C rr rr  
0003C2r 2  18 6D rr rr  
0003EFr 2  AD rr rr D0      famistudio_update_channel_sound 2, FAMISTUDIO_CH2_ENVS, , FAMISTUDIO_ALIAS_TRI_HI, FAMISTUDIO_ALIAS_TRI_LO, FAMISTUDIO_ALIAS_TRI_LINEAR
0003F3r 2  03 4C rr rr  
0003F7r 2  18 6D rr rr  
000420r 2  AD rr rr D0      famistudio_update_channel_sound 3, FAMISTUDIO_CH3_ENVS, , FAMISTUDIO_ALIAS_NOISE_LO, , FAMISTUDIO_ALIAS_NOISE_VOL
000424r 2  03 4C rr rr  
000428r 2  18 6D rr rr  
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_VRC6
00047Er 2               @update_vrc6_sound:
00047Er 2                   famistudio_update_channel_sound FAMISTUDIO_VRC6_CH0_IDX, FAMISTUDIO_VRC6_CH0_ENVS, famistudio_vrc6_pulse1_prev_hi, FAMISTUDIO_VRC6_PL1_HI, FAMISTUDIO_VRC6_PL1_LO, FAMISTUDIO_VRC6_PL1_VOL
00047Er 2                   famistudio_update_channel_sound FAMISTUDIO_VRC6_CH1_IDX, FAMISTUDIO_VRC6_CH1_ENVS, famistudio_vrc6_pulse2_prev_hi, FAMISTUDIO_VRC6_PL2_HI, FAMISTUDIO_VRC6_PL2_LO, FAMISTUDIO_VRC6_PL2_VOL
00047Er 2                   famistudio_update_channel_sound FAMISTUDIO_VRC6_CH2_IDX, FAMISTUDIO_VRC6_CH2_ENVS, famistudio_vrc6_saw_prev_hi, FAMISTUDIO_VRC6_SAW_HI, FAMISTUDIO_VRC6_SAW_LO, FAMISTUDIO_VRC6_SAW_VOL
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_MMC5
00047Er 2               @update_mmc5_sound:
00047Er 2                   famistudio_update_channel_sound FAMISTUDIO_MMC5_CH0_IDX, FAMISTUDIO_MMC5_CH0_ENVS, famistudio_mmc5_pulse1_prev, FAMISTUDIO_MMC5_PL1_HI, FAMISTUDIO_MMC5_PL1_LO, FAMISTUDIO_MMC5_PL1_VOL
00047Er 2                   famistudio_update_channel_sound FAMISTUDIO_MMC5_CH1_IDX, FAMISTUDIO_MMC5_CH1_ENVS, famistudio_mmc5_pulse2_prev, FAMISTUDIO_MMC5_PL2_HI, FAMISTUDIO_MMC5_PL2_LO, FAMISTUDIO_MMC5_PL2_VOL
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_FDS
00047Er 2               @update_fds_sound:
00047Er 2                   jsr famistudio_update_fds_channel_sound
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_VRC7
00047Er 2               @update_vrc7_sound:
00047Er 2                   ldy #0
00047Er 2                   @vrc7_channel_loop:
00047Er 2                       jsr famistudio_update_vrc7_channel_sound
00047Er 2                       iny
00047Er 2                       cpy #6
00047Er 2                       bne @vrc7_channel_loop
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_N163
00047Er 2               @update_n163_sound:
00047Er 2                   ldy #0
00047Er 2                   @n163_channel_loop:
00047Er 2                       jsr famistudio_update_n163_channel_sound
00047Er 2                       iny
00047Er 2                       cpy #FAMISTUDIO_EXP_N163_CHN_CNT
00047Er 2                       bne @n163_channel_loop
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_S5B
00047Er 2               @update_s5b_sound:
00047Er 2                   ldy #0
00047Er 2                   @s5b_channel_loop:
00047Er 2                       jsr famistudio_update_s5b_channel_sound
00047Er 2                       iny
00047Er 2                       cpy #3
00047Er 2                       bne @s5b_channel_loop
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_EXP_EPSM
00047Er 2               @update_epsm_sound:
00047Er 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT > 0
00047Er 2                   ldy #0
00047Er 2                   @epsm_square_channel_loop:
00047Er 2                       jsr famistudio_update_epsm_square_channel_sound
00047Er 2                       iny
00047Er 2                       cpy #FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT
00047Er 2                       bne @epsm_square_channel_loop
00047Er 2               .endif
00047Er 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
00047Er 2                   ldy #FAMISTUDIO_EXP_EPSM_FM_CHN_CNT - 1
00047Er 2                   @epsm_fm_channel_loop:
00047Er 2                       jsr famistudio_update_epsm_fm_channel_sound
00047Er 2                       dey
00047Er 2                       bpl @epsm_fm_channel_loop
00047Er 2               .endif
00047Er 2               .if FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
00047Er 2               @loop_cnt = famistudio_r2
00047Er 2                   lda #5
00047Er 2                   sta @loop_cnt
00047Er 2                   @epsm_rhythm_channel_loop:
00047Er 2                       ldx @loop_cnt
00047Er 2                       ldy famistudio_rhythm_lut,x
00047Er 2                       bmi @skip_epsm_rhythm_update ; if the value we load is $ff then
00047Er 2                       jsr famistudio_update_epsm_rhythm_channel_sound
00047Er 2                   @skip_epsm_rhythm_update:
00047Er 2                       dec @loop_cnt
00047Er 2                       bpl @epsm_rhythm_channel_loop
00047Er 2               .endif
00047Er 2               .endif
00047Er 2               
00047Er 2               .if FAMISTUDIO_USE_PHASE_RESET
00047Er 2  20 rr rr         jsr famistudio_process_phase_resets
000481r 2               .endif
000481r 2               
000481r 2               @update_sound_done:
000481r 2               .if FAMISTUDIO_USE_FAMITRACKER_TEMPO
000481r 2  AD rr rr         lda famistudio_song_speed
000484r 2  30 13            bmi @skip_famitracker_tempo_update ; bit 7 = paused
000486r 2  18                   clc  ; Update frame counter that considers speed, tempo, and PAL/NTSC
000487r 2  AD rr rr             lda famistudio_tempo_acc_lo
00048Ar 2  6D rr rr             adc famistudio_tempo_step_lo
00048Dr 2  8D rr rr             sta famistudio_tempo_acc_lo
000490r 2  AD rr rr             lda famistudio_tempo_acc_hi
000493r 2  6D rr rr             adc famistudio_tempo_step_hi
000496r 2  8D rr rr             sta famistudio_tempo_acc_hi
000499r 2                   @skip_famitracker_tempo_update:
000499r 2               .else
000499r 2                   ; See if we need to run a double frame (playing NTSC song on PAL)
000499r 2                   dec famistudio_tempo_frame_cnt
000499r 2                   beq @skip_frame
000499r 2                   jmp @advance_song
000499r 2               .endif
000499r 2               
000499r 2               @skip_frame:
000499r 2               
000499r 2               ;----------------------------------------------------------------------------------------------------------------------
000499r 2               .if FAMISTUDIO_CFG_SFX_SUPPORT
000499r 2               ;!!! FAMISTUDIO DRIVER MODIFICATION BEGIN
000499r 2               ;*  MODIFIED
000499r 2  A9 rr            LDA #<.bank(sounds)
00049Br 2  20 rr rr         JSR mmc3_tmp_prg_bank_1
00049Er 2               ;!!! FAMISTUDIO DRIVER MODIFICATION END
00049Er 2               
00049Er 2                   ; Process all sound effect streams
00049Er 2                   .if FAMISTUDIO_CFG_SFX_STREAMS > 0
00049Er 2  A2 00            ldx #FAMISTUDIO_SFX_CH0
0004A0r 2  20 rr rr         jsr famistudio_sfx_update
0004A3r 2                   .endif
0004A3r 2                   .if FAMISTUDIO_CFG_SFX_STREAMS > 1
0004A3r 2                   ldx #FAMISTUDIO_SFX_CH1
0004A3r 2                   jsr famistudio_sfx_update
0004A3r 2                   .endif
0004A3r 2                   .if FAMISTUDIO_CFG_SFX_STREAMS > 2
0004A3r 2                   ldx #FAMISTUDIO_SFX_CH2
0004A3r 2                   jsr famistudio_sfx_update
0004A3r 2                   .endif
0004A3r 2                   .if FAMISTUDIO_CFG_SFX_STREAMS > 3
0004A3r 2                   ldx #FAMISTUDIO_SFX_CH3
0004A3r 2                   jsr famistudio_sfx_update
0004A3r 2                   .endif
0004A3r 2               
0004A3r 2                   ; Send data from the output buffer to the APU
0004A3r 2               
0004A3r 2  AD rr rr         lda famistudio_output_buf      ; Pulse 1 volume
0004A6r 2  8D 00 40         sta FAMISTUDIO_APU_PL1_VOL
0004A9r 2  AD rr rr         lda famistudio_output_buf+1    ; Pulse 1 period LSB
0004ACr 2  8D 02 40         sta FAMISTUDIO_APU_PL1_LO
0004AFr 2  AD rr rr         lda famistudio_output_buf+2    ; Pulse 1 period MSB, only applied when changed
0004B2r 2               
0004B2r 2                   .if FAMISTUDIO_CFG_SMOOTH_VIBRATO
0004B2r 2  29 07 AA 38          famistudio_smooth_vibrato famistudio_output_buf+1, famistudio_pulse1_prev, FAMISTUDIO_APU_PL1_HI, FAMISTUDIO_APU_PL1_LO, FAMISTUDIO_APU_PL1_SWEEP
0004B6r 2  ED rr rr F0  
0004BAr 2  30 8E rr rr  
0004EBr 2                   .else
0004EBr 2                       cmp famistudio_pulse1_prev
0004EBr 2                       beq @no_pulse1_upd
0004EBr 2                       sta famistudio_pulse1_prev
0004EBr 2                       sta FAMISTUDIO_APU_PL1_HI
0004EBr 2                   .endif
0004EBr 2               
0004EBr 2               @no_pulse1_upd:
0004EBr 2  AD rr rr         lda famistudio_output_buf+3    ; Pulse 2 volume
0004EEr 2  8D 04 40         sta FAMISTUDIO_APU_PL2_VOL
0004F1r 2  AD rr rr         lda famistudio_output_buf+4    ; Pulse 2 period LSB
0004F4r 2  8D 06 40         sta FAMISTUDIO_APU_PL2_LO
0004F7r 2  AD rr rr         lda famistudio_output_buf+5    ; Pulse 2 period MSB, only applied when changed
0004FAr 2               
0004FAr 2                   .if FAMISTUDIO_CFG_SMOOTH_VIBRATO
0004FAr 2  29 07 AA 38          famistudio_smooth_vibrato famistudio_output_buf+4, famistudio_pulse2_prev, FAMISTUDIO_APU_PL2_HI, FAMISTUDIO_APU_PL2_LO, FAMISTUDIO_APU_PL2_SWEEP
0004FEr 2  ED rr rr F0  
000502r 2  30 8E rr rr  
000533r 2                   .else
000533r 2                       cmp famistudio_pulse2_prev
000533r 2                       beq @no_pulse2_upd
000533r 2                       sta famistudio_pulse2_prev
000533r 2                       sta FAMISTUDIO_APU_PL2_HI
000533r 2                   .endif
000533r 2               
000533r 2               @no_pulse2_upd:
000533r 2  AD rr rr         lda famistudio_output_buf+6    ; Triangle volume (plays or not)
000536r 2  8D 08 40         sta FAMISTUDIO_APU_TRI_LINEAR
000539r 2  AD rr rr         lda famistudio_output_buf+7    ; Triangle period LSB
00053Cr 2  8D 0A 40         sta FAMISTUDIO_APU_TRI_LO
00053Fr 2  AD rr rr         lda famistudio_output_buf+8    ; Triangle period MSB
000542r 2  8D 0B 40         sta FAMISTUDIO_APU_TRI_HI
000545r 2               
000545r 2  AD rr rr         lda famistudio_output_buf+9    ; Noise volume
000548r 2  8D 0C 40         sta FAMISTUDIO_APU_NOISE_VOL
00054Br 2  AD rr rr         lda famistudio_output_buf+10   ; Noise period
00054Er 2  8D 0E 40         sta FAMISTUDIO_APU_NOISE_LO
000551r 2               
000551r 2               .endif
000551r 2               
000551r 2               .if FAMISTUDIO_CFG_THREAD
000551r 2  68               pla
000552r 2  85 rr            sta famistudio_ptr0_hi
000554r 2  68               pla
000555r 2  85 rr            sta famistudio_ptr0_lo
000557r 2               .endif
000557r 2               
000557r 2  60               rts
000558r 2               
000558r 2               ;======================================================================================================================
000558r 2               ; FAMISTUDIO_DO_NOTE_ATTACK + EXP VARIANTS (internal)
000558r 2               ;
000558r 2               ; Internal function to reset all the envelopes of a channnel (note attack).
000558r 2               ;
000558r 2               ; [in] x/r0 : channel index
000558r 2               ;======================================================================================================================
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_VRC7
000558r 2               
000558r 2               famistudio_do_vrc7_note_attack:
000558r 2               
000558r 2                   @chan_idx = famistudio_r0
000558r 2               
000558r 2                   ; Set trigger flag for VRC7
000558r 2                   lda #1
000558r 2                   ldx @chan_idx
000558r 2                   sta famistudio_chn_vrc7_trigger-FAMISTUDIO_VRC7_CH0_IDX,x
000558r 2                   rts
000558r 2               
000558r 2               .endif
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_EPSM
000558r 2               
000558r 2               famistudio_do_epsm_note_attack:
000558r 2               
000558r 2                   @chan_idx = famistudio_r0
000558r 2                   @tmp_y    = famistudio_r1
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT+FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
000558r 2                   sty @tmp_y
000558r 2                   ldy @chan_idx
000558r 2                   cpy #FAMISTUDIO_EPSM_CHAN_FM_START
000558r 2                   bcs @fm_or_rhythm_channel
000558r 2               .endif
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT > 0
000558r 2               @square_channel:
000558r 2               
000558r 2                   ; Reset mixer/noise envelopes.
000558r 2                   ldx famistudio_channel_env,y
000558r 2                   lda #0
000558r 2                   sta famistudio_env_repeat+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
000558r 2                   sta famistudio_env_ptr+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
000558r 2                   sta famistudio_env_value+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
000558r 2                   sta famistudio_env_repeat+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
000558r 2                   sta famistudio_env_ptr+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
000558r 2                   sta famistudio_env_value+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
000558r 2               
000558r 2                   ; Set hi-bit of envelope shape to remember to reset it.
000558r 2                   lda #$80
000558r 2                   ldx @chan_idx
000558r 2                   ora famistudio_epsm_chn_env_shape-FAMISTUDIO_EPSM_CH0_IDX,x
000558r 2                   sta famistudio_epsm_chn_env_shape-FAMISTUDIO_EPSM_CH0_IDX,x
000558r 2               
000558r 2                   beq @done
000558r 2               .endif
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT+FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
000558r 2               @fm_or_rhythm_channel:
000558r 2               
000558r 2                   ; Set trigger flag for FM/rhythm. For rhythm we'll actually write
000558r 2                   ; out of bounds here, but the rhtyhm key array is immediately after.
000558r 2                   lda #1
000558r 2                   sta famistudio_chn_epsm_trigger-FAMISTUDIO_EPSM_CHAN_FM_START,y
000558r 2               .endif
000558r 2               
000558r 2               @done:
000558r 2                   ldx @chan_idx
000558r 2                   ldy @tmp_y
000558r 2                   rts
000558r 2               
000558r 2               .endif
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_N163
000558r 2               
000558r 2               famistudio_do_n163_note_attack:
000558r 2               
000558r 2                   @chan_idx = famistudio_r0
000558r 2                   @tmp_y    = famistudio_r1
000558r 2               
000558r 2                   ; Reset wave envelope.
000558r 2                   sty @tmp_y
000558r 2                   ldy @chan_idx
000558r 2                   ldx famistudio_channel_env,y
000558r 2                   lda #0
000558r 2                   sta famistudio_env_repeat+FAMISTUDIO_ENV_N163_WAVE_IDX_OFF,x
000558r 2                   lda #1 ; Index 0 is release point, so envelope starts at 1.
000558r 2                   sta famistudio_env_ptr+FAMISTUDIO_ENV_N163_WAVE_IDX_OFF,x
000558r 2               
000558r 2                   ; Clear wave index to -1 to force reload.
000558r 2                   ldx @chan_idx
000558r 2                   lda #$ff
000558r 2                   sta famistudio_chn_n163_wave_index-FAMISTUDIO_N163_CH0_IDX, x
000558r 2                   ldy @tmp_y
000558r 2                   rts
000558r 2               
000558r 2               .endif
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_S5B
000558r 2               
000558r 2               famistudio_do_s5b_note_attack:
000558r 2               
000558r 2                   @chan_idx = famistudio_r0
000558r 2                   @tmp_y    = famistudio_r1
000558r 2               
000558r 2                   ; Reset mixer/noise envelopes.
000558r 2                   sty @tmp_y
000558r 2                   ldy @chan_idx
000558r 2                   ldx famistudio_channel_env,y
000558r 2                   lda #0
000558r 2                   sta famistudio_env_repeat+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
000558r 2                   sta famistudio_env_ptr+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
000558r 2                   sta famistudio_env_value+FAMISTUDIO_ENV_MIXER_IDX_OFF,x
000558r 2                   sta famistudio_env_repeat+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
000558r 2                   sta famistudio_env_ptr+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
000558r 2                   sta famistudio_env_value+FAMISTUDIO_ENV_NOISE_IDX_OFF,x
000558r 2                   ldx @chan_idx
000558r 2                   ldy @tmp_y
000558r 2               
000558r 2                   ; Set hi-bit of envelope shape to remember to reset it.
000558r 2                   lda #$80
000558r 2                   ora famistudio_s5b_chn_env_shape-FAMISTUDIO_S5B_CH0_IDX,x
000558r 2                   sta famistudio_s5b_chn_env_shape-FAMISTUDIO_S5B_CH0_IDX,x
000558r 2                   rts
000558r 2               
000558r 2               .endif
000558r 2               
000558r 2               .if FAMISTUDIO_EXP_FDS
000558r 2               
000558r 2               famistudio_do_fds_note_attack:
000558r 2               
000558r 2                   @chan_idx = famistudio_r0
000558r 2                   @tmp_y    = famistudio_r1
000558r 2               
000558r 2                   ; TODO : We used to set the modulation value here, but that's bad.
000558r 2                   ; https://www.nesdev.org/wiki/FDS_audio#Mod_frequency_high_($4087)
000558r 2                   ; lda #$80
000558r 2                   ; sta FAMISTUDIO_FDS_MOD_HI
000558r 2                   ; lda #0
000558r 2                   ; sta FAMISTUDIO_FDS_SWEEP_BIAS
000558r 2               
000558r 2                   lda famistudio_fds_mod_delay
000558r 2                   sta famistudio_fds_mod_delay_counter
000558r 2               
000558r 2                   sty @tmp_y
000558r 2                   ldy @chan_idx
000558r 2                   ldx famistudio_channel_env,y
000558r 2                   lda #0
000558r 2                   sta famistudio_env_repeat+FAMISTUDIO_ENV_FDS_WAVE_IDX_OFF,x
000558r 2                   lda #1 ; Index 0 is release point, so envelope starts at 1.
000558r 2                   sta famistudio_env_ptr+FAMISTUDIO_ENV_FDS_WAVE_IDX_OFF,x
000558r 2               
000558r 2                   ; Clear wave index to -1 to force reload.
000558r 2                   ldx @chan_idx
000558r 2                   lda #$ff
000558r 2                   sta famistudio_fds_wave_index
000558r 2                   ldy @tmp_y
000558r 2                   rts
000558r 2               
000558r 2               .endif
000558r 2               
000558r 2               famistudio_do_note_attack:
000558r 2               
000558r 2                   @chan_idx = famistudio_r0
000558r 2                   @tmp_x    = famistudio_r2
000558r 2               
000558r 2               .if FAMISTUDIO_CFG_EQUALIZER
000558r 2                   lda #9
000558r 2                   sta famistudio_chn_note_counter,x
000558r 2               .endif
000558r 2               .if FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
000558r 2                   lda @chan_idx
000558r 2                   cmp #FAMISTUDIO_EPSM_CHAN_RHYTHM_START
000558r 2                   bcs @epsm_instrument
000558r 2               .endif
000558r 2  BD rr rr         lda famistudio_channel_env,x
00055Br 2  AA               tax
00055Cr 2               
00055Cr 2                   ; Volume envelope.
00055Cr 2  A9 01            lda #1
00055Er 2  9D rr rr         sta famistudio_env_ptr,x ; Reset volume envelope pointer to 1 (volume have releases point in index 0)
000561r 2  A9 00            lda #0
000563r 2  9D rr rr         sta famistudio_env_repeat,x
000566r 2               
000566r 2                   ; Arpeggio envelope
000566r 2  9D rr rr         sta famistudio_env_repeat+FAMISTUDIO_ENV_NOTE_OFF,x
000569r 2  9D rr rr         sta famistudio_env_ptr+FAMISTUDIO_ENV_NOTE_OFF,x
00056Cr 2               
00056Cr 2                   ; Duty envelope (optional)
00056Cr 2  A5 rr            lda @chan_idx
00056Er 2  C9 02            cmp #2 ; Triangle has no duty.
000570r 2  F0 18            beq @no_duty
000572r 2               .if FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_S5B || FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_EPSM
000572r 2                   cmp #5
000572r 2                   bcs @no_duty
000572r 2               .endif
000572r 2               @duty:
000572r 2  A9 00            lda #0
000574r 2  9D rr rr         sta famistudio_env_repeat+FAMISTUDIO_ENV_DUTY_OFF,x
000577r 2  9D rr rr         sta famistudio_env_ptr+FAMISTUDIO_ENV_DUTY_OFF,x
00057Ar 2                   .if FAMISTUDIO_USE_DUTYCYCLE_EFFECT
00057Ar 2  86 rr                stx @tmp_x
00057Cr 2  A6 rr                ldx @chan_idx
00057Er 2  BD rr rr             lda famistudio_channel_to_dutycycle,x
000581r 2  AA                   tax
000582r 2  BD rr rr             lda famistudio_duty_cycle,x
000585r 2  A6 rr                ldx @tmp_x
000587r 2                   .endif
000587r 2  9D rr rr         sta famistudio_env_value+FAMISTUDIO_ENV_DUTY_OFF,x
00058Ar 2               
00058Ar 2               @no_duty:
00058Ar 2                   ; Pitch envelope
00058Ar 2  A6 rr            ldx @chan_idx
00058Cr 2  BD rr rr         lda famistudio_channel_to_pitch_env, x
00058Fr 2  30 11            bmi @no_pitch
000591r 2  AA               tax
000592r 2               
000592r 2               @reset_pitch_env:
000592r 2  A9 00            lda #0
000594r 2  9D rr rr         sta famistudio_pitch_env_value_lo,x
000597r 2  9D rr rr         sta famistudio_pitch_env_value_hi,x
00059Ar 2  9D rr rr         sta famistudio_pitch_env_repeat,x
00059Dr 2  A9 01            lda #1
00059Fr 2  9D rr rr         sta famistudio_pitch_env_ptr,x     ; Reset pitch envelope pointer to 1 (pitch envelope have relative/absolute flag in the first byte)
0005A2r 2               
0005A2r 2               @no_pitch:
0005A2r 2               
0005A2r 2               .if FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_S5B || FAMISTUDIO_EXP_FDS
0005A2r 2                   lda @chan_idx
0005A2r 2                   cmp #5
0005A2r 2                   bcc @done
0005A2r 2                   @vrc7_instrument:
0005A2r 2                   .if FAMISTUDIO_EXP_VRC7
0005A2r 2                       jmp famistudio_do_vrc7_note_attack
0005A2r 2                   .endif
0005A2r 2                   @n163_instrument:
0005A2r 2                   .if FAMISTUDIO_EXP_N163
0005A2r 2                       jmp famistudio_do_n163_note_attack
0005A2r 2                   .endif
0005A2r 2                   @s5b_instrument:
0005A2r 2                   .if FAMISTUDIO_EXP_S5B
0005A2r 2                       jmp famistudio_do_s5b_note_attack
0005A2r 2                   .endif
0005A2r 2                   @fds_instrument:
0005A2r 2                   .if FAMISTUDIO_EXP_FDS
0005A2r 2                       jmp famistudio_do_fds_note_attack
0005A2r 2                   .endif
0005A2r 2                   @epsm_instrument:
0005A2r 2                   .if FAMISTUDIO_EXP_EPSM
0005A2r 2                       jmp famistudio_do_epsm_note_attack
0005A2r 2                   .endif
0005A2r 2               .endif
0005A2r 2               
0005A2r 2               @done:
0005A2r 2  A6 rr            ldx @chan_idx
0005A4r 2  60               rts
0005A5r 2               
0005A5r 2               ;======================================================================================================================
0005A5r 2               ; FAMISTUDIO_LOAD_BASIC_ENVELOPES (internal)
0005A5r 2               ;
0005A5r 2               ; Internal function to load the most common envelopes (volume, arp, duty (optional) and pitch) for an instrument.
0005A5r 2               ;
0005A5r 2               ; [in] x:      first envelope index.
0005A5r 2               ; [in] r0:     instrument index.
0005A5r 2               ; [in] ptr1/y: point to instrument data to load.
0005A5r 2               ;======================================================================================================================
0005A5r 2               
0005A5r 2               famistudio_load_basic_envelopes:
0005A5r 2               
0005A5r 2                   @instrument_ptr = famistudio_ptr1
0005A5r 2                   @chan_idx      = famistudio_r0
0005A5r 2                   @tmp_x         = famistudio_r3
0005A5r 2               
0005A5r 2                   ; Volume envelope
0005A5r 2  B1 rr            lda (@instrument_ptr),y
0005A7r 2  9D rr rr         sta famistudio_env_addr_lo,x
0005AAr 2  C8               iny
0005ABr 2  B1 rr            lda (@instrument_ptr),y
0005ADr 2  C8               iny
0005AEr 2  9D rr rr         sta famistudio_env_addr_hi,x
0005B1r 2  E8               inx
0005B2r 2               
0005B2r 2                   ; Arpeggio envelope
0005B2r 2               .if FAMISTUDIO_USE_ARPEGGIO
0005B2r 2  86 rr            stx @tmp_x
0005B4r 2  A6 rr            ldx @chan_idx
0005B6r 2  BD rr rr         lda famistudio_chn_env_override,x ; Check if its overriden by arpeggio.
0005B9r 2  4A               lsr
0005BAr 2  A6 rr            ldx @tmp_x
0005BCr 2  90 04            bcc @arpeggio_envelope
0005BEr 2  C8               iny ; Instrument arpeggio is overriden by arpeggio, dont touch!
0005BFr 2  4C rr rr         jmp @duty_envelope
0005C2r 2               .endif
0005C2r 2               
0005C2r 2               @arpeggio_envelope:
0005C2r 2  B1 rr            lda (@instrument_ptr),y
0005C4r 2  9D rr rr         sta famistudio_env_addr_lo,x
0005C7r 2  C8               iny
0005C8r 2  B1 rr            lda (@instrument_ptr),y
0005CAr 2  9D rr rr         sta famistudio_env_addr_hi,x
0005CDr 2               
0005CDr 2               @duty_envelope:
0005CDr 2                   ; Duty cycle envelope
0005CDr 2  A5 rr            lda @chan_idx
0005CFr 2  C9 02            cmp #2 ; Triangle has no duty.
0005D1r 2  F0 10            beq @no_duty
0005D3r 2               .if FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_S5B || FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_EPSM
0005D3r 2                   cmp #5
0005D3r 2                   bcs @pitch_envelope
0005D3r 2               .endif
0005D3r 2                   @duty:
0005D3r 2  E8                   inx
0005D4r 2  C8                   iny
0005D5r 2  B1 rr                lda (@instrument_ptr),y
0005D7r 2  9D rr rr             sta famistudio_env_addr_lo,x
0005DAr 2  C8                   iny
0005DBr 2  B1 rr                lda (@instrument_ptr),y
0005DDr 2  9D rr rr             sta famistudio_env_addr_hi,x
0005E0r 2  4C rr rr             jmp @pitch_envelope
0005E3r 2                   @no_duty:
0005E3r 2  C8                   iny
0005E4r 2  C8                   iny
0005E5r 2               
0005E5r 2               @pitch_envelope:
0005E5r 2                   ; Pitch envelopes.
0005E5r 2               .if !FAMISTUDIO_EXP_NONE
0005E5r 2                   stx @tmp_x
0005E5r 2               .endif
0005E5r 2  A6 rr            ldx @chan_idx
0005E7r 2               .if FAMISTUDIO_USE_VIBRATO
0005E7r 2  BD rr rr         lda famistudio_chn_env_override,x
0005EAr 2  0A               asl ; Bit-7 tells us if the pitch env is overriden, temporarely store in carry.
0005EBr 2               .endif
0005EBr 2  BD rr rr         lda famistudio_channel_to_pitch_env, x
0005EEr 2  30 14            bmi @done
0005F0r 2  AA               tax
0005F1r 2               .if FAMISTUDIO_USE_VIBRATO
0005F1r 2  6A               ror ; Bring back our bit-7 from above.
0005F2r 2  10 04            bpl @no_vibrato ; In bit 7 is set, instrument pitch is overriden by vibrato, dont touch pitch envelope!
0005F4r 2  C8               iny
0005F5r 2  C8               iny
0005F6r 2  D0 0C            bne @done
0005F8r 2                   @no_vibrato:
0005F8r 2               .endif
0005F8r 2  C8               iny
0005F9r 2  B1 rr            lda (@instrument_ptr),y
0005FBr 2  9D rr rr         sta famistudio_pitch_env_addr_lo,x
0005FEr 2  C8               iny
0005FFr 2  B1 rr            lda (@instrument_ptr),y
000601r 2  9D rr rr         sta famistudio_pitch_env_addr_hi,x
000604r 2               @done:
000604r 2               .if !FAMISTUDIO_EXP_NONE
000604r 2                   ; For expansion, preserve X (envelope index) and Y (pointer in instrument data)
000604r 2                   ; as they may want to load more after.
000604r 2                   ldx @tmp_x
000604r 2                   inx
000604r 2                   iny
000604r 2               .endif
000604r 2  60               rts
000605r 2               
000605r 2               ;======================================================================================================================
000605r 2               ; FAMISTUDIO_SET_INSTRUMENT (internal)
000605r 2               ;
000605r 2               ; Internal function to set an instrument for a given channel. Will initialize all instrument envelopes.
000605r 2               ;
000605r 2               ; [in] x/r0: channel index
000605r 2               ; [in] a:    instrument index.
000605r 2               ;======================================================================================================================
000605r 2               
000605r 2               famistudio_set_instrument:
000605r 2               
000605r 2                   @instrument_ptr = famistudio_ptr1
000605r 2                   @chan_idx      = famistudio_r0
000605r 2               
000605r 2               ;!!! FAMISTUDIO DRIVER MODIFICATION BEGIN
000605r 2               ;*  MODIFIED
000605r 2               	.ifdef CURSED_MUSIC_ENABLE
000605r 2               	; Randomize the instrument if the music is cursed
000605r 2  2C rr rr         bit _cursedmusic
000608r 2  50 10        	bvc @no_randomization
00060Ar 2  4D rr rr     	eor famistudio_tempo_acc_lo
00060Dr 2               
00060Dr 2               	@randomization_loop:
00060Dr 2  85 rr        		sta @instrument_ptr
00060Fr 2               		.if __THE_ALBUM || HUGE_ROM
00060Fr 2               		jsr rand1
00060Fr 2               		.else
00060Fr 2  20 rr rr     		jsr _newrand
000612r 2               		.endif
000612r 2  45 rr        		eor @instrument_ptr
000614r 2  29 1F        		and #$1F
000616r 2               		; Y is 0
000616r 2               		.if __THE_ALBUM || HUGE_ROM
000616r 2               		cmp #$0A	;	Ensure shit stays in range
000616r 2               		.else
000616r 2  C9 09        		cmp #$09
000618r 2               		.endif
000618r 2  B0 F3        		bcs @randomization_loop				;__
00061Ar 2               
00061Ar 2               	@no_randomization:
00061Ar 2               	.endif
00061Ar 2               ;!!! FAMISTUDIO DRIVER MODIFICATION END
00061Ar 2               
00061Ar 2               
00061Ar 2                   ; Pre-multiply by 4 if not using extended range, faster pointer arithmetic.
00061Ar 2                   .if !FAMISTUDIO_USE_INSTRUMENT_EXTENDED_RANGE
00061Ar 2  0A               asl a
00061Br 2  0A               asl a
00061Cr 2                   .endif
00061Cr 2               
00061Cr 2  A4 rr            ldy @chan_idx
00061Er 2  BE rr rr         ldx famistudio_channel_env,y
000621r 2               
000621r 2               .if FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_S5B
000621r 2                   cpy #5
000621r 2                   bcc @base_instrument
000621r 2                   .if FAMISTUDIO_EXP_FDS
000621r 2                   @fds_instrument:
000621r 2                       jmp famistudio_set_fds_instrument
000621r 2                   .endif
000621r 2                   .if FAMISTUDIO_EXP_VRC7
000621r 2                   @vrc7_instrument:
000621r 2                       jmp famistudio_set_vrc7_instrument
000621r 2                   .endif
000621r 2                   .if FAMISTUDIO_EXP_N163
000621r 2                   @n163_instrument:
000621r 2                       jmp famistudio_set_n163_instrument
000621r 2                   .endif
000621r 2                   .if FAMISTUDIO_EXP_S5B
000621r 2                   @s5b_instrument:
000621r 2                       jmp famistudio_set_s5b_instrument
000621r 2                   .endif
000621r 2                   .if FAMISTUDIO_EXP_EPSM
000621r 2                   @epsm_instrument:
000621r 2                       jmp famistudio_set_epsm_instrument
000621r 2                   .endif
000621r 2               .endif
000621r 2               
000621r 2               @base_instrument:
000621r 2               
000621r 2                   .if !FAMISTUDIO_USE_INSTRUMENT_EXTENDED_RANGE
000621r 2  0A                   asl ; Instrument number is pre multiplied by 4
000622r 2  A8                   tay
000623r 2  AD rr rr             lda famistudio_instrument_hi
000626r 2  69 00                adc #0 ; Use carry to extend range for 64 instruments
000628r 2  85 rr                sta @instrument_ptr+1
00062Ar 2  AD rr rr             lda famistudio_instrument_lo
00062Dr 2  85 rr                sta @instrument_ptr+0
00062Fr 2                   .else
00062Fr 2                       ; Multiply by instrument stride of 8.
00062Fr 2                       ldy #0
00062Fr 2                       sty @instrument_ptr+1
00062Fr 2                       asl
00062Fr 2                       rol @instrument_ptr+1
00062Fr 2                       asl
00062Fr 2                       rol @instrument_ptr+1
00062Fr 2                       asl
00062Fr 2                       rol @instrument_ptr+1
00062Fr 2                       clc
00062Fr 2                       adc famistudio_instrument_lo
00062Fr 2                       sta @instrument_ptr+0
00062Fr 2                       lda @instrument_ptr+1
00062Fr 2                       adc famistudio_instrument_hi
00062Fr 2                       sta @instrument_ptr+1
00062Fr 2                   .endif
00062Fr 2               
00062Fr 2  4C rr rr         jmp famistudio_load_basic_envelopes ; Will 'rts'
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM || FAMISTUDIO_EXP_S5B
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_GET_EXP_INST_PTR (internal)
000632r 2               ;
000632r 2               ; Retrives the expansion instrument pointer for a given index.
000632r 2               ;
000632r 2               ; [in]  a:      instrument index.
000632r 2               ; [out] ptr1/y: the instrument pointer + offset
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_get_exp_inst_ptr:
000632r 2               
000632r 2                   @instrument_ptr = famistudio_ptr1
000632r 2               
000632r 2               .if !FAMISTUDIO_USE_INSTRUMENT_EXTENDED_RANGE
000632r 2                   asl ; Instrument number is pre multiplied by 4
000632r 2                   asl
000632r 2                   tay
000632r 2                   lda famistudio_exp_instrument_hi
000632r 2                   adc #0  ; Use carry to extend range for 32 expansion instruments
000632r 2                   sta @instrument_ptr+1
000632r 2                   lda famistudio_exp_instrument_lo
000632r 2                   sta @instrument_ptr+0
000632r 2               .else
000632r 2                   ; Multiply by expansion instrument stride of 16.
000632r 2                   ldy #0
000632r 2                   sty @instrument_ptr+1
000632r 2                   asl
000632r 2                   rol @instrument_ptr+1
000632r 2                   asl
000632r 2                   rol @instrument_ptr+1
000632r 2                   asl
000632r 2                   rol @instrument_ptr+1
000632r 2                   asl
000632r 2                   rol @instrument_ptr+1
000632r 2                   clc
000632r 2                   adc famistudio_exp_instrument_lo
000632r 2                   sta @instrument_ptr+0
000632r 2                   lda @instrument_ptr+1
000632r 2                   adc famistudio_exp_instrument_hi
000632r 2                   sta @instrument_ptr+1
000632r 2               .endif
000632r 2               
000632r 2                   rts
000632r 2               
000632r 2               .endif
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_FDS || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM
000632r 2               
000632r 2               .macro skip_exp_basic_envelopes
000632r 2               .if FAMISTUDIO_USE_INSTRUMENT_EXTENDED_RANGE
000632r 2                   ldy #6
000632r 2               .else
000632r 2                   iny
000632r 2                   iny
000632r 2                   iny
000632r 2                   iny
000632r 2                   iny
000632r 2                   iny
000632r 2               .endif
000632r 2               .endmacro
000632r 2               
000632r 2               .endif
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_VRC7
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_SET_VRC7_INSTRUMENT (internal)
000632r 2               ;
000632r 2               ; Internal function to set a VRC7 instrument for a given channel. Will load custom patch if needed.
000632r 2               ;
000632r 2               ; [in] y/r0: channel index
000632r 2               ; [in] x:    index of first envelope of instrument
000632r 2               ; [in] a:    instrument index.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_set_vrc7_instrument:
000632r 2               
000632r 2                   @ptr          = famistudio_ptr1
000632r 2                   @chan_idx     = famistudio_r0
000632r 2                   @update_flags = famistudio_r1 ; bit 7 = no attack, bit 6 = has set delayed cut
000632r 2               
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2                   bit @update_flags
000632r 2                   bpl @load_envelopes
000632r 2               
000632r 2                   @skip_envelopes:
000632r 2                       skip_exp_basic_envelopes
000632r 2                       jmp @load_patch
000632r 2                   @load_envelopes:
000632r 2                       jsr famistudio_load_basic_envelopes
000632r 2               
000632r 2                   @load_patch:
000632r 2                   ldx @chan_idx
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_chn_vrc7_patch-FAMISTUDIO_VRC7_CH0_IDX,x
000632r 2                   bne @done
000632r 2               
000632r 2                   @read_custom_patch:
000632r 2                   ldx #0
000632r 2                   iny
000632r 2                   iny
000632r 2                   @read_patch_loop:
000632r 2                       stx FAMISTUDIO_VRC7_REG_SEL
000632r 2                       jsr famistudio_vrc7_wait_reg_select
000632r 2                       lda (@ptr),y
000632r 2                       iny
000632r 2                       sta FAMISTUDIO_VRC7_REG_WRITE
000632r 2                       jsr famistudio_vrc7_wait_reg_write
000632r 2                       inx
000632r 2                       cpx #8
000632r 2                       bne @read_patch_loop
000632r 2               
000632r 2                   @done:
000632r 2                   rts
000632r 2               
000632r 2               .endif
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_S5B
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_SET_S5B_INSTRUMENT (internal)
000632r 2               ;
000632r 2               ; Internal function to set a S5B instrument.
000632r 2               ;
000632r 2               ; [in] y/r0: channel index
000632r 2               ; [in] x:    index of first envelope of instrument
000632r 2               ; [in] a:    instrument index.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_set_s5b_instrument:
000632r 2               
000632r 2                   @chan_idx = famistudio_r0
000632r 2                   @ptr      = famistudio_ptr1
000632r 2               
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2                   jsr famistudio_load_basic_envelopes
000632r 2               
000632r 2                   @mixer:
000632r 2                   sec
000632r 2               
000632r 2                   ; After 'famistudio_load_basic_envelopes' x should point to the correct envelope.
000632r 2                   @loop:
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_env_addr_lo,x
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_env_addr_hi,x
000632r 2                       bcc @load_env_params
000632r 2                       clc
000632r 2                       inx
000632r 2                       iny
000632r 2                       bcc @loop
000632r 2               
000632r 2                   @load_env_params:
000632r 2               
000632r 2                   ; Envelope shape + auto-pitch octave
000632r 2                   ldx @chan_idx
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_s5b_chn_env_shape-FAMISTUDIO_S5B_CH0_IDX,x
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_s5b_chn_env_octave-FAMISTUDIO_S5B_CH0_IDX,x
000632r 2               
000632r 2                   ; Skip if using auto-period
000632r 2                   cmp #$80
000632r 2                   bne @done
000632r 2               
000632r 2                   ; Skip if effect set manual period this frame.
000632r 2                   lda famistudio_s5b_env_override
000632r 2                   bne @done
000632r 2               
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_s5b_env_period_lo
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_s5b_env_period_hi
000632r 2               
000632r 2                   @done:
000632r 2                   rts
000632r 2               
000632r 2               .endif
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_EPSM
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_SET_EPSM_INSTRUMENT (internal)
000632r 2               ;
000632r 2               ; Internal function to set a EPSM instrument.
000632r 2               ;
000632r 2               ; [in] x/r0: channel index
000632r 2               ; [in] a:    instrument index.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_set_epsm_instrument:
000632r 2               
000632r 2                   @ptr          = famistudio_ptr1
000632r 2                   @env_ptr      = famistudio_ptr2
000632r 2                   @ex_patch     = famistudio_ptr2
000632r 2                   @chan_idx     = famistudio_r0
000632r 2                   @chan_idx2    = famistudio_r0
000632r 2                   @update_flags = famistudio_r1 ; bit 7 = no attack, bit 6 = has set delayed cut
000632r 2                   @reg_offset   = famistudio_r3
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_EPSM_RHYTHM_CNT > 0
000632r 2                   cpy #FAMISTUDIO_EPSM_CHAN_RHYTHM_START
000632r 2                   bcc @process_regular_instrument
000632r 2                       ; We are processing a rhythm instrument, so skip all the fluff.
000632r 2                       ; We only need to load the volume of the instrument and store it in the attack.
000632r 2                       ; load the instrument
000632r 2                       ;sty @chan_idx
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2               
000632r 2                       ; Load the offset for the rhythm track and keep it in x
000632r 2                       ldx @chan_idx
000632r 2                       lda famistudio_rhythm_lut-FAMISTUDIO_EPSM_CHAN_RHYTHM_START, x
000632r 2                       tax
000632r 2               
000632r 2                       ; Read the first envelope pointer for the volume, we'll use this to get the volume later
000632r 2                   sty @reg_offset
000632r 2                   lda (@ptr),y
000632r 2                   sta @env_ptr
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta @env_ptr+1
000632r 2                   ; the first value is the release point, so load the second offset which is the volume
000632r 2                   ldy #1
000632r 2                   lda (@env_ptr),y
000632r 2                   and #$0F
000632r 2                   sta famistudio_chn_epsm_rhythm_volume,x
000632r 2                   lda @reg_offset
000632r 2                   clc
000632r 2                   adc #14 ; skip over envelopes + square stuff.
000632r 2                   tay
000632r 2                   lda (@ptr),y
000632r 2                   sta @ex_patch
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta @ex_patch+1
000632r 2                   ldy #1
000632r 2                   lda (@ex_patch),y
000632r 2                   and #$c0
000632r 2                   sta famistudio_chn_epsm_rhythm_stereo,x
000632r 2               
000632r 2                       rts
000632r 2               .endif
000632r 2               @process_regular_instrument:
000632r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
000632r 2                   cpy #FAMISTUDIO_EPSM_CHAN_FM_START
000632r 2                   bcc @skip_fm_instrument
000632r 2                       sta famistudio_chn_epsm_fm_instrument-FAMISTUDIO_EPSM_CHAN_FM_START,y
000632r 2                   @skip_fm_instrument:
000632r 2               .endif
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2                   bit @update_flags
000632r 2                   bpl @load_envelopes
000632r 2               
000632r 2                   ; The exporter will ensure this only happens on FM channels.
000632r 2                   @skip_envelopes:
000632r 2                       skip_exp_basic_envelopes
000632r 2                       jmp @check_square_channel
000632r 2                   @load_envelopes:
000632r 2                       jsr famistudio_load_basic_envelopes
000632r 2               
000632r 2                   @check_square_channel:
000632r 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
000632r 2                   ; channels 0-2 (square) do not need any further handling since they do not support patches
000632r 2                   lda @chan_idx
000632r 2                   cmp #FAMISTUDIO_EPSM_CHAN_FM_START
000632r 2                   bcs @not_square_channel
000632r 2                       ;lda famistudio_channel_env,x
000632r 2                       ;tax
000632r 2               .endif
000632r 2               .if FAMISTUDIO_EXP_EPSM_SSG_CHN_CNT > 0
000632r 2                       @noise:
000632r 2                       sec
000632r 2               
000632r 2                   @loop:
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_env_addr_lo,x
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_env_addr_hi,x
000632r 2                       bcc @load_env_params
000632r 2                       clc
000632r 2                       inx
000632r 2                       iny
000632r 2                       bcc @loop
000632r 2               
000632r 2                   @load_env_params:
000632r 2               
000632r 2                       ; Envelope shape + auto-pitch octave
000632r 2                       ldx @chan_idx
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_epsm_chn_env_shape-FAMISTUDIO_EPSM_CH0_IDX,x
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_epsm_chn_env_octave-FAMISTUDIO_EPSM_CH0_IDX,x
000632r 2               
000632r 2                       ; Skip if using auto-period
000632r 2                       cmp #$80
000632r 2                       bne @done
000632r 2               
000632r 2                       ; Skip if effect set manual period this frame.
000632r 2                       lda famistudio_epsm_env_override
000632r 2                       bne @done
000632r 2               
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_epsm_env_period_lo
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       sta famistudio_epsm_env_period_hi
000632r 2               
000632r 2                       @done:
000632r 2               
000632r 2               .endif
000632r 2                       rts
000632r 2               
000632r 2               @not_square_channel:
000632r 2                   rts
000632r 2               .endif
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_FDS
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_UPDATE_FDS_WAVE (internal)
000632r 2               ;
000632r 2               ; Internal function to upload the FDS waveform (if needed) of an FDS instrument.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_update_fds_wave:
000632r 2               
000632r 2                   @ptr        = famistudio_ptr1
000632r 2                   @wave_ptr   = famistudio_ptr0
000632r 2                   @tmp_enable = famistudio_r3
000632r 2               
000632r 2                   ; See if the wave index has changed.
000632r 2                   lda famistudio_env_value+FAMISTUDIO_FDS_CH0_ENVS+FAMISTUDIO_ENV_FDS_WAVE_IDX_OFF
000632r 2                   cmp famistudio_fds_wave_index
000632r 2                   beq @done
000632r 2               
000632r 2                   ; Retrieve the instrument pointer.
000632r 2                   sta famistudio_fds_wave_index
000632r 2                   lda famistudio_chn_fds_instrument
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2               
000632r 2                   ; Master volume
000632r 2                   tya
000632r 2                   adc #8 ; Carry is clear here.
000632r 2                   tay
000632r 2                   lda (@ptr),y
000632r 2                   and #3 ; Bits 0 and 1 are master volume
000632r 2                   tax    ; Store master volume to x
000632r 2                   ora #$80
000632r 2                   sta @tmp_enable ; Store maaster volume with write enable
000632r 2                   iny
000632r 2               
000632r 2                   ; Load the wave table pointer.
000632r 2                   lda (@ptr),y
000632r 2                   sta @wave_ptr+0
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta @wave_ptr+1
000632r 2               
000632r 2                   ; Load the pointer for the current wave in the table.
000632r 2                   lda famistudio_fds_wave_index
000632r 2                   asl
000632r 2                   tay
000632r 2                   lda (@wave_ptr),y
000632r 2                   sta @ptr+0
000632r 2                   iny
000632r 2                   lda (@wave_ptr),y
000632r 2                   sta @ptr+1
000632r 2               
000632r 2                   ; FDS Waveform
000632r 2                   ldy #63
000632r 2                   @wave_loop:
000632r 2                       lda @tmp_enable
000632r 2                       sta FAMISTUDIO_FDS_VOL ; Enable RAM write.
000632r 2                       lda (@ptr),y
000632r 2                       sta FAMISTUDIO_FDS_WAV_START,y ; Write 2 samples between each write toggle (saves ~500 CPU cycles, sounds identical)
000632r 2                       dey
000632r 2                       lda (@ptr),y
000632r 2                       sta FAMISTUDIO_FDS_WAV_START,y
000632r 2                       stx FAMISTUDIO_FDS_VOL ; Disable RAM write.
000632r 2                       dey
000632r 2                       bpl @wave_loop
000632r 2               
000632r 2                   @done:
000632r 2                   rts
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_SET_FDS_INSTRUMENT (internal)
000632r 2               ;
000632r 2               ; Internal function to set a FDS instrument. Will upload the wave and modulation envelope if needed.
000632r 2               ;
000632r 2               ; [in] y/r0: channel index
000632r 2               ; [in] x:    index of first envelope of instrument
000632r 2               ; [in] a:    instrument index.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_set_fds_instrument:
000632r 2               
000632r 2                   @ptr           = famistudio_ptr1
000632r 2                   @wave_ptr      = famistudio_ptr2
000632r 2                   @tmp_mod_depth = famistudio_r3
000632r 2               
000632r 2                   ; Store instrument number (premultipled by 4 if not using extended range)
000632r 2                   sta famistudio_chn_fds_instrument-FAMISTUDIO_FDS_CH0_IDX,y
000632r 2               
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2                   jsr famistudio_load_basic_envelopes
000632r 2               
000632r 2                   ; Load the wave index envelope, x will point to the correct envelope.
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_env_addr_lo,x
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_env_addr_hi,x
000632r 2               
000632r 2                   ; FDS Modulation
000632r 2                   @write_fds_mod:
000632r 2                       iny
000632r 2                       lda (@ptr),y ; Read depth / master volume, shift twice for depth and store for later.
000632r 2                       lsr
000632r 2                       lsr
000632r 2                       sta @tmp_mod_depth
000632r 2               
000632r 2                       ; Skip to mod envelope
000632r 2                       iny
000632r 2                       iny
000632r 2                       iny
000632r 2               
000632r 2                       ; Compare mod envelope pointer, only write the mod table if it has changed
000632r 2                       lda (@ptr),y
000632r 2                       cmp famistudio_fds_mod_envelope+0
000632r 2                       bne @write_mod_table
000632r 2                       iny
000632r 2                       lda (@ptr),y
000632r 2                       cmp famistudio_fds_mod_envelope+1
000632r 2                       beq @load_mod_param ; Skip writing the mod table
000632r 2                       dey
000632r 2                       lda (@ptr),y
000632r 2               
000632r 2                       @write_mod_table:
000632r 2                           ; Store new envelope pointer
000632r 2                           sta @wave_ptr+0
000632r 2                           sta famistudio_fds_mod_envelope+0
000632r 2                           iny
000632r 2                           lda (@ptr),y
000632r 2                           sta @wave_ptr+1
000632r 2                           sta famistudio_fds_mod_envelope+1
000632r 2               
000632r 2                           ; Reset and write modulation
000632r 2                           tya ; Store y in x and restore after loop
000632r 2                           tax
000632r 2                           lda #$80
000632r 2                           sta FAMISTUDIO_FDS_MOD_HI ; Need to disable modulation before writing.
000632r 2                           sta FAMISTUDIO_FDS_SWEEP_ENV
000632r 2                           ldy #0
000632r 2                           sty FAMISTUDIO_FDS_SWEEP_BIAS
000632r 2                           @mod_loop:
000632r 2                               lda (@wave_ptr),y
000632r 2                               sta FAMISTUDIO_FDS_MOD_TABLE
000632r 2                               iny
000632r 2                               cpy #32
000632r 2                               bne @mod_loop
000632r 2                           txa
000632r 2                           tay
000632r 2               
000632r 2                   @load_mod_param:
000632r 2                       iny
000632r 2                       .if FAMISTUDIO_USE_FDS_AUTOMOD
000632r 2                           lda (@ptr),y
000632r 2                           bpl @check_mod_speed ; Skip auto mod if bit 7 is clear
000632r 2               
000632r 2                           @auto_mod:
000632r 2                               and #$7f ; Clear bit 7 before setting
000632r 2                               sta famistudio_fds_automod_numer
000632r 2                               iny
000632r 2                               lda (@ptr),y
000632r 2                               sta famistudio_fds_automod_denom
000632r 2                               bne @check_mod_depth
000632r 2                       .endif
000632r 2               
000632r 2                       @check_mod_speed:
000632r 2                           .if FAMISTUDIO_USE_FDS_AUTOMOD
000632r 2                               lda #0
000632r 2                               sta famistudio_fds_automod_numer
000632r 2                           .endif
000632r 2                           bit famistudio_fds_override_flags
000632r 2                           bmi @mod_speed_overriden
000632r 2               
000632r 2                           @load_mod_speed:
000632r 2                               lda (@ptr),y
000632r 2                               sta famistudio_fds_mod_speed+0
000632r 2                               iny
000632r 2                               lda (@ptr),y
000632r 2                               sta famistudio_fds_mod_speed+1
000632r 2                               jmp @check_mod_depth
000632r 2               
000632r 2                           @mod_speed_overriden:
000632r 2                               iny
000632r 2               
000632r 2                       @check_mod_depth:
000632r 2                           bit famistudio_fds_override_flags
000632r 2                           bvs @mod_depth_overriden
000632r 2               
000632r 2                           @load_mod_depth:
000632r 2                               tya ; Use depth that was stored earlier
000632r 2                               tax
000632r 2                               lda @tmp_mod_depth
000632r 2                               sta famistudio_fds_mod_depth
000632r 2                               txa
000632r 2                               tay
000632r 2               
000632r 2                           @mod_depth_overriden:
000632r 2                               iny
000632r 2                               lda (@ptr),y
000632r 2                               sta famistudio_fds_mod_delay
000632r 2                   rts
000632r 2               
000632r 2               .endif
000632r 2               
000632r 2               .if FAMISTUDIO_EXP_N163
000632r 2               
000632r 2               famistudio_n163_wave_table:
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $00
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $08
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $10
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $18
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $20
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $28
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $30
000632r 2                   .byte FAMISTUDIO_N163_REG_WAVE - $38
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_UPDATE_N163_WAVE (internal)
000632r 2               ;
000632r 2               ; Internal function to upload the waveform (if needed) of an N163 instrument.
000632r 2               ;
000632r 2               ; [in] y: N163 channel idx (0,1,2,3,4,5,6,7)
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_update_n163_wave:
000632r 2               
000632r 2                   @ptr           = famistudio_ptr1
000632r 2                   @wave_ptr      = famistudio_ptr0
000632r 2                   @wave_pos      = famistudio_r1
000632r 2                   @wave_len      = famistudio_r2
000632r 2               
000632r 2                   lda famistudio_n163_env_table, y
000632r 2                   tax
000632r 2               
000632r 2                   ; See if the wave index has changed.
000632r 2                   lda famistudio_env_value+FAMISTUDIO_ENV_N163_WAVE_IDX_OFF,x
000632r 2                   cmp famistudio_chn_n163_wave_index,y
000632r 2                   beq @done
000632r 2               
000632r 2                   ; Retrieve the instrument pointer.
000632r 2                   sta famistudio_chn_n163_wave_index,y
000632r 2                   tya
000632r 2                   tax
000632r 2                   lda famistudio_chn_n163_instrument,y
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2               
000632r 2                   lda famistudio_n163_wave_table, x
000632r 2                   sta FAMISTUDIO_N163_ADDR
000632r 2               
000632r 2                   ; Wave position
000632r 2                   tya
000632r 2                   adc #8 ; Carry is clear here.
000632r 2                   tay
000632r 2                   lda (@ptr),y
000632r 2                   sta @wave_pos
000632r 2                   sta FAMISTUDIO_N163_DATA
000632r 2                   iny
000632r 2               
000632r 2                   ; Wave length
000632r 2                   lda (@ptr),y
000632r 2                   lsr
000632r 2                   sta @wave_len
000632r 2                   lda #$80 ; (128 - wave length / 2) * 2 == 256 - wave length
000632r 2                   sec
000632r 2                   sbc @wave_len
000632r 2                   asl
000632r 2                   sta famistudio_chn_n163_wave_len, x
000632r 2                   iny
000632r 2               
000632r 2                   ; Load the wave table pointer.
000632r 2                   lda (@ptr),y
000632r 2                   sta @wave_ptr+0
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta @wave_ptr+1
000632r 2               
000632r 2                   ; Load the pointer for the current wave in the table.
000632r 2                   lda famistudio_chn_n163_wave_index,x
000632r 2                   asl
000632r 2                   tay
000632r 2                   lda (@wave_ptr),y
000632r 2                   sta @ptr+0
000632r 2                   iny
000632r 2                   lda (@wave_ptr),y
000632r 2                   sta @ptr+1
000632r 2               
000632r 2                   ; Upload to N163
000632r 2                   ldy #0
000632r 2                   lda @wave_pos
000632r 2                   lsr
000632r 2                   ora #$80
000632r 2                   sta FAMISTUDIO_N163_ADDR
000632r 2                   ldy #0
000632r 2                   @wave_loop:
000632r 2                       lda (@ptr),y
000632r 2                       sta FAMISTUDIO_N163_DATA
000632r 2                       iny
000632r 2                       cpy @wave_len
000632r 2                       bne @wave_loop
000632r 2               
000632r 2                   txa
000632r 2                   tay
000632r 2               
000632r 2                   @done:
000632r 2                   rts
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_SET_N163_INSTRUMENT (internal)
000632r 2               ;
000632r 2               ; Internal function to set a N163 instrument.
000632r 2               ;
000632r 2               ; [in] y/r0: channel index
000632r 2               ; [in] x:    index of first envelope of instrument
000632r 2               ; [in] a:    instrument index.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_set_n163_instrument:
000632r 2               
000632r 2                   @ptr      = famistudio_ptr1
000632r 2                   @chan_idx = famistudio_r0
000632r 2               
000632r 2                   ; Store instrument number (premultipled by 4 if not using extended range)
000632r 2                   sta famistudio_chn_n163_instrument-FAMISTUDIO_N163_CH0_IDX,y
000632r 2               
000632r 2                   jsr famistudio_get_exp_inst_ptr
000632r 2                   jsr famistudio_load_basic_envelopes
000632r 2               
000632r 2                   ; Load the wave index envelope, x will point to the correct envelope.
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_env_addr_lo,x
000632r 2                   iny
000632r 2                   lda (@ptr),y
000632r 2                   sta famistudio_env_addr_hi,x
000632r 2               
000632r 2                   rts
000632r 2               
000632r 2               .endif
000632r 2               
000632r 2               ;======================================================================================================================
000632r 2               ; FAMISTUDIO_UPDATE_CHANNEL (internal)
000632r 2               ;
000632r 2               ; Advances the song by one frame for a given channel. If a new note or effect(s) are found, they will be processed.
000632r 2               ;
000632r 2               ; [in]  x: channel index
000632r 2               ; [out] z: non-zero if we triggered a new note.
000632r 2               ;======================================================================================================================
000632r 2               
000632r 2               famistudio_advance_channel:
000632r 2               
000632r 2                   @chan_idx         = famistudio_r0
000632r 2                   @update_flags     = famistudio_r1 ; bit 7 = no attack, bit 6 = has set delayed cut
000632r 2                   @temp_ptr_y       = famistudio_r2
000632r 2                   @tmp_slide_from   = famistudio_r2
000632r 2                   @tmp_slide_idx    = famistudio_r2
000632r 2                   @tmp_duty_cycle   = famistudio_r2
000632r 2                   @tmp_ptr_lo       = famistudio_r2
000632r 2                   @tmp_y1           = famistudio_r2
000632r 2                   @slide_delta_lo   = famistudio_ptr1_hi
000632r 2                   @tmp_y2           = famistudio_ptr1_lo
000632r 2                   @channel_data_ptr = famistudio_ptr0
000632r 2                   @opcode_jmp_ptr   = famistudio_ptr1
000632r 2                   @tempo_env_ptr    = famistudio_ptr1
000632r 2                   @env_ptr          = famistudio_ptr1
000632r 2               
000632r 2  BD rr rr         lda famistudio_chn_repeat,x
000635r 2  F0 06            beq @no_repeat
000637r 2  DE rr rr         dec famistudio_chn_repeat,x
00063Ar 2  A9 00            lda #0
00063Cr 2  60               rts
00063Dr 2               
00063Dr 2               @no_repeat:
00063Dr 2  BD rr rr         lda famistudio_chn_ptr_lo,x
000640r 2  85 rr            sta @channel_data_ptr+0
000642r 2  BD rr rr         lda famistudio_chn_ptr_hi,x
000645r 2  85 rr            sta @channel_data_ptr+1
000647r 2  A0 00            ldy #0
000649r 2  84 rr            sty @update_flags
00064Br 2  86 rr            stx @chan_idx
00064Dr 2               
00064Dr 2               @read_byte:
00064Dr 2  B1 rr            lda (@channel_data_ptr),y
00064Fr 2  C8               iny
000650r 2               
000650r 2               ; $80 to $ff = sequence of empty notes (up to 64) or instrument changes (up to 64)
000650r 2               @check_negative:
000650r 2  09 00            ora #0
000652r 2  30 2A            bmi @empty_notes_or_instrument_change
000654r 2               
000654r 2               ; $00 to $3f = notes from C1 to D6 (most common notes, same as FT2 range)
000654r 2               ; $40 to $6f = opcodes for various things.
000654r 2               @check_regular_note:
000654r 2  C9 40            cmp #$40
000656r 2  90 3C            bcc @common_note
000658r 2               
000658r 2               .if FAMISTUDIO_USE_VOLUME_TRACK
000658r 2               ; $70 to $7f = volume change
000658r 2               @check_volume_track:
000658r 2  C9 70            cmp #$70
00065Ar 2  90 10            bcc @jmp_to_opcode
00065Cr 2               
00065Cr 2               @volume_track:
00065Cr 2  29 0F            and #$0f
00065Er 2  0A               asl
00065Fr 2  0A               asl
000660r 2  0A               asl
000661r 2  0A               asl
000662r 2  9D rr rr         sta famistudio_chn_volume_track,x
000665r 2                   ; Clear any volume slide.
000665r 2                   .if FAMISTUDIO_USE_VOLUME_SLIDES
000665r 2  A9 00                lda #0
000667r 2  9D rr rr             sta famistudio_chn_volume_slide_step,x
00066Ar 2                   .endif
00066Ar 2  90 E1            bcc @read_byte
00066Cr 2               .endif
00066Cr 2               
00066Cr 2               @jmp_to_opcode:
00066Cr 2  29 3F            and #$3f
00066Er 2  AA               tax
00066Fr 2  BD rr rr         lda @famistudio_opcode_jmp_lo,x
000672r 2  85 rr            sta @opcode_jmp_ptr+0
000674r 2  BD rr rr         lda @famistudio_opcode_jmp_hi,x
000677r 2  85 rr            sta @opcode_jmp_ptr+1
000679r 2  A6 rr            ldx @chan_idx
00067Br 2  6C rr rr         jmp (@opcode_jmp_ptr)
00067Er 2               
00067Er 2               @empty_notes_or_instrument_change:
00067Er 2  29 7F            and #$7f
000680r 2  4A               lsr a
000681r 2  B0 0C            bcs @set_repeat
000683r 2               
000683r 2               @instrument_change:
000683r 2                   ; Set the instrument. `famistudio_set_instrument` (or proc it calls) are not
000683r 2                   ; allowed to clobber r0/r1/r2 or ptr0.
000683r 2  84 rr            sty @temp_ptr_y
000685r 2  20 rr rr         jsr famistudio_set_instrument ; Will clobber x/y, need to save/restore them.
000688r 2  A4 rr            ldy @temp_ptr_y
00068Ar 2  A6 rr            ldx @chan_idx
00068Cr 2  4C rr rr         jmp @read_byte
00068Fr 2               
00068Fr 2               @set_repeat:
00068Fr 2  9D rr rr         sta famistudio_chn_repeat,x ; Set up repeat counter
000692r 2  B0 69            bcs @done
000694r 2               
000694r 2               @common_note:
000694r 2  C9 00            cmp #0
000696r 2  F0 02            beq @play_note
000698r 2  69 0B                adc #11 ; Carry is set here.
00069Ar 2               
00069Ar 2               @play_note:
00069Ar 2  9D rr rr         sta famistudio_chn_note,x ; Store note code
00069Dr 2               ;!!! FAMISTUDIO DRIVER MODIFICATION BEGIN
00069Dr 2               ;*  MODIFIED
00069Dr 2               	.ifdef CURSED_MUSIC_ENABLE
00069Dr 2               	; Randomize the instrument if the music is cursed
00069Dr 2  2C rr rr         bit _cursedmusic
0006A0r 2  10 1C        	bpl @no_randomization
0006A2r 2  4D rr rr     	eor famistudio_tempo_acc_lo
0006A5r 2  84 rr        	sty @temp_ptr_y
0006A7r 2  9D rr rr     	sta famistudio_chn_note,x
0006AAr 2  A9 00        	lda #0
0006ACr 2  9D rr rr     	sta famistudio_slide_step, x
0006AFr 2               
0006AFr 2               	@randomization_loop:
0006AFr 2               		.if __THE_ALBUM || HUGE_ROM
0006AFr 2               		jsr rand1
0006AFr 2               		.else
0006AFr 2  20 rr rr     		jsr _newrand
0006B2r 2               		.endif
0006B2r 2  5D rr rr     		eor famistudio_chn_note,x
0006B5r 2  C9 60        		cmp #96	;	Ensure shit stays in range
0006B7r 2  B0 F6        		bcs @randomization_loop				;__
0006B9r 2               
0006B9r 2  9D rr rr     	sta famistudio_chn_note,x
0006BCr 2  A4 rr        	ldy @temp_ptr_y
0006BEr 2               	@no_randomization:
0006BEr 2               	.endif
0006BEr 2               ;!!! FAMISTUDIO DRIVER MODIFICATION END
0006BEr 2               
0006BEr 2               
0006BEr 2               .if FAMISTUDIO_USE_SLIDE_NOTES
0006BEr 2               @clear_previous_slide:
0006BEr 2  BD rr rr         lda famistudio_channel_to_slide,x ; Clear any previous slide on new note.
0006C1r 2  30 08            bmi @cancel_delayed_cut
0006C3r 2  AA               tax
0006C4r 2  A9 00            lda #0
0006C6r 2  9D rr rr         sta famistudio_slide_step,x
0006C9r 2  A6 rr            ldx @chan_idx
0006CBr 2               .endif
0006CBr 2               
0006CBr 2               @cancel_delayed_cut:
0006CBr 2               .if FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS
0006CBr 2                   ; Any note with an attack clears any pending delayed cut, unless it was set during this update (flags bit 6).
0006CBr 2  24 rr            bit @update_flags
0006CDr 2  70 05            bvs @check_dpcm_channel
0006CFr 2  A9 FF            lda #$ff
0006D1r 2  9D rr rr         sta famistudio_chn_cut_delay,x
0006D4r 2               .endif
0006D4r 2               
0006D4r 2               @check_dpcm_channel:
0006D4r 2               .if FAMISTUDIO_CFG_DPCM_SUPPORT
0006D4r 2                   ; We play/stop DPCM samples immediately.
0006D4r 2  E0 04            cpx #4
0006D6r 2  D0 19            bne @check_attack
0006D8r 2  AD rr rr             lda famistudio_chn_note+4
0006DBr 2  D0 07                bne @play_sample
0006DDr 2  20 rr rr             jsr famistudio_sample_stop
0006E0r 2  A2 04                ldx #4
0006E2r 2  D0 19                bne @done
0006E4r 2                       @play_sample:
0006E4r 2  E9 0C                    sbc #12 ; Carry already set. HACK : Our "notes" for DPCM start at SingleByteNoteMin (12). Need to undo that here. See C# code.
0006E6r 2  84 rr                    sty @tmp_y1
0006E8r 2  20 rr rr                 jsr famistudio_music_sample_play
0006EBr 2  A4 rr                    ldy @tmp_y1
0006EDr 2  A2 04                    ldx #4
0006EFr 2                           .if FAMISTUDIO_CFG_EQUALIZER
0006EFr 2                               lda #9
0006EFr 2                               sta famistudio_chn_note_counter,x
0006EFr 2                           .endif
0006EFr 2  D0 0C                    bne @done
0006F1r 2               .endif
0006F1r 2               
0006F1r 2               @check_attack:
0006F1r 2  BD rr rr         lda famistudio_chn_note,x
0006F4r 2  F0 07            beq @done
0006F6r 2  24 rr            bit @update_flags
0006F8r 2  30 03            bmi @done
0006FAr 2               
0006FAr 2                   ; Note attack. `famistudio_do_note_attack` (or any proc it calls) are not
0006FAr 2                   ; allowed to clobber r0 or ptr0. They can clobber r1 if they are done using it.
0006FAr 2  20 rr rr         jsr famistudio_do_note_attack ; Note attack.
0006FDr 2               
0006FDr 2               @done:
0006FDr 2  BD rr rr         lda famistudio_chn_ref_len,x ; Check reference row counter
000700r 2  F0 12            beq @flush_y                 ; If it is zero, there is no reference
000702r 2  DE rr rr         dec famistudio_chn_ref_len,x ; Decrease row counter
000705r 2  D0 0D            bne @flush_y
000707r 2               
000707r 2  BD rr rr         lda famistudio_chn_return_lo,x ; End of a reference, return to previous pointer
00070Ar 2  9D rr rr         sta famistudio_chn_ptr_lo,x
00070Dr 2  BD rr rr         lda famistudio_chn_return_hi,x
000710r 2  9D rr rr         sta famistudio_chn_ptr_hi,x
000713r 2  60               rts
000714r 2               
000714r 2               @flush_y:
000714r 2               
000714r 2  18               clc
000715r 2  98               tya
000716r 2  65 rr            adc @channel_data_ptr+0
000718r 2  9D rr rr         sta famistudio_chn_ptr_lo,x
00071Br 2  A9 00            lda #0
00071Dr 2  65 rr            adc @channel_data_ptr+1
00071Fr 2  9D rr rr         sta famistudio_chn_ptr_hi,x
000722r 2  60               rts
000723r 2               
000723r 2               @opcode_extended_note:
000723r 2  B1 rr            lda (@channel_data_ptr),y
000725r 2  C8               iny
000726r 2  4C rr rr         jmp @play_note
000729r 2               
000729r 2               @opcode_set_reference:
000729r 2  18               clc ; Remember return address+3
00072Ar 2  98               tya
00072Br 2  69 03            adc #3
00072Dr 2  65 rr            adc @channel_data_ptr+0
00072Fr 2  9D rr rr         sta famistudio_chn_return_lo,x
000732r 2  A5 rr            lda @channel_data_ptr+1
000734r 2  69 00            adc #0
000736r 2  9D rr rr         sta famistudio_chn_return_hi,x
000739r 2  B1 rr            lda (@channel_data_ptr),y ; Read length of the reference (how many rows)
00073Br 2  9D rr rr         sta famistudio_chn_ref_len,x
00073Er 2  C8               iny
00073Fr 2  B1 rr            lda (@channel_data_ptr),y ; Read 16-bit absolute address of the reference
000741r 2  85 rr            sta @tmp_ptr_lo
000743r 2  C8               iny
000744r 2  B1 rr            lda (@channel_data_ptr),y
000746r 2  85 rr            sta @channel_data_ptr+1
000748r 2  A5 rr            lda @tmp_ptr_lo
00074Ar 2  85 rr            sta @channel_data_ptr+0
00074Cr 2  A0 00            ldy #0
00074Er 2  4C rr rr         jmp @read_byte
000751r 2               
000751r 2               @opcode_loop:
000751r 2  B1 rr            lda (@channel_data_ptr),y
000753r 2  85 rr            sta @tmp_ptr_lo
000755r 2  C8               iny
000756r 2  B1 rr            lda (@channel_data_ptr),y
000758r 2  85 rr            sta @channel_data_ptr+1
00075Ar 2  A5 rr            lda @tmp_ptr_lo
00075Cr 2  85 rr            sta @channel_data_ptr+0
00075Er 2  A0 00            ldy #0
000760r 2  4C rr rr         jmp @read_byte
000763r 2               
000763r 2               @opcode_disable_attack:
000763r 2  A9 80            lda #$80
000765r 2  05 rr            ora @update_flags
000767r 2  85 rr            sta @update_flags
000769r 2  4C rr rr         jmp @read_byte
00076Cr 2               
00076Cr 2               @opcode_end_song:
00076Cr 2  A9 80            lda #$80 ; TODO : Should we stop, or just call famistudio_music_stop here?
00076Er 2  8D rr rr         sta famistudio_song_speed
000771r 2  4C rr rr         jmp @read_byte
000774r 2               
000774r 2               .if FAMISTUDIO_USE_RELEASE_NOTES
000774r 2               @jump_to_release_envelope:
000774r 2  BD rr rr         lda famistudio_env_addr_lo,x ; Load envelope data address into temp
000777r 2  85 rr            sta @env_ptr+0
000779r 2  BD rr rr         lda famistudio_env_addr_hi,x
00077Cr 2  85 rr            sta @env_ptr+1
00077Er 2               
00077Er 2  84 rr            sty @tmp_y1
000780r 2  A0 00            ldy #0
000782r 2  B1 rr            lda (@env_ptr),y ; Read first byte of the envelope data, this contains the release index.
000784r 2  F0 08            beq @env_has_no_release
000786r 2               
000786r 2  9D rr rr         sta famistudio_env_ptr,x
000789r 2  A9 00            lda #0
00078Br 2  9D rr rr         sta famistudio_env_repeat,x ; Need to reset envelope repeat to force update.
00078Er 2               
00078Er 2               @env_has_no_release:
00078Er 2  A6 rr            ldx @chan_idx
000790r 2  A4 rr            ldy @tmp_y1
000792r 2  60               rts
000793r 2               
000793r 2               .if FAMISTUDIO_EXP_VRC7
000793r 2               @opcode_vrc7_release_note:
