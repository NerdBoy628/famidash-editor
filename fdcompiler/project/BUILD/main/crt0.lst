000D8Er 2               ; Mapping for the channel id of the rhythm channel, to the RAM offset for it
000D8Er 2               ; If the user disables various channels, then we want to save on the ram for them
000D8Er 2               ; by just not reserving it, so this maps from channel ID to the new RAM offset for the channel
000D8Er 2               ; The end result should be a table that looks like this if you have channel 2, 3, and 5 enabled
000D8Er 2               ; .byte $ff, $00, $01, $ff, $02, $ff
000D8Er 2               EPSM_CHANNEL1_RHYTHM_OFFSET = -1 + FAMISTUDIO_EXP_EPSM_RHYTHM_CHN1_ENABLE
000D8Er 2               EPSM_CHANNEL2_RHYTHM_OFFSET = EPSM_CHANNEL1_RHYTHM_OFFSET + FAMISTUDIO_EXP_EPSM_RHYTHM_CHN2_ENABLE
000D8Er 2               EPSM_CHANNEL3_RHYTHM_OFFSET = EPSM_CHANNEL2_RHYTHM_OFFSET + FAMISTUDIO_EXP_EPSM_RHYTHM_CHN3_ENABLE
000D8Er 2               EPSM_CHANNEL4_RHYTHM_OFFSET = EPSM_CHANNEL3_RHYTHM_OFFSET + FAMISTUDIO_EXP_EPSM_RHYTHM_CHN4_ENABLE
000D8Er 2               EPSM_CHANNEL5_RHYTHM_OFFSET = EPSM_CHANNEL4_RHYTHM_OFFSET + FAMISTUDIO_EXP_EPSM_RHYTHM_CHN5_ENABLE
000D8Er 2               EPSM_CHANNEL6_RHYTHM_OFFSET = EPSM_CHANNEL5_RHYTHM_OFFSET + FAMISTUDIO_EXP_EPSM_RHYTHM_CHN6_ENABLE
