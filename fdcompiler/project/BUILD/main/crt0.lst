000271r 2               ;sprid removed
000271r 2               
000271r 2               __oam_meta_spr:
000271r 2               	; AX = data
000271r 2               	; sreg[0] = x
000271r 2               	; sreg[1] = y
000271r 2               
000271r 2  85 rr        	sta <PTR
000273r 2  86 rr        	stx <PTR+1
000275r 2               
000275r 2  A0 00        	ldy #0
000277r 2               
000277r 2               oam_meta_spr_params_set:	; Put &data into PTR, X and Y into SCRX and SCRY respectively
000277r 2               
000277r 2  A6 rr        	ldx SPRID
000279r 2               
000279r 2               @loop:
000279r 2               
000279r 2  B1 rr        	lda (PTR),y		;
00027Br 2  C9 80        	cmp #$80		;	Load X offset
00027Dr 2  F0 3D        	beq @2			;	Exit if = $80
00027Fr 2  C8           	iny				;__
000280r 2               	; The CMP #$80 has practically loaded the last bit
000280r 2               	; of the X offset into the carry flag
000280r 2  B0 06        	bcs @neg_x_off
000282r 2               	@pos_x_off:
000282r 2  65 rr        		adc sreg+0		;__	Add it to the metasprite X	(carry already cleared)
000284r 2  B0 39        		bcs	@x_overflow	;__	If it had an overflow then don't render the damn sprite
000286r 2  90 06        		bcc	@no_x_overflow
000288r 2               	@neg_x_off:
000288r 2  18           		clc				;	Add it to the metasprite X
000289r 2  65 rr        		adc sreg+0		;__
00028Br 2  90 32        		bcc	@x_overflow	;__	If it had an overflow then don't render the damn sprite
00028Dr 2  18           		clc				;__	We need the clear carry later
00028Er 2               	@no_x_overflow:
00028Er 2  9D rr rr     	sta OAM_BUF+3,x	;__	Store the sprite X
000291r 2  B1 rr        	lda (PTR),y		;__	Load Y offset
000293r 2  30 06        	bmi	@neg_y_off
000295r 2               	@pos_y_off:
000295r 2  65 rr        		adc sreg+1		;__	Add it to the metasprite Y	(carry already cleared)
000297r 2  B0 26        		bcs	@y_overflow	;__	If it had an overflow then don't render the damn sprite
000299r 2  90 09        		bcc	@no_y_overflow
00029Br 2               	@neg_y_off:
00029Br 2  65 rr        		adc	sreg+1		;__	Add it to the metasprite Y
00029Dr 2  B0 04        		bcs	@neg_no_y_overflow	;__	If it had an overflow then don't render the damn sprite
00029Fr 2  C9 F0        			cmp #$F0		;	Do render the sprite if it ended up
0002A1r 2  90 1C        			bcc	@y_overflow	;__	in the negative space
0002A3r 2               		@neg_no_y_overflow:
0002A3r 2  18           		clc				;__	We need the clear carry later
0002A4r 2               	@no_y_overflow:
0002A4r 2  C8           	iny				;
0002A5r 2  9D rr rr     	sta OAM_BUF+0,x	;__	Store the sprite Y
0002A8r 2  B1 rr        	lda (PTR),y		;
0002AAr 2  C8           	iny				;	Load and store the tile
0002ABr 2  9D rr rr     	sta OAM_BUF+1,x	;__
0002AEr 2  B1 rr        	lda (PTR),y		;
0002B0r 2  C8           	iny				;	Load and store the attribute
0002B1r 2  9D rr rr     	sta OAM_BUF+2,x	;__
0002B4r 2  8A           	txa				;	Add 4 to the SPRID
0002B5r 2  69 04        	adc #$04		;__
0002B7r 2  B0 05        	bcs @spr_full	;__	If it overflows, exit
0002B9r 2  AA           	tax				;	Otherwise, loop right back
0002BAr 2  90 BD        	bcc @loop		;__	(= BRA)
0002BCr 2               
0002BCr 2               @2:
0002BCr 2               
0002BCr 2  86 rr        	stx SPRID
0002BEr 2               @spr_full:
0002BEr 2  60           	rts
0002BFr 2               
0002BFr 2               @x_overflow:
0002BFr 2               @y_overflow:
0002BFr 2  C8           	iny
0002C0r 2  C8           	iny
0002C1r 2  C8           	iny
0002C2r 2  D0 B5        	bne	@loop	;__ = BRA
0002C4r 2               
0002C4r 2               
