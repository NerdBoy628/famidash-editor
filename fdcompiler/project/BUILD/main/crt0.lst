00065Cr 2               			; 			else if (player_vel_y[1] > 0) kandotemp3[1] = 1;
00065Cr 2               			; 			else if (player_vel_y[1] < 0) kandotemp3[1] = 2;
00065Cr 2               			; 		}
00065Cr 2               			;	kandotemp3[1] used as index
00065Cr 2               		; Modified pseudo C code:
00065Cr 2               			;	kandotemp3[1] = 1;
00065Cr 2               			;	if (0 < highbyte < $80) {}	// do nothing with it
00065Cr 2               			;	else if ($80 ≤ highbyte ≤ $FF) {
00065Cr 2               			;		kandotemp3[1] = 2;
00065Cr 2               			;	} else if (highbyte == $00) {
00065Cr 2               			;		if (lowbyte == 0) kandotemp3[1] = 0;
00065Cr 2               			; 	}
00065Cr 2               
00065Cr 2  A0 01        		LDY #$1				;__	kandotemp3[1] = 1;
00065Er 2  AD rr rr     		LDA _player_vel_y+3	;__
000661r 2  F0 06        		BEQ :+				;__	else if (highbyte == $00) { // later }
000663r 2  10 0A        		BPL @fin		    ;__	if (0 < highbyte < $80) {}	// do nothing with it
000665r 2  C8           			INY				;__	else if ($80 ≤ highbyte ≤ $FF) { kandotemp3[1] = 2; }
000666r 2  4C rr rr     			JMP drawplayer_common	    ;__
000669r 2               		:
000669r 2  0D rr rr     		ORA _player_vel_y+2	;	if (lowbyte == 0) kandotemp3[1] = 0;
00066Cr 2  D0 01        		BNE @fin			;
00066Er 2  88           			DEY				;	kandotemp3[1] = 0;
00066Fr 2               		@fin:
00066Fr 2  4C rr rr     			JMP drawplayer_common    	;__
000672r 2               	robot:
000672r 2               		; C code:
000672r 2               			;	if (player_vel_y[1] == 0 || player_vel_y[1] == CUBE_GRAVITY) {
000672r 2               			;		[index from ROBOT/MINI_ROBOT using robotframe[1]]
000672r 2               			; 		robotframe[1]++;
000672r 2               			; 		if (robotframe[1] > 19) { robotframe[1] = 0; }
000672r 2               			;	} else {
000672r 2               			;		[index from ROBOT_JUMP/MINI_ROBOT_JUMP using robotjumpframe[1]]
000672r 2               			; 	}
000672r 2  A5 rr        			LDA _was_on_slope_counter+1
000674r 2  D0 08        			BNE @ignoreJump
000676r 2  AD rr rr     			LDA _player_vel_y+3	;
000679r 2  0D rr rr     			ORA _player_vel_y+2	;	if (player_vel_y[1] == 0 || player_vel_y[1] == CUBE_GRAVITY) {
00067Cr 2  D0 2B        			BNE @jump
00067Er 2               		@ignoreJump:
00067Er 2  AD rr rr     			LDA _options
000681r 2  29 04        			and #$04
000683r 2  F0 0F        			beq	@cont1
000685r 2  AD rr rr     			LDA _player_vel_x+2
000688r 2  D0 0A        			bne @cont1
00068Ar 2  A9 00        			lda #0
00068Cr 2  8D rr rr     			sta _robotframe
00068Fr 2  A0 00        			ldy #0
000691r 2  4C rr rr     			jmp @fini
000694r 2               
000694r 2               		@cont1:
000694r 2  A9 00        			LDA #0
000696r 2  AC rr rr     			LDY _robotframe	;	[load robotframe[0] into Y]
000699r 2  38           			SEC				;	robotframe[0]++; (A is 0, so set the carry and bam)
00069Ar 2  6D rr rr     			ADC _robotframe	;__
00069Dr 2  C9 14        			CMP #20			;
00069Fr 2  90 02        			BCC @hur			;	if (robotframe[0] > 19) { robotframe[0] = 0; }
0006A1r 2  A9 00        				LDA #$00	;__
0006A3r 2               			@hur:				;
0006A3r 2  8D rr rr     			STA _robotframe	;__
0006A6r 2               		@fini:
0006A6r 2  4C rr rr     			JMP drawplayer_common
0006A9r 2               		@jump:				;	} else {
0006A9r 2  A9 15        			LDA #21			; ! This is the sizeof ROBOT / MINI_ROBOT, change it as needed
0006ABr 2  18           			CLC				;	ROBOT_JUMP[X] = ROBOT[X+20]
0006ACr 2  6D rr rr     			ADC _robotjumpframe
0006AFr 2  A8           			TAY				;__
0006B0r 2  4C rr rr     			JMP drawplayer_common
0006B3r 2               	spider:
0006B3r 2               		; C code:
0006B3r 2               			;	if (player_vel_y[1] == 0 || player_vel_y[1] == CUBE_GRAVITY) {
0006B3r 2               			;		[index from SPIDER/MINI_SPIDER using spiderframe[1]]
0006B3r 2               			; 		spiderframe[1]++;
0006B3r 2               			; 		if (spiderframe[1] > 15) { spiderframe[1] = 0; }
0006B3r 2               			;	} else {
0006B3r 2               			;		[use SPIDER_JUMP/MINI_SPIDER_JUMP[0]]
0006B3r 2               			; 	}
0006B3r 2  AD rr rr     		LDA _player_vel_y+3	;
0006B6r 2  0D rr rr     		ORA _player_vel_y+2	;	if (player_vel_y[1] == 0 || player_vel_y[1] == CUBE_GRAVITY) {
0006B9r 2  D0 27        		BNE @jump	    	;__
0006BBr 2  AD rr rr     			LDA _options
0006BEr 2  29 04        			and #$04
0006C0r 2  F0 0F        			beq	@cont1
0006C2r 2  AD rr rr     			LDA _player_vel_x
0006C5r 2  D0 0A        			bne @cont1
0006C7r 2  A9 00        			lda #0
0006C9r 2  8D rr rr     			sta _spiderframe
0006CCr 2  A0 00        			ldy #0
0006CEr 2  4C rr rr     			jmp drawplayer_common
0006D1r 2               
0006D1r 2               		@cont1:
0006D1r 2  A9 00        			LDA #0
0006D3r 2  AC rr rr     			LDY _spiderframe+1;	[load spiderframe[1] into Y]
0006D6r 2  38           			SEC				;	spiderframe[1]++; (A is 0, so set the carry and bam)
0006D7r 2  6D rr rr     			ADC _spiderframe+1;__
0006DAr 2  29 0F        			AND #$0F        ;   if (spiderframe[1] > 15) spiderframe[1] = 0;
0006DCr 2  8D rr rr     			STA _spiderframe+1;__
0006DFr 2  4C rr rr     			JMP drawplayer_common
0006E2r 2               		@jump:				;	} else { SPIDER_JUMP[0] = SPIDER[8]
0006E2r 2  A9 10        			LDA #16			; ! This is the sizeof ROBOT / MINI_ROBOT, change it as needed
0006E4r 2  18           			CLC				;	ROBOT_JUMP[X] = ROBOT[X+20]
0006E5r 2  6D rr rr     			ADC _robotjumpframe
0006E8r 2  A8           			TAY				;__
0006E9r 2               
0006E9r 2  4C rr rr     			JMP drawplayer_common
0006ECr 2               	wave:
0006ECr 2               		; C code:
0006ECr 2               			; 		cube_rotate[1] = 0x0400 - player_vel_y[1];
0006ECr 2               			; 		if (high_byte(cube_rotate) >= 0x08) {
0006ECr 2               			; 			cube_rotate[1]= high_byte(cube_rotate) >= 0x80 ? 0x0000 : 0x07FF;
0006ECr 2               			; 		}
0006ECr 2  8A           		TXA						;(X = 0 as per JEQ)
0006EDr 2  A8           		TAY						;
0006EEr 2  38           		sec						;
0006EFr 2  ED rr rr     		sbc _player_vel_y+2		;	cube_rotate[1] = 0x0400 - player_vel_y[1];
0006F2r 2  85 rr        		sta _cube_rotate+2		;	(Mostly generated by cc65 lmao)
0006F4r 2  A9 04        		lda #$04				;
0006F6r 2  ED rr rr     		sbc _player_vel_y+3		;
0006F9r 2               		; A has high byte of _cube_rotate
0006F9r 2  C9 08        		CMP	#$08				;	if (high_byte(cube_rotate) >= 0x08) {
0006FBr 2  90 0A        		BCC :++					;__
0006FDr 2  C9 80        			CMP #$80			;	if (high_byte(cube_rotate) < 0x80)
0006FFr 2  90 03        			BCC	:+				;__
000701r 2  A0 07        				LDY #$07		;	cube_rotate[1] = 0x07FF
000703r 2  CA           				DEX				;__
000704r 2               			:					;__	else 0x0000 (Y and X still remain at 0)
000704r 2  86 rr        			STX _cube_rotate+2	;__	Store low byte
000706r 2  98           			TYA					;
000707r 2               		:						;	Store high byte
000707r 2  85 rr        		STA	_cube_rotate+3		;__
000709r 2               
000709r 2                       ; Fix for speed greater than x3 being mirrored
000709r 2  AC rr rr             LDY _player_vel_x+1
00070Cr 2  C0 04                CPY #$04
00070Er 2  90 0A                BCC :+
000710r 2                           ; 7 - A = -A + 7
000710r 2               			; -A = (A ^ 0xFF) + 1
000710r 2               			; 7 - A = (A ^ 0xFF) + 8
000710r 2  AC rr rr                 LDY _player_mini+1
000713r 2  D0 05                    BNE :+
000715r 2  49 FF        			EOR #$FF
000717r 2  18           			CLC
000718r 2  69 08        			ADC #$08
00071Ar 2                       :
00071Ar 2               		; Frame index is high byte of _cube_rotate if gravity is 0,
00071Ar 2               		;* and 7-high byte if gravity isn't 0
00071Ar 2  AE rr rr     		LDX _player_gravity+1
00071Dr 2  F0 05        		BEQ :+
00071Fr 2               			; 7 - A = -A + 7
00071Fr 2               			; -A = (A ^ 0xFF) + 1
00071Fr 2               			; 7 - A = (A ^ 0xFF) + 8
00071Fr 2  49 FF        			EOR #$FF
000721r 2  18           			CLC
000722r 2  69 08        			ADC #$08
000724r 2               		:
000724r 2  A8           		TAY
000725r 2  4C rr rr     		JMP drawplayer_common
000728r 2               	sprite_table_table_lo:
000728r 2  rr rr rr rr  		.byte <_CUBE2, <_SHIP2, <_BALL2, <_UFO2, <_ROBOT2, <_SPIDER2, <_WAVE2, <_SWING2, <_CUBE2, <_POGO2, <_SNAKE2, <_CUBE2
00072Cr 2  rr rr rr rr  
