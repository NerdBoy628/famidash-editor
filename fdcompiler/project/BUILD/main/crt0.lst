000020r 2               .segment "CODE_2"
000000r 2                   _mmc3_pop_prg_bank_1:
000000r 2  A9 07                LDA #MMC3_REG_SEL_PRG_BANK_1
000002r 2  05 rr                ora mmc3ChrInversionSetting
000004r 2  8D 00 80             sta MMC3_REG_BANK_SELECT
000007r 2  AD rr rr             LDA mmc3PRG1Bank
00000Ar 2  8D 01 80             STA MMC3_REG_BANK_DATA
00000Dr 2  60                   rts
00000Er 2                   .export _mmc3_pop_prg_bank_1
00000Er 2               
00000Er 2                   mmc3_set_prg_bank_1:
00000Er 2                   _mmc3_set_prg_bank_1:
00000Er 2  8D rr rr             STA mmc3PRG1Bank
000011r 2                   mmc3_tmp_prg_bank_1:    ; ONLY MEANT FOR USE WITH NMI-RELATED TEMPORARY BANKSWITCHING
000011r 2  48                   PHA
000012r 2  A9 07                lda #MMC3_REG_SEL_PRG_BANK_1
000014r 2                   mmc3_internal_set_bank:
000014r 2  05 rr                ora mmc3ChrInversionSetting
000016r 2  8D 00 80             sta MMC3_REG_BANK_SELECT
000019r 2  68                   PLA
00001Ar 2  8D 01 80             sta MMC3_REG_BANK_DATA
00001Dr 2  60                   rts
