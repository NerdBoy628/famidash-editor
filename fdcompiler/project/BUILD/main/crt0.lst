0005A1r 2               	; AX = len
0005A1r 2               	; sreg = src
0005A1r 2               	; xargs[0:1] = dst
0005A1r 2               
0005A1r 2  85 rr        	sta <LEN
0005A3r 2  86 rr        	stx <LEN+1
0005A5r 2               
0005A5r 2  A2 00        	ldx #0
0005A7r 2               
0005A7r 2               @1:
0005A7r 2               
0005A7r 2  A5 rr        	lda <LEN+1
0005A9r 2  F0 0C        	beq @2
0005ABr 2  20 rr rr     	jsr @3
0005AEr 2  C6 rr        	dec <LEN+1
0005B0r 2  E6 rr        	inc sreg+1
0005B2r 2  E6 rr        	inc xargs+1
0005B4r 2  4C rr rr     	jmp @1
0005B7r 2               
0005B7r 2               @2:
0005B7r 2               
0005B7r 2  A6 rr        	ldx <LEN
0005B9r 2  F0 0A        	beq @5
0005BBr 2               
0005BBr 2               @3:
0005BBr 2               
0005BBr 2  A0 00        	ldy #0
0005BDr 2               
0005BDr 2               @4:
0005BDr 2               
0005BDr 2  B1 rr        	lda (sreg),y
0005BFr 2  91 rr        	sta (xargs),y
0005C1r 2  C8           	iny
0005C2r 2  CA           	dex
0005C3r 2  D0 F8        	bne @4
0005C5r 2               
0005C5r 2               @5:
0005C5r 2               
0005C5r 2  60           	rts
