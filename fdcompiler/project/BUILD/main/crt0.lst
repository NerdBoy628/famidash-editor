000933r 2               ;======================================================================================================================
000933r 2               ; FAMISTUDIO_SAMPLE_STOP (internal)
000933r 2               ;
000933r 2               ; Stop DPCM sample if it plays
000933r 2               ;
000933r 2               ; [in] no input params.
000933r 2               ;======================================================================================================================
000933r 2               
000933r 2               famistudio_sample_stop:
000933r 2               
000933r 2  A9 0F            lda #%00001111
000935r 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
000938r 2  60               rts
000939r 2               
000939r 2               
000939r 2               .if FAMISTUDIO_CFG_DPCM_SUPPORT
000939r 2               
000939r 2               ;======================================================================================================================
000939r 2               ; FAMISTUDIO_SAMPLE_PLAY_SFX (public)
000939r 2               ;
000939r 2               ; Play DPCM sample with higher priority, for sound effects
000939r 2               ;
000939r 2               ; [in] a: Sample index, 1...63.
000939r 2               ;======================================================================================================================
000939r 2               
000939r 2               famistudio_sfx_sample_play:
000939r 2               
000939r 2  A2 01            ldx #1
00093Br 2  8E rr rr         stx famistudio_dpcm_effect
00093Er 2               
00093Er 2               sample_play:
00093Er 2               
00093Er 2                   @tmp = famistudio_r3
00093Er 2                   @sample_index = famistudio_r3
00093Er 2                   @sample_data_ptr = famistudio_ptr1
00093Er 2               
00093Er 2               .if FAMISTUDIO_USE_DPCM_BANKSWITCHING || FAMISTUDIO_USE_DPCM_EXTENDED_RANGE
00093Er 2                   ; famistudio_dpcm_list + sample number * (4 or 5)
00093Er 2  85 rr            sta @sample_index
000940r 2  A0 00            ldy #0
000942r 2  84 rr            sty @sample_data_ptr+1
000944r 2  0A               asl
000945r 2  26 rr            rol @sample_data_ptr+1
000947r 2  0A               asl
000948r 2  26 rr            rol @sample_data_ptr+1 ; Will clear carry
00094Ar 2               .if FAMISTUDIO_USE_DPCM_BANKSWITCHING
00094Ar 2                   ; Multiply by 5 instead of 4.
00094Ar 2  65 rr            adc @sample_index
00094Cr 2  90 03            bcc @add_list_ptr
00094Er 2  E6 rr                inc @sample_data_ptr+1
000950r 2  18                   clc
000951r 2                   @add_list_ptr:
000951r 2               .endif
000951r 2  6D rr rr             adc famistudio_dpcm_list_lo
000954r 2  85 rr                sta @sample_data_ptr+0
000956r 2  A5 rr                lda @sample_data_ptr+1
000958r 2  6D rr rr             adc famistudio_dpcm_list_hi
00095Br 2  85 rr                sta @sample_data_ptr+1
00095Dr 2               .else
00095Dr 2                   asl ; Sample number * 4, offset in the sample table
00095Dr 2                   asl ; Carry should be clear now, we dont allow more than 63 sample mappings.
00095Dr 2                   adc famistudio_dpcm_list_lo
00095Dr 2                   sta @sample_data_ptr+0
00095Dr 2                   lda #0
00095Dr 2                   adc famistudio_dpcm_list_hi
00095Dr 2                   sta @sample_data_ptr+1
00095Dr 2               .endif
00095Dr 2               
00095Dr 2               @stop_dpcm:
00095Dr 2  A9 0F            lda #%00001111 ; Stop DPCM
00095Fr 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
000962r 2               
000962r 2  A0 00            ldy #0
000964r 2  B1 rr            lda (@sample_data_ptr),y ; Sample offset
000966r 2  8D 12 40         sta FAMISTUDIO_APU_DMC_START
000969r 2  C8               iny
00096Ar 2  B1 rr            lda (@sample_data_ptr),y ; Sample length
00096Cr 2  8D 13 40         sta FAMISTUDIO_APU_DMC_LEN
00096Fr 2  C8               iny
000970r 2  B1 rr            lda (@sample_data_ptr),y ; Pitch and loop
000972r 2  8D 10 40         sta FAMISTUDIO_APU_DMC_FREQ
000975r 2  C8               iny
000976r 2               
000976r 2               .if FAMISTUDIO_USE_DELTA_COUNTER
000976r 2  AD rr rr         lda famistudio_dmc_delta_counter
000979r 2  30 0A            bmi @read_dmc_initial_value
00097Br 2  8D 11 40         sta FAMISTUDIO_APU_DMC_RAW
00097Er 2  A9 FF            lda #$ff
000980r 2  8D rr rr         sta famistudio_dmc_delta_counter
000983r 2  30 05            bmi @start_dmc
000985r 2               @read_dmc_initial_value:
000985r 2               .endif
000985r 2               
000985r 2  B1 rr            lda (@sample_data_ptr),y ; Initial DMC counter
000987r 2  8D 11 40         sta FAMISTUDIO_APU_DMC_RAW
00098Ar 2               
00098Ar 2               @start_dmc:
00098Ar 2               .if FAMISTUDIO_USE_DPCM_BANKSWITCHING
00098Ar 2  C8               iny
00098Br 2  B1 rr            lda (@sample_data_ptr),y ; Bank number
00098Dr 2  20 rr rr         jsr famistudio_dpcm_bank_callback
000990r 2                   ; jroweboy - ADDED if carry is set from the bank callback skip playing the sample
000990r 2                   ; bcs @exit
000990r 2               .endif
000990r 2               
000990r 2  A9 1F            lda #%00011111 ; Start DMC
000992r 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
000995r 2               @exit:
000995r 2  60               rts
000996r 2               
000996r 2               ;======================================================================================================================
000996r 2               ; FAMISTUDIO_SAMPLE_PLAY_MUSIC (internal)
000996r 2               ;
000996r 2               ; Play DPCM sample, used by music player, could be used externally. Samples played for music have lower priority than
000996r 2               ; samples played by SFX.
000996r 2               ;
000996r 2               ; [in] a: Sample index, 1...63.
000996r 2               ;======================================================================================================================
000996r 2               
000996r 2               famistudio_music_sample_play:
000996r 2               
000996r 2  AE rr rr         ldx famistudio_dpcm_effect
000999r 2  F0 A3            beq sample_play
00099Br 2  AA               tax
00099Cr 2  AD 15 40         lda FAMISTUDIO_APU_SND_CHN
00099Fr 2  29 10            and #16
0009A1r 2  F0 01            beq @not_busy
0009A3r 2  60               rts
0009A4r 2               
0009A4r 2               @not_busy:
0009A4r 2  8D rr rr         sta famistudio_dpcm_effect
0009A7r 2  8A               txa
0009A8r 2  4C rr rr         jmp sample_play
0009ABr 2               
0009ABr 2               .endif
0009ABr 2               
0009ABr 2               .if FAMISTUDIO_CFG_SFX_SUPPORT
0009ABr 2               
0009ABr 2               ;======================================================================================================================
0009ABr 2               ; FAMISTUDIO_SFX_INIT (public)
0009ABr 2               ;
0009ABr 2               ; Initialize the sound effect player.
0009ABr 2               ;
0009ABr 2               ; [in] x: Sound effect data pointer (lo)
0009ABr 2               ; [in] y: Sound effect data pointer (hi)
0009ABr 2               ;======================================================================================================================
0009ABr 2               
0009ABr 2               famistudio_sfx_init:
0009ABr 2               
0009ABr 2                   @effect_list_ptr = famistudio_ptr0
0009ABr 2               
0009ABr 2  86 rr            stx @effect_list_ptr+0
0009ADr 2  84 rr            sty @effect_list_ptr+1
0009AFr 2               
0009AFr 2  A0 00            ldy #0
0009B1r 2               
0009B1r 2               .if FAMISTUDIO_DUAL_SUPPORT
0009B1r 2  AD rr rr         lda famistudio_pal_adjust ; Add 2 to the sound list pointer for PAL
0009B4r 2  D0 02            bne @ntsc
0009B6r 2  C8               iny
0009B7r 2  C8               iny
0009B8r 2               @ntsc:
0009B8r 2               .endif
0009B8r 2               
0009B8r 2  B1 rr            lda (@effect_list_ptr),y
0009BAr 2  8D rr rr         sta famistudio_sfx_addr_lo
0009BDr 2  C8               iny
0009BEr 2  B1 rr            lda (@effect_list_ptr),y
0009C0r 2  8D rr rr         sta famistudio_sfx_addr_hi
0009C3r 2               
0009C3r 2  A2 00            ldx #FAMISTUDIO_SFX_CH0
0009C5r 2               
0009C5r 2               @set_channels:
0009C5r 2  20 rr rr         jsr famistudio_sfx_clear_channel
0009C8r 2  8A               txa
0009C9r 2  18               clc
0009CAr 2  69 0F            adc #FAMISTUDIO_SFX_STRUCT_SIZE
0009CCr 2  AA               tax
0009CDr 2  E0 0F            cpx #FAMISTUDIO_SFX_STRUCT_SIZE*FAMISTUDIO_CFG_SFX_STREAMS
0009CFr 2  D0 F4            bne @set_channels
0009D1r 2               
0009D1r 2  60               rts
0009D2r 2               
0009D2r 2               ;======================================================================================================================
0009D2r 2               ; FAMISTUDIO_SFX_CLEAR_CHANNEL (internal)
0009D2r 2               ;
0009D2r 2               ; Clears output buffer of a sound effect.
0009D2r 2               ;
0009D2r 2               ; [in] x: Offset of the sound effect stream.
0009D2r 2               ;======================================================================================================================
0009D2r 2               
0009D2r 2               famistudio_sfx_clear_channel:
0009D2r 2               
0009D2r 2  A9 00            lda #0
0009D4r 2  9D rr rr         sta famistudio_sfx_ptr_hi,x   ; This stops the effect
0009D7r 2  9D rr rr         sta famistudio_sfx_repeat,x
0009DAr 2  9D rr rr         sta famistudio_sfx_offset,x
0009DDr 2  9D rr rr         sta famistudio_sfx_buffer+6,x ; Mute triangle
0009E0r 2  A9 30            lda #$30
0009E2r 2  9D rr rr         sta famistudio_sfx_buffer+0,x ; Mute pulse1
0009E5r 2  9D rr rr         sta famistudio_sfx_buffer+3,x ; Mute pulse2
0009E8r 2  9D rr rr         sta famistudio_sfx_buffer+9,x ; Mute noise
0009EBr 2  60               rts
0009ECr 2               
0009ECr 2               ;======================================================================================================================
0009ECr 2               ; FAMISTUDIO_SFX_PLAY (public)
0009ECr 2               ;
0009ECr 2               ; Plays a sound effect.
0009ECr 2               ;
0009ECr 2               ; [in] a: Sound effect index (0...127)
0009ECr 2               ; [in] x: Offset of sound effect channel, should be FAMISTUDIO_SFX_CH0..FAMISTUDIO_SFX_CH3
0009ECr 2               ;======================================================================================================================
0009ECr 2               
0009ECr 2               famistudio_sfx_play:
0009ECr 2               
0009ECr 2                   @effect_data_ptr = famistudio_ptr0
0009ECr 2               
0009ECr 2  0A               asl a
0009EDr 2  A8               tay
0009EEr 2               
0009EEr 2  20 rr rr         jsr famistudio_sfx_clear_channel ; Stops the effect if it plays
0009F1r 2               
0009F1r 2  AD rr rr         lda famistudio_sfx_addr_lo
0009F4r 2  85 rr            sta @effect_data_ptr+0
0009F6r 2  AD rr rr         lda famistudio_sfx_addr_hi
0009F9r 2  85 rr            sta @effect_data_ptr+1
0009FBr 2               
0009FBr 2  B1 rr            lda (@effect_data_ptr),y
0009FDr 2  9D rr rr         sta famistudio_sfx_ptr_lo,x
000A00r 2  C8               iny
000A01r 2  B1 rr            lda (@effect_data_ptr),y
000A03r 2  9D rr rr         sta famistudio_sfx_ptr_hi,x ; This write enables the effect
000A06r 2               
000A06r 2  60               rts
000A07r 2               
000A07r 2               ;======================================================================================================================
000A07r 2               ; FAMISTUDIO_SFX_UPDATE (internal)
000A07r 2               ;
000A07r 2               ; Updates a single sound effect stream.
000A07r 2               ;
000A07r 2               ; [in] x: Offset of sound effect channel, should be FAMISTUDIO_SFX_CH0..FAMISTUDIO_SFX_CH3
000A07r 2               ;======================================================================================================================
000A07r 2               
000A07r 2               famistudio_sfx_update:
000A07r 2               
000A07r 2                   @tmp = famistudio_r0
000A07r 2                   @tmpx = famistudio_r1
000A07r 2                   @effect_data_ptr = famistudio_ptr0
000A07r 2               
000A07r 2  BD rr rr         lda famistudio_sfx_repeat,x ; Check if repeat counter is not zero
000A0Ar 2  F0 05            beq @no_repeat
000A0Cr 2  DE rr rr         dec famistudio_sfx_repeat,x ; Decrement and return
000A0Fr 2  D0 4B            bne @update_buf ; Just mix with output buffer
000A11r 2               
000A11r 2               @no_repeat:
000A11r 2  BD rr rr         lda famistudio_sfx_ptr_hi,x ; Check if MSB of the pointer is not zero
000A14r 2  D0 01            bne @sfx_active
000A16r 2  60               rts ; Return otherwise, no active effect
000A17r 2               
000A17r 2               @sfx_active:
000A17r 2  85 rr            sta @effect_data_ptr+1         ;load effect pointer into temp
000A19r 2  BD rr rr         lda famistudio_sfx_ptr_lo,x
000A1Cr 2  85 rr            sta @effect_data_ptr+0
000A1Er 2  BC rr rr         ldy famistudio_sfx_offset,x
000A21r 2  18               clc
000A22r 2               
000A22r 2               @read_byte:
000A22r 2  B1 rr            lda (@effect_data_ptr),y ; Read byte of effect
000A24r 2  30 12            bmi @get_data ; If bit 7 is set, it is a register write
000A26r 2  F0 31            beq @eof
000A28r 2  C8               iny
000A29r 2  D0 03            bne @store_repeat
000A2Br 2  20 rr rr         jsr @inc_sfx
000A2Er 2               @store_repeat:
000A2Er 2  9D rr rr         sta famistudio_sfx_repeat,x ; If bit 7 is reset, it is number of repeats
000A31r 2  98               tya
000A32r 2  9D rr rr         sta famistudio_sfx_offset,x
000A35r 2  4C rr rr         jmp @update_buf
000A38r 2               
000A38r 2               @get_data:
000A38r 2  C8               iny
000A39r 2  D0 03            bne @get_data2
000A3Br 2  20 rr rr         jsr @inc_sfx
000A3Er 2               @get_data2:
000A3Er 2  86 rr            stx @tmp ; It is a register write
000A40r 2  65 rr            adc @tmp ; Get offset in the effect output buffer
000A42r 2  AA               tax
000A43r 2  B1 rr            lda (@effect_data_ptr),y
000A45r 2  C8               iny
000A46r 2  D0 09            bne @write_buffer
000A48r 2  86 rr            stx @tmpx
000A4Ar 2  A6 rr            ldx @tmp
000A4Cr 2  20 rr rr         jsr @inc_sfx
000A4Fr 2  A6 rr            ldx @tmpx
000A51r 2               @write_buffer:
000A51r 2  9D rr rr         sta famistudio_sfx_buffer-128,x
000A54r 2  A6 rr            ldx @tmp
000A56r 2  4C rr rr         jmp @read_byte
000A59r 2               
000A59r 2               @eof:
000A59r 2  9D rr rr         sta famistudio_sfx_ptr_hi,x ; Mark channel as inactive
000A5Cr 2               
000A5Cr 2               @update_buf:
000A5Cr 2  AD rr rr         lda famistudio_output_buf ; Compare effect output buffer with main output buffer
000A5Fr 2  29 0F            and #$0f ; If volume of pulse 1 of effect is higher than that of the main buffer, overwrite the main buffer value with the new one
000A61r 2  85 rr            sta @tmp
000A63r 2  BD rr rr         lda famistudio_sfx_buffer+0,x
000A66r 2  29 0F            and #$0f
000A68r 2  C5 rr            cmp @tmp
000A6Ar 2  90 12            bcc @no_pulse1
000A6Cr 2  BD rr rr         lda famistudio_sfx_buffer+0,x
000A6Fr 2  8D rr rr         sta famistudio_output_buf+0
000A72r 2  BD rr rr         lda famistudio_sfx_buffer+1,x
000A75r 2  8D rr rr         sta famistudio_output_buf+1
000A78r 2  BD rr rr         lda famistudio_sfx_buffer+2,x
000A7Br 2  8D rr rr         sta famistudio_output_buf+2
000A7Er 2               
000A7Er 2               @no_pulse1:
000A7Er 2  AD rr rr         lda famistudio_output_buf+3
000A81r 2  29 0F            and #$0f
000A83r 2  85 rr            sta @tmp
000A85r 2  BD rr rr         lda famistudio_sfx_buffer+3,x
000A88r 2  29 0F            and #$0f
000A8Ar 2  C5 rr            cmp @tmp
000A8Cr 2  90 12            bcc @no_pulse2
000A8Er 2  BD rr rr         lda famistudio_sfx_buffer+3,x
000A91r 2  8D rr rr         sta famistudio_output_buf+3
000A94r 2  BD rr rr         lda famistudio_sfx_buffer+4,x
000A97r 2  8D rr rr         sta famistudio_output_buf+4
000A9Ar 2  BD rr rr         lda famistudio_sfx_buffer+5,x
000A9Dr 2  8D rr rr         sta famistudio_output_buf+5
000AA0r 2               
000AA0r 2               @no_pulse2:
000AA0r 2  BD rr rr         lda famistudio_sfx_buffer+6,x ; Overwrite triangle of main output buffer if it is active
000AA3r 2  F0 0F            beq @no_triangle
000AA5r 2  8D rr rr         sta famistudio_output_buf+6
000AA8r 2  BD rr rr         lda famistudio_sfx_buffer+7,x
000AABr 2  8D rr rr         sta famistudio_output_buf+7
000AAEr 2  BD rr rr         lda famistudio_sfx_buffer+8,x
000AB1r 2  8D rr rr         sta famistudio_output_buf+8
000AB4r 2               
000AB4r 2               @no_triangle:
000AB4r 2  AD rr rr         lda famistudio_output_buf+9
000AB7r 2  29 0F            and #$0f
000AB9r 2  85 rr            sta @tmp
000ABBr 2  BD rr rr         lda famistudio_sfx_buffer+9,x
000ABEr 2  29 0F            and #$0f
000AC0r 2  C5 rr            cmp @tmp
000AC2r 2  90 0C            bcc @no_noise
000AC4r 2  BD rr rr         lda famistudio_sfx_buffer+9,x
000AC7r 2  8D rr rr         sta famistudio_output_buf+9
000ACAr 2  BD rr rr         lda famistudio_sfx_buffer+10,x
000ACDr 2  8D rr rr         sta famistudio_output_buf+10
000AD0r 2               
000AD0r 2               @no_noise:
000AD0r 2  60               rts
000AD1r 2               
000AD1r 2               @inc_sfx:
000AD1r 2  E6 rr            inc @effect_data_ptr+1
000AD3r 2  FE rr rr         inc famistudio_sfx_ptr_hi,x
000AD6r 2  60               rts
000AD7r 2               
000AD7r 2               .endif
000AD7r 2               
000AD7r 2               ; Dummy envelope used to initialize all channels with silence
000AD7r 2               famistudio_dummy_envelope:
000AD7r 2  C0 7F 00 00      .byte $c0,$7f,$00,$00
000ADBr 2               
000ADBr 2               famistudio_dummy_pitch_envelope:
000ADBr 2  00 C0 7F 00      .byte $00,$c0,$7f,$00,$01
000ADFr 2  01           
