00088Er 2               .if FAMISTUDIO_USE_NOISE_SLIDE_NOTES
00088Er 2               @noise_slide:
00088Er 2  B1 rr            lda (@channel_data_ptr),y ; Read slide step size
000890r 2  C8               iny
000891r 2  8D rr rr         sta famistudio_slide_step+FAMISTUDIO_NOISE_SLIDE_INDEX
000894r 2  B1 rr            lda (@channel_data_ptr),y ; Read slide note from
000896r 2  C8               iny
000897r 2  38               sec
000898r 2  F1 rr            sbc (@channel_data_ptr),y ; Read slide note to
00089Ar 2  8D rr rr         sta famistudio_slide_pitch_lo+FAMISTUDIO_NOISE_SLIDE_INDEX
00089Dr 2  10 04            bpl @positive_noise_slide
00089Fr 2               @negative_noise_slide:
00089Fr 2                   ; Sign extend.
00089Fr 2  A9 FF            lda #$ff
0008A1r 2  30 02            bmi @noise_shift
0008A3r 2               @positive_noise_slide:
0008A3r 2  A9 00            lda #$00
0008A5r 2               @noise_shift:
0008A5r 2                   ; Noise slides have 4-bits of fraction.
0008A5r 2  0E rr rr         asl famistudio_slide_pitch_lo+FAMISTUDIO_NOISE_SLIDE_INDEX
0008A8r 2  2A               rol
0008A9r 2  0E rr rr         asl famistudio_slide_pitch_lo+FAMISTUDIO_NOISE_SLIDE_INDEX
0008ACr 2  2A               rol
0008ADr 2  0E rr rr         asl famistudio_slide_pitch_lo+FAMISTUDIO_NOISE_SLIDE_INDEX
0008B0r 2  2A               rol
0008B1r 2  0E rr rr         asl famistudio_slide_pitch_lo+FAMISTUDIO_NOISE_SLIDE_INDEX
0008B4r 2  2A               rol
0008B5r 2  8D rr rr         sta famistudio_slide_pitch_hi+FAMISTUDIO_NOISE_SLIDE_INDEX
0008B8r 2  4C rr rr         jmp @slide_done_pos
0008BBr 2               .endif
0008BBr 2               
0008BBr 2               @opcode_slide:
0008BBr 2               .if FAMISTUDIO_USE_NOISE_SLIDE_NOTES
0008BBr 2  E0 03            cpx #3
0008BDr 2  F0 CF            beq @noise_slide
0008BFr 2               .endif
0008BFr 2  BD rr rr         lda famistudio_channel_to_slide,x
0008C2r 2  AA               tax
0008C3r 2  B1 rr            lda (@channel_data_ptr),y ; Read slide step size
0008C5r 2  C8               iny
0008C6r 2  9D rr rr         sta famistudio_slide_step,x
0008C9r 2  B1 rr            lda (@channel_data_ptr),y ; Read slide note from
0008CBr 2  C8               iny
0008CCr 2  84 rr            sty @tmp_y2
0008CEr 2               .if FAMISTUDIO_DUAL_SUPPORT
0008CEr 2  18               clc
0008CFr 2  6D rr rr         adc famistudio_pal_adjust
0008D2r 2               .endif
0008D2r 2  85 rr            sta @tmp_slide_from
0008D4r 2  B1 rr            lda (@channel_data_ptr),y ; Read slide note to
0008D6r 2  A4 rr            ldy @tmp_slide_from       ; reload note from
0008D8r 2               .if FAMISTUDIO_DUAL_SUPPORT
0008D8r 2  6D rr rr         adc famistudio_pal_adjust
0008DBr 2               .endif
0008DBr 2  86 rr            stx @tmp_slide_idx ; X contained the slide index.
0008DDr 2  AA               tax
0008DEr 2               .ifdef FAMISTUDIO_EXP_NOTE_START
0008DEr 2                   lda @chan_idx
0008DEr 2               .if FAMISTUDIO_EXP_EPSM
0008DEr 2                   cmp #FAMISTUDIO_EPSM_CHAN_FM_START
0008DEr 2                   bcs @note_table_epsm
0008DEr 2               .endif
0008DEr 2                   cmp #FAMISTUDIO_EXP_NOTE_START
0008DEr 2                   bcs @note_table_expansion
0008DEr 2               .endif
0008DEr 2  38               sec ; Subtract the pitch of both notes.
0008DFr 2  B9 rr rr         lda famistudio_note_table_lsb,y
0008E2r 2  FD rr rr         sbc famistudio_note_table_lsb,x
0008E5r 2  85 rr            sta @slide_delta_lo
0008E7r 2  B9 rr rr         lda famistudio_note_table_msb,y
0008EAr 2  FD rr rr         sbc famistudio_note_table_msb,x
0008EDr 2               .ifdef FAMISTUDIO_EXP_NOTE_START
0008EDr 2                   jmp @note_table_done
0008EDr 2               .if FAMISTUDIO_EXP_EPSM
0008EDr 2               @note_table_epsm:
0008EDr 2               .if FAMISTUDIO_EXP_EPSM_FM_CHN_CNT > 0
0008EDr 2                   lda famistudio_epsm_note_table_lsb,y
0008EDr 2                   sbc famistudio_epsm_note_table_lsb,x
0008EDr 2                   sta @slide_delta_lo
0008EDr 2                   lda famistudio_epsm_note_table_msb,y
0008EDr 2                   sbc famistudio_epsm_note_table_msb,x
0008EDr 2                   jmp @note_table_done
0008EDr 2               .endif
0008EDr 2               .endif
0008EDr 2               @note_table_expansion:
0008EDr 2                   lda famistudio_exp_note_table_lsb,y
0008EDr 2                   sbc famistudio_exp_note_table_lsb,x
0008EDr 2                   sta @slide_delta_lo
0008EDr 2                   lda famistudio_exp_note_table_msb,y
0008EDr 2                   sbc famistudio_exp_note_table_msb,x
0008EDr 2               @note_table_done:
0008EDr 2               .endif
0008EDr 2  A6 rr            ldx @tmp_slide_idx ; slide index.
0008EFr 2  9D rr rr         sta famistudio_slide_pitch_hi,x
0008F2r 2                   .if FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM
0008F2r 2                       cpx #FAMISTUDIO_FIRST_POSITIVE_SLIDE_CHANNEL ; Slide #3 is the first of expansion slides.
0008F2r 2                       bcs @positive_shift
0008F2r 2                   .endif
0008F2r 2                   @negative_shift:
0008F2r 2  A5 rr                lda @slide_delta_lo
0008F4r 2  0A                   asl ; Shift-left, we have 1 bit of fractional slide.
0008F5r 2  9D rr rr             sta famistudio_slide_pitch_lo,x
0008F8r 2  3E rr rr             rol famistudio_slide_pitch_hi,x ; Shift-left, we have 1 bit of fractional slide.
0008FBr 2                   .if FAMISTUDIO_EXP_N163 || FAMISTUDIO_EXP_VRC7 || FAMISTUDIO_EXP_EPSM
0008FBr 2                       jmp @shift_done
0008FBr 2                   @positive_shift:
0008FBr 2                       lda @slide_delta_lo
0008FBr 2                       sta famistudio_slide_pitch_lo,x
0008FBr 2                       ldy #FAMISTUDIO_PITCH_SHIFT
0008FBr 2                       @positive_shift_loop:
0008FBr 2                           lda famistudio_slide_pitch_hi,x
0008FBr 2                           cmp #$80
0008FBr 2                           ror famistudio_slide_pitch_hi,x
0008FBr 2                           ror famistudio_slide_pitch_lo,x
0008FBr 2                           dey
0008FBr 2                           bne @positive_shift_loop
0008FBr 2                   @shift_done:
0008FBr 2                   .endif
0008FBr 2  A6 rr            ldx @chan_idx
0008FDr 2  A4 rr            ldy @tmp_y2
0008FFr 2               
0008FFr 2               @slide_done_pos:
0008FFr 2  B1 rr            lda (@channel_data_ptr),y ; Re-read the target note (ugly...)
000901r 2  9D rr rr         sta famistudio_chn_note,x ; Store note code
000904r 2  C8               iny
000905r 2  4C rr rr         jmp @cancel_delayed_cut
000908r 2               .endif
000908r 2               
000908r 2               @opcode_invalid:
000908r 2               
000908r 2                   ; If you hit this, this mean you either:
000908r 2                   ; - exported a song that uses FamiStudio tempo but have defined "FAMISTUDIO_USE_FAMITRACKER_TEMPO"
000908r 2                   ; - use delayed notes/cuts, but didnt enable "FAMISTUDIO_USE_FAMITRACKER_DELAYED_NOTES_OR_CUTS"
000908r 2                   ; - use vibrato effect, but didnt enable "FAMISTUDIO_USE_VIBRATO"
000908r 2                   ; - use arpeggiated chords, but didnt enable "FAMISTUDIO_USE_ARPEGGIO"
000908r 2                   ; - use fine pitches, but didnt enable "FAMISTUDIO_USE_PITCH_TRACK"
000908r 2                   ; - use a duty cycle effect, but didnt enable "FAMISTUDIO_USE_DUTYCYCLE_EFFECT"
000908r 2                   ; - use slide notes, but didnt enable "FAMISTUDIO_USE_SLIDE_NOTES"
000908r 2                   ; - use volume slides, but didnt enable "FAMISTUDIO_USE_VOLUME_SLIDES"
000908r 2                   ; - use DMC counter effect, but didnt enable "FAMISTUDIO_USE_DELTA_COUNTER"
000908r 2                   ; - use a Phase Reset efect, but didnt enable the "FAMISTUDIO_USE_PHASE_RESET"
000908r 2                   ; - use an instrument > 63, but didnt enable "FAMISTUDIO_USE_INSTRUMENT_EXTENDED_RANGE"
000908r 2               
000908r 2  00               brk
000909r 2               
