00001Fr 4               COL_ALL   = $07
00001Fr 4               COL_BOTTOM   = $06
00001Fr 4               COL_TOP   = $05
00001Fr 4               COL_DEATH_BOTTOM   = $04
00001Fr 4               COL_DEATH_TOP   = $03
