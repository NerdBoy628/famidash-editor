000238r 2               .segment "CODE_2"
000238r 2               
000238r 2               .export crossPRGBankJump
000238r 2               .proc crossPRGBankJump
000238r 2               	; AX = address of function
000238r 2               	; Y = bank of function
000238r 2  85 rr        	STA ptr4
00023Ar 2  86 rr        	STX ptr4+1
00023Cr 2  AD rr rr     	LDA mmc3PRG1Bank
00023Fr 2  48           	PHA
000240r 2  98           	TYA
000241r 2  20 rr rr     	JSR mmc3_set_prg_bank_1
000244r 2  A5 rr        	LDA ptr3
000246r 2  A6 rr        	LDX ptr3+1
000248r 2  20 rr rr     	JSR callptr4
00024Br 2  85 rr        	STA ptr3
00024Dr 2  86 rr        	STX ptr3+1
00024Fr 2  68           	PLA
000250r 2  4C rr rr     	JMP mmc3_set_prg_bank_1
000253r 2               .endproc
000253r 2               
000253r 2               .if !THE_ALBUM
000253r 2               ; void __fastcall__ playPCM(uint8_t sample);
000253r 2               .segment "XCD_BANK_00"
000000r 2               SSDPCM_ptr = ptr1
000000r 2               SSDPCM_bank_num = tmp1
000000r 2               SSDPCM_amp = tmp2
000000r 2               SSDPCM_wait = tmp3
000000r 2               SSDPCM_delta_add = ptr2
000000r 2               
000000r 2               SSDPCM_luts:
000000r 2  00 00 00 00  .repeat 256, I
000004r 2  00 00 00 00  
000008r 2  00 00 00 00  
000100r 2               	.byte ((I>>6)&3)
000100r 2               .endrepeat
000100r 2  00 00 00 00  .repeat 256, I
000104r 2  00 00 00 00  
000108r 2  00 00 00 00  
000200r 2               	.byte ((I>>4)&3)
000200r 2               .endrepeat
000200r 2  00 00 00 00  .repeat 256, I
000204r 2  01 01 01 01  
000208r 2  02 02 02 02  
000300r 2               	.byte ((I>>2)&3)
000300r 2               .endrepeat
000300r 2  00 01 02 03  .repeat 256, I
000304r 2  00 01 02 03  
000308r 2  00 01 02 03  
000400r 2               	.byte ((I>>0)&3)
000400r 2               .endrepeat
000400r 2               
000400r 2               SSDPCM_amps:
000400r 2  00 00 00 00  .repeat 64, I
000404r 2  FF 00 01 02  
000408r 2  FE 00 02 04  
000500r 2               	.byte (-1*I)&$ff
000500r 2               	.byte (0*I)&$ff
000500r 2               	.byte (1*I)&$ff
000500r 2               	.byte (2*I)&$ff
000500r 2               .endrepeat
000500r 2               
000500r 2               SSDPCM_amplo:
000500r 2  rr rr rr rr  .repeat 64, I
000504r 2  rr rr rr rr  
000508r 2  rr rr rr rr  
000540r 2               	.lobytes SSDPCM_amps+(I*4)
000540r 2               .endrepeat
000540r 2               SSDPCM_amphi:
000540r 2  rr rr rr rr  .repeat 64, I
000544r 2  rr rr rr rr  
000548r 2  rr rr rr rr  
000580r 2               	.hibytes SSDPCM_amps+(I*4)
000580r 2               .endrepeat
000580r 2               
000580r 2               .export _playPCM
000580r 2               .proc _playPCM
000580r 2                   ; A = Sample
000580r 2  A8           	tay
000581r 2  A6 rr        	ldx	cpuRegion
000583r 2  D0 03        	bne :+
000585r 2  18           		clc
000586r 2  69 02        		adc #(SampleRate_PAL-SampleRate_NTSC)
000588r 2               	:
000588r 2  AA           	tax
000589r 2  BD rr rr     	lda SampleRate_NTSC, x
00058Cr 2  85 rr            sta SSDPCM_wait
00058Er 2  BE rr rr     	ldx Bank, y
000591r 2               
000591r 2                   ; enable DMC but disable DPCM
000591r 2  A9 00            lda #%00000000
000593r 2  8D 10 40         sta FAMISTUDIO_APU_DMC_FREQ
000596r 2  A9 0B            lda #%00001011
000598r 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
00059Br 2                   ; disable automatic FS updates
00059Br 2  AD rr rr         lda	auto_fs_updates
00059Er 2  48               pha
00059Fr 2  A9 00            lda #0
0005A1r 2  A8               tay
0005A2r 2  8D rr rr         sta auto_fs_updates
0005A5r 2                   ; continue enabling DMC but disabling DPCM
0005A5r 2  8D 13 40         sta FAMISTUDIO_APU_DMC_LEN
0005A8r 2  A9 1B            lda #%00011011
0005AAr 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
0005ADr 2                   ; mute sqs+noi
0005ADr 2  A9 30            lda #$30
0005AFr 2  8D 0C 40         sta FAMISTUDIO_APU_NOISE_VOL
0005B2r 2  A9 30            lda #%00110000
0005B4r 2  8D 00 40         sta FAMISTUDIO_APU_PL1_VOL
0005B7r 2  8D 04 40         sta FAMISTUDIO_APU_PL2_VOL
0005BAr 2               
0005BAr 2                   ;init pcm
0005BAr 2  A9 80            lda #128
0005BCr 2  85 rr            sta SSDPCM_amp
0005BEr 2  A9 BF            lda #>$BFFF		;	2
0005C0r 2  85 rr            sta SSDPCM_ptr+1	;__	3
0005C2r 2  A9 FF            lda #<$BFFF		;	2
0005C4r 2  85 rr            sta SSDPCM_ptr	;__	3
0005C6r 2               
0005C6r 2  8A               txa		;__	2
0005C7r 2  20 rr rr         jsr mmc3_set_prg_bank_0	;__	35
0005CAr 2               
0005CAr 2                   ;play pcm
0005CAr 2               @RestartPtr:
0005CAr 2  20 rr rr     	jsr SSDPCM_getbyte
0005CDr 2  AA           	tax
0005CEr 2  BD rr rr     	lda SSDPCM_amplo, x
0005D1r 2  85 rr        	sta SSDPCM_delta_add
0005D3r 2  BD rr rr     	lda SSDPCM_amphi, x
0005D6r 2  85 rr        	sta SSDPCM_delta_add+1
0005D8r 2  E0 FF        	cpx #$ff
0005DAr 2  D0 03        	bne :+
0005DCr 2  4C rr rr         jmp @DoneWithPCM
0005DFr 2               :
0005DFr 2  20 rr rr 20  .repeat 128/4
0005E3r 2  rr rr 20 rr  
0005E7r 2  rr 20 rr rr  
00063Fr 2               	jsr SSDPCM_dobyte
00063Fr 2               .endrepeat
00063Fr 2  4C rr rr     	jmp @RestartPtr
000642r 2               
000642r 2               
000642r 2               @DoneWithPCM:
000642r 2               	; Re-enable all channels
000642r 2  A9 1F            lda #%00011111
000644r 2  8D 15 40         sta FAMISTUDIO_APU_SND_CHN
000647r 2                   ; Re-enable automatic FS updates
000647r 2  68               pla
000648r 2  8D rr rr         sta	auto_fs_updates
00064Br 2               
00064Br 2  A9 rr            lda #<FIRST_DMC_BANK
00064Dr 2  4C rr rr     	jmp mmc3_set_prg_bank_0
000650r 2               
000650r 2               
000650r 2               SSDPCM_dobyte:
000650r 2  20 rr rr         jsr SSDPCM_getbyte
000653r 2  AA           	tax
000654r 2  BC rr rr     	ldy SSDPCM_luts, x ; 4
000657r 2  A5 rr        	lda SSDPCM_amp ; 2
000659r 2  18           	clc ; 2
00065Ar 2  71 rr        	adc (SSDPCM_delta_add), y ; 5
00065Cr 2  85 rr        	sta SSDPCM_amp ; 3
00065Er 2  4A           	lsr ; 2
00065Fr 2  20 rr rr     	jsr SSDPCM_store_pcm ; 6
000662r 2               
000662r 2  BC rr rr     	ldy SSDPCM_luts+256, x
000665r 2  A5 rr        	lda SSDPCM_amp
000667r 2  18           	clc
000668r 2  71 rr        	adc (SSDPCM_delta_add), y
00066Ar 2  85 rr        	sta SSDPCM_amp
00066Cr 2  4A           	lsr
00066Dr 2  20 rr rr     	jsr SSDPCM_store_pcm
000670r 2               
000670r 2  BC rr rr     	ldy SSDPCM_luts+512, x
000673r 2  A5 rr        	lda SSDPCM_amp
000675r 2  18           	clc
000676r 2  71 rr        	adc (SSDPCM_delta_add), y
000678r 2  85 rr        	sta SSDPCM_amp
00067Ar 2  4A           	lsr
00067Br 2  20 rr rr     	jsr SSDPCM_store_pcm
00067Er 2               
00067Er 2  BC rr rr     	ldy SSDPCM_luts+768, x
000681r 2  A5 rr        	lda SSDPCM_amp
000683r 2  18           	clc
000684r 2  71 rr        	adc (SSDPCM_delta_add), y
000686r 2  85 rr        	sta SSDPCM_amp
000688r 2  4A           	lsr
000689r 2  20 rr rr     	jsr SSDPCM_store_pcm
00068Cr 2  60           	rts
00068Dr 2               
00068Dr 2               
00068Dr 2               SSDPCM_store_pcm:
00068Dr 2                   ; 4+2+5+2+3+2+6 = 24 cycles
00068Dr 2  8D 11 40         sta $4011 ; 4
000690r 2  EA               nop
000691r 2  EA               nop
000692r 2  EA               nop
000693r 2  A5 rr            lda SSDPCM_wait	; 3
000695r 2  38               sec
000696r 2               @Delay:
000696r 2  E9 01        	sbc #1		;	5n cycles
000698r 2  B0 FC        	bcs @Delay	;__
00069Ar 2  60               rts
00069Br 2               
00069Br 2               SSDPCM_getbyte:
00069Br 2  E6 rr         inc SSDPCM_ptr
00069Dr 2  D0 02         bne @g1
00069Fr 2  E6 rr         inc SSDPCM_ptr+1
0006A1r 2               @g1:
0006A1r 2  A5 rr         lda SSDPCM_ptr
0006A3r 2  C9 00         cmp #$00
0006A5r 2  D0 15         bne @g2
0006A7r 2  A5 rr         lda SSDPCM_ptr+1
0006A9r 2  C9 E0         cmp #$C0+$20
0006ABr 2  D0 0F         bne @g2
0006ADr 2               
0006ADr 2  A9 80         lda #$80
0006AFr 2  85 rr         sta SSDPCM_ptr+1
0006B1r 2  AD rr rr      lda SSDPCM_getbyte
0006B4r 2  48            pha
0006B5r 2  EE rr rr      inc SSDPCM_getbyte
0006B8r 2  68            pla
0006B9r 2  20 rr rr      jsr mmc3_set_prg_bank_0
0006BCr 2               
0006BCr 2               @g2:
0006BCr 2  A0 00         ldy #0
0006BEr 2  B1 rr         lda (SSDPCM_ptr), y
0006C0r 2  60            rts
0006C1r 2               
0006C1r 2               ; BurnCycles:	; 6 for JSR
0006C1r 2               ;     php	;	7
0006C1r 2               ;     plp	;__
0006C1r 2               ;     php	;	7
0006C1r 2               ;     plp	;__
0006C1r 2               ;     rts	;	6
0006C1r 2               
0006C1r 2               ; Sample rate calculations go per this formula:
0006C1r 2               ; ((Region Clock / Sample Rate)-Sample Load Time)/5
0006C1r 2               ; Sample Load Time is:
0006C1r 2               ; 58 cycles?
0006C1r 2               ; A reverse calculation is:
0006C1r 2               ; Region Clock / ((Ans)*5+Sample Load Time)
0006C1r 2               ; The target sample speed is specified after each value,
0006C1r 2               ; Real playback speed and deviation percentage are specified in parentheses
0006C1r 2               ; TODO: get proper sample calculations for SSDPCM2
0006C1r 2               .include "pcm_metadata.s"
0006C1r 3               ; Generated by export.py using data in metadata.json
0006C1r 3               
0006C1r 3               Bank:
0006C1r 3  rr           	.byte <.bank(pcmData0)
0006C2r 3  rr           	.byte <.bank(pcmData1)
0006C3r 3               
0006C3r 3               SampleRate_NTSC:   ; Also applies to Dendy, as it is derived from the CPU speed
0006C3r 3  04           	.byte 4
0006C4r 3  0A           	.byte 10
0006C5r 3               
0006C5r 3               SampleRate_PAL:
0006C5r 3  03           	.byte 3
0006C6r 3  08           	.byte 8
0006C7r 3               
0006C7r 2               .endproc
0006C7r 2               
0006C7r 2               .endif
0006C7r 2               ; uint16_t hexToDec (uint16_t input)
0006C7r 2               .segment "CODE_2"
000253r 2               
000253r 2               .export _hexToDec
000253r 2               .proc _hexToDec
000253r 2               	; AX = input
000253r 2               	; hexToDecOutputBuffer = output
000253r 2               	; AX = duplicate output
000253r 2               
000253r 2               	; Step 1. loop over X and add 256
000253r 2               	start:
000253r 2  E8           		INX			; for BEQ ending condition
000254r 2  86 rr        		STX tmp1
000256r 2  A0 00        		LDY #0		; for storing when overflows
000258r 2  8C rr rr     		STY hexToDecOutputBuffer+2
00025Br 2  8C rr rr     		STY hexToDecOutputBuffer+3
00025Er 2  8C rr rr     		STY hexToDecOutputBuffer+4
000261r 2               
000261r 2               	clr_x_loop:
000261r 2  A2 00        		LDX #0
000263r 2               	loop:
000263r 2  38           		SEC
000264r 2  E9 0A        		SBC #10
000266r 2  B0 04        		BCS :+
000268r 2  C6 rr        			DEC tmp1
00026Ar 2  F0 20        			BEQ end
00026Cr 2               		:
00026Cr 2  E8           		INX
00026Dr 2  E0 0A        		CPX #10
00026Fr 2  D0 F2        		BNE loop	; carry is always clear
000271r 2               
000271r 2  EE rr rr     		INC hexToDecOutputBuffer+2
000274r 2  EC rr rr     		CPX hexToDecOutputBuffer+2	; if 10 == out[2]
000277r 2  D0 E8        		BNE clr_x_loop
000279r 2  8C rr rr     		STY hexToDecOutputBuffer+2
00027Cr 2               
00027Cr 2  EE rr rr     		INC hexToDecOutputBuffer+3
00027Fr 2  EC rr rr     		CPX hexToDecOutputBuffer+3	; if 10 == out[3]
000282r 2  D0 DD        		BNE clr_x_loop
000284r 2  8C rr rr     		STY hexToDecOutputBuffer+3
000287r 2               
000287r 2  EE rr rr     		INC hexToDecOutputBuffer+4
00028Ar 2  D0 D5        		BNE clr_x_loop	; BRA
00028Cr 2               
00028Cr 2               	end:
00028Cr 2               		; Carry is clear
00028Cr 2  69 0A        		ADC #10
00028Er 2  8D rr rr     		STA hexToDecOutputBuffer+0
000291r 2  8E rr rr     		STX hexToDecOutputBuffer+1
000294r 2  60           		RTS
000295r 2               .endproc
000295r 2               
000295r 2               
000295r 2               
000295r 2               ; void printDecimal (uintptr_t ppu_address, uint16_t value, uint8_t digits, uint8_t zeroChr, uint8_t spaceChr)
000295r 2               .segment "CODE_2"
000295r 2               
000295r 2               .export __printDecimal
000295r 2               .proc __printDecimal
000295r 2               	; AX = ppu_address
000295r 2               	; sreg = value
000295r 2               	; xargs[0] = digits
000295r 2               	; xargs[1] = zeroChr
000295r 2               	; xargs[2] = spaceChr
000295r 2               	value = sreg
000295r 2               	digits = xargs+0
000295r 2               	zeroChr = xargs+1
000295r 2               	spaceChr = xargs+2
000295r 2               
000295r 2               	start:
000295r 2  A4 rr        		LDY VRAM_INDEX
000297r 2  99 rr rr     		STA VRAM_BUF+1, Y	;
00029Ar 2  8A           		TXA					;	VRAM pointer
00029Br 2  99 rr rr     		STA VRAM_BUF+0, Y	;__
00029Er 2  A5 rr        		LDA digits			;	Length
0002A0r 2  99 rr rr     		STA VRAM_BUF+2, Y	;__
0002A3r 2  18           		CLC					;
0002A4r 2  65 rr        		ADC VRAM_INDEX		;	Update VRAM index
0002A6r 2  69 03        		ADC #3				;__
0002A8r 2  48           		PHA					;
0002A9r 2  A8           		TAY					;
0002AAr 2  A9 FF        		LDA #$FF			;	Mark section as taken
0002ACr 2  99 rr rr     		STA VRAM_BUF, Y		;__
0002AFr 2               
0002AFr 2  A5 rr        		LDA value			;
0002B1r 2  A6 rr        		LDX value+1			;	Convert to decimal
0002B3r 2  20 rr rr     		JSR _hexToDec		;__
0002B6r 2               
0002B6r 2  A4 rr        		LDY VRAM_INDEX
0002B8r 2               
0002B8r 2  A6 rr        		LDX digits
0002BAr 2  CA           		DEX
0002BBr 2  F0 0E        		BEQ numberLoop
0002BDr 2               
0002BDr 2               	spaceLoop:
0002BDr 2  BD rr rr     		LDA hexToDecOutputBuffer, X
0002C0r 2  D0 0C        		BNE numberStart
0002C2r 2  A5 rr        		LDA spaceChr
0002C4r 2  99 rr rr     		STA VRAM_BUF+3, Y
0002C7r 2  C8           		INY
0002C8r 2  CA           		DEX
0002C9r 2  D0 F2        		BNE spaceLoop
0002CBr 2               
0002CBr 2               		; Fallthrough on the last digit
0002CBr 2               	numberLoop:
0002CBr 2  BD rr rr     		LDA hexToDecOutputBuffer, X
0002CEr 2               	numberStart:
0002CEr 2  18           		CLC
0002CFr 2  65 rr        		ADC zeroChr
0002D1r 2  99 rr rr     		STA VRAM_BUF+3, Y
0002D4r 2  C8           		INY
0002D5r 2  CA           		DEX
0002D6r 2  10 F3        		BPL numberLoop
0002D8r 2               
0002D8r 2               	end:
0002D8r 2  68           		PLA
0002D9r 2  85 rr        		STA VRAM_INDEX
0002DBr 2  60           		RTS
0002DCr 2               
0002DCr 2               .endproc
0002DCr 2               
0002DCr 2               .segment "CODE_2"
0002DCr 2               
0002DCr 2               ; void update_level_completeness();
0002DCr 2               .segment "CODE_2"
0002DCr 2               
0002DCr 2               .import _level, _practice_point_count
0002DCr 2               .import _level_completeness_normal
0002DCr 2               
0002DCr 2               .export _update_level_completeness
0002DCr 2               .proc _update_level_completeness
0002DCr 2               	levelsInTable = ::_MAX_LEVEL_COMPLETE
0002DCr 2               
0002DCr 2               	levelLengthLo = ptr1+0
0002DCr 2               	levelLengthMd = ptr1+1
0002DCr 2               	levelLengthHi = tmp1
0002DCr 2               
0002DCr 2               	percentage = tmp2
0002DCr 2               
0002DCr 2               	start:
0002DCr 2  AC rr rr     		LDY	_level
0002DFr 2  B9 rr rr     		LDA	_level_lengths_lo, Y
0002E2r 2  85 rr        		STA levelLengthLo
0002E4r 2               		.if MID_LEVEL_LENGTHS_ENABLED
0002E4r 2               			LDA _level_lengths_md, Y
0002E4r 2               			STA levelLengthMd
0002E4r 2               		.endif
0002E4r 2               		.if HIGH_LEVEL_LENGTHS_ENABLED
0002E4r 2               			LDA _level_lengths_hi, Y
0002E4r 2               			STA levelLengthHi
0002E4r 2               		.endif
0002E4r 2               
0002E4r 2  A0 FF        		LDY #$FF
0002E6r 2               		.if MID_LEVEL_LENGTHS_ENABLED
0002E6r 2               			STY percentage
0002E6r 2               		.endif
0002E6r 2               
0002E6r 2  AD rr rr     		LDA _scroll_x+3
0002E9r 2  85 rr        		STA sreg+1
0002EBr 2  AD rr rr     		LDA _scroll_x+2
0002EEr 2  85 rr        		STA sreg+0
0002F0r 2  AE rr rr     		LDX _scroll_x+1
0002F3r 2               		.if MID_LEVEL_LENGTHS_ENABLED
0002F3r 2               			LDY _scroll_x+0
0002F3r 2               		.else
0002F3r 2  AD rr rr     			LDA _scroll_x+0
0002F6r 2               		.endif
0002F6r 2               
0002F6r 2               		; Adjust for BEQ ending condition
0002F6r 2  E6 rr        		INC sreg+1
0002F8r 2               		.if !HIGH_LEVEL_LENGTHS_ENABLED
0002F8r 2  E6 rr        			INC sreg+0
0002FAr 2               		.endif
0002FAr 2               		.if !MID_LEVEL_LENGTHS_ENABLED
0002FAr 2  E8           			INX
0002FBr 2               		.endif
0002FBr 2               
0002FBr 2               	loop_sec:
0002FBr 2               		.if MID_LEVEL_LENGTHS_ENABLED
0002FBr 2               			TYA
0002FBr 2               		.endif
0002FBr 2  38           		SEC
0002FCr 2               	loop:
0002FCr 2               		.if MID_LEVEL_LENGTHS_ENABLED
0002FCr 2               			INC percentage
0002FCr 2               		.else
0002FCr 2  C8           			INY
0002FDr 2               		.endif
0002FDr 2  E5 rr        		SBC	levelLengthLo
0002FFr 2  B0 FB        		BCS loop
000301r 2               
000301r 2               		.if MID_LEVEL_LENGTHS_ENABLED
000301r 2               			TAY
000301r 2               			TXA
000301r 2               			SBC levelLengthMd
000301r 2               			TAX
000301r 2               			BCS loop_sec
000301r 2               		.else
000301r 2  CA           			DEX
000302r 2  D0 F7        			BNE loop_sec
000304r 2               		.endif
000304r 2               
000304r 2               		.if HIGH_LEVEL_LENGTHS_ENABLED
000304r 2               			LDA sreg+0
000304r 2               			SBC levelLengthHi
000304r 2               			STA sreg+0
000304r 2               			BCS loop_sec
000304r 2               		.else
000304r 2  C6 rr        			DEC	sreg+0
000306r 2  D0 F3        			BNE loop_sec
000308r 2               		.endif
000308r 2               
000308r 2  C6 rr        		DEC sreg+1
00030Ar 2  D0 EF        		BNE loop_sec
00030Cr 2               
00030Cr 2               	fin:
00030Cr 2               
00030Cr 2               		.if MID_LEVEL_LENGTHS_ENABLED
00030Cr 2               			LDY percentage
00030Cr 2               		.endif
00030Cr 2               
00030Cr 2  C0 63        		CPY #99			;
00030Er 2  90 02        		BCC :+			;	Cap at 99
000310r 2  A0 63        			LDY #99		;	100% is reserved for complete levels only
000312r 2               		:				;__
000312r 2               
000312r 2  AD rr rr     		LDA _practice_point_count	;
000315r 2  F0 02        		BEQ :+					;
000317r 2  A9 80        			LDA #levelsInTable	;	Calculate whether to store
000319r 2               		:						;	the new completeness in the
000319r 2  18           		CLC						;	normal or practice table
00031Ar 2  6D rr rr     		ADC _level				;
00031Dr 2  AA           		TAX						;__
00031Er 2               
00031Er 2  98           		TYA						;
00031Fr 2  DD rr rr     		CMP _level_completeness_normal, X
000322r 2  90 03        		BCC :+					;	Update value if bigger than last one
000324r 2  9D rr rr     			STA _level_completeness_normal, X
000327r 2               		:						;__
000327r 2  60           		RTS
000328r 2               
000328r 2               .endproc
000328r 2               
000328r 2               ; [Not used in C]
